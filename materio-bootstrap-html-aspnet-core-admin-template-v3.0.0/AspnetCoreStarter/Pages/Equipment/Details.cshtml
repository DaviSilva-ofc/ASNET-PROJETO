@page
@model AspnetCoreStarter.Pages.Equipment.DetailsModel
@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Ficha Técnica";
}

<div class="container-xxl p-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white p-4 d-flex justify-content-between align-items-center">
            <h3 class="mb-0 text-white"><i class="ri-survey-line me-2"></i>Ficha Técnica</h3>
            <img src="/img/favicon.png" height="30" alt="Logo" class="opacity-75">
        </div>
        
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-center py-5">
                    <i class="ri-shield-keyhole-line text-danger display-1 mb-4"></i>
                    <h2 class="text-danger fw-bold">Acesso Restrito</h2>
                    <p class="text-muted fs-5">@Model.ErrorMessage</p>
                    <hr class="my-4">
                    <p class="small text-muted">Se acredita que deveria ter acesso, contacte o administrador do sistema ou verifique se tem tickets ativos para este agrupamento.</p>
                    <a href="/" class="btn btn-outline-primary mt-3">Voltar ao Início</a>
                </div>
            }
            else
            {
                var item = Model.Equipment != null ? (dynamic)Model.Equipment : (dynamic)Model.StockItem;
                bool isStock = Model.StockItem != null;

                <div class="text-center mb-5">
                    <div class="badge bg-label-primary mb-2 px-3 py-2 fs-6">
                        <i class="ri-id-card-line me-1"></i> ID #@(item.Id)
                    </div>
                    <h1 class="fw-bold mb-1">@(isStock ? item.EquipmentName : item.Name)</h1>
                    <span class="badge bg-label-info fs-6">@(item.Type)</span>
                </div>

                <div class="row g-4">
                    <!-- Basic Info -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-center mb-4">
                            <div class="p-3 bg-label-secondary rounded me-3">
                                <i class="ri-price-tag-3-line fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-muted small uppercase">Especificações</h6>
                                <p class="mb-0 fw-bold">@(isStock ? item.Description ?? "N/A" : $"{item.Brand} {item.Model}")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Serial Number -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-center mb-4">
                            <div class="p-3 bg-label-warning rounded me-3">
                                <i class="ri-hashtag fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-muted small uppercase">Nº de Série</h6>
                                <p class="mb-0 fw-bold">@(isStock ? "Stock Item" : item.SerialNumber ?? "N/A")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-center mb-4">
                            <div class="p-3 bg-label-success rounded me-3">
                                <i class="ri-map-pin-2-line fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-muted small uppercase">Localização</h6>
                                <p class="mb-0 fw-bold">
                                    @if (isStock) {
                                        @item.School?.Name @: (Stock)
                                    } else {
                                        @item.Room?.Name @: (@item.Room?.Block?.Name)
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-center mb-4">
                            <div class="p-3 bg-label-info rounded me-3">
                                <i class="ri-pulse-line fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-muted small uppercase">Estado Atual</h6>
                                @{
                                    string status = item.Status ?? "Ativo";
                                    string badgeClass = status.Contains("repara") || status.Contains("Avariado") ? "danger" : "success";
                                }
                                <span class="badge bg-label-@badgeClass">@status</span>
                            </div>
                        </div>
                    </div>

                    @if (!isStock)
                    {
                        <!-- Network Info (Equipment only) -->
                        <div class="col-12">
                            <div class="card bg-label-secondary border-0 shadow-none">
                                <div class="card-body p-3">
                                    <div class="row text-center">
                                        <div class="col-6 border-end">
                                            <small class="text-muted d-block">Endereço IP</small>
                                            <span class="fw-bold">@(item.IpAddress ?? "—")</span>
                                        </div>
                                        <div class="col-6">
                                            <small class="text-muted d-block">MAC Address</small>
                                            <span class="fw-bold">@(item.MacAddress ?? "—")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-5 pt-4 border-top text-center">
                    <p class="text-muted small">
                        <i class="ri-information-line me-1"></i> 
                        Informação atualizada em tempo real via ASNET Platform.
                    </p>
                </div>
            }
        </div>
    </div>
    
    <div class="text-center mt-4">
        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary d-print-none">
            <i class="ri-printer-line me-1"></i> Imprimir Ficha
        </button>
    </div>
</div>

<style>
    body { background-color: #f5f5f9; }
    .bg-label-primary { background-color: #e7e7ff !important; color: #696cff !important; }
    .bg-label-info { background-color: #d7f5fc !important; color: #03c3ec !important; }
    .bg-label-success { background-color: #e8fadf !important; color: #71dd37 !important; }
    .bg-label-warning { background-color: #fff2d6 !important; color: #ffab00 !important; }
    .bg-label-danger { background-color: #ffe5e5 !important; color: #ff3e1d !important; }
    .bg-label-secondary { background-color: #ebeef0 !important; color: #8592a3 !important; }
    .uppercase { text-transform: uppercase; letter-spacing: 1px; }
    
    @@media print {
        .d-print-none { display: none !important; }
        .card { box-shadow: none !important; border: 1px solid #ddd !important; }
    }
</style>
