@page
@model AspnetCoreStarter.Pages.Equipment.DetailsModel
@{
    Layout = "Layouts/_BlankLayout";
    ViewData["Title"] = "Ficha Técnica";
}

<div class="container-fluid p-0 min-vh-100 d-flex flex-column">
    <div class="card shadow-none border-0 flex-grow-1 rounded-0" style="background-color: #2b2c40;">
        <!-- Header -->
        <div class="card-header border-bottom-0 p-4 d-flex justify-content-between align-items-center" style="background: linear-gradient(90deg, #ffab00 0%, #ffcf50 100%);">
            <h3 class="mb-0 text-white fw-bold"><i class="ri-survey-line me-2"></i>Ficha Técnica</h3>
            <img src="/img/favicon.png" height="30" alt="Logo" class="opacity-75">
        </div>
        
        <div class="card-body p-4 p-md-5 text-white">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-center py-5">
                    <i class="ri-shield-keyhole-line text-danger display-1 mb-4"></i>
                    <h2 class="text-danger fw-bold">Acesso Restrito</h2>
                    <p class="text-light fs-5">@Model.ErrorMessage</p>
                    <hr class="my-4 opacity-25">
                    <a href="/" class="btn btn-outline-warning mt-3">Voltar ao Início</a>
                </div>
            }
            else
            {
                var item = Model.Equipment != null ? (dynamic)Model.Equipment : (dynamic)Model.StockItem;
                bool isStock = Model.StockItem != null;

                <!-- Top Info -->
                <div class="text-center mb-5">
                    <div class="mb-2 px-3 py-1 d-inline-block rounded border border-light border-opacity-25 text-white-50 small">
                        <i class="ri-id-card-line me-1"></i> ID #@(item.Id)
                    </div>
                    <h1 class="display-4 fw-bold mb-1 text-white">@(isStock ? item.EquipmentName : item.Name)</h1>
                    <div class="text-white-50 fs-5 mt-2">
                         <span class="border-bottom border-warning pb-1">@(item.Type)</span>
                    </div>
                </div>

                <div class="row g-4 mt-2">
                    <!-- Specifications -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-start p-3 rounded border border-white border-opacity-10" style="background: rgba(255, 255, 255, 0.03);">
                            <div class="p-3 bg-warning bg-opacity-10 rounded me-3 text-warning">
                                <i class="ri-price-tag-3-line fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 text-warning small text-uppercase fw-bold">Especificações</h6>
                                <p class="mb-0 fs-5 text-white">@(isStock ? item.Description ?? "N/A" : $"{item.Brand} {item.Model}")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Serial Number -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-start p-3 rounded border border-white border-opacity-10" style="background: rgba(255, 255, 255, 0.03);">
                            <div class="p-3 bg-info bg-opacity-10 rounded me-3 text-info">
                                <i class="ri-hashtag fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 text-info small text-uppercase fw-bold">Nº de Série</h6>
                                <p class="mb-0 fs-5 text-white">@(isStock ? "Stock Item" : item.SerialNumber ?? "N/A")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-start p-3 rounded border border-white border-opacity-10" style="background: rgba(255, 255, 255, 0.03);">
                            <div class="p-3 bg-success bg-opacity-10 rounded me-3 text-success">
                                <i class="ri-map-pin-2-line fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 text-success small text-uppercase fw-bold">Localização</h6>
                                <p class="mb-0 fs-5 text-white">
                                    @if (isStock) {
                                        @item.School?.Name @: (Stock)
                                    } else {
                                        @item.Room?.Name @: (@item.Room?.Block?.Name)
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex align-items-start p-3 rounded border border-white border-opacity-10" style="background: rgba(255, 255, 255, 0.03);">
                            <div class="p-3 bg-danger bg-opacity-10 rounded me-3 text-danger">
                                <i class="ri-pulse-line fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 text-danger small text-uppercase fw-bold">Estado Atual</h6>
                                @{
                                    string status = item.Status ?? "Ativo";
                                    string badgeClass = status.Contains("repara") || status.Contains("Avariado") ? "danger" : "success";
                                }
                                <span class="badge bg-@badgeClass mt-1">@status</span>
                            </div>
                        </div>
                    </div>

                    @if (!isStock)
                    {
                        <!-- Network Info -->
                        <div class="col-12">
                            <div class="card bg-transparent border border-white border-opacity-10 shadow-none">
                                <div class="card-body p-3">
                                    <div class="row text-center">
                                        <div class="col-6 border-end border-white border-opacity-10">
                                            <small class="text-white-50 d-block text-uppercase small">Endereço IP</small>
                                            <span class="fw-bold fs-5 text-white">@(item.IpAddress ?? "—")</span>
                                        </div>
                                        <div class="col-6">
                                            <small class="text-white-50 d-block text-uppercase small">MAC Address</small>
                                            <span class="fw-bold fs-5 text-white">@(item.MacAddress ?? "—")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- History Timeline -->
                        <div class="col-12 mt-5">
                            <h4 class="fw-bold mb-4 border-bottom border-white border-opacity-10 pb-2">
                                <i class="ri-history-line me-2 text-warning"></i>Histórico de Intervenções
                            </h4>
                            @if (Model.Interventions != null && Model.Interventions.Any())
                            {
                                <ul class="timeline timeline-dashed mt-4">
                                    @foreach (var ticket in Model.Interventions)
                                    {
                                        string statusColor = ticket.Status == "Concluído" ? "success" : ticket.Status == "Pedido" ? "info" : "warning";
                                        <li class="timeline-item timeline-item-transparent @(ticket == Model.Interventions.Last() ? "border-transparent" : "")">
                                            <span class="timeline-point timeline-point-@statusColor"></span>
                                            <div class="timeline-event">
                                                <div class="timeline-header mb-1">
                                                    <h6 class="mb-0 fw-bold text-white">Ticket #@ticket.Id - @ticket.Level</h6>
                                                    <small class="text-white-50">@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                                </div>
                                                <p class="mb-2 text-light small">@ticket.Description</p>
                                                <div class="d-flex flex-wrap align-items-center gap-3">
                                                    <div class="d-flex align-items-center">
                                                        <i class="ri-user-settings-line me-1 text-warning"></i>
                                                        <span class="small text-white-50">Técnico: @(ticket.Technician?.Username ?? "N/A")</span>
                                                    </div>
                                                    <span class="badge bg-label-@statusColor rounded-pill">@ticket.Status</span>
                                                    @if (ticket.SatisfacaoRating.HasValue)
                                                    {
                                                        <div class="ms-auto text-warning small">
                                                            @for(int i=1; i<=5; i++) { <i class="ri-star-@(i <= ticket.SatisfacaoRating ? "fill" : "line")"></i> }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="p-4 rounded bg-white bg-opacity-5 text-center border border-white border-opacity-10">
                                    <p class="mb-0 text-white-50 small">Sem histórico de intervenções registado para este equipamento.</p>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="mt-auto pt-5 pb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <p class="text-white-50 small mb-0">
                        <i class="ri-information-line me-1"></i> 
                        ASNET Platform • @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                    </p>
                    <div class="d-flex gap-2 d-print-none">
                        <a href="/" class="btn btn-outline-light btn-sm px-3"><i class="ri-home-4-line me-1"></i> Dashboard</a>
                        <button onclick="window.print()" class="btn btn-warning btn-sm px-4">
                            <i class="ri-printer-line me-1"></i> Imprimir
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    body { background-color: #2b2c40; margin: 0; padding: 0; }
    .timeline-event { color: #fff !important; }
    .bg-label-success { background-color: rgba(113, 221, 55, 0.1) !important; color: #71dd37 !important; }
    .bg-label-info { background-color: rgba(3, 195, 236, 0.1) !important; color: #03c3ec !important; }
    .bg-label-warning { background-color: rgba(255, 171, 0, 0.1) !important; color: #ffab00 !important; }
    
    @@media print {
        .d-print-none { display: none !important; }
        .card { background-color: #fff !important; color: #000 !important; }
        .text-white, .text-white-50, .text-light { color: #000 !important; }
        .bg-white { background-color: #fff !important; border: 1px solid #ddd !important; }
    }
</style>
