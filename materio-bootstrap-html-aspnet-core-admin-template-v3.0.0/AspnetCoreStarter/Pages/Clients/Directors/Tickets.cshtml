@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorTicketsModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Tickets";
}

<link rel="stylesheet" href="~/css/tickets-v2.css" />
<style>
    .cursor-pointer { cursor: pointer; }
</style>

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Diretor /</span> Tickets</h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Solicitações de Suporte @(Model.MyAgrupamentoName != null ? $"- {Model.MyAgrupamentoName}" : "")</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    <i class="ri-filter-3-line"></i> Filtros
                </button>
                <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalNovoTicketGlobal">
                    <i class='bx bx-plus-circle me-1'></i> Novo Ticket
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.FilterStatus) && Model.FilterStatus != "Todos os Estados" || !string.IsNullOrEmpty(Model.FilterArticle) || !string.IsNullOrEmpty(Model.FilterType))
        {
            <div class="card-body py-2">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0 shadow-sm border-0" role="alert" style="padding: 0.6rem 1.2rem; background-color: #e7f3ff;">
                    <div class="d-flex align-items-center">
                        <i class="ri-filter-3-line me-2 text-primary"></i>
                        <span class="small text-primary fw-medium">
                            Filtros ativos: 
                            @if (!string.IsNullOrEmpty(Model.FilterStatus) && Model.FilterStatus != "Todos os Estados") { <span class="badge bg-white text-primary border me-1">Estado: @Model.FilterStatus</span> }
                            @if (!string.IsNullOrEmpty(Model.FilterArticle)) { <span class="badge bg-white text-primary border me-1">Artigo: @Model.FilterArticle</span> }
                            @if (!string.IsNullOrEmpty(Model.FilterType)) { <span class="badge bg-white text-primary border me-1">Tipo: @Model.FilterType</span> }
                        </span>
                    </div>
                    <a asp-page="./Tickets" class="btn btn-sm btn-primary rounded-pill px-3">
                        <i class="ri-refresh-line me-1 small"></i> Limpar Filtros
                    </a>
                </div>
            </div>
        }
        <div class="tk-list">
            @if (Model.Tickets == null || !Model.Tickets.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="ri-inbox-line fs-1 d-block mb-2"></i>
                    Nenhum ticket encontrado.
                </div>
            }
            else
            {
                @foreach (var t in Model.Tickets)
                {
                    <div class="tk-row" onclick="openTicketPanel(@t.Id)">
                        <div class="tk-left">
                            <div class="tk-icon">
                                @{
                                    var type = t.Equipamento?.Type ?? "";
                                    var name = t.Equipamento?.Name ?? "";
                                    var emoji = type switch {
                                        var s when s.Contains("Monitor") => "🖥️",
                                        var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                                        var s when s.Contains("Impressora") => "🖨️",
                                        var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                                        var s when s.Contains("Projetor") => "📽️",
                                        var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                                        var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                                        var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                                        var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                                        var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                                        var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                                        _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                                    };
                                }
                                @emoji
                            </div>
                            <div class="tk-details">
                                <div class="tk-title">@(t.Equipamento?.Name ?? "Avaria Geral")</div>
                                <div class="tk-sub">
                                    <i class="ri-community-line me-1"></i> @(t.School?.Name ?? "N/A") • @t.CreatedAt.ToString("dd/MM HH:mm")
                                </div>
                            </div>
                        </div>
                        <div class="tk-right">
                            @{
                                var stCol = t.Status switch {
                                    "Concluído" => "var(--tk-green)",
                                    "Em Reparação" or "Em Resolução" => "var(--tk-primary)",
                                    "Pedido" or "Pendente" => "var(--tk-amber)",
                                    _ => "var(--tk-muted)"
                                };
                            }
                            <span class="badge-tk" style="color: @stCol; border-color: @stCol; background: @(stCol)11;">@t.Status</span>
                            <i class="ri-arrow-right-s-line text-muted"></i>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Panel Overlay & Slide-over Panel -->
<div class="tk-overlay @(Model.SelectedTicketId.HasValue ? "open" : "")" onclick="closeTicketPanel()"></div>

<div class="tk-panel @(Model.SelectedTicketId.HasValue ? "open" : "")" id="ticketPanel">
    @if (Model.SelectedTicket != null)
    {
        var t = Model.SelectedTicket;
        
        <div class="tk-ph">
            <div class="tk-ph-top">
                <div class="tk-ph-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.5rem; display: flex; align-items: center; justify-content: center;">
                    @{
                        var type = t.Equipamento?.Type ?? "";
                        var name = t.Equipamento?.Name ?? "";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") => "🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                            var s when s.Contains("Impressora") => "🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                            var s when s.Contains("Projetor") => "📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                            _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-ph-info">
                    <div class="tk-ph-badges">
                        <span class="badge-tk" style="color: var(--tk-muted); border-color: var(--tk-border);">TK-@t.Id.ToString("D3")</span>
                        <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">@t.Status</span>
                    </div>
                    <h2 class="tk-ph-title">@(t.Equipamento?.Name ?? "Avaria Geral"): @(t.Description?.Length > 30 ? t.Description.Substring(0, 30) + "..." : t.Description)</h2>
                </div>
                <button class="tk-close" onclick="closeTicketPanel()">✕</button>
            </div>

            <div class="tk-stepper">
                @{
                    var steps = new[] { "Aberto", "Aceite", "Em Reparação", "Concluído" };
                    int si = Array.IndexOf(steps, t.Status);
                    if (si == -1 && t.Status == "Pedido") si = 0;
                    if (si == -1 && t.Status == "Em Resolução") si = 2;
                    if (si == -1 && t.Status == "Pendente") si = 0;
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i < si || t.Status == "Concluído";
                    bool active = i == si && t.Status != "Concluído";
                    <div class="tk-step">
                        @if (i < steps.Length - 1) {
                            <div class="tk-step-line @(i < si || t.Status == "Concluído" ? "done" : "")"></div>
                        }
                        <div class="tk-step-dot @(done ? "done" : "") @(active ? "active" : "")">
                            @(done ? "✓" : (i + 1).ToString())
                        </div>
                        <div class="tk-step-label @(active ? "active" : "")">@steps[i]</div>
                    </div>
                }
            </div>
        </div>

        <div class="tk-tabs">
            <div class="tk-tab active" onclick="showTab(0)">📁 Detalhes</div>
            <div class="tk-tab" onclick="showTab(2)">🕒 Histórico</div>
        </div>

        <div class="tk-body">
            <div class="tk-tab-content" id="tab-0">
                <div class="tk-info-grid">
                    <div class="tk-info-card"><div class="tk-info-label">Solicitante</div><div class="tk-info-val">@(t.RequestedBy?.Username ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Técnico</div><div class="tk-info-val">@(t.Technician?.Username ?? "A aguardar...")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Escola</div><div class="tk-info-val">@(t.School?.Name ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Criado em</div><div class="tk-info-val">@t.CreatedAt.ToString("dd/MM/yyyy, HH:mm")</div></div>
                </div>
                
                <div class="tk-desc-card">
                    <div class="tk-info-label">Descrição</div>
                    <div style="margin-top:6px;font-size:14px;line-height:1.6">@t.Description</div>
                </div>

                @if (Model.AssociatedEquipment.Any())
                {
                    <div class="tk-eq-card">
                        <div class="tk-eq-header">Material Aplicado</div>
                        @foreach (var eq in Model.AssociatedEquipment)
                        {
                            <div class="tk-eq-item">
                                <span><strong>@eq.Name</strong> · <span style="color:#6b7280;font-size:12px">@eq.SerialNumber</span></span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="tk-tab-content d-none" id="tab-2">
                <div style="display:flex;flex-direction:column;gap:12px">
                    @if (!Model.TicketHistory.Any()) {
                        <div style="color:var(--tk-muted);font-size:13px;padding:20px;text-align:center">Sem histórico registado.</div>
                    } else {
                        @foreach(var h in Model.TicketHistory) {
                            <div style="background:#1a232e;border-left:3px solid @(h.TipoAcao == TipoAcaoHistorico.Comentario ? "var(--tk-primary)" : "var(--tk-muted)");padding:12px;border-radius:0 8px 8px 0">
                                <div style="font-size:13px;line-height:1.5">@h.Acao</div>
                                <div style="font-size:11px;color:var(--tk-muted);margin-top:4px">@h.Autor · @h.Data.ToString("dd/MM HH:mm")</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @if(t.Status != "Concluído") {
            <div class="tk-footer">
                <form method="post" asp-page-handler="AddComment" asp-route-ticketId="@t.Id" class="d-flex w-100 gap-2">
                    <input type="text" name="comment" class="tk-comment" placeholder="Enviar mensagem ao técnico..." required autocomplete="off">
                    <button type="submit" class="tk-send-btn">✈ Enviar</button>
                </form>
            </div>
        }
    }
</div>
    </div>
</div>

<!-- Modal Novo Ticket Global -->
<div class="modal fade" id="modalNovoTicketGlobal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="CreateTicket" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Novo Ticket de Suporte</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Equipamento</label>
                    <select asp-for="NewTicket.EquipamentoId" id="selectEquipamento" class="form-select" required onchange="updatePriorityLevels()">
                        <option value="">Selecione um equipamento...</option>
                        @foreach (var eq in Model.AvailableEquipment)
                        {
                            var hasActive = Model.EqIdsWithActiveTickets.Contains(eq.Id);
                            var isBroken = eq.Status != null && (eq.Status.Contains("repara") || eq.Status.Contains("manutenção") || eq.Status.Contains("Avariado"));
                            var indicator = (hasActive || isBroken) ? "⚠️" : "✅";
                            
                            <option value="@eq.Id" data-type="@eq.Type" data-school="@eq.Room?.Block?.SchoolId">
                                @indicator @eq.Name (@eq.SerialNumber) - @eq.Type (@eq.Room?.Block?.School?.Name)
                            </option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Escola / Local</label>
                    <input type="hidden" asp-for="NewTicket.SchoolId" id="hiddenSchoolId" />
                    <select id="selectSchool" class="form-select" disabled style="background-color: #f8f9fa; cursor: not-allowed; opacity: 1;">
                        <option value="">Selecione um equipamento primeiro...</option>
                        @foreach (var s in Model.Schools)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                    <div class="form-text small"><i class="bx bx-info-circle"></i> A localização é determinada automaticamente pelo equipamento selecionado.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Nível de Prioridade</label>
                    <select asp-for="NewTicket.Level" id="selectPriority" class="form-select" required>
                        <option value="Baixo">Baixo</option>
                        <option value="Médio">Médio</option>
                        <option value="Alto">Alto</option>
                        <option value="Extremo">Extremo</option>
                    </select>
                    <div id="priorityHint" class="form-text text-muted small mt-1"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Período Preferencial</label>
                    <select asp-for="NewTicket.Period" class="form-select" required>
                        <option value="Manhã">Manhã</option>
                        <option value="Tarde" selected>Tarde</option>
                        <option value="Integral">Integral</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Descrição do Problema</label>
                    <textarea asp-for="NewTicket.Description" class="form-control" rows="3" required></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-primary">Submeter Ticket</button>
            </div>
        </form>
    </div>
</div>
    <!-- Modal Filtros -->
    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="get" class="modal-content">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title">Filtrar Tickets</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Estado do Ticket</label>
                            <select asp-for="FilterStatus" class="form-select">
                                <option value="Todos os Estados">Todos os Estados</option>
                                <option value="Pendente">Pendente</option>
                                <option value="Concluído">Concluído</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Artigo</label>
                            <select id="filterArtigo" asp-for="FilterArticle" class="form-select" onchange="filterTypesByArtigo()">
                                <option value="">Todos</option>
                                <option value="Computadores">Computadores</option>
                                <option value="Monitores">Monitores</option>
                                <option value="Impressoras">Impressoras</option>
                                <option value="Networking">Networking</option>
                                <option value="Servidores/Infra">Servidores/Infra</option>
                                <option value="Componentes">Componentes</option>
                                <option value="Periféricos">Periféricos</option>
                                <option value="Projetores">Projetores</option>
                                <option value="Quadros Interativos">Quadros Interativos</option>
                                <option value="Outros">Outros</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Tipo</label>
                            <select id="filterTipo" asp-for="FilterType" class="form-select">
                                <option value="">Todos</option>
                                <!-- Computadores -->
                                <option value="Desktop" data-art="Computadores">Desktop</option>
                                <option value="Portátil" data-art="Computadores">Portátil</option>
                                <option value="AIO" data-art="Computadores">AIO</option>
                                <option value="Laptop" data-art="Computadores">Laptop</option>
                                <!-- Monitores -->
                                <option value="Monitor" data-art="Monitores">Monitor</option>
                                <option value="Televisão" data-art="Monitores">Televisão</option>
                                <option value="TV" data-art="Monitores">TV</option>
                                <!-- Impressoras -->
                                <option value="Impressora" data-art="Impressoras">Impressora</option>
                                <!-- Networking -->
                                <option value="Router" data-art="Networking">Router</option>
                                <option value="Switch" data-art="Networking">Switch</option>
                                <option value="Access Point" data-art="Networking">Access Point</option>
                                <option value="Firewall" data-art="Networking">Firewall</option>
                                <!-- Servidores/Infra -->
                                <option value="Servidor" data-art="Servidores/Infra">Servidor</option>
                                <option value="Storage" data-art="Servidores/Infra">Storage</option>
                                <option value="NAS" data-art="Servidores/Infra">NAS</option>
                                <!-- Componentes -->
                                <option value="Motherboard" data-art="Componentes">Motherboard</option>
                                <option value="Disco HDD" data-art="Componentes">Disco HDD</option>
                                <option value="Disco SSD" data-art="Componentes">Disco SSD</option>
                                <option value="Memória RAM" data-art="Componentes">Memória RAM</option>
                                <option value="Processador (CPU)" data-art="Componentes">Processador (CPU)</option>
                                <option value="Placa Gráfica" data-art="Componentes">Placa Gráfica</option>
                                <option value="Fonte Alimentação" data-art="Componentes">Fonte Alimentação</option>
                                <!-- Periféricos -->
                                <option value="Teclado" data-art="Periféricos">Teclado</option>
                                <option value="Rato" data-art="Periféricos">Rato</option>
                                <option value="Headphones" data-art="Periféricos">Headphones</option>
                                <option value="Colunas" data-art="Periféricos">Colunas</option>
                                <!-- Projetores -->
                                <option value="Projetor" data-art="Projetores">Projetor</option>
                                <!-- Quadros Interativos -->
                                <option value="Quadro Interativo" data-art="Quadros Interativos">Quadro Interativo</option>
                                <option value="Mesa Interativa" data-art="Quadros Interativos">Mesa Interativa</option>
                                <!-- Outros -->
                                <option value="Cabo/Adaptador" data-art="Outros">Cabo/Adaptador</option>
                                <option value="Outro" data-art="Outros">Outro</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function openTicketPanel(id) {
        const url = new URL(window.location);
        url.searchParams.set('SelectedTicketId', id);
        window.location.href = url.toString();
    }
    function closeTicketPanel() {
        const url = new URL(window.location);
        url.searchParams.delete('SelectedTicketId');
        window.location.href = url.toString();
    }
    function showTab(idx) {
        document.querySelectorAll('.tk-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
        document.querySelectorAll('.tk-tab-content').forEach((c, i) => c.classList.toggle('d-none', i !== idx));
    }
    function filterTypesByArtigo() {
        const artName = document.getElementById('filterArtigo').value;
        const tipoSelect = document.getElementById('filterTipo');
        const options = tipoSelect.querySelectorAll('option');
        
        tipoSelect.value = "";
        
        options.forEach(opt => {
            if (opt.value === "") return;
            const optArts = (opt.getAttribute('data-art') || "").split('|');
            if (artName === "" || optArts.includes(artName)) {
                opt.style.display = 'block';
            } else {
                opt.style.display = 'none';
            }
        });
    }

    function updatePriorityLevels() {
        const selectEq = document.getElementById('selectEquipamento') || document.getElementById('selectEquipamentoDisabled');
        if (!selectEq) return;
        
        const selectPri = document.getElementById('selectPriority');
        const selectSchool = document.getElementById('selectSchool');
        const hiddenSchoolId = document.getElementById('hiddenSchoolId');
        const hint = document.getElementById('priorityHint');
        
        // Get selected option and its data attributes
        const selectedOption = selectEq.options[selectEq.selectedIndex];
        const type = selectedOption ? selectedOption.getAttribute('data-type') : '';
        const schoolId = selectedOption ? selectedOption.getAttribute('data-school') : '';

        console.log("Selected equipment type:", type, "School ID:", schoolId);

        // 1. Update School/Location (Locked)
        if (schoolId && selectSchool && hiddenSchoolId) {
            selectSchool.value = schoolId;
            hiddenSchoolId.value = schoolId;
            
            // Apply visual feedback for locked state
            selectSchool.style.pointerEvents = "none";
            selectSchool.style.backgroundColor = "#f8f9fa";
            selectSchool.style.opacity = "1";
        } else if (selectSchool && hiddenSchoolId) {
            selectSchool.value = "";
            hiddenSchoolId.value = "";
            selectSchool.style.pointerEvents = "auto";
            selectSchool.style.backgroundColor = "";
        }

        // 2. Process Priority based on Type
        if (type) {
            processPriority(type);
        }
    }

    function processPriority(type) {
        const selectPri = document.getElementById('selectPriority');
        const hint = document.getElementById('priorityHint');
        console.log("Processing priority for type:", type);

        if (!selectPri) return;

        // Reset all options
        for (let i = 0; i < selectPri.options.length; i++) {
            selectPri.options[i].disabled = false;
        }
        hint.innerText = "";

        if (!type) return;
        const typeLower = type.toLowerCase().trim();

        const disableByValue = (val) => {
            for (let i = 0; i < selectPri.options.length; i++) {
                if (selectPri.options[i].value === val) selectPri.options[i].disabled = true;
            }
        };

        if (typeLower.includes('aio') || typeLower.includes('computador') || typeLower.includes('desktop') || typeLower.includes('portátil') || typeLower.includes('laptop')) {
            // Médio ONLY (as requested)
            selectPri.value = 'Médio';
            disableByValue('Baixo');
            disableByValue('Alto');
            disableByValue('Extremo');
            hint.innerText = "Prioridade: Médio.";
        } else if (typeLower.includes('quadro interativo') || typeLower.includes('smartboard') || typeLower.includes('networking') || typeLower.includes('switch') || typeLower.includes('router') || typeLower.includes('access point') || typeLower.includes('firewall')) {
            // Médio/Alto
            if (selectPri.value === 'Baixo' || selectPri.value === 'Extremo') selectPri.value = 'Médio';
            disableByValue('Baixo');
            disableByValue('Extremo');
            hint.innerText = "Prioridade: Médio / Alto.";
        } else if (typeLower.includes('impressora') || typeLower.includes('monitor') || typeLower.includes('projetor') || typeLower.includes('televisao') || typeLower.includes('tv')) {
            // Baixo/Médio
            if (selectPri.value === 'Alto' || selectPri.value === 'Extremo') selectPri.value = 'Médio';
            disableByValue('Alto');
            disableByValue('Extremo');
            hint.innerText = "Prioridade: Baixo / Médio.";
        } else if (typeLower.includes('mesa interativa')) {
            // Médio only
            selectPri.value = 'Médio';
            disableByValue('Baixo');
            disableByValue('Alto');
            disableByValue('Extremo');
            hint.innerText = "Prioridade: Médio.";
        } else if (typeLower.includes('servidor') || typeLower.includes('storage') || typeLower.includes('nas')) {
            // Critical Infra fallback: Alto/Extremo
            if (selectPri.value === 'Baixo' || selectPri.value === 'Médio') selectPri.value = 'Alto';
            disableByValue('Baixo');
            disableByValue('Médio');
            hint.innerText = "Infraestrutura crítica: Alto / Extremo.";
        }

        console.log("Allowed priorities updated for:", typeLower);
    }

    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const modalElement = document.getElementById('modalNovoTicketGlobal');
        
        // Auto-open modal if context is provided via URL
        if (urlParams.has('eqId')) {
            const eqIdVal = urlParams.get('eqId');
            const myModal = new bootstrap.Modal(modalElement);
            myModal.show();
            // Trigger priority check after modal is shown to lock school etc
            modalElement.addEventListener('shown.bs.modal', function () {
                var selectEq = document.getElementById('selectEquip');
                if (selectEq && eqIdVal) {
                    selectEq.value = eqIdVal;
                    if (typeof jQuery !== 'undefined' && $(selectEq).hasClass("select2-hidden-accessible")) {
                        $(selectEq).trigger('change');
                    }
                }
                updatePriorityLevels();
            }, { once: true });
        }

        // Clear ticket context from URL and reset form when modal is closed
        modalElement.addEventListener('hidden.bs.modal', function () {
            // Remove eqId from URL without reloading
            if (window.location.search.includes('eqId')) {
                const url = new URL(window.location.href);
                url.searchParams.delete('eqId');
                window.history.replaceState({}, '', url);
            }
            
            // Re-enable school select if it was locked
            const selectSchool = document.getElementById('selectSchool');
            if (selectSchool) {
                selectSchool.style.pointerEvents = "auto";
                selectSchool.style.backgroundColor = "";
                selectSchool.style.opacity = "1";
            }
            
            // Clear priority hint
            const hint = document.getElementById('priorityHint');
            if (hint) hint.innerText = "";
            
            const selectEq = document.getElementById('selectEquip');
            if (selectEq) {
                selectEq.value = "";
                if (typeof jQuery !== 'undefined' && $(selectEq).hasClass("select2-hidden-accessible")) {
                    $(selectEq).trigger('change');
                }
            }
        });
    });
</script>
}
