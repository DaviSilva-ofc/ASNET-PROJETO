@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorTicketsModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Tickets";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Diretor /</span> Tickets</h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Solicitações de Suporte @(Model.MyAgrupamentoName != null ? $"- {Model.MyAgrupamentoName}" : "")</h5>
            <div class="d-flex gap-3 align-items-center">
                <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalNovoTicketGlobal">
                    <i class='bx bx-plus-circle me-1'></i> Novo Ticket
                </button>
                <form method="get" class="d-flex gap-2">
                    <select name="FilterStatus" class="form-select form-select-sm" style="width: auto;">
                        <option value="">Todos os Estados</option>
                        <option value="Pedido" selected="@(Model.FilterStatus == "Pedido" ? "selected" : null)">Pedido</option>
                        <option value="Pendente" selected="@(Model.FilterStatus == "Pendente" ? "selected" : null)">Pendente</option>
                        <option value="Em Resolução" selected="@(Model.FilterStatus == "Em Resolução" ? "selected" : null)">Em Resolução</option>
                        <option value="Fechado" selected="@(Model.FilterStatus == "Fechado" ? "selected" : null)">Fechado</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-primary">Filtrar</button>
                    <a asp-page="./Tickets" class="btn btn-sm btn-outline-secondary">Limpar</a>
                </form>
            </div>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Escola</th>
                        <th>Assunto / Descrição</th>
                        <th>Prioridade</th>
                        <th>Estado</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Tickets == null || !Model.Tickets.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Nenhum ticket encontrado para este agrupamento.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var t in Model.Tickets)
                        {
                            <tr>
                                <td>#@t.Id</td>
                                <td>@t.School?.Name</td>
                                <td>
                                    <div class="text-wrap" style="max-width: 300px;">
                                        @t.Description
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(t.Level))
                                    {
                                        <span class="badge @(t.Level.Contains("Alto") || t.Level.Contains("Crítico") ? "bg-label-danger" : (t.Level.Contains("Média") ? "bg-label-warning" : "bg-label-info"))">
                                            @t.Level
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">N/A</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusClass = t.Status switch
                                        {
                                            "Pedido" => "bg-label-primary",
                                            "Pendente" => "bg-label-warning",
                                            "Em Resolução" => "bg-label-info",
                                            "Fechado" => "bg-label-success",
                                            _ => "bg-label-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@t.Status</span>
                                </td>
                                <td>@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Novo Ticket Global -->
<div class="modal fade" id="modalNovoTicketGlobal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form method="post" asp-page-handler="CreateTicket" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Novo Ticket de Suporte</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <!-- Agrupamento -->
                    <div class="col-md-12">
                        <label class="form-label">Agrupamento</label>
                        <input type="text" class="form-control" value="@(Model.Agrupamento?.Name ?? "N/A")" readonly disabled />
                    </div>

                    <!-- Localização -->
                    <div class="col-md-4">
                        <label class="form-label">Escola</label>
                        <select name="schoolId" id="ticketSchool" class="form-select" required onchange="filterTicketBlocks()">
                            <option value="">Selecione a Escola</option>
                            @if(Model.Schools != null) {
                                foreach (var school in Model.Schools)
                                {
                                    <option value="@school.Id">@school.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Bloco</label>
                        <select name="blockId" id="ticketBlock" class="form-select" required onchange="filterTicketRooms()">
                            <option value="">Selecione o Bloco</option>
                            @if(Model.Blocos != null) {
                                foreach (var bloco in Model.Blocos)
                                {
                                    <option value="@bloco.Id" data-esc="@bloco.SchoolId" style="display:none;">@bloco.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sala</label>
                        <select name="roomId" id="ticketRoom" class="form-select" required>
                            <option value="">Selecione a Sala</option>
                            @if(Model.Salas != null) {
                                foreach (var sala in Model.Salas)
                                {
                                    <option value="@sala.Id" data-blc="@sala.BlockId" style="display:none;">@sala.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Equipamento & Urgência -->
                    <div class="col-md-6">
                        <label class="form-label">Tipo de Equipamento</label>
                        <select name="equipmentType" class="form-select" required>
                            <option value="">Selecione o Tipo</option>
                            @foreach (var type in Model.EquipmentTypes)
                            {
                                <option value="@type">@type</option>
                            }
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nível de Urgência</label>
                        <select name="level" class="form-select" required>
                            <option value="Baixa">Baixa</option>
                            <option value="Normal" selected>Normal</option>
                            <option value="Alta">Alta</option>
                            <option value="Crítico">Crítico</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-primary">Submeter Ticket</button>
            </div>
        </form>
    </div>
</div>

@section PageScripts {
<script>
    // ===== Cascade Filtering for Tickets =====
    function filterTicketBlocks() {
        const escId = document.getElementById('ticketSchool').value;
        const blcSelect = document.getElementById('ticketBlock');
        const options = blcSelect.querySelectorAll('option:not([value=""])');
        
        blcSelect.value = "";
        options.forEach(opt => {
            opt.style.display = (escId === "" || opt.getAttribute('data-esc') === escId) ? 'block' : 'none';
        });
        filterTicketRooms(); // cascade reset
    }

    function filterTicketRooms() {
        const blcId = document.getElementById('ticketBlock').value;
        const salaSelect = document.getElementById('ticketRoom');
        const options = salaSelect.querySelectorAll('option:not([value=""])');
        
        salaSelect.value = "";
        options.forEach(opt => {
            opt.style.display = (blcId === "" || opt.getAttribute('data-blc') === blcId) ? 'block' : 'none';
        });
    }
</script>
}
