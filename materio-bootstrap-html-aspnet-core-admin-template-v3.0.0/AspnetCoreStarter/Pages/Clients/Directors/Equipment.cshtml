    function filterSelect(input, selectId) {
        if (!input) return;
        const filter = input.value.toLowerCase();
        const select = document.getElementById(selectId);
        const options = select.querySelectorAll('option');
        const artigo = document.getElementById('regArtigo')?.value;

        options.forEach(option => {
            if (option.value === "") return;
            const matchesArtigo = !artigo || !option.hasAttribute('data-artigo') || option.getAttribute('data-artigo') === artigo;
            const matchesSearch = option.text.toLowerCase().includes(filter);
            option.style.display = (matchesArtigo && matchesSearch) ? 'block' : 'none';
        });
    }

    function updateSpecificTypes() {
        const artigo = document.getElementById('regArtigo').value;
        const tipoSelect = document.getElementById('regTipo');
        tipoSelect.value = "";
        
        const wrapper = tipoSelect.closest('.select-search-wrapper');
        if (wrapper) {
            const searchInput = wrapper.querySelector('.select-search-input');
            filterSelect(searchInput, 'regTipo');
        }
    }

    function updateBrandsModels(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const marcaSelect = document.getElementById(prefix + 'Marca');
        const modeloSelect = document.getElementById(prefix + 'Modelo');
        const tipoSelect = document.getElementById(prefix + 'Tipo');

        marcaSelect.innerHTML = '<option value="">Selecione a marca...</option>';
        modeloSelect.innerHTML = '<option value="">Selecione o modelo...</option>';

        // Filter specific types in the dropdown
        if (tipoSelect) {
            Array.from(tipoSelect.options).forEach(opt => {
                if (opt.value === "") return;
                const dataArt = opt.getAttribute('data-artigo');
                opt.style.display = (!artigo || !dataArt || dataArt === artigo) ? 'block' : 'none';
            });
        }

        const marcaWrapper = marcaSelect.closest('.select-search-wrapper');
        if (marcaWrapper) marcaWrapper.querySelector('.select-search-input').value = '';
        const modeloWrapper = modeloSelect.closest('.select-search-wrapper');
        if (modeloWrapper) modeloWrapper.querySelector('.select-search-input').value = '';

        if (artigo && brandModelData[artigo]) {
            const brands = Object.keys(brandModelData[artigo]).sort();
            brands.forEach(brand => {
                marcaSelect.add(new Option(brand, brand));
            });
        }
    }

    function updateModels(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const marca = document.getElementById(prefix + 'Marca').value;
        const modeloSelect = document.getElementById(prefix + 'Modelo');

        modeloSelect.innerHTML = '<option value="">Selecione o modelo...</option>';
        const modeloWrapper = modeloSelect.closest('.select-search-wrapper');
        if (modeloWrapper) modeloWrapper.querySelector('.select-search-input').value = '';

        if (artigo && marca && brandModelData[artigo] && brandModelData[artigo][marca]) {
            brandModelData[artigo][marca].forEach(model => {
                modeloSelect.add(new Option(model, model));
            });
        }
    }

    function regFilterBlocos() {
        const escId = document.getElementById('regEscola').value;
        const blcSelect = document.getElementById('regBloco');
        const options = blcSelect.querySelectorAll('option');
        blcSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (escId === "" || opt.getAttribute('data-esc') === escId) ? 'block' : 'none';
        });
        regFilterSalas();
    }

    function regFilterSalas() {
        const blcId = document.getElementById('regBloco').value;
        const salaSelect = document.getElementById('regSala');
        const options = salaSelect.querySelectorAll('option');
        salaSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (blcId === "" || opt.getAttribute('data-blc') === blcId) ? 'block' : 'none';
        });
    }

    function filterBlocos() {
        const escId = document.getElementById('filterEscola').value;
        const blcSelect = document.getElementById('filterBloco');
        const options = blcSelect.querySelectorAll('option');
        blcSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (escId === "" || opt.getAttribute('data-esc') === escId) ? 'block' : 'none';
        });
        filterSalas();
    }

    function openEditModal(id, name, type, brand, model, serial, roomId, empId, status) {
        document.getElementById('editId').value = id;
        
        // Set Artigo and trigger brands update
        const artSelect = document.getElementById('editArtigo');
        artSelect.value = name;
        updateBrandsModels('edit');

        // Set Marca and trigger models update
        const marcaSelect = document.getElementById('editMarca');
        marcaSelect.value = brand;
        updateModels('edit');

        // Set others
        document.getElementById('editModelo').value = model;
        document.getElementById('editTipo').value = type;
        document.getElementById('editSerial').value = serial;
        document.getElementById('editSala').value = roomId || "";
        document.getElementById('editEmpresa').value = empId || "";

        const statusSelect = document.getElementById('editStatus');
        if (statusSelect) {
            if (status === "Funcionando" || !status) status = "A funcionar";
            statusSelect.value = status;
        }

        var modal = new bootstrap.Modal(document.getElementById('modalEditarEquipamento'));
        modal.show();
    }

    function filterSalas() {
        const blcId = document.getElementById('filterBloco').value;
        const salaSelect = document.getElementById('filterSala');
        const options = salaSelect.querySelectorAll('option');
        salaSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (blcId === "" || opt.getAttribute('data-blc') === blcId) ? 'block' : 'none';
        });
    }

    function filterTypesByArtigo() {
        const artName = document.getElementById('filterArtigo').value;
        const tipoSelect = document.getElementById('filterTipo');
        const options = tipoSelect.querySelectorAll('option');
        
        tipoSelect.value = "";
        
        options.forEach(opt => {
            if (opt.value === "") return;
            const optArts = (opt.getAttribute('data-art') || "").split('|');
            if (artName === "" || optArts.includes(artName)) {
                opt.style.display = 'block';
            } else {
                opt.style.display = 'none';
            }
        });
    }

    function toggleLocationType() {
        const hdnLocType = document.getElementById('hdnLocationType');
        if (hdnLocType) hdnLocType.value = "escola";
        const divEscola = document.getElementById('divLocEscola');
        if (divEscola) divEscola.style.display = 'block';
    }
</script>
