@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorEquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Equipamentos";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Diretor /</span> Equipamentos</h4>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class='bx bx-check-circle me-1'></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Inventário de Equipamentos</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    🔍 Pesquisa e Filtros
                </button>
            </div>
        </div>
        @{
            var activeFilterText = "";
            if (Model.ActiveFilterRoom != null) activeFilterText = $"sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) activeFilterText = $"bloco: {Model.ActiveFilterBloco.Name}";
            else if (Model.ActiveFilterEscola != null) activeFilterText = $"escola: {Model.ActiveFilterEscola.Name}";
            else if (Model.ActiveFilterAgrupamento != null) activeFilterText = $"agrupamento: {Model.ActiveFilterAgrupamento.Name}";
        }
        @if (!string.IsNullOrEmpty(activeFilterText))
        {
            <div class="card-body">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert">
                    <span>A visualizar equipamentos do <strong>@activeFilterText</strong></span>
                    <a asp-page="./Equipment" class="btn btn-sm btn-info border-1 border-white">Limpar Filtro</a>
                </div>
            </div>
        }
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th>Tipo</th>
                        <th>Nº Série</th>
                        <th>Estado</th>
                        <th>Localização (Sala)</th>
                        <th>Escola</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Equipments == null || !Model.Equipments.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">Nenhum equipamento encontrado.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Equipments)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.Type</td>
                                <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                                <td>
                                    @if (item.Status == "Avariado" || item.Status == "Indisponível" || item.Status == "Indisponivel")
                                    {
                                        <span class="badge bg-label-danger">Indisponível</span>
                                    }
                                    else if (item.Status == "Em uso" || item.Status == "Em Uso")
                                    {
                                        <span class="badge bg-label-warning">Em uso</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-success">Disponível</span>
                                    }
                                </td>
                                <td>@item.Room?.Name (@item.Room?.Block?.Name)</td>
                                <td>@item.Room?.Block?.School?.Name</td>
                                <td>
                                    @if (item.Status == "Avariado")
                                    {
                                        <button class="btn btn-sm btn-danger" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#modalSolicitarTicket" 
                                                onclick="setEquipmentId(@item.Id, '@item.Name', '@item.Type')">
                                            <i class='bx bx-plus-circle me-1'></i> Solicitar Ticket
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Filtros -->
    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="get" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Pesquisar Equipamentos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Artigo</label>
                            <input type="text" asp-for="FilterName" class="form-control" placeholder="Pesquisar por artigo (ex: Computadores)..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tipo</label>
                            <select asp-for="FilterType" class="form-select">
                                <option value="">Todos</option>
                                <option value="Desktop">Desktop</option>
                                <option value="Portátil">Portátil</option>
                                <option value="Monitor">Monitor</option>
                                <option value="Motherboard">Motherboard</option>
                                <option value="Disco HDD">Disco HDD</option>
                                <option value="Disco SSD">Disco SSD</option>
                                <option value="Memória RAM">Memória RAM</option>
                                <option value="Processador (CPU)">Processador (CPU)</option>
                                <option value="Teclado">Teclado</option>
                                <option value="Rato">Rato</option>
                                <option value="Impressora">Impressora</option>
                                <option value="Projetor">Projetor</option>
                                <option value="Router">Router</option>
                                <option value="Switch">Switch</option>
                                <option value="Outro">Outro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Estado</label>
                            <select asp-for="FilterStatus" class="form-select">
                                <option value="">Todos</option>
                                <option value="Disponível">Disponível</option>
                                <option value="Em uso">Em uso</option>
                                <option value="Indisponível">Indisponível</option>
                            </select>
                        </div>
                        
                        <hr class="my-3">
                        <h6>Localização</h6>
                        
                        <div class="col-12">
                            <label class="form-label">Escola</label>
                            <select id="filterEscola" asp-for="FilterEscolaId" class="form-select" onchange="filterBlocos()">
                                <option value="">Todas</option>
                                @foreach (var esc in Model.AvailableEscolas)
                                {
                                    <option value="@esc.Id">@esc.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bloco</label>
                            <select id="filterBloco" asp-for="FilterBlocoId" class="form-select" onchange="filterSalas()">
                                <option value="">Todos</option>
                                @foreach (var blc in Model.AvailableBlocos)
                                {
                                    <option value="@blc.Id" data-esc="@blc.SchoolId">@blc.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sala</label>
                            <select id="filterSala" asp-for="FilterRoomId" class="form-select">
                                <option value="">Todas</option>
                                @foreach (var sala in Model.Rooms)
                                {
                                    <option value="@sala.Id" data-blc="@sala.BlockId">@sala.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="reset" class="btn btn-outline-secondary" onclick="window.location.href='@Url.Page("./Equipment")'">Limpar Tudo</button>
                    <button type="submit" class="btn btn-primary">🔍 Pesquisar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Solicitar Ticket -->
    <div class="modal fade" id="modalSolicitarTicket" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="CreateTicket" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Solicitar Reparação</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="modalEqId" asp-for="NewTicket.EquipamentoId" />
                    <div class="row g-3">
                        <div class="col-12">
                            <p class="mb-2">A solicitar reparação para: <strong id="modalEqName">...</strong></p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nível de Urgência</label>
                            <select asp-for="NewTicket.Level" class="form-select" required>
                                <option value="Baixo">Baixo</option>
                                <option value="Normal" selected>Normal</option>
                                <option value="Alto">Alto</option>
                                <option value="Urgente">Urgente</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Período Preferencial</label>
                            <select asp-for="NewTicket.Period" class="form-select" required>
                                <option value="Manhã">Manhã</option>
                                <option value="Tarde">Tarde</option>
                                <option value="Integral">Integral</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descrição da Avaria</label>
                            <textarea asp-for="NewTicket.Description" class="form-control" rows="3" placeholder="Descreva o problema detalhadamente..." required></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Enviar Pedido</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function setEquipmentId(id, name, type) {
        document.getElementById('modalEqId').value = id;
        document.getElementById('modalEqName').innerText = name + (type ? ' (' + type + ')' : '');
    }

    function filterBlocos() {
        const escId = document.getElementById('filterEscola').value;
        const blcSelect = document.getElementById('filterBloco');
        const options = blcSelect.querySelectorAll('option');
        
        blcSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (escId === "" || opt.getAttribute('data-esc') === escId) ? 'block' : 'none';
        });
        filterSalas();
    }

    function filterSalas() {
        const blcId = document.getElementById('filterBloco').value;
        const salaSelect = document.getElementById('filterSala');
        const options = salaSelect.querySelectorAll('option');
        
        salaSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (blcId === "" || opt.getAttribute('data-blc') === blcId) ? 'block' : 'none';
        });
    }
</script>
}
