@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorEquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Equipamentos";
}

@section PageStyles {
<style>
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
</style>
}


<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Diretor /</span> Equipamentos</h4>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class='bx bx-check-circle me-1'></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Inventário de Equipamentos</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    <i class="ri-filter-3-line me-1"></i> Filtros
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEquipamento">
                    <i class="ri-add-line me-1"></i> Novo Equipamento
                </button>
            </div>
        </div>
        @{
            var hasSpecificLocationFilter = Model.ActiveFilterRoom != null || Model.ActiveFilterBloco != null || Model.ActiveFilterEscola != null;
            var hasAnyFilter = !string.IsNullOrEmpty(Model.FilterName) || !string.IsNullOrEmpty(Model.FilterType) || !string.IsNullOrEmpty(Model.FilterStatus) || hasSpecificLocationFilter;
            
            var activeFilterText = "";
            if (Model.ActiveFilterRoom != null) activeFilterText = $"Sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) activeFilterText = $"Bloco: {Model.ActiveFilterBloco.Name}";
            else if (Model.ActiveFilterEscola != null) activeFilterText = $"Escola: {Model.ActiveFilterEscola.Name}";
        }
        @if (hasAnyFilter)
        {
            <div class="card-body border-top py-2 bg-light">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert" style="padding: 0.5rem 1rem;">
                    <span class="small">
                        <i class="ri-information-line me-1"></i>
                        Filtros ativos: 
                        <strong>
                            @(!string.IsNullOrEmpty(Model.FilterName) ? $"Artigo: {Model.FilterName}, " : "")
                            @(!string.IsNullOrEmpty(Model.FilterType) ? $"Tipo: {Model.FilterType}, " : "")
                            @(!string.IsNullOrEmpty(Model.FilterStatus) ? $"Estado: {Model.FilterStatus}, " : "")
                            @(!string.IsNullOrEmpty(activeFilterText) ? activeFilterText : "")
                        </strong>
                    </span>
                    <a asp-page="./Equipment" class="btn btn-sm btn-outline-secondary">Limpar Filtros</a>
                </div>
            </div>
        }
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th>Tipo</th>
                        <th>Nº Série</th>
                        <th>Localização</th>
                        <th>Estado</th>
                        <th class="ps-3" style="width: 500px; min-width: 500px; white-space: nowrap;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Equipments == null || !Model.Equipments.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Nenhum equipamento encontrado.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Equipments)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.Type</td>
                                <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                                <td>
                                    @if (item.Room != null)
                                    {
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@item.Room.Name (@item.Room.Block?.Name)</span>
                                            <small class="text-muted">@item.Room.Block?.School?.Name</small>
                                        </div>
                                    }
                                    else if (item.Empresa != null)
                                    {
                                        <span class="text-warning"><i class="ri-building-4-line me-1"></i> @item.Empresa.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status != null && (item.Status.Trim().Equals("A funcionar", StringComparison.OrdinalIgnoreCase) || 
                                        item.Status.Trim().Equals("Disponível", StringComparison.OrdinalIgnoreCase) || 
                                        item.Status.Trim().Equals("Funcionando", StringComparison.OrdinalIgnoreCase) || 
                                        item.Status.Trim().Equals("Em uso", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <span class="badge bg-label-success">A funcionar</span>
                                    }
                                    else if (item.Status != null && (item.Status.Trim().Equals("Avariado", StringComparison.OrdinalIgnoreCase) || 
                                             item.Status.Trim().Equals("Indisponível", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <span class="badge bg-label-danger">Avariado</span>
                                    }
                                    else if (item.Status != null && item.Status.Trim().Equals("Em reparo", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-label-warning">Em reparo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary">@(item.Status ?? "Indefinido")</span>
                                    }
                                </td>
                                <td style="width: 500px; min-width: 500px; white-space: nowrap; padding-right: 60px !important;">
                                    <div class="d-flex align-items-center justify-content-start gap-2">
                                        @if (item.Status == "Em reparo")
                                        {
                                            <span class="text-muted small ps-2"><i class="ri-settings-line me-1"></i> Em Manutenção</span>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                                @if (item.Status == "Avariado" || item.Status == "Indisponível" || item.Status == "Danificado")
                                                {
                                                    <button type="submit" class="btn btn-sm text-success" title="Marcar como A funcionar"><i class="ri-check-line"></i> Funcional</button>
                                                    
                                                    @if (Model.EquipmentWithActiveTickets.Contains(item.Id))
                                                    {
                                                        <span class="text-info small ps-2" title="Já existe um ticket ativo para este equipamento">
                                                            <i class="ri-history-line me-1"></i> Ticket em curso
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <a asp-page="./Tickets" asp-route-eqId="@item.Id" class="btn btn-sm text-primary" title="Solicitar Ticket">
                                                            <i class="ri-add-circle-line"></i> Solicitar Ticket
                                                        </a>
                                                    }
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm text-warning" title="Marcar como Avariado"><i class="ri-error-warning-line"></i> Avariar</button>
                                                }
                                            </form>
                                        }

                                        <div class="d-flex align-items-center gap-1">
                                            <button type="button" class="btn btn-sm text-primary p-1" title="Editar"
                                                    onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@item.Brand', '@item.Model', '@item.SerialNumber', '@item.RoomId', '@item.EmpresaId', '@item.Status')">
                                                <i class="bx bx-edit"></i> ✏️
                                            </button>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?');" style="display:inline-block;">
                                                <button type="submit" class="btn btn-sm text-danger p-1" title="Eliminar"><i class="bx bx-trash"></i> 🗑️</button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Modal Editar Equipamento *@
    <div class="modal fade" id="modalEditarEquipamento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <form method="post" asp-page-handler="Edit">
                    <input type="hidden" asp-for="NewEquipment.Id" id="editId" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bx bx-edit me-2"></i>Editar Equipamento</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Artigo</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar artigo..." onkeyup="filterSelect(this, 'editArtigo')">
                                    <select asp-for="NewEquipment.Name" id="editArtigo" class="form-select" required onchange="updateBrandsModels('edit')">
                                        <option value="">Selecione...</option>
                                        <option value="Computadores">Computadores</option>
                                        <option value="Monitores">Monitores</option>
                                        <option value="Impressoras">Impressoras</option>
                                        <option value="Networking">Networking</option>
                                        <option value="Servidores/Infra">Servidores/Infra</option>
                                        <option value="Componentes">Componentes</option>
                                        <option value="Periféricos">Periféricos</option>
                                        <option value="Projetores">Projetores</option>
                                        <option value="Quadros Interativos">Quadros Interativos</option>
                                        <option value="Outros">Outros</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tipo Específico</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar tipo..." onkeyup="filterSelect(this, 'editTipo')">
                                    <select asp-for="NewEquipment.Type" id="editTipo" class="form-select" required>
                                        <option value="">Selecione o artigo primeiro...</option>
                                        <option value="Desktop" data-artigo="Computadores">Desktop</option>
                                        <option value="Portátil" data-artigo="Computadores">Portátil</option>
                                        <option value="AIO" data-artigo="Computadores">AIO</option>
                                        <option value="Laptop" data-artigo="Computadores">Laptop</option>
                                        <option value="Monitor" data-artigo="Monitores">Monitor</option>
                                        <option value="Televisão" data-artigo="Monitores">Televisão</option>
                                        <option value="TV" data-artigo="Monitores">TV</option>
                                        <option value="Motherboard" data-artigo="Componentes">Motherboard</option>
                                        <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
                                        <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
                                        <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
                                        <option value="Processador (CPU)" data-artigo="Componentes">Processador (CPU)</option>
                                        <option value="Placa Gráfica" data-artigo="Componentes">Placa Gráfica</option>
                                        <option value="Fonte Alimentação" data-artigo="Componentes">Fonte Alimentação</option>
                                        <option value="Teclado" data-artigo="Periféricos">Teclado</option>
                                        <option value="Rato" data-artigo="Periféricos">Rato</option>
                                        <option value="Impressora" data-artigo="Impressoras">Impressora</option>
                                        <option value="Projetor" data-artigo="Projetores">Projetor</option>
                                        <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
                                        <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
                                        <option value="Router" data-artigo="Networking">Router</option>
                                        <option value="Switch" data-artigo="Networking">Switch</option>
                                        <option value="Access Point" data-artigo="Networking">Access Point</option>
                                        <option value="Firewall" data-artigo="Networking">Firewall</option>
                                        <option value="Servidor" data-artigo="Servidores/Infra">Servidor</option>
                                        <option value="Storage" data-artigo="Servidores/Infra">Storage</option>
                                        <option value="NAS" data-artigo="Servidores/Infra">NAS</option>
                                        <option value="Cabo/Adatador" data-artigo="Outros">Cabo/Adaptador</option>
                                        <option value="Outro" data-artigo="Outros">Outro</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Marca</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar marca..." onkeyup="filterSelect(this, 'editMarca')">
                                    <select asp-for="NewEquipment.Brand" id="editMarca" class="form-select" required onchange="updateModels('edit')">
                                        <option value="">Selecione...</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Modelo</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar modelo..." onkeyup="filterSelect(this, 'editModelo')">
                                    <select asp-for="NewEquipment.Model" id="editModelo" class="form-select" required>
                                        <option value="">Selecione a marca primeiro...</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Nº Série</label>
                                <input type="text" asp-for="NewEquipment.SerialNumber" id="editSerial" class="form-control" required />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Sala (Opcional se for Empresa)</label>
                                <select asp-for="NewEquipment.RoomId" id="editSala" class="form-select">
                                    <option value="">Nenhuma / Empresa</option>
                                    @foreach (var sala in Model.Rooms)
                                    {
                                        <option value="@sala.Id">@sala.Name (@(sala.Block?.Name ?? "N/A"))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Estado do Equipamento</label>
                                <select asp-for="NewEquipment.Status" id="editStatus" class="form-select" required>
                                    <option value="A funcionar">A funcionar</option>
                                    <option value="Armazenado">Armazenado</option>
                                    <option value="Avariado">Avariado</option>
                                    <option value="Indisponível">Indisponível</option>
                                    <option value="Em Reparação">Em Reparação</option>
                                </select>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Empresa (Opcional se for Sala)</label>
                                <select asp-for="NewEquipment.EmpresaId" id="editEmpresa" class="form-select">
                                    <option value="">Nenhuma / Escola</option>
                                    @foreach (var emp in Model.AvailableEmpresas)
                                    {
                                        <option value="@emp.Id">@emp.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Novo Equipamento (Admin-style) -->
    <div class="modal fade" id="modalEquipamento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Add" class="modal-content">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title"><i class="ri-computer-line me-2 text-primary"></i>Registar Equipamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Artigo</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar artigo..." oninput="filterSelect(this, 'regArtigo')" />
                                <select asp-for="NewEquipment.Name" id="regArtigo" class="form-select" required onchange="updateBrandsModels(); updateSpecificTypes();">
                                    <option value="">Selecione o artigo...</option>
                                    <option value="Computadores">Computadores</option>
                                    <option value="Monitores">Monitores</option>
                                    <option value="Impressoras">Impressoras</option>
                                    <option value="Networking">Networking</option>
                                    <option value="Servidores/Infra">Servidores/Infra</option>
                                    <option value="Componentes">Componentes</option>
                                    <option value="Periféricos">Periféricos</option>
                                    <option value="Projetores">Projetores</option>
                                    <option value="Quadros Interativos">Quadros Interativos</option>
                                    <option value="Outros">Outros</option>
                                </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Tipo Específico</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar tipo..." oninput="filterSelect(this, 'regTipo')" />
                                <select asp-for="NewEquipment.Type" id="regTipo" class="form-select" required>
                                    <option value="">Selecione o tipo...</option>
                                    <option value="Desktop" data-artigo="Computadores">Desktop</option>
                                    <option value="Portátil" data-artigo="Computadores">Portátil</option>
                                    <option value="AIO" data-artigo="Computadores">AIO</option>
                                    <option value="Laptop" data-artigo="Computadores">Laptop</option>
                                    <option value="Monitor" data-artigo="Monitores">Monitor</option>
                                    <option value="Televisão" data-artigo="Monitores">Televisão</option>
                                    <option value="TV" data-artigo="Monitores">TV</option>
                                    <option value="Motherboard" data-artigo="Componentes">Motherboard</option>
                                    <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
                                    <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
                                    <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
                                    <option value="Processador (CPU)" data-artigo="Componentes">Processador (CPU)</option>
                                    <option value="Placa Gráfica" data-artigo="Componentes">Placa Gráfica</option>
                                    <option value="Fonte Alimentação" data-artigo="Componentes">Fonte Alimentação</option>
                                    <option value="Teclado" data-artigo="Periféricos">Teclado</option>
                                    <option value="Rato" data-artigo="Periféricos">Rato</option>
                                    <option value="Impressora" data-artigo="Impressoras">Impressora</option>
                                    <option value="Projetor" data-artigo="Projetores">Projetor</option>
                                    <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
                                    <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
                                    <option value="Router" data-artigo="Networking">Router</option>
                                    <option value="Switch" data-artigo="Networking">Switch</option>
                                    <option value="Access Point" data-artigo="Networking">Access Point</option>
                                    <option value="Firewall" data-artigo="Networking">Firewall</option>
                                    <option value="Servidor" data-artigo="Servidores/Infra">Servidor</option>
                                    <option value="Storage" data-artigo="Servidores/Infra">Storage</option>
                                    <option value="NAS" data-artigo="Servidores/Infra">NAS</option>
                                    <option value="Cabo/Adatador" data-artigo="Outros">Cabo/Adaptador</option>
                                    <option value="Outro" data-artigo="Outros">Outro</option>
                                </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small">Marca</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar marca..." oninput="filterSelect(this, 'regMarca')" />
                                <select asp-for="NewEquipment.Brand" id="regMarca" class="form-select" onchange="updateModels()">
                                    <option value="">Selecione a marca...</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small">Modelo</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar modelo..." oninput="filterSelect(this, 'regModelo')" />
                                <select asp-for="NewEquipment.Model" id="regModelo" class="form-select">
                                    <option value="">Selecione o modelo...</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Nº Série</label>
                        <input type="text" asp-for="NewEquipment.SerialNumber" class="form-control" placeholder="Ex: SN-2024-001" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-primary fw-semibold small">Estado Inicial</label>
                        <select asp-for="NewEquipment.Status" class="form-select border-primary" required>
                            <option value="A funcionar" selected>A funcionar</option>
                            <option value="Armazenado">Armazenado (Stock)</option>
                            <option value="Avariado">Avariado</option>
                        </select>
                    </div>

                    <input type="hidden" asp-for="LocationType" id="hdnLocationType" value="escola" />

                    <hr class="my-3">
                    <h6 class="mb-3 text-muted"><i class="ri-map-pin-line me-1"></i>Localização</h6>

                    <div id="divLocEscola">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Escola</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar escola..." oninput="filterSelect(this, 'regEscola')" />
                                <select id="regEscola" class="form-select" onchange="regFilterBlocos()">
                                    <option value="">Selecione a escola...</option>
                                    @foreach (var esc in Model.AvailableEscolas)
                                    {
                                        <option value="@esc.Id">@esc.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Bloco</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar bloco..." oninput="filterSelect(this, 'regBloco')" />
                                <select id="regBloco" class="form-select" onchange="regFilterSalas()">
                                    <option value="">Selecione o bloco...</option>
                                    @foreach (var blc in Model.AvailableBlocos)
                                    {
                                        <option value="@blc.Id" data-esc="@blc.SchoolId">@blc.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Sala</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar sala..." oninput="filterSelect(this, 'regSala')" />
                                <select id="regSala" asp-for="NewEquipment.RoomId" class="form-select">
                                    <option value="">Selecione a sala...</option>
                                    @foreach (var sala in Model.Rooms)
                                    {
                                        <option value="@sala.Id" data-blc="@sala.BlockId">@sala.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary"><i class="ri-save-line me-1"></i>Registar Equipamento</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Filtros -->
    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="get" class="modal-content">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title">Filtrar Equipamentos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Artigo</label>
                            <select id="filterArtigo" asp-for="FilterName" class="form-select" onchange="filterTypesByArtigo()">
                                <option value="">Todos</option>
                                <option value="Computador">Computadores</option>
                                <option value="Monitor">Monitores</option>
                                <option value="Impressora">Impressoras</option>
                                <option value="Projetor">Projetores</option>
                                <option value="Networking">Networking</option>
                                <option value="Componente">Componentes</option>
                                <option value="Periférico">Periféricos</option>
                                <option value="Quadro Interativo">Quadros Interativos</option>
                                <option value="Outro">Outros</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold small">Tipo</label>
                            <select id="filterTipo" asp-for="FilterType" class="form-select">
                                <option value="">Todos</option>
                                @* Standard types matching registration modal *@
                                <option value="Desktop" data-art="Computador">Desktop</option>
                                <option value="Portátil" data-art="Computador">Portátil</option>
                                <option value="Monitor" data-art="Monitor">Monitor</option>
                                <option value="Motherboard" data-art="Componente">Motherboard</option>
                                <option value="Disco HDD" data-art="Componente">Disco HDD</option>
                                <option value="Disco SSD" data-art="Componente">Disco SSD</option>
                                <option value="Memória RAM" data-art="Componente">Memória RAM</option>
                                <option value="Processador (CPU)" data-art="Componente">Processador (CPU)</option>
                                <option value="Teclado" data-art="Periférico">Teclado</option>
                                <option value="Rato" data-art="Periférico">Rato</option>
                                <option value="Impressora" data-art="Impressora">Impressora</option>
                                <option value="Projetor" data-art="Projetor">Projetor</option>
                                <option value="Router" data-art="Networking">Router</option>
                                <option value="Switch" data-art="Networking">Switch</option>
                                <option value="Outro" data-art="Outro">Outro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Estado</label>
                            <select asp-for="FilterStatus" class="form-select">
                                <option value="">Todos</option>
                                <option value="A funcionar">A funcionar</option>
                                <option value="Avariado">Avariado</option>
                                <option value="Em reparo">Em reparo</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Marca</label>
                            <select asp-for="FilterBrand" class="form-select">
                                <option value="">Todas</option>
                                @foreach (var brand in Model.UniqueBrands)
                                {
                                    <option value="@brand">@brand</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mt-0">
                            <label class="form-label fw-semibold small">Modelo</label>
                            <select asp-for="FilterModel" class="form-select">
                                <option value="">Todos</option>
                                @foreach (var m in Model.UniqueModels)
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        </div>
                        
                        <hr class="my-3">
                        <h6 class="mb-1 text-muted">Localização</h6>
                        
                        <div class="col-12 mt-2">
                            <label class="form-label fw-semibold small">Escola</label>
                            <select id="filterEscola" asp-for="FilterEscolaId" class="form-select" onchange="filterBlocos()">
                                <option value="">Todas</option>
                                @foreach (var esc in Model.AvailableEscolas)
                                {
                                    <option value="@esc.Id">@esc.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Bloco</label>
                            <select id="filterBloco" asp-for="FilterBlocoId" class="form-select" onchange="filterSalas()">
                                <option value="">Todos</option>
                                @foreach (var blc in Model.AvailableBlocos)
                                {
                                    <option value="@blc.Id" data-esc="@blc.SchoolId">@blc.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Sala</label>
                            <select id="filterSala" asp-for="FilterRoomId" class="form-select">
                                <option value="">Todas</option>
                                @foreach (var sala in Model.Rooms)
                                {
                                    <option value="@sala.Id" data-blc="@sala.BlockId">@sala.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
                </div>
            </form>
        </div>
    </div>
</div>

