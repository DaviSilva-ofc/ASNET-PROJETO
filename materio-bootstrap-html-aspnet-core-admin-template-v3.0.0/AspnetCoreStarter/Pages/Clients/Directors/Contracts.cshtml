@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorContractsModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Contratos";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Diretor /</span> Contratos</h4>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Lista de Contratos @(Model.MyAgrupamentoName != null ? $"- {Model.MyAgrupamentoName}" : "")</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    <i class="ri-filter-3-line me-1"></i> Filtros
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.FilterType) || !string.IsNullOrEmpty(Model.FilterPeriod) || !string.IsNullOrEmpty(Model.FilterStatus))
        {
            <div class="card-body border-top py-2 bg-light">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert" style="padding: 0.5rem 1rem;">
                    <span class="small">
                        <i class="ri-information-line me-1"></i>
                        Filtros ativos: 
                        <strong>
                            @(!string.IsNullOrEmpty(Model.FilterType) ? $"Tipo: {Model.FilterType}, " : "")
                            @(!string.IsNullOrEmpty(Model.FilterPeriod) ? $"Período: {Model.FilterPeriod}, " : "")
                            @(!string.IsNullOrEmpty(Model.FilterStatus) ? $"Estado: {Model.FilterStatus}, " : "")
                        </strong>
                    </span>
                    <a asp-page="./Contracts" class="btn btn-sm btn-outline-secondary">Limpar Filtros</a>
                </div>
            </div>
        }
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Período</th>
                        <th>Estado</th>
                        <th>Agrupamento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Contracts)
                    {
                        <tr>
                            <td><strong>@item.ContractType</strong></td>
                            <td>@item.Period</td>
                            <td>
                                <span class="badge @(item.ContractStatus == "Ativo" ? "bg-label-success" : "bg-label-warning")">
                                    @item.ContractStatus
                                </span>
                            </td>
                            <td>@(item.Agrupamento?.Name ?? "N/A")</td>
                        </tr>
                    }
                    @if (!Model.Contracts.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4">Nenhum contrato encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </div>
    </div>
</div>

<!-- Modal Filtros -->
<div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="get" class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">Filtrar Contratos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-semibold small">Tipo</label>
                        <input type="text" name="FilterType" value="@Model.FilterType" class="form-control" placeholder="Filtrar por tipo" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold small">Período (meses)</label>
                        <input type="text" name="FilterPeriod" value="@Model.FilterPeriod" class="form-control" placeholder="Filtrar por período" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold small">Estado</label>
                        <select name="FilterStatus" class="form-select">
                            <option value="">Todos</option>
                            <option value="Ativo" selected="@(Model.FilterStatus == "Ativo" ? "selected" : null)">Ativo</option>
                            <option value="Pendente" selected="@(Model.FilterStatus == "Pendente" ? "selected" : null)">Pendente</option>
                            <option value="Finalizado" selected="@(Model.FilterStatus == "Finalizado" ? "selected" : null)">Finalizado</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
            </div>
        </form>
    </div>
</div>
