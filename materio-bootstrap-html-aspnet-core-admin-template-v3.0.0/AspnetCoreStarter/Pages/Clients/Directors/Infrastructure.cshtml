@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorInfrastructureModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Infraestrutura";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/notyf/notyf.dist.css" />
}

@section PageStyles {
<style>
    .dark-style .card-header h5,
    [data-bs-theme="dark"] .card-header h5 { color: var(--bs-heading-color) !important; }
    
    .dark-style .list-group-item,
    [data-bs-theme="dark"] .list-group-item {
        background-color: transparent;
        color: #cbcbe2;
        border-color: rgba(255,255,255,0.1);
    }
    
    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: var(--tk-card-solid) !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .dark-style h4.fw-bold,
    [data-bs-theme="dark"] h4.fw-bold { color: #f5f5f9 !important; }

    /* New Styles for Client Dashboard */
    .bg-light-section {
        background-color: rgba(67, 89, 113, 0.02);
        transition: all 0.3s ease;
    }
    .dark-style .bg-light-section,
    [data-bs-theme="dark"] .bg-light-section {
        background-color: rgba(255, 255, 255, 0.03);
    }

    .bg-light-section:hover {
        background-color: rgba(67, 89, 113, 0.05);
    }

    .infra-tree .tree-node {
        position: relative;
        padding: 4px 0;
    }

    .tree-node i {
        font-size: 1.1rem;
        vertical-align: middle;
        opacity: 0.8;
    }

    .cursor-pointer { cursor: pointer; }

    /* Animation for arrows */
    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold;
        color: var(--bs-primary);
        font-size: 1.4rem;
        display: inline-block;
        line-height: 1;
        background-color: rgba(105, 108, 255, 0.15);
        border: 1px solid rgba(105, 108, 255, 0.3);
        border-radius: 4px;
        padding: 4px;
        margin-right: 8px;
    }
    
    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: var(--bs-primary);
        color: var(--bs-heading-color);
    }

    .agrupamento-node { color: var(--bs-primary); }
    .school-node { color: var(--bs-success); }
    .bloc-node { color: var(--bs-info); }
    .room-node { color: var(--bs-warning); }
    .director-node { color: #8592a3; }
    .equip-node { color: #a1acb8; }
    
    .icon-base {
        font-size: 1.25rem;
        vertical-align: middle;
        line-height: 1;
    }

    .tree-node i.ri-arrow-right-s-line, 
    .tree-node i.ri-arrow-down-s-line {
        background-color: rgba(105, 108, 255, 0.1);
        border-radius: 4px;
        padding: 4px;
        font-weight: bold;
        transition: all 0.2s;
    }
    
    .dark-style .agrupamento-node { color: #696cff; }
    .dark-style .school-node { color: #71dd37; }
    .dark-style .bloc-node { color: #03c3ec; }
    .dark-style .room-node { color: #ffab00; }
    .dark-style .director-node { color: #e1e1e3; }
    .dark-style .equip-node { color: #707186; }

    /* Subtle Delete Buttons */
    .btn-delete-subtle {
        opacity: 0.2;
        transition: all 0.2s ease;
        padding: 0 4px;
        font-size: 0.85rem;
        color: #8592a3 !important;
        border: none !important;
        background: transparent !important;
    }
    
    .tree-node:hover .btn-delete-subtle,
    .d-flex:hover > .btn-delete-subtle,
    .d-flex:hover > form > .btn-delete-subtle {
        opacity: 1;
    }
    
    .btn-delete-subtle:hover {
        color: #ff3e1d !important;
        transform: scale(1.2);
    }
    
    .dark-style .btn-delete-subtle { color: #a1acb8 !important; }

    /* Searchable select wrapper */
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
    .select-search-wrapper select option.hidden-option { display: none; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Diretor /</span> Infraestrutura</h4>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-checkbox-circle-line me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-error-warning-line me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }


    <div class="row">
        @foreach (var client in Model.Clients)
        {
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary  d-flex justify-content-between align-items-center cursor-pointer" style="color: var(--bs-heading-color) !important;" 
                         data-bs-toggle="collapse" data-bs-target="#client-@client.Agrupamento.Id">
                        <div class="d-flex align-items-center">
                            <h5 class="mb-0  me-3" style="color: var(--bs-heading-color) !important;">
                                <strong>@client.Agrupamento.Name</strong>
                            </h5>
                        </div>
                        <i class="icon-base ri-arrow-down-s-line  fs-4" style="color: var(--bs-heading-color) !important;"></i>
                    </div>
                    <div id="client-@client.Agrupamento.Id" class="collapse show">
                        <div class="card-body pt-4">
                            <div class="row">
                                <!-- Coluna Tickets -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer" 
                                             data-bs-toggle="collapse" data-bs-target="#tickets-@client.Agrupamento.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-ticket-2-line me-2"></i>Tickets</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="tickets-@client.Agrupamento.Id" class="collapse show">
                                            <h3 class="mb-1 text-primary">@client.TicketCount</h3>
                                            <p class="text-muted small mb-2">Tickets ativos em todas as escolas</p>
                                            <a asp-page="./Tickets" class="btn btn-sm btn-outline-primary w-100 mt-2">
                                                Ver Tickets
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Coluna Contratos -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer" 
                                             data-bs-toggle="collapse" data-bs-target="#contracts-@client.Agrupamento.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-file-list-3-line me-2"></i>Contratos</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="contracts-@client.Agrupamento.Id" class="collapse show">
                                            <h3 class="mb-1 text-success">@client.ContractCount</h3>
                                            <p class="text-muted small mb-2">Contratos registados</p>
                                            <a asp-page="./Contracts" class="btn btn-sm btn-outline-success w-100 mt-2">
                                                Ver Contratos
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Coluna Agrupamento (Árvore) -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer" 
                                             data-bs-toggle="collapse" data-bs-target="#infra-@client.Agrupamento.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-node-tree me-2"></i>Agrupamento</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="infra-@client.Agrupamento.Id" class="collapse show mt-3">
                                            <div class="infra-tree">
                                                <div class="tree-node director-node mb-2 d-flex align-items-center">
                                                    <i class="icon-base ri-user-star-line me-1"></i> <strong>Diretor: @client.DirectorName</strong>
                                                </div>
                                                <div class="tree-node agrupamento-node">
                                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-schools-@client.Agrupamento.Id">
                                                        <i class="icon-base ri-arrow-right-s-line"></i>
                                                        <i class="icon-base ri-community-line me-1"></i> <strong>@client.Agrupamento.Name</strong>
                                                    </div>
                                                    
                                                    <div id="tree-schools-@client.Agrupamento.Id" class="collapse">
                                                        @foreach (var schoolVm in client.Schools)
                                                        {
                                                            <div class="tree-node school-node ms-4 mt-2">
                                                                <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-blocks-@schoolVm.School.Id">
                                                                    <i class="icon-base ri-arrow-right-s-line"></i>
                                                                    <i class="icon-base ri-building-line me-1"></i> <strong>@schoolVm.School.Name</strong>
                                                                    <span class="ms-2 text-muted small">(Coord: @schoolVm.CoordinatorName)</span>
                                                                </div>
                                                                
                                                                <div id="tree-blocks-@schoolVm.School.Id" class="collapse">
                                                                    @foreach (var bloc in schoolVm.Blocos)
                                                                    {
                                                                        <div class="tree-node bloc-node ms-4 mt-1">
                                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-rooms-@bloc.Id">
                                                                                <i class="icon-base ri-arrow-right-s-line"></i>
                                                                                <i class="icon-base ri-box-3-line me-1"></i> @bloc.Name
                                                                                <div class="d-flex align-items-center ms-auto">
                                                                                    <button class="btn btn-sm btn-icon btn-outline-secondary border-0" 
                                                                                            data-id="@bloc.Id"
                                                                                            data-name="@bloc.Name"
                                                                                            data-school="@schoolVm.School.Id"
                                                                                            onclick="event.stopPropagation(); openEditBloco(this)"
                                                                                            title="Editar Bloco">
                                                                                        ✏️
                                                                                    </button>
                                                                                    <form method="post" asp-page-handler="DeleteBloco" asp-route-id="@bloc.Id" 
                                                                                          onsubmit="return confirm('Eliminar este bloco?');" 
                                                                                          style="display:inline;" onclick="event.stopPropagation();">
                                                                                        <button type="submit" class="btn-delete-subtle" title="Eliminar Bloco">
                                                                                            🗑️
                                                                                        </button>
                                                                                    </form>
                                                                                </div>
                                                                            </div>
                                                                            
                                                                            <div id="tree-rooms-@bloc.Id" class="collapse">
                                                                                @{ var rooms = Model.Salas.Where(s => s.BlockId == bloc.Id).ToList(); }
                                                                                @foreach (var room in rooms)
                                                                                {
                                                                                    <div class="tree-node room-node ms-4 mt-1">
                                                                                        <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-equips-@room.Id">
                                                                                            <i class="icon-base ri-arrow-right-s-line"></i>
                                                                                            <i class="icon-base ri-door-open-line me-1"></i> @room.Name
                                                                                            <div class="d-flex align-items-center ms-auto">
                                                                                                <button class="btn btn-sm btn-icon btn-outline-secondary border-0" 
                                                                                                        data-id="@room.Id"
                                                                                                        data-name="@room.Name"
                                                                                                        data-bloc="@bloc.Id"
                                                                                                        data-prof="@room.ResponsibleProfessorId"
                                                                                                        onclick="event.stopPropagation(); openEditSala(this)"
                                                                                                        title="Editar Sala">
                                                                                                    ✏️
                                                                                                </button>
                                                                                                <form method="post" asp-page-handler="DeleteSala" asp-route-id="@room.Id" 
                                                                                                      onsubmit="return confirm('Eliminar esta sala?');" 
                                                                                                      style="display:inline;" onclick="event.stopPropagation();">
                                                                                                    <button type="submit" class="btn-delete-subtle" title="Eliminar Sala">
                                                                                                        🗑️
                                                                                                    </button>
                                                                                                </form>
                                                                                                <a asp-page="./Equipment" asp-route-FilterRoomId="@room.Id" class="btn btn-sm btn-icon btn-outline-info border-0 ms-1" title="Ver Equipamentos">
                                                                                                    <i class="ri-computer-line small"></i>
                                                                                                </a>
                                                                                            </div>
                                                                                        </div>
                                                                                        
                                                                                            <div id="tree-equips-@room.Id" class="collapse">
                                                                                                @if (room.Equipments != null && room.Equipments.Any())
                                                                                                {
                                                                                                    var groupedEquips = room.Equipments
                                                                                                        .GroupBy(e => e.Name)
                                                                                                        .Select(g => new { Name = g.Key, Count = g.Count() })
                                                                                                        .ToList();

                                                                                                    foreach (var g in groupedEquips)
                                                                                                    {
                                                                                                        var label = g.Name;
                                                                                                        if (g.Count > 1)
                                                                                                        {
                                                                                                            var pluralLabel = label;
                                                                                                            if (label.EndsWith("r") || label.EndsWith("z") || label.EndsWith("n"))
                                                                                                            {
                                                                                                                pluralLabel +="es";
                                                                                                            }
                                                                                                            else if (label.EndsWith("l"))
                                                                                                            {
                                                                                                                pluralLabel = label.Substring(0, label.Length - 1) +"is";
                                                                                                            }
                                                                                                            else if (!label.EndsWith("s"))
                                                                                                            {
                                                                                                                pluralLabel +="s";
                                                                                                            }
                                                                                                            label = $"{pluralLabel} ({g.Count})";
                                                                                                        }
                                                                                                        <a asp-page="./Equipment" asp-route-FilterRoomId="@room.Id" asp-route-FilterName="@g.Name" class="tree-node equip-node ms-4 mt-1 small text-decoration-none d-block">
                                                                                                            <i class="ri-computer-line me-1"></i> @label 
                                                                                                        </a>
                                                                                                    }
                                                                                                }
                                                                                                else
                                                                                            {
                                                                                                <div class="ms-4 mt-1 small italic text-muted">
                                                                                                    Sem equipamentos
                                                                                                </div>
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>


    <!-- Edit Modals -->
    <div class="modal fade" id="modalEditBloco" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="EditBloco" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Bloco</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditId" id="editBlocoId" />
                    <div class="mb-3">
                        <label class="form-label">Nome do Bloco</label>
                        <input type="text" asp-for="EditName" id="editBlocoName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Escola</label>
                        <select asp-for="EditParentId" id="editBlocoEscolaId" class="form-select" required>
                            @foreach (var client in Model.Clients) {
                                @foreach (var schoolVm in client.Schools) {
                                    <option value="@schoolVm.School.Id">@schoolVm.School.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Atualizar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal fade" id="modalEditSala" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="EditSala" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Sala</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditId" id="editSalaId" />
                    <div class="mb-3">
                        <label class="form-label">Nome da Sala</label>
                        <input type="text" asp-for="EditName" id="editSalaName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bloco</label>
                        <select asp-for="EditParentId" id="editSalaBlocoId" class="form-select" required>
                            @foreach (var client in Model.Clients) {
                                @foreach (var schoolVm in client.Schools) {
                                    @foreach (var bloc in schoolVm.Blocos) {
                                        <option value="@bloc.Id">@schoolVm.School.Name - @bloc.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Professor Responsável</label>
                        <select asp-for="EditResponsibleProfessorId" id="editSalaProfessorId" class="form-select">
                            <option value="0">-- Sem Professor --</option>
                            @foreach (var prof in Model.AvailableProfessores) {
                                <option value="@prof.Id">@prof.Username</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Atualizar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script src="~/vendor/libs/notyf/notyf.min.js"></script>
<script>
    function openEditBloco(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var schoolId = el.getAttribute('data-school');

        document.getElementById('editBlocoId').value = id;
        document.getElementById('editBlocoName').value = name;
        document.getElementById('editBlocoEscolaId').value = schoolId;
        
        var modalEl = document.getElementById('modalEditBloco');
        var modal = new bootstrap.Modal(modalEl);
        modal.show();
    }

    function openEditSala(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var blocoId = el.getAttribute('data-bloc');
        var profId = el.getAttribute('data-prof');

        document.getElementById('editSalaId').value = id;
        document.getElementById('editSalaName').value = name;
        document.getElementById('editSalaBlocoId').value = blocoId;
        document.getElementById('editSalaProfessorId').value = profId || 0;
        
        var modalEl = document.getElementById('modalEditSala');
        var modal = new bootstrap.Modal(modalEl);
        modal.show();
    }

    document.addEventListener('DOMContentLoaded', function() {
        const notyf = new Notyf({
            duration: 5000,
            position: { x: 'right', y: 'top' },
            types: [
                { type: 'success', background: '#28a745', icon: { className: 'ri-checkbox-circle-fill', tagName: 'i', color: 'white' } },
                { type: 'error', background: '#dc3545', icon: { className: 'ri-close-circle-fill', tagName: 'i', color: 'white' } }
            ]
        });
        
        @if (TempData["SuccessMessage"] != null) { <text>notyf.success('@TempData["SuccessMessage"]');</text> }
        @if (TempData["ErrorMessage"] != null) { <text>notyf.error('@TempData["ErrorMessage"]');</text> }
    });
</script>
}



