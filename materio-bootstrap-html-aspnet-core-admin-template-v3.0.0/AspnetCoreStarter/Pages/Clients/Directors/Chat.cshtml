@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorChatModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Centro de Mensagens";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Diretor /</span> Chat</h4>

    <div class="card overflow-hidden" style="height: calc(100vh - 200px);">
        <div class="row g-0 h-100">
            <!-- Sidebar de Contactos (Técnicos e Administradores) -->
            <div class="col-3 border-end h-100 bg-light d-none d-md-block">
                <div class="p-3 border-bottom bg-white">
                    <input type="text" class="form-control form-control-sm" placeholder="Pesquisar contacto..." />
                </div>
                <div class="list-group list-group-flush overflow-auto" style="height: calc(100% - 60px);">
                    @foreach (var contact in Model.Contacts)
                    {
                        <a asp-page="./Chat" asp-route-techId="@contact.User.Id" 
                           class="list-group-item list-group-item-action border-0 py-3 @(Model.SelectedTechId == contact.User.Id ? "active" : "")">
                            <div class="d-flex align-items-center">
                                <div class="avatar me-2">
                                    <span class="avatar-initial rounded-circle bg-label-primary">@contact.User.Username[0]</span>
                                </div>
                                <div class="w-100">
                                    <h6 class="mb-0 small">@contact.User.Username</h6>
                                    <p class="mb-0 text-muted x-small">@contact.Role</p>
                                </div>
                            </div>
                        </a>
                    }
                    @if (!Model.Contacts.Any())
                    {
                        <div class="p-3 text-center text-muted">Nenhum contacto disponível.</div>
                    }
                </div>
            </div>

            <!-- Janela de Chat -->
            <div class="col-12 col-md-9 h-100 d-flex flex-column">
                @if (Model.SelectedTechId.HasValue)
                {
                    var currentContact = Model.Contacts.FirstOrDefault(t => t.User.Id == Model.SelectedTechId);
                    <!-- Header -->
                    <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-white">
                        <div class="d-flex align-items-center">
                            <div class="avatar me-2">
                                <span class="avatar-initial rounded-circle bg-label-primary">@currentContact?.User.Username[0]</span>
                            </div>
                            <div>
                                <h6 class="mb-0">@currentContact?.User.Username</h6>
                                <small class="text-muted">@currentContact?.Role</small>
                            </div>
                        </div>
                    </div>

                    <!-- Mensagens -->
                    <div id="chatWindow" class="flex-grow-1 p-3 overflow-auto bg-white">
                        <div id="messageContainer" class="d-flex flex-column gap-3">
                            @foreach (var msg in Model.Messages)
                            {
                                bool isMe = msg.SenderId == Model.CurrentUserId;
                                <div class="message-wrapper d-flex @(isMe ? "justify-content-end" : "justify-content-start") align-items-center w-100 mb-3" data-msg-id="@msg.Id">
                                    <div class="@(isMe ? "text-white bg-primary" : "bg-light") p-2 rounded-3 shadow-sm msg-bubble animate__animated animate__fadeInUp" 
                                         style="max-width: 70%;">
                                        <p class="mb-0 small">@msg.Content</p>
                                        <small class="@(isMe ? "text-white-50" : "text-muted") x-small">@msg.CreatedAt.ToString("HH:mm")</small>
                                    </div>
                                    @if (isMe)
                                    {
                                        <button class="btn btn-link btn-sm p-0 ms-2 delete-msg-btn" onclick="deleteMsg(@msg.Id)" title="Apagar">
                                            🗑️
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Input -->
                    <div class="p-3 border-top bg-white">
                        <form id="chatForm" class="input-group">
                            <input type="text" id="messageInput" class="form-control" placeholder="Escreva a sua mensagem..." required autocomplete="off" />
                            <input type="hidden" id="receiverId" value="@Model.SelectedTechId" />
                            <button type="submit" class="btn btn-primary"><i class="ri-send-plane-fill"></i></button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center bg-light text-center p-5">
                        <div class="mb-3 text-primary" style="font-size: 3rem;"><i class="ri-chat-smile-2-line"></i></div>
                        <h5>Bem-vindo ao Chat ASNET</h5>
                        <p class="text-muted">Selecione um contacto à esquerda para iniciar uma conversa.</p>
                        <div class="d-md-none mt-3">
                            <h6>Contactos Disponíveis:</h6>
                            <div class="list-group mt-2">
                                @foreach (var contact in Model.Contacts)
                                {
                                    <a asp-page="./Chat" asp-route-techId="@contact.User.Id" class="list-group-item list-group-item-action">@contact.User.Username (@contact.Role)</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const chatWindow = document.getElementById('chatWindow');
    const messageContainer = document.getElementById('messageContainer');
    const chatForm = document.getElementById('chatForm');
    const messageInput = document.getElementById('messageInput');
    const receiverId = document.getElementById('receiverId')?.value;

    const scrollToBottom = () => {
        if (chatWindow) chatWindow.scrollTop = chatWindow.scrollHeight;
    };

    // Initialize SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveMessage", function (msg) {
        // Only show if it's from the person we are chatting with OR if it's from us
        const isFromSelectedContact = msg.senderId == receiverId;
        const isFromMe = msg.isMe;

        if (isFromSelectedContact || isFromMe) {
            const wrapper = document.createElement('div');
            wrapper.className = `message-wrapper d-flex ${isFromMe ? 'justify-content-end' : 'justify-content-start'} align-items-center w-100 mb-3 animate__animated animate__fadeInUp`;
            wrapper.setAttribute('data-msg-id', msg.id);

            wrapper.innerHTML = `
                <div class="${isFromMe ? 'text-white bg-primary' : 'bg-light'} p-2 rounded-3 shadow-sm msg-bubble" style="max-width: 70%;">
                    <p class="mb-0 small">${msg.content}</p>
                    <small class="${isFromMe ? 'text-white-50' : 'text-muted'} x-small">${msg.createdAt}</small>
                </div>
                ${isFromMe ? `<button class="btn btn-link btn-sm p-0 ms-2 delete-msg-btn" onclick="deleteMsg(${msg.id})" title="Apagar">🗑️</button>` : ''}
            `;
            messageContainer.appendChild(wrapper);
            scrollToBottom();
        }
    });

    connection.on("MessageDeleted", function (msgId) {
        const msgElement = document.querySelector(`.message-wrapper[data-msg-id="${msgId}"]`);
        if (msgElement) {
            msgElement.classList.add('animate__animated', 'animate__fadeOut');
            setTimeout(() => msgElement.remove(), 500);
        }
    });

    window.deleteMsg = async function(msgId) {
        if (confirm("Deseja apagar esta mensagem para todos?")) {
            try {
                const errorMessage = await connection.invoke("DeleteMessage", msgId);
                if (errorMessage) {
                    alert(errorMessage);
                }
            } catch (err) {
                console.error(err);
                alert("Erro de conexão ao apagar mensagem: " + err.toString());
            }
        }
    };

    connection.start().catch(err => console.error(err.toString()));

    if (chatForm) {
        scrollToBottom();

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = messageInput.value;
            if (!content.trim()) return;

            messageInput.value = '';

            try {
                // Send via SignalR
                await connection.invoke("SendMessage", parseInt(receiverId), content);
            } catch (err) {
                console.error('Error sending message:', err);
                alert("Erro ao enviar mensagem. Tente novamente.");
            }
        });
    }
</script>
}

<style>
    .x-small { font-size: 0.75rem; }
    .avatar-initial { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; font-weight: bold; }
    /* Fix for dark mode inside card */
    .dark-style .bg-white, [data-bs-theme="dark"] .bg-white { background-color: #2b2c40 !important; }
    .dark-style .bg-light, [data-bs-theme="dark"] .bg-light { background-color: rgba(255,255,255,0.05) !important; }
    .dark-style .border-bottom, .dark-style .border-end, .dark-style .border-top,
    [data-bs-theme="dark"] .border-bottom, [data-bs-theme="dark"] .border-end, [data-bs-theme="dark"] .border-top 
    { border-color: rgba(255,255,255,0.1) !important; }

    /* Delete Button Hover Effect */
    .message-wrapper .delete-msg-btn { opacity: 0; transition: opacity 0.2s; text-decoration: none; border: none; font-size: 1.1rem; }
    .message-wrapper:hover .delete-msg-btn { opacity: 1; }
    .delete-msg-btn:hover { transform: scale(1.2); }
</style>
