@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorDashboardModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Dashboard Direção";
}

@section PageStyles {
<style>
    :root {
        --asnet-navy: #1e2130;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
        
        /* Theme aware variables */
        --dash-card-bg: #fff;
        --dash-text: #566a7f;
        --dash-title: #566a7f;
        --dash-subtitle: #a1acb8;
        --dash-border: rgba(67, 89, 113, 0.1);
        --dash-shadow: 0 2px 6px 0 rgba(67, 89, 113, 0.12);
    }

    .dark-style, [data-bs-theme="dark"] {
        --dash-card-bg: #2b2e44;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-subtitle: #7071a4;
        --dash-border: rgba(255, 255, 255, 0.05);
        --dash-shadow: 0 4px 18px rgba(0,0,0,0.2);
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--dash-title);
    }

    .stat-card, .tree-card, .pending-card, .chart-card, .map-card {
        background: var(--dash-card-bg) !important;
        border: none !important;
        border-radius: 16px !important;
        box-shadow: var(--dash-shadow) !important;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
    }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; color: var(--dash-title); }
    .stat-label  { font-size: .8rem; color: var(--dash-subtitle); margin: 0; }

    .chart-card .card-header, .tree-card .card-header, .map-card .card-header {
        background: transparent !important;
        border-bottom: 1px solid var(--dash-border) !important;
        font-weight: 600;
        color: var(--dash-title);
    }

    .tree-tabs .nav-link {
        font-size: .85rem;
        padding: .45rem .9rem;
        border-radius: 8px !important;
        color: var(--dash-text);
        font-weight: 500;
    }
    .tree-tabs .nav-link.active {
        background: var(--asnet-blue);
        color: #fff;
    }

    .tree-list { list-style: none; padding-left: 0; }
    .tree-list ul {
        list-style: none;
        padding-left: 1.6rem;
        border-left: 1px solid var(--dash-border);
    }
    .tree-item { position: relative; padding: .35rem 0; color: var(--dash-text); }
    .tree-toggle { cursor: pointer; user-select: none; }

    .tree-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px; height: 26px;
        border-radius: 8px;
        font-size: .7rem;
        font-weight: 700;
        color: #fff;
        margin-right: .4rem;
    }
    .tree-badge-agrup { background: var(--asnet-blue); }
    .tree-badge-school { background: var(--asnet-green); }
    .tree-badge-bloco  { background: var(--asnet-teal); }
    .tree-badge-sala   { background: var(--asnet-orange); }

    .tree-label { font-weight: 500; font-size: .88rem; }
    .tree-children { display: none; }
    .tree-children.show { display: block; }

    .tree-toggle .tree-arrow {
        display: inline-block;
        width: 20px; height: 20px;
        text-align: center;
        line-height:20px;
        font-size: .65rem;
        color: var(--dash-text);
        background: var(--dash-border);
        border-radius: 6px;
        margin-left: .3rem;
        transition: transform .15s;
    }
    .tree-toggle.open .tree-arrow { transform: rotate(90deg); }

    .pending-big-number {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dash-title);
        line-height: 1;
    }
    .pending-subtitle { font-size: .85rem; color: var(--dash-subtitle); }

    .pending-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: rgba(var(--asnet-blue-rgb), 0.1);
        color: var(--asnet-blue);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem;
        font-weight: 600;
        margin-right: -8px;
        border: 2px solid var(--dash-card-bg);
    }
    .dark-style .pending-avatar, [data-bs-theme="dark"] .pending-avatar {
        background: rgba(255,255,255,0.1);
        color: #fff;
        border-color: var(--dash-card-bg);
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- Title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="dash-title mb-1">Direção</h4>
            <p class="text-muted mb-0">Agrupamento: <span class="fw-bold text-primary">@(Model.Agrupamento?.Name ?? "N/A")</span></p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm" style="background:var(--asnet-orange);color:#fff;">
                <i class='bx bx-user-voice me-1'></i> Professores
            </button>
        </div>
    </div>

    <!-- ===== Stat mini-cards ===== -->
    <div class="row g-3 mb-4">
        <!-- Professores -->
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--asnet-blue);">
                        <i class='bx bx-user-voice'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalProfessores</p>
                        <p class="stat-label">Professores</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Pending Tickets -->
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ff3e1d;">
                        <i class='bx bx-support'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.PendingTicketsCount</p>
                        <p class="stat-label">Tickets pendentes</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Escolas -->
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#03c3ec;">
                        <i class='bx bx-file'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalContratos</p>
                        <p class="stat-label">Contratos</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Alertas de Stock -->
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#fd7e14;">
                        <i class='bx bx-package'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.LowStockAlertsCount</p>
                        <p class="stat-label">Alertas de Stock</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Infrastructure Tree (Filtered by Agrupamento) -->
        <div class="col-lg-4">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-blue);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <ul class="nav tree-tabs" role="tablist">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabTree">Agrupamento</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabSchools">Escolas</a></li>
                    </ul>
                </div>
                <div class="card-body" style="max-height:380px; overflow-y:auto;">
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tabTree">
                            <ul class="tree-list">
                                @if (Model.Agrupamento != null)
                                {
                                    <li class="tree-item">
                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                            <span class="tree-badge tree-badge-agrup">@Model.Schools?.Count</span>
                                            <span class="tree-label">@Model.Agrupamento.Name</span>
                                            @if (Model.Schools != null && Model.Schools.Any()) { <span class="tree-arrow">▶</span> }
                                        </div>
                                        @if (Model.Schools != null && Model.Schools.Any())
                                        {
                                            <ul class="tree-children">
                                                @foreach (var school in Model.Schools)
                                                {
                                                    var schoolBlocos = Model.Blocos?.Where(b => b.SchoolId == school.Id).ToList();
                                                    <li class="tree-item">
                                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                                            <span class="tree-badge tree-badge-school">@schoolBlocos?.Count</span>
                                                            <span class="tree-label">@school.Name</span>
                                                            @if (schoolBlocos != null && schoolBlocos.Any()) { <span class="tree-arrow">▶</span> }
                                                        </div>
                                                        @if (schoolBlocos != null && schoolBlocos.Any())
                                                        {
                                                            <ul class="tree-children">
                                                                @foreach (var bloco in schoolBlocos)
                                                                {
                                                                    var blocoSalas = Model.Salas?.Where(s => s.BlockId == bloco.Id).ToList();
                                                                    <li class="tree-item">
                                                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                                                            <span class="tree-badge tree-badge-bloco">@blocoSalas?.Count</span>
                                                                            <span class="tree-label">@bloco.Name</span>
                                                                            @if (blocoSalas != null && blocoSalas.Any()) { <span class="tree-arrow">▶</span> }
                                                                        </div>
                                                                        @if (blocoSalas != null && blocoSalas.Any())
                                                                        {
                                                                            <ul class="tree-children">
                                                                                @foreach (var sala in blocoSalas)
                                                                                {
                                                                                    <li class="tree-item">
                                                                                        <span class="tree-badge tree-badge-sala"><i class='bx bx-door-open' style="font-size:.7rem;"></i></span>
                                                                                        <span class="tree-label">@sala.Name</span>
                                                                                    </li>
                                                                                }
                                                                            </ul>
                                                                        }
                                                                    </li>
                                                                }
                                                            </ul>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </li>
                                }
                                else
                                {
                                    <li class="text-muted py-3 text-center">Nenhum agrupamento atribuído.</li>
                                }
                            </ul>
                        </div>
                        <div class="tab-pane fade" id="tabSchools">
                            <ul class="tree-list">
                                @if (Model.Schools != null)
                                {
                                    @foreach (var school in Model.Schools)
                                    {
                                        <li class="tree-item d-flex align-items-center gap-2 py-2">
                                            <span class="tree-badge tree-badge-school"><i class='bx bx-buildings' style="font-size:.7rem;"></i></span>
                                            <span class="tree-label">@school.Name</span>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Notifications Card -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid #71dd37;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:#71dd37;">
                                <i class='bx bx-chat'></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Mensagens</h6>
                        </div>
                        <p class="pending-big-number">@Model.TotalUnreadMessages<span style="font-size:1rem;color:#71dd37;"> novas</span></p>
                        <p class="pending-subtitle">mensagens no chat aguardam resposta</p>

                        @if (Model.RecentMessageSenders.Any())
                        {
                            <div class="d-flex mt-3 mb-3">
                                @foreach (var u in Model.RecentMessageSenders)
                                {
                                    <div class="pending-avatar" title="@u.Username">
                                        @(u.Username?.Substring(0, Math.Min(2, u.Username.Length)).ToUpper())
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <a href="/Clients/Directors/Chat" class="btn w-100" style="background:#71dd37;color:#fff;font-weight:600;">
                        <i class='bx bx-reply me-1'></i> Responder
                    </a>
                </div>
            </div>
        </div>

        <!-- Pedir Reparo -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid #ff4d4d;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:#ff4d4d;">
                                <i class='bx bx-wrench'></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Pedir Reparo</h6>
                        </div>
                        <p class="pending-big-number">Suporte</p>
                        <p class="pending-subtitle">Existem @Model.DamagedEquipmentCount equipamentos avariados no seu agrupamento.</p>
                    </div>
                    <a href="/Clients/Directors/Equipment?FilterStatus=Avariado" class="btn w-100" style="background:#ff4d4d;color:#fff;font-weight:600;">
                        <i class='bx bx-plus-circle me-1'></i> Novo Pedido
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Charts Row ===== -->
    <div class="row g-4 mb-4">
        <!-- Monthly Ticket Comparison Chart (Modified) -->
        <div class="col-lg-7">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-trending-up' style="color:var(--asnet-blue);"></i>
                    Comparação Mensal de Tickets
                </div>
                <div class="card-body">
                    <div style="height: 250px; position: relative;">
                        <canvas id="monthlyTicketChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <!-- System Overview (Only Tickets and Stocks) -->
        <div class="col-lg-5">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-pie-chart-alt-2' style="color:var(--asnet-orange);"></i>
                    Visão Geral do Sistema
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div style="height: 250px; width: 100%; position: relative;">
                        <canvas id="overviewChart"></canvas>
                    </div>
                    <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                        <span><i class='bx bxs-circle' style="color:#ff3e1d;font-size:.6rem;"></i> Tickets</span>
                        <span><i class='bx bxs-circle' style="color:#f89223;font-size:.6rem;"></i> Stock</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Map Row (Filtered) ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card map-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-map-pin' style="color:#f89223;"></i>
                    Escolas do Agrupamento
                </div>
                <div class="card-body p-0">
                    <div id="clientMap" style="height: 400px; width: 100%; border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // ===== Tree toggle =====

    function toggleTree(el) {
        el.classList.toggle('open');
        var children = el.parentElement.querySelector('.tree-children');
        if (children) children.classList.toggle('show');
    }

    // ===== Monthly Ticket Chart =====
    const ticketCtx = document.getElementById('monthlyTicketChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels)),
            datasets: [{
                label: 'Número de Tickets',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData)),
                backgroundColor: '#696cff',
                borderRadius: 6,
                maxBarThickness: 40
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== System Overview Chart (Bar) =====
    const overviewCtx = document.getElementById('overviewChart').getContext('2d');
    new Chart(overviewCtx, {
        type: 'bar',
        data: {
            labels: ['Tickets', 'Stock'],
            datasets: [{
                label: 'Total',
                data: [@Model.PendingTicketsCount, @Model.LowStockAlertsCount],
                backgroundColor: ['#ff3e1d', '#f89223'],
                borderRadius: 8,
                maxBarThickness: 50
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });
</script>
<script>
    function initMap() {
        // Default center: Braga
        var myLatLng = { lat: 41.5454, lng: -8.4265 };

        var map = new google.maps.Map(document.getElementById('clientMap'), {
            zoom: 10,
            center: myLatLng
        });

        // Parse locations from model
        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw) {
            var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
            var geocoder = new google.maps.Geocoder();

            locations.forEach(function(loc) {
                if (loc.address) {
                    geocoder.geocode({ 'address': loc.address + ", Portugal" }, function(results, status) {
                        if (status === 'OK') {
                            new google.maps.Marker({
                                map: map,
                                position: results[0].geometry.location,
                                title: loc.name
                            });
                        } else {
                            console.warn('Geocode failed for ' + loc.address + ': ' + status);
                        }
                    });
                }
            });
        }
    }
</script>
<script async defer src="https://maps.googleapis.com/maps/api/js?key=&callback=initMap"></script>
}
