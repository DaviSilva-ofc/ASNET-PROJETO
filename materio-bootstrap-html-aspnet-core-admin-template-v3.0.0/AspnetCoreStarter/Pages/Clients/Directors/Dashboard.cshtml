@page
@model AspnetCoreStarter.Pages.Clients.Directors.DirectorDashboardModel
@using System.Linq
@* Preventive maintenance notification system - Recompile *@
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Dashboard Direção";
    ViewData["container"] ="container-fluid";
    ViewData["containerNav"] ="container-fluid";
}

@section PageStyles {
<style>
    :root {
        --asnet-navy: #1e2130;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
        
        /* Theme aware variables */
        --dash-card-bg: #fff;
        --dash-text: #566a7f;
        --dash-title: #566a7f;
        --dash-subtitle: #a1acb8;
        --dash-border: rgba(67, 89, 113, 0.1);
        --dash-shadow: 0 2px 6px 0 rgba(67, 89, 113, 0.12);
    }

    .dark-style, [data-bs-theme="dark"] {
        --dash-card-bg: #2b2e44;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-subtitle: #7071a4;
        --dash-border: rgba(255, 255, 255, 0.05);
        --dash-shadow: 0 4px 18px rgba(0,0,0,0.2);
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--dash-title);
    }

    .stat-card, .tree-card, .pending-card, .chart-card, .map-card {
        background: var(--dash-card-bg) !important;
        border: none !important;
        border-radius: 16px !important;
        box-shadow: var(--dash-shadow) !important;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
    }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--bs-heading-color);
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; color: var(--dash-title); }
    .stat-label  { font-size: .8rem; color: var(--dash-subtitle); margin: 0; }

    .chart-card .card-header, .tree-card .card-header, .map-card .card-header {
        background: transparent !important;
        border-bottom: 1px solid var(--dash-border) !important;
        font-weight: 600;
        color: var(--dash-title);
    }

    .tree-tabs .nav-link {
        font-size: .85rem;
        padding: .45rem .9rem;
        border-radius: 8px !important;
        color: var(--dash-text);
        font-weight: 500;
    }
    .tree-tabs .nav-link.active {
        background: #64748b; /* A nice distinct gray instead of black */
        color: #fff !important; /* Ensure text is readable */
    }

    .tree-list { list-style: none; padding-left: 0; }
    .tree-list ul {
        list-style: none;
        padding-left: 1.6rem;
        border-left: 1px solid var(--dash-border);
    }
    .tree-item { position: relative; padding: .35rem 0; color: var(--dash-text); }
    .tree-toggle { cursor: pointer; user-select: none; }

    .tree-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px; height: 26px;
        border-radius: 8px;
        font-size: .7rem;
        font-weight: 700;
        color: var(--bs-heading-color);
        margin-right: .4rem;
    }
    .tree-badge-agrup { background: var(--asnet-blue); }
    .tree-badge-school { background: var(--asnet-green); }
    .tree-badge-bloco  { background: var(--asnet-teal); }
    .tree-badge-sala   { background: var(--asnet-orange); }

    .tree-label { font-weight: 500; font-size: .88rem; }
    .tree-children { display: none; }
    .tree-children.show { display: block; }

    .tree-toggle .tree-arrow {
        display: inline-block;
        width: 20px; height: 20px;
        text-align: center;
        line-height:20px;
        font-size: .65rem;
        color: var(--dash-text);
        background: var(--dash-border);
        border-radius: 6px;
        margin-left: .3rem;
        transition: transform .15s;
    }
    .tree-toggle.open .tree-arrow { transform: rotate(90deg); }

    .pending-big-number {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dash-title);
        line-height: 1;
    }
    .pending-subtitle { font-size: .85rem; color: var(--dash-subtitle); }

    .pending-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: rgba(var(--asnet-blue-rgb), 0.1);
        color: var(--asnet-blue);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem;
        font-weight: 600;
        margin-right: -8px;
        border: 2px solid var(--dash-card-bg);
    }
    .dark-style .pending-avatar, [data-bs-theme="dark"] .pending-avatar {
        background: rgba(255,255,255,0.1);
        color: var(--bs-heading-color);
        border-color: var(--dash-card-bg);
    }

    /* Custom Navigation Tabs */
    .nav-pills .nav-link {
        background: transparent !important;
        color: rgba(255,255,255,0.6) !important;
        transition: all 0.2s ease;
    }
    .nav-pills .nav-link.active {
        background: var(--asnet-orange) !important;
        color: var(--bs-heading-color) !important;
    }
    .nav-pills .nav-link:hover:not(.active) {
        background: rgba(255,255,255,0.1) !important;
        color: var(--bs-heading-color) !important;
    }
</style>
}


    <!-- Title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="dash-title mb-1">Direção</h4>
            <p class="text-muted mb-0">Agrupamento: <span class="fw-bold text-primary">@(Model.Agrupamento?.Name ??"N/A")</span></p>
        </div>
        <div class="d-flex gap-2">
            @if (Model.HasPreventiveMaintenanceToday)
            {
                <span class="badge bg-danger rounded-pill p-2 animate-pulse" title="Manutenção Preventiva Hoje">
                    <i class="ri-notification-3-line fs-5"></i>
                </span>
            }
        </div>
    </div>

    @if (Model.HasPreventiveMaintenanceToday)
    {
        <div class="alert alert-warning d-flex align-items-center p-3 mb-4 border-0 shadow-sm" style="background: rgba(255, 171, 0, 0.1); border-left: 5px solid #ffab00 !important; border-radius: 12px;">
            <div class="stat-icon me-3" style="background: #ffab00; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #fff;">
                🛡️
            </div>
            <div class="flex-grow-1">
                <h6 class="mb-0 fw-bold" style="color: #ffab00;">Hoje é Dia de Manutenção Preventiva!</h6>
                <p class="mb-0 small text-muted">Existem @Model.TodaysPreventiveMaintenances.Count intervenções programadas para o seu agrupamento hoje.</p>
            </div>
            <button type="button" class="btn btn-sm btn-warning fw-bold px-3 shadow-none" style="background: #ffab00; border: none; color: #fff;" data-bs-toggle="collapse" data-bs-target="#todaysMaintenances">
                Ver Locais
            </button>
        </div>
        
        <div class="collapse mb-4" id="todaysMaintenances">
            <div class="card card-body border-0 shadow-sm" style="background: var(--dash-card-bg) !important; border-radius: 12px; border: 1px solid var(--dash-border) !important;">
                <div class="list-group list-group-flush">
                    @foreach (var m in Model.TodaysPreventiveMaintenances)
                    {
                        <div class="list-group-item bg-transparent border-0 d-flex justify-content-between align-items-center py-2 px-0">
                            <div class="d-flex align-items-center">
                                <div class="avatar avatar-sm me-3" style="width: 32px; height: 32px;">
                                    <span class="avatar-initial rounded-circle bg-label-warning" style="font-size: 0.8rem;">🛡️</span>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold" style="color: var(--bs-heading-color); font-size: 0.9rem;">@m.School?.Name</h6>
                                    <small class="text-muted" style="font-size: 0.75rem;">Técnico: @(m.Technician?.Username ?? "Por atribuir")</small>
                                </div>
                            </div>
                            <span class="badge bg-label-warning text-uppercase" style="font-size: 0.6rem;">@m.Status</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- VISÃO GERAL (Imagem 1 style) -->
    <!-- ===== Stat mini-cards (Restored) ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--asnet-blue); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                        <span style="font-size: 1.2rem;">👥</span>
                    </div>
                    <div>
                        <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.TotalProfessores</p>
                        <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Utilizadores</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--asnet-orange); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                        <span style="font-size: 1.2rem;">📄</span>
                    </div>
                    <div>
                        <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.TotalContratos</p>
                        <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Contratos</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ff3e1d; width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                        <span style="font-size: 1.2rem;">🚨</span>
                    </div>
                    <div>
                        <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.PendingTicketsCount</p>
                        <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Tickets pendentes</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#fd7e14; width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                        <span style="font-size: 1.2rem;">📦</span>
                    </div>
                    <div>
                        <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.LowStockAlertsCount</p>
                        <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Alertas de stock</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- VISÃO GERAL (Imagem 2 style - 3 Columns Horizontal) -->
    <div class="row g-4 mb-4">
        <!-- Infrastructure Tree (Col 1) -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important; border-left: 4px solid var(--asnet-blue) !important;">
                <div class="card-header border-bottom-0 pb-0">
                    <ul class="nav nav-pills gap-2 mb-3" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active py-2 px-3 fw-bold" style="font-size: 0.8rem;" data-bs-toggle="tab" data-bs-target="#tab-agrup">Agrupamentos</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-2 px-3 fw-bold shadow-none" style="font-size: 0.8rem;" data-bs-toggle="tab" data-bs-target="#tab-esc">Escolas</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-2 px-3 fw-bold shadow-none" style="font-size: 0.8rem;" data-bs-toggle="tab" data-bs-target="#tab-blocos">Blocos</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-2 px-3 fw-bold shadow-none" style="font-size: 0.8rem;" data-bs-toggle="tab" data-bs-target="#tab-salas">Salas</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body pt-0" style="max-height: 400px; overflow-y: auto;">
                    <div class="tab-content p-0 border-0 shadow-none">
                        <!-- Agrupamentos List -->
                         <div class="tab-pane fade show active" id="tab-agrup">
                            @if (Model.Agrupamento != null)
                            {
                                <div class="d-flex flex-column gap-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 28px; height: 28px; background: #696cff; border-radius: 6px; font-size: 1rem;">
                                            🏢
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold" style="color: var(--bs-heading-color) !important;" style="font-size: 0.85rem;">@Model.Agrupamento.Name</span>
                                            <i class=' ' style='color: var(--bs-heading-color) !important;' style="font-size: 1.1rem; margin-top: -2px;"></i>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <!-- Escolas List -->
                        <div class="tab-pane fade" id="tab-esc">
                            <div class="d-flex flex-column gap-3">
                                @if (Model.Schools != null) {
                                    @foreach (var school in Model.Schools) {
                                         <div class="d-flex align-items-center gap-3">
                                            <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 28px; height: 28px; background: #71dd37; border-radius: 6px; font-size: 1rem;">
                                                🏫
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-semibold" style="color: var(--bs-heading-color) !important;" style="font-size: 0.85rem;">@school.Name</span>
                                                <i class=' ' style='color: var(--bs-heading-color) !important;' style="font-size: 1.1rem; margin-top: -2px;"></i>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <!-- Blocos List -->
                        <div class="tab-pane fade" id="tab-blocos">
                            <div class="d-flex flex-column gap-3">
                                @if (Model.Blocos != null) {
                                    @foreach (var bloco in Model.Blocos) {
                                         <div class="d-flex align-items-center gap-3">
                                            <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 28px; height: 28px; background: #03c3ec; border-radius: 6px; font-size: 1rem;">
                                                🧱
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-semibold" style="color: var(--bs-heading-color) !important;" style="font-size: 0.85rem;">@bloco.Name</span>
                                                <i class=' ' style='color: var(--bs-heading-color) !important;' style="font-size: 1.1rem; margin-top: -2px;"></i>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <!-- Salas List -->
                        <div class="tab-pane fade" id="tab-salas">
                            <div class="d-flex flex-column gap-3">
                                @if (Model.Salas != null) {
                                    @foreach (var sala in Model.Salas) {
                                         <div class="d-flex align-items-center gap-3">
                                            <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 28px; height: 28px; background: #f89223; border-radius: 6px; font-size: 1rem;">
                                                🚪
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-semibold" style="color: var(--bs-heading-color) !important;" style="font-size: 0.85rem;">@sala.Name</span>
                                                <i class=' ' style='color: var(--bs-heading-color) !important;' style="font-size: 1.1rem; margin-top: -2px;"></i>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Messages Card (Col 2) -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="background: var(--tk-card-solid) !important; border-left: 4px solid #71dd37 !important;">
                <div class="card-body p-4 flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div style="width: 40px; height: 40px; background: #71dd37; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                            💬
                        </div>
                        <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color) !important;">Mensagens</h5>
                    </div>
                    <div class="mb-3">
                        <span class="fw-bolder" style="font-size: 3rem; color: var(--bs-heading-color); line-height: 1;">@Model.TotalUnreadMessages</span>
                        <span class="fw-bold" style="color: #71dd37; font-size: 1.2rem;"> novas</span>
                    </div>
                    <p class="-50 small" style="color: var(--bs-heading-color) !important;">mensagens no chat aguardam resposta</p>
                </div>
                <div class="p-4 pt-0">
                    <a href="/Clients/Directors/Chat" class="btn w-100 py-2 fw-bold" style="background: #71dd37; color: var(--bs-heading-color); border-radius: 8px;">Responder</a>
                </div>
            </div>
        </div>

        <!-- Pending Requests Card (Col 3) -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="background: var(--tk-card-solid) !important; border-left: 4px solid #ff3e1d !important;">
                <div class="card-body p-4 flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div style="width: 40px; height: 40px; background: #ff4d4d; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                            📝
                        </div>
                        <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color) !important;">Pedidos Pendentes</h5>
                    </div>
                    <div class="mb-3">
                        <span class="fw-bolder" style="font-size: 3rem; color: var(--bs-heading-color); line-height: 1;">@Model.SchoolRequests?.Count</span>
                        <span class="fw-bold" style="color: #ff4d4d; font-size: 1.2rem;"> novos</span>
                    </div>
                    <p class="-50 small" style="color: var(--bs-heading-color) !important;">pedidos de registo aguardam aprovação</p>
                </div>
                <div class="p-4 pt-0">
                    <a href="/Clients/Directors/Stocks" class="btn w-100 py-2 fw-bold" style="background: #ff3e1d; color: var(--bs-heading-color); border-radius: 8px;">Ver Pedidos</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card chart-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3"><i class='bx bx-trending-up' style="color:var(--asnet-blue);"></i> Comparação de Tickets</div>
                <div class="card-body pt-4"><canvas id="monthlyTicketChart" style="max-height: 250px;"></canvas></div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card chart-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3"><i class='bx bx-pie-chart-alt-2' style="color:var(--asnet-orange);"></i> Visão Geral</div>
                <div class="card-body pt-4 d-flex flex-column align-items-center justify-content-center">
                    <canvas id="overviewChart" style="max-height: 250px;"></canvas>
                    <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                        <span class="-50" style="color: var(--bs-heading-color) !important;"><i class='bx bxs-circle me-1' style="color:#ff3e1d;font-size:.6rem;"></i> Tickets</span>
                        <span class="-50" style="color: var(--bs-heading-color) !important;"><i class='bx bxs-circle me-1' style="color:#f89223;font-size:.6rem;"></i> Stock</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Table -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
                <div class="card-header d-flex justify-content-between align-items-center p-4 border-bottom border-secondary">
                    <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color) !important;"><i class="bx bx-history me-2 text-info"></i>Tickets de Manutenção Recentes</h5>
                    <a href="/Clients/Directors/Tickets" class="btn btn-sm btn-outline-primary fw-bold">Ver todos os tickets</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-label-secondary">
                            <tr>
                                <th class="-50" style="color: var(--bs-heading-color) !important;">TICKET</th>
                                <th class="-50" style="color: var(--bs-heading-color) !important;">EQUIPAMENTO / SALA</th>
                                <th class="-50" style="color: var(--bs-heading-color) !important;">TÉCNICO</th>
                                <th class="-50" style="color: var(--bs-heading-color) !important;">DATA</th>
                                <th class="-50" style="color: var(--bs-heading-color) !important;">ESTADO</th>
                                <th class="-50 text-center" style="color: var(--bs-heading-color) !important;">AÇÕES</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTickets != null && Model.RecentTickets.Any()) {
                                @foreach (var ticket in Model.RecentTickets.Take(3)) {
                                    <tr>
                                        <td><span class="badge bg-label-secondary">#@ticket.Id</span></td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                @{
                                                    var type = ticket.Equipamento?.Type ??"";
                                                    var name = ticket.Equipamento?.Name ??"";
                                                    var emoji = type switch {
                                                        var s when s.Contains("Monitor") =>"🖥️",
                                                        var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") =>"💻",
                                                        var s when s.Contains("Impressora") =>"🖨️",
                                                        var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") =>"🌐",
                                                        var s when s.Contains("Projetor") =>"📽️",
                                                        var s when s.Contains("Rato") || s.Contains("Mouse") =>"🖱️",
                                                        var s when s.Contains("Teclado") || s.Contains("Keyboard") =>"⌨️",
                                                        var s when s.Contains("Servidor") || s.Contains("Server") =>"🗄️",
                                                        var s when s.Contains("UPS") || s.Contains("Bateria") =>"🔋",
                                                        var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") =>"🔊",
                                                        var s when s.Contains("Câmara") || s.Contains("Camera") =>"📷",
                                                        _ => name.Contains("Monitor") ?"🖥️" : (name.Contains("Computador") ?"💻" : (name.Contains("Impressora") ?"🖨️" :"🔧"))
                                                    };
                                                }
                                                <span class="fw-bold" style="color: var(--bs-heading-color) !important;">@emoji @ticket.Equipamento?.Name</span>
                                                <small class="-50 small" style="color: var(--bs-heading-color) !important;">
                                                    @(ticket.Equipamento?.Brand ??"Genérico") @(ticket.Equipamento?.Model ??"")
                                                    @if (!string.IsNullOrEmpty(ticket.Equipamento?.SerialNumber))
                                                    {
                                                        <span class="ms-1">(S/N: @ticket.Equipamento.SerialNumber)</span>
                                                    }
                                                </small>
                                            </div>
                                            <small class="-50" style="color: var(--bs-heading-color) !important;">@ticket.Equipamento?.Room?.Name</small>
                                        </td>
                                        <td>
                                            @if (ticket.Technician != null)
                                            {
                                                <a asp-page="/Profile" asp-route-id="@ticket.Technician.Id" class="d-flex align-items-center text-decoration-none text-body">
                                                    <div class="avatar avatar-xs me-2">
                                                        <span class="avatar-initial rounded-circle bg-label-primary" style="font-size: 0.6rem;">@(ticket.Technician.Username?.Substring(0, 1).ToUpper())</span>
                                                    </div>
                                                    <span class="fw-medium   hover-primary" style="color: var(--bs-heading-color) !important;">@ticket.Technician.Username</span>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-warning small italic">A aguardar técnico...</span>
                                            }
                                        </td>
                                        <td class="-50" style="color: var(--bs-heading-color) !important;">@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @{
                                                var statusLabel = ticket.Status switch {"Pendente" or"Pedido" =>"badge bg-label-warning","Em Reparação" or"EmResolução" or"Em andamento" =>"badge bg-label-info","Concluído" =>"badge bg-label-success",
                                                    _ =>"badge bg-label-secondary"
                                                };
                                                var statusDisplayName = (ticket.Status =="Pedido" || ticket.Status =="Pendente") ?"A aguardar" : ticket.Status;
                                            }
                                            <span class="@statusLabel text-uppercase" style="font-size: 0.65rem;">@statusDisplayName</span>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                                    onclick="showQRCode('@ticket.Equipamento?.Id', 'equip', '@(ticket.Equipamento?.Name?.Replace("'","\\'"))', '@(ticket.Equipamento?.SerialNumber ??"S/N N/A")')">
                                                <i class="ri-qr-code-line"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            } else {
                                <tr>
                                    <td colspan="6" class="text-center py-5  -50" style="color: var(--bs-heading-color) !important;">Sem tickets recentes a reportar.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Map (Row 3) -->
        <div class="col-12 mt-4">
            <div class="card map-card h-100">
                <div class="card-header d-flex align-items-center gap-2"><i class='bx bx-map-pin' style="color:#f89223;"></i> Escolas do Agrupamento</div>
                <div class="card-body p-0"><div id="clientMap" style="height: 400px; width: 100%; border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;"></div></div>
            </div>
        </div>

    <!-- Modal Processar Pedido (Diretor) -->
    <div class="modal fade" id="modalFulfillRequest" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post" id="fulfillForm">
                    <input type="hidden" name="requestId" id="fulfillRequestId" />
                    <div class="modal-header bg-primary py-3">
                        <h5 class="modal-title   fw-bold" style="color: var(--bs-heading-color) !important;"><i class='bx bx-task me-2'></i>Processar Pedido: <span id="fulfillItemDisplay"></span></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="alert alert-info border-0 shadow-none mb-4">
                            <i class='bx bx-info-circle me-1'></i> Pedido de <strong><span id="fulfillQuantityDisplay"></span></strong> unidade(s) para <strong><span id="fulfillSchoolDisplay"></span></strong>.
                        </div>

                        <h6 class="fw-bold mb-2">Stock Disponível (Armazenado no Agrupamento)</h6>
                        <p class="text-muted small mb-3">Itens com o tipo correspondente marcados automaticamente.</p>
                        
                        <div class="table-responsive border rounded mb-4" style="max-height: 250px;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;"><input type="checkbox" id="selectAllStock" onclick="toggleAllStock(this)" /></th>
                                        <th>Nome</th>
                                        <th>Tipo</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody id="availableStockList">
                                    @foreach (var s in Model.AvailableStock)
                                    {
                                        <tr class="stock-row" data-type="@s.Type">
                                            <td>
                                                <input type="checkbox" name="selectedStockIds" value="@s.Id" class="stock-checkbox" />
                                            </td>
                                            <td>
                                                @{
                                                    var stype = s.Type ??"";
                                                    var sname = s.EquipmentName ??"";
                                                    var semoji = stype.ToLower() switch {
                                                        var str when str.Contains("monitor") =>"🖥️",
                                                        var str when str.Contains("portátil") || str.Contains("laptop") =>"💻",
                                                        var str when str.Contains("ups") || str.Contains("bateria") =>"🔋",
                                                        var str when str.Contains("quadro") || str.Contains("interativo") =>"📺",
                                                        var str when str.Contains("impressora") =>"🖨️",
                                                        var str when str.Contains("rato") || str.Contains("mouse") =>"🖱️",
                                                        var str when str.Contains("teclado") =>"⌨️",
                                                        _ =>"📦"
                                                    };
                                                }
                                                @semoji @s.EquipmentName
                                            </td>
                                            <td><span class="badge bg-label-secondary">@s.Type</span></td>
                                            <td><span class="badge @(s.Status =="Armazenado" || s.Status =="Disponível" ?"bg-label-warning" :"bg-label-info")">@s.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold">Notas / Justificação</label>
                            <textarea name="directorNotes" class="form-control" rows="2" placeholder="Notas para o coordenador ou administrador..."></textarea>
                        </div>

                        <div id="selectionWarning" class="alert alert-warning border-0 shadow-none d-none">
                            <i class='bx bx-error me-1'></i> A quantidade selecionada é diferente da solicitada.
                        </div>
                    </div>
                    <div class="modal-footer bg-light d-flex justify-content-between">
                        <div>
                            <button type="submit" asp-page-handler="RejectRequest" class="btn btn-outline-danger">Recusar</button>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" asp-page-handler="EscalateRequest" class="btn btn-outline-info">Reencaminhar ao Admin</button>
                            <button type="submit" asp-page-handler="FulfillRequest" class="btn btn-success px-4 fw-bold">Emprestar</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // ===== Tree toggle =====

    function toggleTree(el) {
        el.classList.toggle('open');
        var children = el.parentElement.querySelector('.tree-children');
        if (children) children.classList.toggle('show');
    }

    function openFulfillModal(id, type, qty, itemName, schoolName) {
        document.getElementById('fulfillRequestId').value = id;
        document.getElementById('fulfillItemDisplay').innerText = itemName;
        document.getElementById('fulfillQuantityDisplay').innerText = qty;
        document.getElementById('fulfillSchoolDisplay').innerText = schoolName;

        // Auto-select logic
        const checkboxes = document.querySelectorAll('.stock-checkbox');
        let selectedCount = 0;
        checkboxes.forEach(cb => {
            const row = cb.closest('.stock-row');
            const rowType = row.getAttribute('data-type');
            if (rowType === type && selectedCount < qty) {
                cb.checked = true;
                selectedCount++;
            } else {
                cb.checked = false;
            }
        });

        checkSelection(qty);
        new bootstrap.Modal(document.getElementById('modalFulfillRequest')).show();
    }

    function toggleAllStock(el) {
        const checkboxes = document.querySelectorAll('.stock-checkbox');
        checkboxes.forEach(cb => cb.checked = el.checked);
        checkSelection(parseInt(document.getElementById('fulfillQuantityDisplay').innerText));
    }

    function checkSelection(requestedQty) {
        const selectedCount = document.querySelectorAll('.stock-checkbox:checked').length;
        const warning = document.getElementById('selectionWarning');
        if (selectedCount !== requestedQty) {
            warning.classList.remove('d-none');
        } else {
            warning.classList.add('d-none');
        }
    }

    document.querySelectorAll('.stock-checkbox').forEach(cb => {
        cb.onchange = () => checkSelection(parseInt(document.getElementById('fulfillQuantityDisplay').innerText));
    });

    // ===== Monthly Ticket Chart =====
    const ticketCtx = document.getElementById('monthlyTicketChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels)),
            datasets: [{
                label: 'Número de Tickets',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData)),
                backgroundColor: '#696cff',
                borderRadius: 6,
                maxBarThickness: 40
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== System Overview Chart (Bar) =====
    const overviewCtx = document.getElementById('overviewChart').getContext('2d');
    new Chart(overviewCtx, {
        type: 'bar',
        data: {
            labels: ['Tickets', 'Stock'],
            datasets: [{
                label: 'Total',
                data: [@Model.PendingTicketsCount, @Model.LowStockAlertsCount],
                backgroundColor: ['#ff3e1d', '#f89223'],
                borderRadius: 8,
                maxBarThickness: 50
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });
</script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        initMap();
    });

    async function initMap() {
        // Default center: Braga
        var map = L.map('clientMap').setView([41.5454, -8.4265], 10);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw) {
            var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
            
            for (let i = 0; i < locations.length; i++) {
                const loc = locations[i];
                if (loc.address) {
                    try {
                        const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(loc.address +", Portugal")}`);
                        const data = await response.json();
                        
                        if (data && data.length > 0) {
                            const result = data[0];
                            L.marker([result.lat, result.lon])
                             .addTo(map)
                             .bindPopup(`<b>${loc.name}</b><br>${loc.address}`);
                        }
                    } catch (error) {
                        console.error('Geocoding error:', error);
                    }
                    if (locations.length > 1) await new Promise(resolve => setTimeout(resolve, 1000));
                }
            }
        }
    }
</script>
<partial name="Shared/_QrModal" />
