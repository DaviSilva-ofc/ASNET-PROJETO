@page
@model AspnetCoreStarter.Pages.Clients.Professors.ProfessorChatModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Centro de Mensagens";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Professor /</span> Chat</h4>
    </div>

    <div class="card overflow-hidden" style="height: calc(100vh - 200px);">
        <div class="row g-0 h-100">
            <!-- Sidebar de Contactos -->
            <div class="col-md-4 col-lg-3 border-end h-100 bg-light d-none d-md-block">
                <div class="p-3 border-bottom bg-white d-flex align-items-center">
                    <div class="input-group input-group-merge">
                        <span class="input-group-text"><i class="ri-search-line"></i></span>
                        <input type="text" id="contactSearch" class="form-control form-control-sm" placeholder="Pesquisar contacto..." />
                    </div>
                </div>
                <div class="list-group list-group-flush overflow-auto" style="height: calc(100% - 60px);">
                    @foreach (var contact in Model.Contacts)
                    {
                        <a asp-page="./Chat" asp-route-contactId="@contact.Id" 
                           class="contact-item list-group-item list-group-item-action border-0 py-3 @(Model.SelectedContactId == contact.Id ?"active" :"")">
                            <div class="d-flex align-items-center">
                                <div class="avatar me-2">
                                    @if (!string.IsNullOrEmpty(contact.ProfilePhotoPath))
                                    {
                                        <img src="@contact.ProfilePhotoPath" alt="Avatar" class="rounded-circle" style="object-fit: cover;">
                                    }
                                    else
                                    {
                                        <span class="avatar-initial rounded-circle bg-label-warning">@(contact.Username?[0] ?? 'U')</span>
                                    }
                                </div>
                                <div class="w-100 overflow-hidden">
                                    <h6 class="mb-0 small text-truncate">@contact.Username</h6>
                                    <p class="mb-0 text-muted x-small text-truncate">Suporte ASNET</p>
                                </div>
                            </div>
                        </a>
                    }
                    @if (!Model.Contacts.Any())
                    {
                        <div class="p-3 text-center text-muted">Nenhum contacto encontrado.</div>
                    }
                </div>
            </div>

            <!-- Janela de Chat -->
            <div class="col-12 col-md-8 col-lg-9 h-100 d-flex flex-column">
                @if (Model.SelectedContactId.HasValue)
                {
                    var currentContact = Model.Contacts.FirstOrDefault(c => c.Id == Model.SelectedContactId);
                    <!-- Header -->
                    <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-white">
                        <a asp-page="/Profile" asp-route-id="@currentContact?.Id" class="d-flex align-items-center text-body">
                            <div class="avatar me-2">
                                @if (!string.IsNullOrEmpty(currentContact?.ProfilePhotoPath))
                                {
                                    <img src="@currentContact.ProfilePhotoPath" alt="Avatar" class="rounded-circle" style="object-fit: cover;">
                                }
                                else
                                {
                                    <span class="avatar-initial rounded-circle bg-label-warning">@(currentContact?.Username?[0] ?? 'U')</span>
                                }
                            </div>
                            <div>
                                <h6 class="mb-0">@currentContact?.Username</h6>
                                <small class="text-success x-small"><i class="ri-checkbox-blank-circle-fill me-1"></i> Online</small>
                            </div>
                        </a>
                    </div>

                    <!-- Mensagens -->
                    <div id="chatWindow" class="flex-grow-1 p-4 overflow-auto bg-white">
                        <div id="messageContainer" class="d-flex flex-column gap-3">
                            @foreach (var msg in Model.Messages)
                            {
                                bool isMe = msg.SenderId == Model.CurrentUserId;
                                <div class="message-wrapper d-flex @(isMe ?"justify-content-end" :"justify-content-start") align-items-center w-100 mb-2" data-msg-id="@msg.Id">
                                    <div class="@(isMe ?"text-white bg-primary shadow-primary" :"bg-light") p-2 px-3 rounded-3 msg-bubble" 
                                         style="max-width: 75%; position: relative;">
                                        <p class="mb-0 small">@msg.Content</p>
                                        <div class="text-end mt-1" style="font-size: 0.65rem; opacity: 0.7;">@msg.CreatedAt.ToString("HH:mm")</div>
                                    </div>
                                    @if (isMe)
                                    {
                                        <button class="btn btn-link btn-sm p-0 ms-2 delete-msg-btn text-muted" onclick="deleteMsg(@msg.Id)" title="Apagar">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Input -->
                    <div class="p-3 border-top bg-white">
                        <form id="chatForm" class="d-flex align-items-center gap-2">
                            <input type="text" id="messageInput" class="form-control border-0 bg-light shadow-none" placeholder="Escreva a sua mensagem..." required autocomplete="off" />
                            <input type="hidden" id="receiverId" value="@Model.SelectedContactId" />
                            <button type="submit" class="btn btn-primary btn-icon rounded-circle shadow-none"><i class="ri-send-plane-2-line"></i></button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center bg-light text-center p-5">
                        <div class="avatar avatar-xl bg-label-warning mb-4 shadow-sm" style="width:100px; height:100px; font-size: 3rem;">
                            <i class="ri-chat-smile-2-line"></i>
                        </div>
                        <h4 class="fw-bold">Centro de Mensagens</h4>
                        <p class="text-muted" style="max-width: 320px;">Selecione um contacto para iniciar uma conversa de suporte técnico.</p>
                        <div class="d-md-none mt-3">
                            <h6>Contactos Disponíveis:</h6>
                            <div class="list-group mt-2">
                                @foreach (var contact in Model.Contacts)
                                {
                                    <a asp-page="./Chat" asp-route-contactId="@contact.Id" class="list-group-item list-group-item-action">@contact.Username</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const chatWindow = document.getElementById('chatWindow');
    const messageContainer = document.getElementById('messageContainer');
    const chatForm = document.getElementById('chatForm');
    const messageInput = document.getElementById('messageInput');
    const receiverId = document.getElementById('receiverId')?.value;
    const currentUserId ="@Model.CurrentUserId";

    const scrollToBottom = () => {
        if (chatWindow) chatWindow.scrollTop = chatWindow.scrollHeight;
    };

    // Initialize SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveMessage", function (msg) {
        const isFromSelectedContact = msg.senderId == receiverId;
        const isFromMe = msg.isMe;

        if (isFromSelectedContact || isFromMe) {
            const wrapper = document.createElement('div');
            wrapper.className = `message-wrapper d-flex ${isFromMe ? 'justify-content-end' : 'justify-content-start'} align-items-center w-100 mb-2 animate__animated animate__fadeInUp`;
            wrapper.setAttribute('data-msg-id', msg.id);

            wrapper.innerHTML = `
                <div class="${isFromMe ? ' bg-primary shadow-primary' : 'bg-light'} p-2 px-3 rounded-3 msg-bubble" style="color: var(--bs-heading-color) !important;" style="max-width: 75%; position: relative;">
                    <p class="mb-0 small">${msg.content}</p>
                    <div class="text-end mt-1" style="font-size: 0.65rem; opacity: 0.7;">${msg.createdAt}</div>
                </div>
                ${isFromMe ? `<button class="btn btn-link btn-sm p-0 ms-2 delete-msg-btn text-muted" onclick="deleteMsg(${msg.id})" title="Apagar"><i class="ri-delete-bin-line"></i></button>` : ''}
            `;
            messageContainer.appendChild(wrapper);
            scrollToBottom();
        }
    });

    connection.on("MessageDeleted", function (msgId) {
        const msgElement = document.querySelector(`.message-wrapper[data-msg-id="${msgId}"]`);
        if (msgElement) {
            msgElement.classList.add('animate__animated', 'animate__fadeOut');
            setTimeout(() => msgElement.remove(), 500);
        }
    });

    window.deleteMsg = async function(msgId) {
        if (confirm("Deseja apagar esta mensagem?")) {
            try {
                const errorMessage = await connection.invoke("DeleteMessage", msgId);
                if (errorMessage) alert(errorMessage);
            } catch (err) {
                console.error(err);
            }
        }
    };

    connection.start().catch(err => console.error(err.toString()));

    if (chatForm) {
        scrollToBottom();
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = messageInput.value;
            if (!content.trim()) return;
            messageInput.value = '';
            try { await connection.invoke("SendMessage", parseInt(receiverId), content); } 
            catch (err) { console.error('Error sending message:', err); }
        });
    }

    document.getElementById('contactSearch')?.addEventListener('keyup', function() {
        const term = this.value.toLowerCase();
        document.querySelectorAll('.contact-item').forEach(item => {
            const name = item.querySelector('h6')?.innerText.toLowerCase() || '';
            item.style.display = name.includes(term) ? 'block' : 'none';
        });
    });
</script>
}

<style>
    .x-small { font-size: 0.75rem; }
    .avatar-initial { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; font-weight: bold; }
    
    .dark-style .bg-white, [data-bs-theme="dark"] .bg-white { background-color: var(--tk-card-solid) !important; }
    .dark-style .bg-light, [data-bs-theme="dark"] .bg-light { background-color: var(--bs-border-color-translucent) !important; }
    
    .dark-style .border-bottom, .dark-style .border-end, .dark-style .border-top,
    [data-bs-theme="dark"] .border-bottom, [data-bs-theme="dark"] .border-end, [data-bs-theme="dark"] .border-top 
    { border-color: rgba(255,255,255,0.1) !important; }

    /* Shadow for primary bubbles */
    .shadow-primary { box-shadow: 0 0.125rem 0.25rem rgba(105, 108, 255, 0.4); }

    /* Delete Button Hover Effect */
    .message-wrapper .delete-msg-btn { opacity: 0; transition: opacity 0.2s; text-decoration: none; border: none; font-size: 1rem; }
    .message-wrapper:hover .delete-msg-btn { opacity: 1; }
    .delete-msg-btn:hover { color: #ff3e1d !important; transform: scale(1.1); }
    
    .contact-item.active { background-color: rgba(105, 108, 255, 0.1) !important; color: #696cff !important; border-left: 3px solid #696cff !important; }
</style>



