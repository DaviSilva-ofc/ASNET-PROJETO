@page
@model AspnetCoreStarter.Pages.Clients.Professors.ChatModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Suporte ASNET";
}

@section PageStyles {
<style>
    :root {
        --dash-bg: #232333;
        --dash-card-bg: #2b2c40;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-border: rgba(255, 255, 255, 0.08);
        --asnet-orange: #f89223;
        --asnet-green: #71dd37;
    }

    [data-bs-theme="dark"] {
        --dash-bg: #232333;
        --dash-card-bg: #2b2c40;
    }

    .container-xxl {
        padding-top: 2rem !important;
    }

    .page-header-title {
        color: var(--dash-title);
        font-size: 1.375rem;
        font-weight: 500;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--dash-border);
        padding-bottom: 1rem;
    }
    .page-header-title .text-muted { color: #7071a4 !important; }

    .chat-card {
        height: calc(100vh - 220px);
        border-radius: 6px;
        overflow: hidden;
        border: none;
        box-shadow: 0 0.125rem 0.25rem 0 rgba(0, 0, 0, 0.2);
        background: var(--dash-card-bg);
    }

    .chat-sidebar {
        background: rgba(255,255,255,0.02);
        border-right: 1px solid var(--dash-border);
        display: flex;
        flex-direction: column;
    }

    .contact-item {
        transition: all 0.2s;
        border-left: 3px solid transparent;
        cursor: pointer;
        padding: 1.25rem 1.5rem;
        text-decoration: none !important;
        color: inherit !important;
    }
    .contact-item:hover { background: rgba(255, 255, 255, 0.03); }
    .contact-item.active { 
        background: rgba(255, 255, 255, 0.05); 
        border-left-color: var(--asnet-orange);
    }

    .chat-window {
        display: flex;
        flex-direction: column;
        background: var(--dash-card-bg);
    }

    .chat-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--dash-border);
        background: rgba(255,255,255,0.02);
    }

    .chat-messages {
        flex-grow: 1;
        padding: 2rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .msg-bubble {
        max-width: 70%;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.9375rem;
    }

    .msg-sent {
        align-self: flex-end;
        background: #696cff;
        color: #fff;
    }

    .msg-received {
        align-self: flex-start;
        background: #323249;
        color: #a3adbb;
        border: 1px solid var(--dash-border);
    }

    .chat-input-area {
        padding: 1.5rem;
        border-top: 1px solid var(--dash-border);
    }

    .chat-input {
        background: rgba(255,255,255,0.05) !important;
        border: 1px solid var(--dash-border) !important;
        color: #fff !important;
        border-radius: 6px !important;
    }

    .btn-send {
        background: var(--asnet-orange) !important;
        border: none !important;
        color: #fff !important;
        border-radius: 50% !important;
        width: 40px; height: 40px;
        display: flex; align-items: center; justify-content: center;
    }
</style>
}

<div class="container-xxl flex-grow-1">
    <div class="page-header-title">
        <span class="text-muted fw-light">Professor /</span> Chat de Suporte 💬
    </div>

    <div class="card chat-card">
        <div class="row g-0 h-100">
            <!-- Sidebar -->
            <div class="col-md-4 col-lg-3 chat-sidebar h-100 d-none d-md-flex">
                <div class="p-4 border-bottom border-light border-opacity-10">
                    <div class="input-group input-group-merge">
                        <span class="input-group-text bg-transparent border-secondary pe-2"><i class="ri-search-line text-info"></i></span>
                        <input type="text" class="form-control bg-transparent border-secondary text-white" placeholder="Procurar contacto..." id="contactSearch">
                    </div>
                </div>
                <div class="overflow-auto flex-grow-1">
                    @foreach (var contact in Model.Contacts)
                    {
                        <a asp-page="./Chat" asp-route-contactId="@contact.Id" 
                           class="contact-item d-flex align-items-center @(Model.SelectedContactId == contact.Id ? "active" : "")">
                            <div class="position-relative me-3">
                                <div class="avatar">
                                    <span class="avatar-initial rounded-circle bg-label-warning fw-bold">@(contact.Username?[0] ?? 'U')</span>
                                </div>
                                <span class="bg-success position-absolute bottom-0 end-0 border border-dark rounded-circle" style="width: 8px; height: 8px;"></span>
                            </div>
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="mb-0 fw-bold small text-white text-truncate">@contact.Username</h6>
                                <p class="mb-0 text-muted small text-truncate">ASNET Staff</p>
                            </div>
                        </a>
                    }
                </div>
            </div>

            <!-- Chat Window -->
            <div class="col-md-8 col-lg-9 chat-window h-100">
                @if (Model.SelectedContactId.HasValue)
                {
                    var activeContact = Model.Contacts.FirstOrDefault(c => c.Id == Model.SelectedContactId);
                    
                    <div class="chat-header d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <a href="/Clients/Professors/Chat" class="btn btn-sm btn-icon d-md-none me-2"><i class="ri-arrow-left-s-line text-white fs-3"></i></a>
                            <div class="avatar me-3">
                                <span class="avatar-initial rounded-circle bg-label-warning fw-bold">@(activeContact?.Username?[0] ?? 'U')</span>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-white">@activeContact?.Username</h6>
                                <small class="text-success fw-bold"><i class="ri-checkbox-blank-circle-fill me-1 x-small"></i> Online</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-icon btn-label-secondary border-0"><i class="ri-more-2-fill text-white fs-4"></i></button>
                        </div>
                    </div>

                    <div id="chatWindow" class="chat-messages">
                        <div id="messageContainer" class="d-flex flex-column gap-3">
                            @foreach (var msg in Model.Messages)
                            {
                                bool isMe = msg.SenderId == Model.CurrentUserId;
                                <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") w-100" data-msg-id="@msg.Id">
                                    <div class="msg-bubble @(isMe ? "msg-sent" : "msg-received")">
                                        <div>@msg.Content</div>
                                        <div class="text-end mt-1" style="font-size: 0.7rem; opacity: 0.6;">@msg.CreatedAt.ToString("HH:mm")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="chat-input-area">
                        <form id="chatForm" class="d-flex align-items-center gap-3">
                            <input type="text" id="messageInput" class="form-control chat-input" placeholder="Escreva a sua mensagem..." required autocomplete="off" />
                            <input type="hidden" id="receiverId" value="@Model.SelectedContactId" />
                            <button type="submit" class="btn-send shadow-sm"><i class="ri-send-plane-2-line fs-5"></i></button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center p-5">
                        <div class="avatar avatar-xl bg-label-warning mb-4 shadow-sm" style="width:100px; height:100px; font-size: 3rem;">
                            <i class="ri-chat-smile-2-line"></i>
                        </div>
                        <h4 class="fw-bold text-white">Centro de Mensagens</h4>
                        <p class="text-muted" style="max-width: 320px;">Selecione um contacto para iniciar uma conversa.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const chatWindow = document.getElementById('chatWindow');
    const messageContainer = document.getElementById('messageContainer');
    const chatForm = document.getElementById('chatForm');
    const messageInput = document.getElementById('messageInput');
    const receiverId = document.getElementById('receiverId')?.value;

    const scrollToBottom = () => {
        if (chatWindow) chatWindow.scrollTop = chatWindow.scrollHeight;
    };

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveMessage", function (msg) {
        if (msg.senderId == receiverId || msg.isMe) {
            const wrapper = document.createElement('div');
            wrapper.className = `d-flex ${msg.isMe ? 'justify-content-end' : 'justify-content-start'} w-100`;
            wrapper.innerHTML = `<div class="msg-bubble ${msg.isMe ? 'msg-sent' : 'msg-received'}"><div>${msg.content}</div><div class="text-end mt-1" style="font-size: 0.7rem; opacity: 0.6;">${msg.createdAt}</div></div>`;
            messageContainer.appendChild(wrapper);
            scrollToBottom();
        }
    });

    connection.start().catch(err => console.error(err.toString()));

    if (chatForm) {
        scrollToBottom();
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = messageInput.value;
            if (!content.trim()) return;
            messageInput.value = '';
            try { await connection.invoke("SendMessage", parseInt(receiverId), content); } 
            catch (err) { console.error(err); }
        });
    }

    document.getElementById('contactSearch')?.addEventListener('keyup', function() {
        const term = this.value.toLowerCase();
        document.querySelectorAll('.contact-item').forEach(item => {
            const name = item.querySelector('h6')?.innerText.toLowerCase() || '';
            item.style.display = name.includes(term) ? 'flex' : 'none';
        });
    });
</script>
}
