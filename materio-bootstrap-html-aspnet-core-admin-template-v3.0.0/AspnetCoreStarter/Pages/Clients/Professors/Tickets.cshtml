@page
@model AspnetCoreStarter.Pages.Clients.Professors.ProfessorTicketsModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Tickets";
}

<link rel="stylesheet" href="~/css/tickets-v2.css" />
<style>
    .cursor-pointer { cursor: pointer; }
    .animate-pulse { animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
</style>

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Professor /</span> Tickets</h4>

    <div class="card shadow-sm" style="background: var(--tk-card-solid);">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Gestão de Tickets</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    <i class="ri-filter-3-line"></i> Filtros
                </button>
                <button class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#modalTicket">
                    <i class='bx bx-plus-circle me-1'></i> Novo Ticket
                </button>
            </div>
        </div>

        @if (Model.SalaId.HasValue || (!string.IsNullOrEmpty(Model.FilterStatus) && Model.FilterStatus !="Todos os Estados"))
        {
            <div class="card-body py-2">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0 shadow-sm border-0 active-filters-bar" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="ri-filter-3-line me-2 text-filters-blue"></i>
                        <span class="small text-filters-blue fw-medium">
                            Filtros ativos: 
                            @if (Model.SalaId.HasValue) { 
                                var sala = Model.MyRooms.FirstOrDefault(r => r.Id == Model.SalaId.Value);
                                <span class="badge filter-badge me-1">Sala: @(sala?.Name ??"N/A")</span> 
                            }
                            @if (!string.IsNullOrEmpty(Model.FilterStatus) && Model.FilterStatus !="Todos os Estados") { 
                                <span class="badge filter-badge me-1">Estado: @Model.FilterStatus</span> 
                            }
                        </span>
                    </div>
                    <a asp-page="./Tickets" class="btn btn-sm btn-outline-info rounded-pill px-3">
                        <i class="ri-refresh-line me-1 small"></i> Limpar Filtros
                    </a>
                </div>
            </div>
        }

        <div class="tk-list">
            @if (!Model.MyTickets.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="ri-inbox-line fs-1 d-block mb-2"></i>
                    Nenhum ticket encontrado.
                </div>
            }
            else
            {
                @foreach (var t in Model.MyTickets)
                {
                    <div class="tk-row" onclick="openTicketPanel(@t.Id)">
                        <div class="tk-left">
                            <div class="tk-icon">
                                @{
                                    var type = t.Equipamento?.Type ??"";
                                    var name = t.Equipamento?.Name ??"";
                                    var emoji = type switch {
                                        var s when s.Contains("Monitor") =>"🖥️",
                                        var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") =>"💻",
                                        var s when s.Contains("Impressora") =>"🖨️",
                                        var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") =>"🌐",
                                        var s when s.Contains("Projetor") =>"📽️",
                                        var s when s.Contains("Rato") || s.Contains("Mouse") =>"🖱️",
                                        var s when s.Contains("Teclado") || s.Contains("Keyboard") =>"⌨️",
                                        var s when s.Contains("Servidor") || s.Contains("Server") =>"🗄️",
                                        var s when s.Contains("UPS") || s.Contains("Bateria") =>"🔋",
                                        var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") =>"🔊",
                                        var s when s.Contains("Câmara") || s.Contains("Camera") =>"📷",
                                        _ => name.Contains("Monitor") ?"🖥️" : (name.Contains("Computador") ?"💻" : (name.Contains("Impressora") ?"🖨️" :"🔧"))
                                    };
                                }
                                @emoji
                            </div>
                            <div class="tk-details">
                                <div class="tk-title">@(t.Equipamento?.Name ??"Avaria Geral")</div>
                                <div class="tk-sub">
                                    <i class="ri-map-pin-line me-1"></i> @(t.Equipamento?.Room?.Name ??"N/A") • @t.CreatedAt.ToString("dd/MM HH:mm")
                                </div>
                            </div>
                        </div>
                        <div class="tk-right">
                            @{
                                var stCol = t.Status switch {"Concluído" =>"var(--tk-green)","Em reparação" or"Em Reparação" or"Em Resolução" =>"var(--tk-primary)","Aceite" =>"var(--tk-blue)","Pendente" or"Pedido" or"Aberto" =>"var(--tk-amber)",
                                    _ =>"var(--tk-muted)"
                                };
                            }
                            <span class="badge-tk" style="color: @stCol; border-color: @stCol; background: @(stCol)11;">@t.Status</span>
                            <i class="ri-arrow-right-s-line text-muted"></i>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Panel Overlay & Slide-over Panel -->
<div class="tk-overlay @(Model.SelectedTicketId.HasValue ?"open" :"")" onclick="closeTicketPanel()"></div>

<div class="tk-panel @(Model.SelectedTicketId.HasValue ?"open" :"")" id="ticketPanel">
    @if (Model.SelectedTicket != null)
    {
        var t = Model.SelectedTicket;
        var mainEq = t.Equipamento ?? t.UtilizedEquipments?.FirstOrDefault() ?? Model.AssociatedEquipment.FirstOrDefault();
        
        <div class="tk-ph">
            <div class="tk-ph-top">
                <div class="tk-ph-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.5rem; display: flex; align-items: center; justify-content: center;">
                    @{
                        var type = mainEq?.Type ??"";
                        var name = mainEq?.Name ??"";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") =>"🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") =>"💻",
                            var s when s.Contains("Impressora") =>"🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") =>"🌐",
                            var s when s.Contains("Projetor") =>"📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") =>"🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") =>"⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") =>"🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") =>"🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") =>"🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") =>"📷",
                            _ => name.Contains("Monitor") ?"🖥️" : (name.Contains("Computador") ?"💻" : (name.Contains("Impressora") ?"🖨️" :"🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-ph-info">
                    <div class="tk-ph-badges">
                        <span class="badge-tk" style="color: var(--tk-muted); border-color: var(--tk-border);">TK-@t.Id.ToString("D3")</span>
                        <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">@t.Status</span>
                    </div>
                    <h2 class="tk-ph-title">@(mainEq?.Name ??"Avaria Geral"): @(t.Description?.Length > 30 ? t.Description.Substring(0, 30) +"..." : t.Description)</h2>
                </div>
                <button class="tk-close" onclick="closeTicketPanel()">✕</button>
            </div>

            <div class="tk-stepper">
                @{
                    var steps = new[] {"Pendente","Aceite","Em reparação","Concluído" };
                    int si = Array.IndexOf(steps, t.Status);
                    if (si == -1) {
                        if (t.Status =="Pedido" || t.Status =="Aberto") si = 0;
                        else if (t.Status.Contains("repara") || t.Status.Contains("Resolução")) si = 2;
                    }
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i < si || t.Status =="Concluído";
                    bool active = i == si && t.Status !="Concluído";
                    <div class="tk-step">
                        @if (i < steps.Length - 1) {
                            <div class="tk-step-line @(i < si || t.Status =="Concluído" ?"done" :"")"></div>
                        }
                        <div class="tk-step-dot @(done ?"done" :"") @(active ?"active" :"")">
                            @(done ?"✓" : (i + 1).ToString())
                        </div>
                        <div class="tk-step-label @(active ?"active" :"")">@steps[i]</div>
                    </div>
                }
            </div>
            
            @if(t.Status =="Concluído" && t.SatisfacaoRating == null) {
                <div class="tk-advance-row">
                    <button type="button" class="tk-advance-btn" onclick="openEvalModal(@t.Id, '@t.Equipamento?.Name')">⭐ Avaliar Serviço</button>
                </div>
            }
        </div>

        <div class="tk-tabs">
            <div class="tk-tab active" onclick="showTab(0)">📁 Detalhes</div>
            <div class="tk-tab" onclick="showTab(2)">🕒 Histórico</div>
        </div>

        <div class="tk-body">
            <div class="tk-tab-content" id="tab-0">
                <div class="tk-info-grid">
                    <div class="tk-info-card"><div class="tk-info-label">Solicitante</div><div class="tk-info-val">@(t.RequestedBy?.Username ??"—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Técnico</div><div class="tk-info-val">@(t.Technician?.Username ??"A aguardar...")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Escola</div><div class="tk-info-val">@(t.School?.Name ??"—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Criado em</div><div class="tk-info-val">@t.CreatedAt.ToString("dd/MM/yyyy, HH:mm")</div></div>
                    
                    @if (mainEq != null) {
                        <div class="tk-info-card">
                            <div class="tk-info-label">Nº de Série</div>
                            <div class="tk-info-val text-primary fw-bold">@(mainEq.SerialNumber ??"N/A")</div>
                        </div>
                        <div class="tk-info-card" style="grid-row: span 2; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; padding: 10px; border-radius: 8px;">
                            <div class="tk-info-label" style="color: #000; margin-bottom: 5px;">QR CODE</div>
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=@(mainEq.SerialNumber ?? t.Id.ToString())" alt="QR Code" style="width: 80px; height: 80px;" />
                        </div>
                    }
                </div>
                
                <div class="tk-desc-card">
                    <div class="tk-info-label">Descrição</div>
                    <div style="margin-top:6px;font-size:14px;line-height:1.6">@t.Description</div>
                </div>

                @if (Model.AssociatedEquipment.Any())
                {
                    <div class="tk-eq-card">
                        <div class="tk-eq-header">Material Aplicado</div>
                        @foreach (var eq in Model.AssociatedEquipment)
                        {
                            <div class="tk-eq-item">
                                <span><strong>@eq.Name</strong> · <span style="color:#6b7280;font-size:12px">@eq.SerialNumber</span></span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="tk-tab-content d-none" id="tab-2">
                <div style="display:flex;flex-direction:column;gap:12px">
                    @if (!Model.TicketHistory.Any()) {
                        <div style="color:var(--tk-muted);font-size:13px;padding:20px;text-align:center">Sem histórico registado.</div>
                    } else {
                        @foreach(var h in Model.TicketHistory) {
                            <div style="background:#1a232e;border-left:3px solid @(h.TipoAcao == TipoAcaoHistorico.Comentario ?"var(--tk-primary)" :"var(--tk-muted)");padding:12px;border-radius:0 8px 8px 0">
                                <div style="font-size:13px;line-height:1.5">@h.Acao</div>
                                <div style="font-size:11px;color:var(--tk-muted);margin-top:4px">@h.Autor · @h.Data.ToString("dd/MM HH:mm")</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @if(t.Status !="Concluído") {
            <div class="tk-footer">
                <form method="post" asp-page-handler="AddComment" asp-route-ticketId="@t.Id" class="d-flex w-100 gap-2">
                    <input type="text" name="comment" class="tk-comment" placeholder="Enviar mensagem ao técnico..." required autocomplete="off">
                    <button type="submit" class="tk-send-btn">✈ Enviar</button>
                </form>
            </div>
        }
    }
</div>
</div>

<!-- Modal Novo Ticket -->
<div class="modal fade" id="modalTicket" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="CreateTicket" class="modal-content shadow-lg border-0" style="border-radius: 8px;">
            <div class="modal-header border-bottom pb-3">
                <h5 class="modal-title fw-bold"><i class="ri-ticket-2-line me-2 text-success"></i>Novo Ticket</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Equipamento</label>
                    <select asp-for="NewTicket.EquipamentoId" id="selectEquipamento" class="form-select bg-transparent" required onchange="updatePriorityLevels()">
                        <option value="">Selecione um equipamento...</option>
                        @foreach (var eq in Model.AvailableEquipment)
                        {
                            var hasActive = Model.EqIdsWithActiveTickets.Contains(eq.Id);
                            var isBroken = eq.Status != null && (eq.Status.Contains("repara") || eq.Status.Contains("manutenção") || eq.Status.Contains("Avariado"));
                            var indicator = (hasActive || isBroken) ?"⚠️" :"✅";
                            
                            <option value="@eq.Id" data-type="@eq.Type">
                                @indicator @eq.Name - @eq.SerialNumber (@eq.Room?.Name)
                            </option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nível de Prioridade</label>
                    <select asp-for="NewTicket.Level" id="selectPriority" class="form-select bg-transparent" required>
                        <option value="Baixo">Baixo</option>
                        <option value="Médio">Médio</option>
                        <option value="Alto">Alto</option>
                        <option value="Extremo">Extremo</option>
                    </select>
                    <div id="priorityHint" class="form-text text-muted small mt-1"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Período Preferencial</label>
                    <select asp-for="NewTicket.Period" class="form-select bg-transparent" required>
                        <option value="Manhã">Manhã</option>
                        <option value="Tarde" selected>Tarde</option>
                        <option value="Integral">Integral</option>
                    </select>
                </div>
                <div class="mt-3">
                    <label class="form-label fw-semibold small">DESCRIÇÃO DO PEDIDO</label>
                    <textarea asp-for="NewTicket.Description" class="form-control bg-transparent" rows="3" placeholder="Ex: O monitor não liga..." required></textarea>
                </div>
            </div>
            <div class="modal-footer border-top pt-3">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-success">Submeter Ticket</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Filtros -->
<div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="get" class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">Filtrar Tickets</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-semibold small text-uppercase mb-1">Minhas Salas</label>
                        <select asp-for="SalaId" class="form-select">
                            <option value="">Todas as minhas salas</option>
                            @foreach (var room in Model.MyRooms)
                            {
                                <option value="@room.Id">@room.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold small text-uppercase mb-1">Estado do Ticket</label>
                        <select asp-for="FilterStatus" class="form-select">
                            <option value="Todos os Estados">Todos os Estados</option>
                            <option value="Pendente">Pendente</option>
                            <option value="Aceite">Aceite</option>
                            <option value="Em reparação">Em reparação</option>
                            <option value="Concluído">Concluído</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
            </div>
        </form>
    </div>
</div>

@section PageScripts {
<script>
    function openTicketPanel(id) {
        const url = new URL(window.location);
        url.searchParams.set('SelectedTicketId', id);
        window.location.href = url.toString();
    }
    function closeTicketPanel() {
        const url = new URL(window.location);
        url.searchParams.delete('SelectedTicketId');
        window.location.href = url.toString();
    }
    function showTab(idx) {
        document.querySelectorAll('.tk-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
        document.querySelectorAll('.tk-tab-content').forEach((c, i) => c.classList.toggle('d-none', i !== idx));
    }
    function openEvalModal(id, name) {
        document.getElementById('evalTicketId').value = id;
        document.getElementById('evalEquipName').innerText = name ||"Equipamento";
        setRating(5); // Default to 5
        var modal = new bootstrap.Modal(document.getElementById('modalAvaliacao'));
        modal.show();
    }

    function setRating(val) {
        document.getElementById('evalRatingValue').value = val;
        const btns = document.querySelectorAll('.csat-rating-buttons .rating-btn');
        const label = document.getElementById('ratingLabel');
        
        const labels = {
            1: { text: 'Péssimo', class: 'bg-label-danger', btn: 'btn-danger' },
            2: { text: 'Mau', class: 'bg-label-warning', btn: 'btn-warning' },
            3: { text: 'Médio', class: 'bg-label-info', btn: 'btn-info' },
            4: { text: 'Bom', class: 'bg-label-primary', btn: 'btn-primary' },
            5: { text: 'Excelente', class: 'bg-label-success', btn: 'btn-success' }
        };

        btns.forEach((btn, idx) => {
            const btnVal = parseInt(btn.getAttribute('data-value'));
            btn.className = 'btn btn-outline-secondary rounded-pill rating-btn';
            if (btnVal === val) {
                btn.classList.replace('btn-outline-secondary', labels[val].btn);
            }
        });

        if (labels[val]) {
            label.innerText = labels[val].text;
            label.className = 'badge ' + labels[val].class;
        }
    }

    function updatePriorityLevels() {
        const selectEq = document.getElementById('selectEquipamento');
        const selectPri = document.getElementById('selectPriority');
        const hint = document.getElementById('priorityHint');
        
        if (!selectEq || !selectPri) return;
        
        const selectedOption = selectEq.options[selectEq.selectedIndex];
        const type = selectedOption ? (selectedOption.getAttribute('data-type') ||"") :"";
        const typeLower = type.toLowerCase().trim();

        // 1. Reset: Enable and show all options first
        for (let i = 0; i < selectPri.options.length; i++) {
            selectPri.options[i].disabled = false;
            selectPri.options[i].hidden = false;
        }
        if (hint) hint.innerText ="";

        if (!typeLower) return;

        // Helper to restrict to specific values
        const restrictTo = (allowedValues) => {
            let matches = false;
            for (let i = 0; i < selectPri.options.length; i++) {
                const opt = selectPri.options[i];
                if (!allowedValues.includes(opt.value)) {
                    opt.disabled = true;
                    opt.hidden = true;
                } else {
                    matches = true;
                }
            }
            // If current value is now disabled, switch to first allowed
            if (allowedValues.length > 0 && !allowedValues.includes(selectPri.value)) {
                selectPri.value = allowedValues[0];
            }
        };

        // 2. Priority Logic based on broader keywords
        const isComputer = typeLower.includes('computador') || typeLower.includes('pc') || typeLower.includes('desktop') || 
                           typeLower.includes('portátil') || typeLower.includes('laptop') || typeLower.includes('aio') || 
                           typeLower.includes('all-in-one') || typeLower.includes('estação') || typeLower.includes('workstation');
        
        const isCritical = typeLower.includes('servidor') || typeLower.includes('server') || typeLower.includes('storage') || 
                           typeLower.includes('nas') || typeLower.includes('firewall');

        const isNetwork = typeLower.includes('networking') || typeLower.includes('switch') || typeLower.includes('router') || 
                          typeLower.includes('access point') || typeLower.includes('ap') || typeLower.includes('wi-fi') || 
                          typeLower.includes('quadro interativo') || typeLower.includes('smartboard');

        const isPeripheral = typeLower.includes('impressora') || typeLower.includes('monitor') || typeLower.includes('projetor') || 
                             typeLower.includes('televisao') || typeLower.includes('tv') || typeLower.includes('ecrã') || 
                             typeLower.includes('teclado') || typeLower.includes('rato');

        if (isComputer) {
            restrictTo(['Médio']);
        } else if (isCritical) {
            restrictTo(['Alto', 'Extremo']);
        } else if (isNetwork) {
            restrictTo(['Médio', 'Alto']);
        } else if (isPeripheral) {
            restrictTo(['Baixo', 'Médio']);
        } else if (typeLower.includes('mesa interativa')) {
            restrictTo(['Médio']);
        }
    }

    $(document).ready(function () {
        const urlParams = new URLSearchParams(window.location.search);
        const modalElement = document.getElementById('modalTicket');
        if (!modalElement) return;

        if (urlParams.has('eqId') || urlParams.has('openModal')) {
            const eqIdVal = urlParams.get('eqId');
            var myModal = new bootstrap.Modal(modalElement);
            myModal.show();
            // Trigger check after modal is fully rendered
            modalElement.addEventListener('shown.bs.modal', function () {
                var selectEq = document.getElementById('selectEquipamento');
                if (selectEq && eqIdVal) {
                    selectEq.value = eqIdVal;
                    if (typeof jQuery !== 'undefined' && $(selectEq).hasClass("select2-hidden-accessible")) {
                        $(selectEq).trigger('change');
                    }
                }
                updatePriorityLevels();
            }, { once: true });
        }

        modalElement.addEventListener('hidden.bs.modal', function () {
            const hint = document.getElementById('priorityHint');
            if (hint) hint.innerText ="";
            const selectPri = document.getElementById('selectPriority');
            if (selectPri) {
                for (let i = 0; i < selectPri.options.length; i++) {
                    selectPri.options[i].disabled = false;
                    selectPri.options[i].hidden = false;
                }
            }
            if (window.location.search.includes('eqId') || window.location.search.includes('openModal')) {
                const url = new URL(window.location.href);
                url.searchParams.delete('eqId');
                url.searchParams.delete('openModal');
                window.history.replaceState({}, '', url);
            }
            const selectEq = document.getElementById('selectEquipamento');
            if (selectEq) {
                selectEq.value ="";
                if (typeof jQuery !== 'undefined' && $(selectEq).hasClass("select2-hidden-accessible")) {
                    $(selectEq).trigger('change');
                }
            }
        });
    });
</script>

<partial name="Shared/_QrModal" />
}


