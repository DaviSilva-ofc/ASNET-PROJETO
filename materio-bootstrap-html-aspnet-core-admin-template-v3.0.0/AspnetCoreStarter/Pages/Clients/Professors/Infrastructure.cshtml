@page
@model AspnetCoreStarter.Pages.Clients.Professors.InfrastructureModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Minhas Salas";
}

@section PageStyles {
<style>
    .dark-style .card-header h5,
    [data-bs-theme="dark"] .card-header h5 { color: var(--bs-heading-color) !important; }
    
    .dark-style .list-group-item,
    [data-bs-theme="dark"] .list-group-item {
        background-color: transparent;
        color: #cbcbe2;
        border-color: rgba(255,255,255,0.1);
    }
    
    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: var(--tk-card-solid) !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .bg-light-section {
        background-color: rgba(67, 89, 113, 0.02);
        transition: all 0.3s ease;
    }
    .dark-style .bg-light-section,
    [data-bs-theme="dark"] .bg-light-section {
        background-color: rgba(255, 255, 255, 0.03);
    }
    .bg-light-section:hover { background-color: rgba(67, 89, 113, 0.05); }

    .infra-tree .tree-node { position: relative; padding: 4px 0; }
    .tree-node i { font-size: 1.1rem; vertical-align: middle; opacity: 0.8; }
    .cursor-pointer { cursor: pointer; }

    /* Animation for arrows */
    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold;
        color: var(--bs-primary);
        font-size: 1.4rem;
        display: inline-block;
        line-height: 1;
        background-color: rgba(105, 108, 255, 0.15);
        border: 1px solid rgba(105, 108, 255, 0.3);
        border-radius: 4px;
        padding: 4px;
        margin-right: 8px;
    }
    
    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: var(--bs-primary);
        color: var(--bs-heading-color);
    }

    .agrupamento-node { color: #696cff; }
    .school-node { color: #71dd37; }
    .bloc-node { color: #03c3ec; }
    .room-node { color: #ffab00; }
    .equip-node { color: #707186; }
    
    .dark-style .agrupamento-node { color: #696cff; }
    .dark-style .school-node { color: #71dd37; }
    .dark-style .bloc-node { color: #03c3ec; }
    .dark-style .room-node { color: #ffab00; }

    .infra-header {
        background: #f89223 !important;
        padding: 1rem 1.5rem;
        border-radius: 6px 6px 0 0;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Professor /</span> Minhas Salas</h4>
        <a href="/Clients/Professors/Equipment" class="btn btn-warning shadow-none fw-bold px-4">
            <i class="ri-computer-line me-2"></i> Ver Equipamentos
        </a>
    </div>

    @if (Model.Agrupamento != null)
    {
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="infra-header  d-flex justify-content-between align-items-center" style="color: var(--bs-heading-color) !important;">
                        <h5 class="mb-0  fw-bold" style="color: var(--bs-heading-color) !important;">@Model.Agrupamento.Name</h5>
                        <i class="ri-node-tree  fs-4" style="color: var(--bs-heading-color) !important;"></i>
                    </div>
                    
                    <div class="card-body pt-4">
                        <div class="row">
                            <!-- Column 1: Tickets -->
                            <div class="col-md-3 mb-3">
                                <div class="border rounded p-4 h-100 bg-light-section d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="mb-0 fw-bold"><i class="ri-ticket-2-line me-2 text-primary"></i>Tickets</h6>
                                    </div>
                                    <h2 class="mb-1 text-primary fw-bold">@Model.TotalTickets</h2>
                                    <p class="text-muted small mb-4">Tickets ativos em todas as suas salas</p>
                                    <div class="mt-auto">
                                        <a href="/Clients/Professors/Tickets" class="btn btn-sm btn-outline-primary w-100">Ver Tickets</a>
                                    </div>
                                </div>
                            </div>

                            <!-- Column 2: Equipamentos -->
                            <div class="col-md-3 mb-3">
                                <div class="border rounded p-4 h-100 bg-light-section d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="mb-0 fw-bold"><i class="ri-computer-line me-2 text-success"></i>Equipamentos</h6>
                                    </div>
                                    <h2 class="mb-1 text-success fw-bold">@Model.TotalEquipments</h2>
                                    <p class="text-muted small mb-4">Dispositivos sob sua supervisão</p>
                                    <div class="mt-auto">
                                        <a href="/Clients/Professors/Equipment" class="btn btn-sm btn-outline-success w-100">Ver Inventário</a>
                                    </div>
                                </div>
                            </div>

                            <!-- Column 3: Hierarchy Tree -->
                            <div class="col-md-6 mb-3">
                                <div class="border rounded p-4 h-100 bg-light-section">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="mb-0 fw-bold text-info"><i class="ri-node-tree me-2"></i>A Minha Rede</h6>
                                    </div>
                                    
                                    <div class="infra-tree mt-3" style="max-height: 500px; overflow-y: auto;">
                                        <!-- Root Agrupamento -->
                                        <div class="tree-node agrupamento-node">
                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-main">
                                                <i class="ri-arrow-right-s-line"></i>
                                                <i class="ri-community-line me-2"></i> <strong>@Model.Agrupamento.Name</strong>
                                            </div>
                                            
                                            <div id="tree-main" class="collapse show">
                                                @foreach (var schoolGroup in Model.MySalas.GroupBy(s => s.Block.School.Id))
                                                {
                                                    var school = schoolGroup.First().Block.School;
                                                    <div class="tree-node school-node ms-4 mt-2">
                                                        <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-school-@school.Id">
                                                            <i class="ri-arrow-right-s-line"></i>
                                                            <i class="ri-building-line me-2"></i> <strong>@school.Name</strong>
                                                        </div>
                                                        
                                                        <div id="tree-school-@school.Id" class="collapse show">
                                                            @foreach (var blockGroup in schoolGroup.GroupBy(s => s.BlockId))
                                                            {
                                                                var block = blockGroup.First().Block;
                                                                <div class="tree-node bloc-node ms-4 mt-1">
                                                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-block-@block.Id">
                                                                        <i class="ri-arrow-right-s-line"></i>
                                                                        <i class="ri-box-3-line me-2"></i> @block.Name
                                                                    </div>
                                                                    
                                                                    <div id="tree-block-@block.Id" class="collapse show">
                                                                        @foreach (var sala in blockGroup)
                                                                        {
                                                                            <div class="tree-node room-node ms-4 mt-1">
                                                                                <div class="d-flex align-items-center justify-content-between cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-equips-@sala.Id">
                                                                                    <div>
                                                                                        <i class="ri-arrow-right-s-line"></i>
                                                                                        <i class="ri-door-open-line me-2"></i> @sala.Name
                                                                                    </div>
                                                                                    <div class="tree-actions ms-auto">
                                                                                        <a href="/Clients/Professors/Tickets?SalaId=@sala.Id" class="btn btn-sm btn-icon btn-outline-warning border-0" title="Tickets">
                                                                                            <i class="ri-ticket-2-line"></i>
                                                                                        </a>
                                                                                        <a href="/Clients/Professors/Equipment?SalaId=@sala.Id" class="btn btn-sm btn-icon btn-outline-info border-0 ms-1" title="Equipamentos">
                                                                                            <i class="ri-computer-line"></i>
                                                                                        </a>
                                                                                    </div>
                                                                                </div>
                                                                                
                                                                                <div id="tree-equips-@sala.Id" class="collapse">
                                                                                    @if (sala.Equipments != null && sala.Equipments.Any())
                                                                                    {
                                                                                        var groupedEquips = sala.Equipments.GroupBy(e => e.Name).Select(g => new { Name = g.Key, Count = g.Count() }).ToList();
                                                                                        foreach (var g in groupedEquips)
                                                                                        {
                                                                                            var label = g.Count > 1 ? $"{g.Name} ({g.Count})" : g.Name;
                                                                                            <a href="/Clients/Professors/Equipment?SalaId=@sala.Id&FilterName=@g.Name" class="tree-node equip-node ms-5 mt-1 small text-decoration-none d-block">
                                                                                                <i class="ri-computer-line me-2"></i> @label
                                                                                            </a>
                                                                                        }
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <div class="ms-5 mt-1 small fst-italic text-muted opacity-50">Sem equipamentos</div>
                                                                                    }
                                                                                </div>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card p-5 text-center shadow-sm border-0">
            <div class="card-body">
                <i class="ri-error-warning-line ri-4x text-muted mb-3 opacity-25"></i>
                <h5 class="text-muted">Sem salas atribuídas</h5>
                <p class="text-muted small">Não possui infraestrutura sob sua responsabilidade neste momento.</p>
                <a href="/Clients/Professors/Dashboard" class="btn btn-primary mt-3">Voltar ao Painel</a>
            </div>
        </div>
    }
</div>



