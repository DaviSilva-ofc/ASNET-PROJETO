@page
@model AspnetCoreStarter.Pages.Clients.Professors.DashboardModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Dashboard Professor";
    ViewData["container"] ="container-fluid";
    ViewData["containerNav"] ="container-fluid";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.dist.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.dist.js"></script>
}

@section PageStyles {
<style>
    :root {
        --asnet-navy: #1e2130;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
        
        /* Theme aware variables */
        --dash-card-bg: #fff;
        --dash-text: #566a7f;
        --dash-title: #566a7f;
        --dash-subtitle: #a1acb8;
        --dash-border: rgba(67, 89, 113, 0.1);
        --dash-shadow: 0 2px 6px 0 rgba(67, 89, 113, 0.12);
        --chart-label: #a1acb8;
        --chart-grid: rgba(67, 89, 113, 0.1);
    }

    [data-bs-theme="dark"] {
        --dash-card-bg: #2b2e44;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-subtitle: #7071a4;
        --dash-border: rgba(255, 255, 255, 0.05);
        --dash-shadow: 0 4px 18px rgba(0,0,0,0.2);
        --chart-label: #7071a4;
        --chart-grid: rgba(255, 255, 255, 0.08);
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--dash-title);
    }

    .stat-card, .tree-card, .action-card, .chart-card, .asnet-table-card {
        background: var(--dash-card-bg) !important;
        border: none !important;
        border-radius: 16px !important;
        box-shadow: var(--dash-shadow) !important;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover { transform: translateY(-4px); }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        color: var(--bs-heading-color);
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; color: var(--dash-title); }
    .stat-label  { font-size: .8rem; color: var(--dash-subtitle); margin: 0; text-transform: uppercase; }

    .nav-pills .nav-link {
        background: transparent !important;
        color: var(--dash-subtitle) !important;
        transition: all 0.2s ease;
        font-size: 0.8rem;
        font-weight: 700;
    }
    .nav-pills .nav-link.active {
        background: var(--asnet-orange) !important;
        color: var(--bs-heading-color) !important;
    }

    .asnet-table th {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--dash-subtitle);
        padding: 1rem 1.25rem !important;
        background: rgba(0,0,0,0.02);
        border: none !important;
    }
    [data-bs-theme="dark"] .asnet-table th { background: rgba(255,255,255,0.02); }

    .asnet-table td {
        padding: 0.75rem 1.25rem !important;
        border-bottom: 1px solid var(--dash-border) !important;
        color: var(--dash-text);
        font-size: 0.8125rem;
    }

    .big-number { font-size: 3rem; font-weight: 800; color: var(--dash-title); line-height: 1; }
</style>
}

<div class="container-xxl flex-grow-1">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="dash-title mb-1">Painel Professor</h4>
            <p class="text-muted mb-0">Gestão de <span class="fw-bold text-primary">@(Model.TotalSalas) Salas</span> submetidas à sua responsabilidade</p>
        </div>
        <a href="/Clients/Professors/Infrastructure" class="btn btn-warning shadow-none fw-bold px-4">
            <i class="ri-node-tree me-1"></i> Minha Rede
        </a>
    </div>

    <!-- Row 1: Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: var(--asnet-blue); font-size: 1.2rem;">
                        🚪
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalSalas</p>
                        <p class="stat-label">Minhas Salas</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: var(--asnet-teal); font-size: 1.2rem;">
                        📦
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalEquipamentos</p>
                        <p class="stat-label">Equipamentos</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: var(--asnet-orange); font-size: 1.2rem;">
                        📄
                    </div>
                    <div>
                        <p class="stat-number">@Model.PendingTicketsCount</p>
                        <p class="stat-label">Tickets Abertos</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: var(--asnet-pink); font-size: 1.2rem;">
                        🚨
                    </div>
                    <div>
                        <p class="stat-number">@Model.DamagedEquipmentCount</p>
                        <p class="stat-label">Avarias</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Navigation, Messages, Reports -->
    <div class="row g-4 mb-4">
        <!-- Infrastructure Tree -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid var(--asnet-blue) !important;">
                <div class="card-header border-bottom-0 pb-0">
                    <ul class="nav nav-pills gap-2 mb-3" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active py-2 px-3" data-bs-toggle="tab" data-bs-target="#tab-esc">Escolas</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-2 px-3" data-bs-toggle="tab" data-bs-target="#tab-blocos">Blocos</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-2 px-3" data-bs-toggle="tab" data-bs-target="#tab-salas">Salas</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body pt-0" style="max-height: 300px; overflow-y: auto;">
                    <div class="tab-content p-0 border-0 shadow-none">
                        <div class="tab-pane fade show active" id="tab-esc">
                            <div class="d-flex flex-column gap-3">
                                @foreach (var school in Model.MySchools) {
                                    <div class="d-flex align-items-center gap-2">
                                        <span style="font-size: 1rem;">🏫</span>
                                        <span class="fw-semibold" style="font-size: 0.85rem;">@school.Name</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-blocos">
                            <div class="d-flex flex-column gap-3">
                                @foreach (var bloco in Model.MyBlocos) {
                                    <div class="d-flex align-items-center gap-2">
                                        <span style="font-size: 1rem;">🧱</span>
                                        <span class="fw-semibold" style="font-size: 0.85rem;">@bloco.Name</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-salas">
                            <div class="d-flex flex-column gap-3">
                                @foreach (var sala in Model.MySalas) {
                                    <div class="d-flex align-items-center gap-2">
                                        <span style="font-size: 1rem;">🚪</span>
                                        <span class="fw-semibold" style="font-size: 0.85rem;">@sala.Name</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Messages Card -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="border-left: 4px solid var(--asnet-green) !important;">
                <div class="card-body p-4 flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div class="stat-icon" style="background: var(--asnet-green); font-size: 1.2rem;">
                            💬
                        </div>
                        <h5 class="mb-0 fw-bold">Mensagens</h5>
                    </div>
                    <div class="mb-3">
                        <span class="big-number">@Model.TotalUnreadMessages</span>
                        <span class="fw-bold fs-5 text-success"> novas</span>
                    </div>
                    <p class="text-muted small">mensagens no chat aguardam resposta</p>
                </div>
                <div class="p-4 pt-0">
                    <a href="/Clients/Professors/Chat" class="btn btn-success w-100 py-2 fw-bold">Responder</a>
                </div>
            </div>
        </div>

        <!-- Reports Card -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="border-left: 4px solid var(--asnet-pink) !important;">
                <div class="card-body p-4 flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div class="stat-icon" style="background: var(--asnet-pink); font-size: 1.2rem;">
                            🔧
                        </div>
                        <h5 class="mb-0 fw-bold">Avarias Pendentes</h5>
                    </div>
                    <div class="mb-3">
                        <span class="big-number">@Model.DamagedEquipmentCount</span>
                        <span class="fw-bold fs-5 text-danger"> por reportar</span>
                    </div>
                    <p class="text-muted small">equipamentos aguardam abertura de ticket</p>
                </div>
                <div class="p-4 pt-0">
                    <a href="/Clients/Professors/Tickets?openModal=1" class="btn btn-danger w-100 py-2 fw-bold">Criar Ticket</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 3: Charts -->
    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card chart-card h-100 shadow-sm border-0">
                <div class="card-header d-flex align-items-center gap-2 border-bottom pb-3">
                    <i class='bx bx-trending-up text-primary'></i> <span class="fw-bold">Tendência de Tickets (6 Meses)</span>
                </div>
                <div class="card-body pt-4">
                    <div id="ticketTrendChart" style="min-height: 250px;"></div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card chart-card h-100 shadow-sm border-0">
                <div class="card-header d-flex align-items-center gap-2 border-bottom pb-3">
                    <i class='bx bx-pie-chart-alt-2 text-warning'></i> <span class="fw-bold">Visão Geral de Estado</span>
                </div>
                <div class="card-body pt-4 d-flex flex-column align-items-center justify-content-center">
                    <div id="healthOverviewChart" style="min-height: 250px; width: 100%;"></div>
                    <div class="d-flex gap-4 mt-3 flex-wrap justify-content-center">
                        <span class="text-muted small"><i class='bx bxs-circle me-1' style="color:var(--asnet-blue);"></i> Funcional</span>
                        <span class="text-muted small"><i class='bx bxs-circle me-1' style="color:var(--asnet-pink);"></i> Avariado</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Table -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card asnet-table-card">
                <div class="card-header d-flex justify-content-between align-items-center p-4">
                    <h5 class="mb-0 fw-bold"><i class="ri-history-line me-2 text-info"></i>Atividade Recente</h5>
                    <a href="/Clients/Professors/Tickets" class="btn btn-sm btn-outline-primary fw-bold">Ver histórico completo</a>
                </div>
                <div class="table-responsive">
                    <table class="table asnet-table">
                        <thead>
                            <tr>
                                <th>TICKET</th>
                                <th>EQUIPAMENTO</th>
                                <th>TÉCNICO</th>
                                <th>DATA / HORA</th>
                                <th>ESTADO</th>
                                <th class="text-center">AÇÕES</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTickets != null && Model.RecentTickets.Any()) {
                                @foreach (var ticket in Model.RecentTickets.Take(3)) {
                                    <tr>
                                        <td><span class="badge bg-label-secondary">#@ticket.Id</span></td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                @{
                                                    var ttype = ticket.Equipamento?.Type ??"";
                                                    var tname = ticket.Equipamento?.Name ??"";
                                                    var temoji = ttype.ToLower() switch {
                                                        var s when s.Contains("monitor") =>"🖥️",
                                                        var s when s.Contains("computador") || s.Contains("desktop") || s.Contains("portátil") || s.Contains("pc") =>"💻",
                                                        var s when s.Contains("impressora") =>"🖨️",
                                                        var s when s.Contains("rede") || s.Contains("network") || s.Contains("switch") || s.Contains("router") =>"🌐",
                                                        var s when s.Contains("projetor") =>"📽️",
                                                        var s when s.Contains("rato") || s.Contains("mouse") =>"🖱️",
                                                        var s when s.Contains("teclado") =>"⌨️",
                                                        var s when s.Contains("servidor") =>"🗄️",
                                                        var s when s.Contains("ups") || s.Contains("bateria") =>"🔋",
                                                        var s when s.Contains("quadro") || s.Contains("interativo") =>"📺",
                                                        _ => tname.Contains("Monitor") ?"🖥️" : (tname.Contains("Computador") ?"💻" : (tname.Contains("Impressora") ?"🖨️" :"🔧"))
                                                    };
                                                }
                                                <span class="fw-bold">@temoji @ticket.Equipamento?.Name</span>
                                                <small class="text-muted small">
                                                    @(ticket.Equipamento?.Brand ??"Genérico") @(ticket.Equipamento?.Model ??"")
                                                    @if (!string.IsNullOrEmpty(ticket.Equipamento?.SerialNumber))
                                                    {
                                                        <span class="ms-1">(S/N: @ticket.Equipamento.SerialNumber)</span>
                                                    }
                                                </small>
                                            </div>
                                            <small class="text-muted">@ticket.Equipamento?.Room?.Name</small>
                                        </td>
                                        <td>
                                            @if (ticket.Technician != null)
                                            {
                                                <a asp-page="/Profile" asp-route-id="@ticket.Technician.Id" class="d-flex align-items-center text-body">
                                                    <div class="avatar avatar-xs me-2">
                                                        <span class="avatar-initial rounded-circle bg-label-primary" style="font-size: 0.6rem;">@(ticket.Technician.Username?.Substring(0, 1).ToUpper())</span>
                                                    </div>
                                                    <span class="fw-medium">@ticket.Technician.Username</span>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted small italic">A aguardar...</span>
                                            }
                                        </td>
                                        <td>@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @if (ticket.Status =="Pendente" || ticket.Status =="Aguardando" || ticket.Status =="Pedido") {
                                                <span class="badge bg-label-warning text-uppercase" style="font-size: 0.65rem;"><i class="bx bx-time me-1"></i> A aguardar Técnico</span>
                                            } else if (ticket.Status =="Em andamento" || ticket.Status =="Atribuído" || ticket.Status =="Em Reparação") {
                                                <span class="badge bg-label-warning text-uppercase" style="font-size: 0.65rem;"><i class="bx bx-wrench me-1"></i> Em Reparação</span>
                                            } else {
                                                <span class="badge bg-label-success text-uppercase" style="font-size: 0.65rem;"><i class="bx bx-check-circle me-1"></i> Resolvido</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                                    onclick="showQRCode('@ticket.Equipamento?.Id', 'equip', '@(ticket.Equipamento?.Name?.Replace("'","\\'"))', '@(ticket.Equipamento?.SerialNumber ??"S/N N/A")')">
                                                <i class="ri-qr-code-line"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            } else {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">Sem atividade recente a reportar.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>




@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const isDark = document.documentElement.classList.contains('dark-style') || document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const labelColor = isDark ? '#7071a4' : '#a1acb8';
        const borderColor = isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(67, 89, 113, 0.1)';

        // Ticket Trend Chart
        if (document.querySelector("#ticketTrendChart")) {
            const trendOptions = {
                series: [{
                    name: 'Tickets',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData ?? new List<int>()))
                }],
                chart: {
                    height: 250,
                    type: 'area',
                    toolbar: { show: false },
                    zoom: { enabled: false },
                    foreColor: labelColor,
                    fontFamily: 'Public Sans'
                },
                dataLabels: { enabled: false },
                stroke: { curve: 'smooth', width: 3, colors: ['#696cff'] },
                fill: {
                    type: 'gradient',
                    gradient: {
                        shadeIntensity: 1,
                        opacityFrom: 0.5,
                        opacityTo: 0.1,
                        stops: [0, 90, 100],
                        colorStops: [
                            { offset: 0, color: '#696cff', opacity: 0.4 },
                            { offset: 100, color: '#696cff', opacity: 0 }
                        ]
                    }
                },
                grid: {
                    borderColor: borderColor,
                    padding: { top: 0, bottom: 0, left: 10, right: 10 }
                },
                xaxis: {
                    categories: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels ?? new List<string>())),
                    labels: { style: { colors: labelColor } },
                    axisBorder: { show: false },
                    axisTicks: { show: false }
                },
                yaxis: { 
                    labels: { 
                        offsetX: -10,
                        style: { colors: labelColor }
                    } 
                },
                legend: { show: false },
                colors: ['#696cff'],
                tooltip: { theme: isDark ? 'dark' : 'light' }
            };

            const trendChart = new ApexCharts(document.querySelector("#ticketTrendChart"), trendOptions);
            trendChart.render();
        }

        // Health Overview Chart (Donut)
        if (document.querySelector("#healthOverviewChart")) {
            const healthOptions = {
                series: [@Model.HealthyCount, @Model.DamagedCount],
                labels: ['Funcional', 'Avariado'],
                chart: {
                    type: 'donut',
                    height: 250,
                    fontFamily: 'Public Sans'
                },
                dataLabels: { enabled: false },
                stroke: { show: false },
                colors: ['#696cff', '#e7305b'],
                legend: { show: false },
                plotOptions: {
                    pie: {
                        donut: {
                            size: '75%',
                            labels: {
                                show: true,
                                name: { show: true, fontSize: '1rem', color: labelColor, offsetY: 5 },
                                value: { show: false },
                                total: {
                                    show: true,
                                    label: 'Equipamentos',
                                    color: labelColor,
                                    fontSize: '0.85rem'
                                }
                            }
                        }
                    }
                },
                tooltip: { theme: isDark ? 'dark' : 'light' }
            };

            const healthChart = new ApexCharts(document.querySelector("#healthOverviewChart"), healthOptions);
            healthChart.render();
        }
    });
</script>
<partial name="Shared/_QrModal" />
}


