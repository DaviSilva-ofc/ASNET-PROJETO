            <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
            <!-- Outros -->
            <option value="Cabo/Adaptador" data-artigo="Outros">Cabo/Adaptador</option>
            <option value="Outro" data-artigo="Outros">Outro</option>
        `;
        document.body.appendChild(tSource);

        const sHidden = document.createElement('select');
        sHidden.id = 'regSetor-hidden';
        sHidden.style.display = 'none';
        @foreach(var s in Model.Setores) {
            @:sHidden.innerHTML += '<option value="@s.Id" data-dept="@s.DepartamentoId">@s.Name</option>';
        }
        document.body.appendChild(sHidden);

        const rHidden = document.createElement('select');
        rHidden.id = 'regSala-hidden';
        rHidden.style.display = 'none';
        @foreach(var r in Model.Salas) {
            @:rHidden.innerHTML += '<option value="@r.Id" data-setor="@r.SetorId">@r.Name</option>';
        }
        document.body.appendChild(rHidden);

        // Initialize cascades for active filters
        const activeFilterNameSelect = document.getElementById('filterName');
        if (activeFilterNameSelect && activeFilterNameSelect.value) {
            updateSpecificTypes('filter', '@Model.FilterType');
        }
    });

    function openEditModal(id, name, type, brand, model, serial, roomId, setorId, deptId, status) {
        document.getElementById('editId').value = id;
        
        // Normalize Article name
        const artSelect = document.getElementById('editName');
        const cleanName = (name || '').toLowerCase().trim();
        let matchingOpt = Array.from(artSelect.options).find(o => o.value.toLowerCase().trim() === cleanName);
        
        // Specific normalization rules
        if (!matchingOpt) {
            if (cleanName === 'computador') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Computadores');
            else if (cleanName === 'monitor' || cleanName === 'televisão' || cleanName === 'tv') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Monitores');
            else if (cleanName === 'impressora') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Impressoras');
            else if (cleanName.includes('quadro') || cleanName.includes('board')) matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Quadros Interativos');
        }

        if (matchingOpt) {
            $(artSelect).val(matchingOpt.value).trigger('change');
        } else {
            $(artSelect).val('Outros').trigger('change');
        }
        
        // Trigger cascading updates with Select2 support
        updateSpecificTypes('edit', type);
        updateBrands('edit');
        $(document.getElementById('editBrand')).val(brand).trigger('change');
        updateModels('edit', model);
        
        document.getElementById('editSerial').value = serial;
        
        const statusSelect = document.getElementById('editStatus');
        if (statusSelect) {
            let cleanStatus = (status || 'A funcionar').trim();
            if (cleanStatus === "A funcionar") cleanStatus = "A funcionar";
            $(statusSelect).val(cleanStatus).trigger('change');
        }
        
        document.getElementById('editDept').value = deptId || "";
        cascadeSetores('edit', setorId);
        cascadeSalas('edit', roomId);

        new bootstrap.Modal(document.getElementById('modalEditarEquipamento')).show();
    }

    // Removida função redundante filterReqEqTypes
</script>
}

