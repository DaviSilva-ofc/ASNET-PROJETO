    function updateSpecificTypes(prefix, selectedValue = null) {
        const artigo = document.getElementById(prefix + 'Name').value;
        const typeSelect = document.getElementById(prefix + 'Type');
        const sourceSelect = document.getElementById('type-hidden-source');
        
        typeSelect.innerHTML = '<option value="">Selecione...</option>';
        $(typeSelect).val("").trigger('change');
        
        if (artigo) {
            Array.from(sourceSelect.options).forEach(opt => {
                const targetArtigo = opt.getAttribute('data-artigo');
                if (targetArtigo === artigo) {
                    const cloned = opt.cloneNode(true);
                    if (selectedValue && cloned.value === selectedValue) cloned.selected = true;
                    typeSelect.appendChild(cloned);
                }
            });
        }
        
        $(typeSelect).select2({
            placeholder: artigo ? 'Selecione o tipo...' : 'Selecione o artigo primeiro',
            dropdownParent: $(typeSelect).parent()
        });
    }

    function updateBrands(prefix) {
        const artigo = document.getElementById(prefix + 'Name').value;
        const brandSelect = document.getElementById(prefix + 'Brand');
        
        brandSelect.innerHTML = '<option value="">Selecione...</option>';
        $(brandSelect).val("").trigger('change');

        if (artigo && brandModelData[artigo]) {
            Object.keys(brandModelData[artigo]).forEach(brand => {
                const opt = document.createElement('option');
                opt.value = brand;
                opt.textContent = brand;
                brandSelect.appendChild(opt);
            });
        }
        $(brandSelect).select2({
            placeholder: artigo ? 'Selecione a marca...' : 'Selecione o tipo primeiro',
            dropdownParent: $(brandSelect).parent()
        });
        updateModels(prefix);
    }

    function updateModels(prefix, selectedModel = null) {
        const artigo = document.getElementById(prefix + 'Name').value;
        const brand = document.getElementById(prefix + 'Brand').value;
        const modelSelect = document.getElementById(prefix + 'Model');
        
        modelSelect.innerHTML = '<option value="">Selecione...</option>';
        $(modelSelect).val("").trigger('change');

        if (artigo && brand && brandModelData[artigo] && brandModelData[artigo][brand]) {
            brandModelData[artigo][brand].forEach(model => {
                const opt = document.createElement('option');
                opt.value = model;
                opt.textContent = model;
                if (selectedModel && model === selectedModel) opt.selected = true;
                modelSelect.appendChild(opt);
            });
        }
        $(modelSelect).select2({
            placeholder: brand ? 'Selecione o modelo...' : 'Selecione a marca primeiro',
            dropdownParent: $(modelSelect).parent()
        });
    }

    function cascadeSetores(prefix, selectedValue = null) {
        const deptId = document.getElementById(prefix + 'Dept').value;
        const setorSelect = document.getElementById(prefix + 'Setor');
        const salaSelect = document.getElementById(prefix + 'Sala');
        
        setorSelect.innerHTML = '<option value="">Selecione...</option>';
        setorSelect.disabled = !deptId;
        if (prefix === 'reg') {
            salaSelect.innerHTML = '<option value="">Selecione Setor primeiro...</option>';
            salaSelect.disabled = true;
        }

        if (deptId) {
            const allSetores = Array.from(document.querySelectorAll('#regSetor-hidden option'));
            allSetores.forEach(opt => {
                if (opt.getAttribute('data-dept') === deptId) {
                    const cloned = opt.cloneNode(true);
                    if (selectedValue && cloned.value == selectedValue) cloned.selected = true;
                    setorSelect.appendChild(cloned);
                }
            });
        }
    }

    function cascadeSalas(prefix, selectedValue = null) {
        const setorId = document.getElementById(prefix + 'Setor').value;
        const salaSelect = document.getElementById(prefix + 'Sala');
        
        salaSelect.innerHTML = '<option value="">Selecione...</option>';
        salaSelect.disabled = !setorId;

        if (setorId) {
            const allSalas = Array.from(document.querySelectorAll('#regSala-hidden option'));
            allSalas.forEach(opt => {
                if (opt.getAttribute('data-setor') === setorId) {
                    const cloned = opt.cloneNode(true);
                    if (selectedValue && cloned.value == selectedValue) cloned.selected = true;
                    salaSelect.appendChild(cloned);
                }
            });
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Source for Specific Types - used for cascading filtering
        const tSource = document.createElement('select');
        tSource.id = 'type-hidden-source';
        tSource.style.display = 'none';
        tSource.innerHTML = `
            <option value="Desktop" data-artigo="Computadores">Desktop</option>
            <option value="Portátil" data-artigo="Computadores">Portátil</option>
            <option value="AIO" data-artigo="Computadores">AIO</option>
            <option value="Laptop" data-artigo="Computadores">Laptop</option>
            <option value="Monitor" data-artigo="Monitores">Monitor</option>
            <option value="Televisão" data-artigo="Monitores">Televisão</option>
            <option value="Impressora" data-artigo="Impressoras">Impressora</option>
            <option value="Router" data-artigo="Networking">Router</option>
            <option value="Switch" data-artigo="Networking">Switch</option>
            <option value="Access Point" data-artigo="Networking">Access Point</option>
            <option value="Teclado" data-artigo="Periféricos">Teclado</option>
            <option value="Rato" data-artigo="Periféricos">Rato</option>
            <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
            <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
            <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
            <option value="Projetor" data-artigo="Projetores">Projetor</option>
            <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
            <option value="Servidor" data-artigo="Servidores/Infra">Servidor</option>
            <option value="NAS" data-artigo="Servidores/Infra">NAS</option>
            <option value="Outro" data-artigo="Outros">Outro</option>
        `;
        document.body.appendChild(tSource);

        const sHidden = document.createElement('select');
        sHidden.id = 'regSetor-hidden';
        sHidden.style.display = 'none';
        @foreach(var s in Model.Setores) {
            @:sHidden.innerHTML += '<option value="@s.Id" data-dept="@s.DepartamentoId">@s.Name</option>';
        }
        document.body.appendChild(sHidden);

        const rHidden = document.createElement('select');
        rHidden.id = 'regSala-hidden';
        rHidden.style.display = 'none';
        @foreach(var r in Model.Salas) {
            @:rHidden.innerHTML += '<option value="@r.Id" data-setor="@r.SetorId">@r.Name</option>';
        }
        document.body.appendChild(rHidden);
    });

    function openEditModal(id, name, type, brand, model, serial, roomId, setorId, deptId, status) {
        document.getElementById('editId').value = id;
        document.getElementById('editName').value = name;
        
        // Trigger cascading updates
        updateSpecificTypes('edit', type);
        updateBrands('edit');
        document.getElementById('editBrand').value = brand;
        updateModels('edit', model);
        
        document.getElementById('editSerial').value = serial;
        document.getElementById('editStatus').value = status;
        
        document.getElementById('editDept').value = deptId || "";
        cascadeSetores('edit', setorId);
        cascadeSalas('edit', roomId);

        new bootstrap.Modal(document.getElementById('modalEditarEquipamento')).show();
    }
</script>
