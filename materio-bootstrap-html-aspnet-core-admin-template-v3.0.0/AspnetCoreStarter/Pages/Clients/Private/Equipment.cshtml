@page
@model AspnetCoreStarter.Pages.Clients.Private.PrivateEquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Equipamentos - " + (Model.Empresa?.Name ?? "Cliente Privado");
    ViewData["isNavbar"] = true;
    ViewData["contentNavbar"] = true;
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/notyf/notyf.dist.css" />
<link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

@section PageStyles {
<style>
    .infra-chip { font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; background: rgba(0,0,0,0.05); color: #666; margin-right: 4px; }
    .dark-style .infra-chip { background: rgba(255,255,255,0.05); color: #aaa; }

    /* Infrastructure Tree Styles */
    .infra-tree .tree-node { position: relative; padding: 4px 0; }
    .tree-node i { font-size: 1.1rem; vertical-align: middle; opacity: 0.8; }
    .cursor-pointer { cursor: pointer; }
    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold; color: var(--asnet-blue);
        display: inline-block; padding: 2px;
    }
    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line { transform: rotate(90deg); }
    .dept-node { color: var(--asnet-blue); }
    .setor-node { color: #71dd37; }
    .sala-node { color: #ffab00; }
    .equip-node { color: #8592a3; font-size: 0.85rem; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Private Client /</span> Equipamentos</h4>

    <!-- Infrastructure Tree View (Collapsible) -->
    <div class="card mb-4 border-primary shadow-sm overflow-hidden">
        <div class="card-header bg-primary py-2 d-flex justify-content-between align-items-center cursor-pointer" 
             data-bs-toggle="collapse" data-bs-target="#infraTreeCollapse">
            <h6 class="mb-0 text-white fw-bold"><i class="bx bx-node me-2"></i>Estrutura da Empresa (Árvore)</h6>
            <i class="bx bx-chevron-down text-white"></i>
        </div>
        <div id="infraTreeCollapse" class="collapse">
            <div class="card-body pt-3 pb-2">
                <div class="infra-tree">
                    @if (!Model.Departamentos.Any())
                    {
                        <div class="text-center py-3">
                            <p class="text-muted small mb-0">Nenhuma unidade registada. Use o botão "Gerir Unidades" para começar.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var dept in Model.Departamentos)
                        {
                            <div class="tree-node dept-node">
                                <div class="d-flex align-items-center cursor-pointer" data-bs-toggle="collapse" data-bs-target="#dept-@dept.Id">
                                    <i class="ri-arrow-right-s-line me-1"></i>
                                    <i class="bx bx-briefcase me-1"></i> <strong>@dept.Name</strong>
                                </div>
                                <div id="dept-@dept.Id" class="collapse ps-4 border-start ms-2">
                                    @foreach (var setor in dept.Setores)
                                    {
                                        <div class="tree-node setor-node mt-2">
                                            <div class="d-flex align-items-center cursor-pointer" data-bs-toggle="collapse" data-bs-target="#setor-@setor.Id">
                                                <i class="ri-arrow-right-s-line me-1"></i>
                                                <i class="bx bx-collection me-1"></i> @setor.Name
                                            </div>
                                            <div id="setor-@setor.Id" class="collapse ps-4 border-start ms-2">
                                                @foreach (var sala in setor.Salas)
                                                {
                                                    <div class="tree-node sala-node mt-1">
                                                        <div class="d-flex align-items-center cursor-pointer" data-bs-toggle="collapse" data-bs-target="#sala-@sala.Id">
                                                            <i class="ri-arrow-right-s-line me-1"></i>
                                                            <i class="bx bx-door-open me-1"></i> <span class="fw-medium">@sala.Name</span>
                                                            <span class="badge bg-label-secondary ms-2 small">@sala.Equipments.Count</span>
                                                        </div>
                                                        <div id="sala-@sala.Id" class="collapse ps-4 ms-2">
                                                            @foreach (var eqGroup in sala.Equipments.GroupBy(e => e.Name))
                                                            {
                                                                <a asp-page="./Equipment" asp-route-FilterName="@eqGroup.Key" asp-route-FilterRoomId="@sala.Id" 
                                                                   class="tree-node equip-node d-flex align-items-center py-1 text-decoration-none hover-primary">
                                                                    <i class="bx bx-chevron-right me-1"></i>
                                                                    <span>@eqGroup.Key (@eqGroup.Count())</span>
                                                                </a>
                                                            }
                                                            @if (!sala.Equipments.Any())
                                                            {
                                                                <span class="text-muted italic small ms-3">Vazia</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible shadow-sm mb-4" role="alert">
            <i class="bx bx-check-circle me-2"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible shadow-sm mb-4" role="alert">
            <i class="bx bx-error-circle me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

        @if (!string.IsNullOrEmpty(Model.FilterName) || !string.IsNullOrEmpty(Model.FilterType) || 
             !string.IsNullOrEmpty(Model.FilterBrand) || !string.IsNullOrEmpty(Model.FilterStatus) || 
             Model.FilterRoomId.HasValue)
        {
            <div class="card-body">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert">
                    <div>
                        <i class="bx bx-info-circle me-1"></i> A filtrar por:
                        @if (!string.IsNullOrEmpty(Model.FilterName)) { <span class="badge bg-white text-info ms-1">Artigo: @Model.FilterName</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterType)) { <span class="badge bg-white text-info ms-1">Tipo: @Model.FilterType</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterBrand)) { <span class="badge bg-white text-info ms-1">Marca: @Model.FilterBrand</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterStatus)) { <span class="badge bg-white text-info ms-1">Estado: @Model.FilterStatus</span> }
                        @if (Model.FilterRoomId.HasValue)
                        {
                            var roomName = Model.UniqueRooms.FirstOrDefault(r => r.Id == Model.FilterRoomId)?.Name ?? "Selecionada";
                            <span class="badge bg-white text-info ms-1">Localização: @roomName</span>
                        }
                    </div>
                    <a asp-page="./Equipment" class="btn btn-sm btn-label-secondary">Limpar Tudo</a>
                </div>
            </div>
        }

    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-inventario">
                    <i class="bx bx-list-ul me-1"></i> Inventário Geral
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-devolucoes">
                    <i class="bx bx-undo me-1"></i> Pedidos e Devoluções
                    @if (Model.BorrowedItems.Any())
                    {
                        <span class="badge rounded-pill bg-danger ms-2">@Model.BorrowedItems.Sum(i => i.Quantity)</span>
                    }
                </button>
            </li>
        </ul>
        <div class="tab-content" style="background: transparent; padding: 0; box-shadow: none;">
            <!-- Aba Inventário -->
            <div class="tab-pane fade show active" id="tab-inventario" role="tabpanel">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center border-bottom mb-3 py-3">
                        <h5 class="mb-0 text-primary fw-bold">Gestão de Ativos</h5>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                                <i class="bx bx-filter-alt me-1"></i> Filtros
                            </button>
                            <button class="btn btn-warning text-white" data-bs-toggle="modal" data-bs-target="#modalRequisitarEq">
                                <i class="ri-hand-coin-line me-1"></i> Requisitar Equipamento
                            </button>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalRegistarEquipamento">
                                <i class="bx bx-plus me-1"></i> Novo Equipamento
                            </button>
                        </div>
                    </div>
                
                    <div class="table-responsive text-nowrap">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th class="small text-uppercase fw-bold">Artigo</th>
                                    <th class="small text-uppercase fw-bold">Tipo</th>
                                    <th class="small text-uppercase fw-bold">Nº Série</th>
                                    <th class="small text-uppercase fw-bold">Localização (Sala)</th>
                                    <th class="small text-uppercase fw-bold">Status</th>
                                    <th class="small text-uppercase fw-bold text-center">Ações</th>
                                </tr>
                            </thead>
                            <tbody class="table-border-bottom-0">
                                @if (Model.Equipments == null || !Model.Equipments.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <i class="bx bx-box fs-1 text-muted mb-2"></i>
                                            <p class="text-muted">Nenhum equipamento encontrado no inventário.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.Equipments)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                <div class="d-flex flex-column">
                                                    <strong class="text-dark">@item.Name</strong>
                                                    <small class="text-muted" style="font-size: 0.75rem;">
                                                        @(item.Brand ?? "Genérico") @(item.Model ?? "")
                                                    </small>
                                                </div>
                                            </td>
                                            <td>@item.Type</td>
                                            <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                                            <td>
                                                @if (item.Room != null)
                                                {
                                                    <span>@item.Room.Name (@(item.Room.Setor?.Name ?? "N/A"))</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted italic small">Não definida</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.Status == "Avariado")
                                                {
                                                    <span class="badge bg-label-danger">Avariado</span>
                                                }
                                                else if (item.Status == "Em reparação")
                                                {
                                                    <span class="badge bg-label-info">Em reparação</span>
                                                }
                                                else if (item.Status == "Associado")
                                                {
                                                    <span class="badge bg-label-warning">Associado (Em Intervenção)</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-label-success">A funcionar</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex align-items-center justify-content-center gap-2">
                                                    @if (item.Status == null || (!item.Status.Contains("repara", StringComparison.OrdinalIgnoreCase) && !item.Status.Contains("manutenção", StringComparison.OrdinalIgnoreCase)))
                                                    {
                                                        <a asp-page="./Tickets" asp-route-eqId="@item.Id" class="text-decoration-none p-1 cursor-pointer lh-1" title="Solicitar Ticket">
                                                            🎫
                                                        </a>
                                                    }
                                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                                        @if (item.Status == "Avariado" || item.Status == "Danificado")
                                                        {
                                                            <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Marcar como Funcional">
                                                                ✅
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Marcar como Avariado">
                                                                ⚠️
                                                            </button>
                                                        }
                                                    </form>
                                                    
                                                    <button type="button" class="border-0 bg-transparent p-1 lh-1" title="Código QR" 
                                                            onclick="showQRCode('@item.Id', 'Equipamento', '@item.Name', '@(item.SerialNumber ?? "S/N N/A")')">
                                                        📱
                                                    </button>

                                                    <button type="button" class="border-0 bg-transparent p-1 lh-1" title="Editar" 
                                                            onclick="openEditModal(@item.Id, '@item.Name', '@item.Type', '@item.Brand', '@item.Model', '@item.SerialNumber', '@(item.RoomId)', '@(item.Room?.SetorId)', '@(item.Room?.Setor?.DepartamentoId)', '@item.Status')">
                                                        ✏️
                                                    </button>
                                                    
                                                    <form method="post" asp-page-handler="DeleteEquipment" asp-route-id="@item.Id" 
                                                          onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?')" style="display:inline-block;">
                                                        <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Eliminar">
                                                            🗑️
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Aba Pedidos e Devoluções -->
            <div class="tab-pane fade" id="tab-devolucoes" role="tabpanel">
                <!-- Requisições Pendentes -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header border-bottom bg-label-warning py-3">
                        <h5 class="mb-0 text-dark"><i class="ri-time-line me-2"></i>Requisições Pendentes</h5>
                    </div>
                    <div class="table-responsive text-nowrap">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Artigo Pedido</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.MyStockRequests == null || !Model.MyStockRequests.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted small">
                                            Não existem pedidos de stock pendentes.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var ticket in Model.MyStockRequests)
                                    {
                                        <tr>
                                            <td><span class="small text-muted">@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="fw-bold">@ticket.Description.Split('\n').FirstOrDefault()?.Replace("PEDIDO DE STOCK (CLIENTE):", "").Trim()</span>
                                                    @if (ticket.Equipamento != null)
                                                    {
                                                        <small class="text-muted">Ref: @ticket.Equipamento.SerialNumber</small>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                @{
                                                    var statusClass = ticket.Status switch {
                                                        "Pendente" or "Pedido" => "badge bg-label-warning",
                                                        "Concluído" => "badge bg-label-success",
                                                        _ => "badge bg-label-info"
                                                    };
                                                }
                                                <span class="@statusClass text-uppercase" style="font-size: 0.7rem;">@ticket.Status</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Equipamentos Emprestados (Para Devolução) -->
                <div class="card shadow-sm">
                    <div class="card-header border-bottom">
                        <h5 class="mb-0">Equipamentos Emprestados (Na Posse)</h5>
                    </div>
                    <div class="table-responsive text-nowrap">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th class="small text-uppercase fw-bold">Artigo</th>
                                    <th class="small text-uppercase fw-bold">Tipo</th>
                                    <th class="small text-uppercase fw-bold text-center">Quantidade Atual</th>
                                    <th class="small text-uppercase fw-bold">Status</th>
                                    <th class="small text-uppercase fw-bold text-center">Ações</th>
                                </tr>
                            </thead>
                            <tbody class="table-border-bottom-0">
                                @if (Model.BorrowedItems == null || !Model.BorrowedItems.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <i class="bx bx-refresh fs-1 text-muted mb-2"></i>
                                            <p class="text-muted small">Não existem equipamentos requisitados em sua posse.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.BorrowedItems)
                                    {
                                        <tr>
                                            <td class="ps-3"><strong class="text-dark">@item.Name</strong></td>
                                            <td>@item.Category</td>
                                            <td class="text-center"><span class="badge bg-label-info fw-bold">@item.Quantity un.</span></td>
                                            <td><span class="badge bg-label-warning">Em seu uso</span></td>
                                            <td class="text-center">
                                                <form method="post" asp-page-handler="ReturnLoan" class="d-flex align-items-center justify-content-center gap-2">
                                                    <input type="hidden" name="sampleId" value="@item.Id" />
                                                    <div class="input-group input-group-sm" style="width: 130px;">
                                                        <input type="number" name="quantity" class="form-control" value="1" min="1" max="@item.Quantity" required />
                                                        <button type="submit" class="btn btn-warning text-white" 
                                                                onclick="return confirm('Confirmar a devolução deste equipamento à Administração ASNET?')">
                                                            <i class="bx bx-undo me-1"></i> Devolver
                                                        </button>
                                                    </div>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Requisitar Equipamento -->
<div class="modal fade" id="modalRequisitarEq" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="CreateStockRequest" class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold"><i class="ri-hand-coin-line me-2 text-warning"></i>Requisitar Equipamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Artigo</label>
                    <select name="itemName" id="reqEqName" class="form-select" required onchange="updateSpecificTypes('reqEq')">
                        <option value="">Selecione o artigo...</option>
                        <option value="Computadores">Computadores</option>
                        <option value="Monitores">Monitores</option>
                        <option value="Impressoras">Impressoras</option>
                        <option value="Networking">Networking</option>
                        <option value="Servidores/Infra">Servidores/Infra</option>
                        <option value="Componentes">Componentes</option>
                        <option value="Perifericos">Perifericos</option>
                        <option value="Projetores">Projetores</option>
                        <option value="Quadros Interativos">Quadros Interativos</option>
                        <option value="Outros">Outros</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Tipo</label>
                    <select name="itemType" id="reqEqType" class="form-select">
                        <option value="">Selecione o artigo primeiro...</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Quantidade</label>
                    <input type="number" name="quantity" class="form-control" value="1" min="1" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Motivo do Pedido</label>
                    <textarea name="notes" class="form-control" rows="3" placeholder="Descreva a necessidade..." required></textarea>
                </div>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-warning text-white">Solicitar Equipamento</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Registar Equipamento -->
<div class="modal fade" id="modalRegistarEquipamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form method="post" asp-page-handler="AddEquipment" class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold"><i class="bx bx-plus-circle me-2"></i>Novo Equipamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Artigo</label>
                        <select asp-for="NewEquipment.Name" id="regName" class="form-select select2" required onchange="updateSpecificTypes('reg')">
                            <option value="">Selecione...</option>
                            <option value="Computadores">Computadores</option>
                            <option value="Monitores">Monitores</option>
                            <option value="Impressoras">Impressoras</option>
                            <option value="Networking">Networking</option>
                            <option value="Servidores/Infra">Servidores/Infra</option>
                            <option value="Componentes">Componentes</option>
                            <option value="Periféricos">Periféricos</option>
                            <option value="Projetores">Projetores</option>
                            <option value="Quadros Interativos">Quadros Interativos</option>
                            <option value="Outros">Outros</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tipo Específico</label>
                        <select asp-for="NewEquipment.Type" id="regType" class="form-select select2" required onchange="updateBrands('reg')">
                            <option value="">Selecione Artigo...</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Marca</label>
                        <select asp-for="NewEquipment.Brand" id="regBrand" class="form-select select2" required onchange="updateModels('reg')">
                            <option value="">Selecione Tipo...</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Modelo</label>
                        <select asp-for="NewEquipment.Model" id="regModel" class="form-select select2" required>
                            <option value="">Selecione Marca...</option>
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Nº de Série</label>
                        <input type="text" asp-for="NewEquipment.SerialNumber" class="form-control" placeholder="X-XXXX-XXXX-X" required />
                    </div>

                    <div class="col-12"><hr class="my-2"></div>
                    <div class="col-12">
                        <p class="mb-2 fw-bold text-primary small"><i class="bx bx-map-pin me-1"></i>LOCALIZAÇÃO HIERÁRQUICA</p>
                    </div>
                    
                    <div class="col-md-4">
