@page
@model AspnetCoreStarter.Pages.Clients.Private.PrivateChatModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Centro de Mensagens - Suporte ASNET";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Private Client /</span> Chat de Suporte</h4>

    <div class="card overflow-hidden" style="height: calc(100vh - 200px);">
        <div class="row g-0 h-100">
            <!-- Sidebar de Contactos (Administradores/Suporte) -->
            <div class="col-3 border-end h-100 bg-light d-none d-md-block">
                <div class="p-3 border-bottom bg-white d-flex align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="ri-customer-service-2-line me-2"></i>Suporte ASNET</h6>
                </div>
                <div class="list-group list-group-flush overflow-auto" style="height: calc(100% - 60px);">
                    @foreach (var contact in Model.Contacts)
                    {
                        <a asp-page="./Chat" asp-route-contactId="@contact.Id" 
                           class="list-group-item list-group-item-action border-0 py-3 @(Model.SelectedContactId == contact.Id ? "active" : "")">
                            <div class="d-flex align-items-center">
                                <div class="avatar me-2">
                                    <span class="avatar-initial rounded-circle bg-label-primary">@contact.Username[0]</span>
                                </div>
                                <div class="w-100">
                                    <h6 class="mb-0 small fw-medium">@contact.Username</h6>
                                    <p class="mb-0 text-muted x-small">Técnico/Administrador</p>
                                </div>
                            </div>
                        </a>
                    }
                    @if (!Model.Contacts.Any())
                    {
                        <div class="p-3 text-center text-muted small">Nenhum administrador disponível no momento.</div>
                    }
                </div>
            </div>

            <!-- Janela de Chat -->
            <div class="col-12 col-md-9 h-100 d-flex flex-column">
                @if (Model.SelectedContactId.HasValue)
                {
                    var currentContact = Model.Contacts.FirstOrDefault(c => c.Id == Model.SelectedContactId);
                    <!-- Header -->
                    <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-white shadow-sm" style="z-index: 5;">
                        <div class="d-flex align-items-center">
                            <a asp-page="./Chat" class="btn btn-sm btn-icon d-md-none me-2"><i class="bx bx-chevron-left"></i></a>
                            <div class="avatar me-2">
                                <span class="avatar-initial rounded-circle bg-label-primary">@currentContact?.Username[0]</span>
                            </div>
                            <div>
                                <h6 class="mb-0">@currentContact?.Username</h6>
                                <small class="text-success"><span class="badge badge-dot bg-success me-1"></span>Online/Suporte</small>
                            </div>
                        </div>
                    </div>

                    <!-- Mensagens -->
                    <div id="chatWindow" class="flex-grow-1 p-3 overflow-auto bg-white">
                        <div id="messageContainer" class="d-flex flex-column gap-3">
                            @foreach (var msg in Model.Messages)
                            {
                                bool isMe = msg.SenderId == Model.CurrentUserId;
                                <div class="message-wrapper d-flex @(isMe ? "justify-content-end" : "justify-content-start") align-items-center w-100 mb-3" data-msg-id="@msg.Id">
                                    <div class="@(isMe ? "text-white bg-primary" : "bg-light") p-2 rounded-3 shadow-sm msg-bubble" 
                                         style="max-width: 70%;">
                                        <p class="mb-0 small">@msg.Content</p>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <small class="@(isMe ? "text-white-50" : "text-muted") x-small">@msg.CreatedAt.ToString("HH:mm")</small>
                                            @if (isMe && msg.IsRead) { <i class="ri-check-double-line @(isMe ? "text-white-50" : "text-primary") ms-1 x-small"></i> }
                                        </div>
                                    </div>
                                    @if (isMe)
                                    {
                                        <button class="btn btn-link btn-sm p-0 ms-2 delete-msg-btn text-muted" onclick="deleteMsg(@msg.Id)" title="Apagar">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Input -->
                    <div class="p-3 border-top bg-white">
                        <form id="chatForm" class="input-group overflow-hidden">
                            <input type="text" id="messageInput" class="form-control border-0 bg-light px-3" placeholder="Escreva a sua mensagem..." required autocomplete="off" />
                            <input type="hidden" id="receiverId" value="@Model.SelectedContactId" />
                            <button type="submit" class="btn btn-warning px-4 shadow-sm fw-bold">
                                <i class="ri-send-plane-2-line me-1"></i> Enviar
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center bg-light text-center p-5">
                        <div class="mb-4 text-primary opacity-25" style="font-size: 5rem;"><i class="ri-chat-smile-2-line"></i></div>
                        <h5 class="fw-bold">Centro de Ajuda ASNET</h5>
                        <p class="text-muted" style="max-width: 400px;">Selecione um técnico de suporte na lista lateral para iniciar uma conversa ou tirar dúvidas sobre os seus equipamentos.</p>
                        <div class="d-md-none mt-4 w-100">
                            <h6 class="small text-uppercase fw-bold text-muted mb-3">Técnicos Disponíveis:</h6>
                            <div class="list-group shadow-sm">
                                @foreach (var contact in Model.Contacts)
                                {
                                    <a asp-page="./Chat" asp-route-contactId="@contact.Id" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                                        <div class="avatar avatar-sm me-2">
                                            <span class="avatar-initial rounded-circle bg-label-primary">@contact.Username[0]</span>
                                        </div>
                                        <span>@contact.Username</span>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const chatWindow = document.getElementById('chatWindow');
    const messageContainer = document.getElementById('messageContainer');
    const chatForm = document.getElementById('chatForm');
    const messageInput = document.getElementById('messageInput');
    const receiverId = document.getElementById('receiverId')?.value;

    const currentUserId = "@Model.CurrentUserId";

    const scrollToBottom = () => {
        if (chatWindow) chatWindow.scrollTop = chatWindow.scrollHeight;
    };

    // Initialize SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveMessage", function (msg) {
        // Only show if it's from the person we are chatting with OR if it's from us
        const isFromSelectedContact = msg.senderId == receiverId;
        const isFromMe = msg.senderId == currentUserId;

        if (isFromSelectedContact || isFromMe) {
            const wrapper = document.createElement('div');
            wrapper.className = `message-wrapper d-flex ${isFromMe ? 'justify-content-end' : 'justify-content-start'} align-items-center w-100 mb-3 animate__animated animate__fadeInUp`;
            wrapper.setAttribute('data-msg-id', msg.id);

            wrapper.innerHTML = `
                <div class="${isFromMe ? 'text-white bg-primary' : 'bg-light'} p-2 rounded-3 shadow-sm msg-bubble" style="max-width: 70%;">
                    <p class="mb-0 small">${msg.content}</p>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <small class="${isFromMe ? 'text-white-50' : 'text-muted'} x-small">${msg.createdAt}</small>
                    </div>
                </div>
                ${isFromMe ? `<button class="btn btn-link btn-sm p-0 ms-2 delete-msg-btn text-muted" onclick="deleteMsg(${msg.id})" title="Apagar"><i class="ri-delete-bin-line"></i></button>` : ''}
            `;
            messageContainer.appendChild(wrapper);
            scrollToBottom();
        }
    });

    connection.on("MessageDeleted", function (msgId) {
        const msgElement = document.querySelector(`.message-wrapper[data-msg-id="${msgId}"]`);
        if (msgElement) {
            msgElement.classList.add('animate__animated', 'animate__fadeOut');
            setTimeout(() => msgElement.remove(), 500);
        }
    });

    window.deleteMsg = async function(msgId) {
        if (confirm("Deseja apagar esta mensagem para todos?")) {
            try {
                await connection.invoke("DeleteMessage", msgId);
            } catch (err) {
                console.error(err);
                alert("Erro ao apagar mensagem.");
            }
        }
    };

    connection.start().catch(err => console.error(err.toString()));

    if (chatForm) {
        scrollToBottom();

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = messageInput.value;
            if (!content.trim()) return;

            messageInput.value = '';

            try {
                await connection.invoke("SendMessage", parseInt(receiverId), content);
            } catch (err) {
                console.error('Error sending message:', err);
                alert("Erro ao enviar mensagem.");
            }
        });
    }
</script>
}

<style>
    .x-small { font-size: 0.7rem; }
    .avatar-initial { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; font-weight: bold; }
    .msg-bubble { border-radius: 12px !important; }
    .dark-style .bg-white, [data-bs-theme="dark"] .bg-white { background-color: #2b2c40 !important; }
    .dark-style .bg-light, [data-bs-theme="dark"] .bg-light { background-color: rgba(255,255,255,0.05) !important; }
    
    .message-wrapper .delete-msg-btn { opacity: 0; transition: opacity 0.2s; }
    .message-wrapper:hover .delete-msg-btn { opacity: 1; }
</style>
