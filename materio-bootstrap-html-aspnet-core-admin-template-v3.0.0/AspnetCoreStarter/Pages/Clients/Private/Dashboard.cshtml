@page
@model AspnetCoreStarter.Pages.Clients.Private.PrivateDashboardModel
@using System.Linq
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Dashboard Cliente";
    ViewData["isNavbar"] = true;
    ViewData["contentNavbar"] = true;
    ViewData["container"] ="container-fluid";
    ViewData["containerNav"] ="container-fluid";
}

@section PageStyles {
<style>
    :root {
        --asnet-navy: #1e2130;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
        
        /* Theme aware variables */
        --dash-card-bg: #fff;
        --dash-text: #566a7f;
        --dash-title: #566a7f;
        --dash-subtitle: #a1acb8;
        --dash-border: rgba(67, 89, 113, 0.1);
        --dash-shadow: 0 2px 6px 0 rgba(67, 89, 113, 0.12);
    }

    .dark-style, [data-bs-theme="dark"] {
        --dash-card-bg: #2b2e44;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-subtitle: #7071a4;
        --dash-border: rgba(255, 255, 255, 0.05);
        --dash-shadow: 0 4px 18px rgba(0,0,0,0.2);
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--dash-title);
    }

    .stat-card, .tree-card, .pending-card, .chart-card, .map-card {
        background: var(--dash-card-bg) !important;
        border: none !important;
        border-radius: 16px !important;
        box-shadow: var(--dash-shadow) !important;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
    }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--bs-heading-color);
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; color: var(--dash-title); }
    .stat-label  { font-size: .8rem; color: var(--dash-subtitle); margin: 0; }

    .chart-card .card-header, .tree-card .card-header, .map-card .card-header {
        background: transparent !important;
        border-bottom: 1px solid var(--dash-border) !important;
        font-weight: 600;
        color: var(--dash-title);
    }

    .pending-big-number {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dash-title);
        line-height: 1;
    }
    .pending-subtitle { font-size: .85rem; color: var(--dash-subtitle); }

    /* Forced Full Width Layout */
    .container-xxl, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
    }
    
    .layout-page, .content-wrapper, .layout-container {
        width: 100% !important;
    }
</style>
}

<!-- Title -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="dash-title mb-1">Cliente Privado</h4>
        <p class="text-muted mb-0">Empresa: <span class="fw-bold text-primary">@(Model.Empresa?.Name ??"N/A")</span></p>
    </div>
</div>

<!-- Stat mini-cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:var(--asnet-blue); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center; font-size: 1.1rem;">
                    👥
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.TotalUsers</p>
                    <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Utilizadores</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:var(--asnet-orange); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center; font-size: 1.1rem;">
                    📄
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.TotalContratos</p>
                    <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Contratos</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#ff3e1d; width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center; font-size: 1.1rem;">
                    🚨
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.PendingTicketsCount</p>
                    <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Tickets Ativos</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#fd7e14; width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center; font-size: 1.1rem;">
                    📦
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold   fs-5" style="color: var(--bs-heading-color) !important;">@Model.LowStockAlertsCount</p>
                    <p class="stat-label mb-0  -50 small" style="color: var(--bs-heading-color) !important;">Alertas de Stock</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Messages Card -->
    <div class="col-lg-6">
        <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="background: var(--tk-card-solid) !important; border-left: 4px solid #71dd37 !important;">
            <div class="card-body p-4 flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div style="width: 40px; height: 40px; background: #71dd37; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">
                        💬
                    </div>
                    <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color) !important;">Mensagens</h5>
                </div>
                <div class="mb-3">
                    <span class="fw-bolder" style="font-size: 3rem; color: var(--bs-heading-color); line-height: 1;">@Model.TotalUnreadMessages</span>
                    <span class="fw-bold" style="color: #71dd37; font-size: 1.2rem;"> novas</span>
                </div>
                <p class="-50 small" style="color: var(--bs-heading-color) !important;">mensagens no chat aguardam resposta</p>
            </div>
            <div class="p-4 pt-0">
                <a asp-page="/Clients/Private/Chat" class="btn w-100 py-2 fw-bold" style="background: #71dd37; color: var(--bs-heading-color); border-radius: 8px;">Ir para o Chat</a>
            </div>
        </div>
    </div>

    <!-- Contracts Management Card -->
    <div class="col-lg-6">
        <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="background: var(--tk-card-solid) !important; border-left: 4px solid #f89223 !important;">
            <div class="card-body p-4 flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div style="width: 40px; height: 40px; background: #f89223; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">
                        📜
                    </div>
                    <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color) !important;">Gestão de Contratos</h5>
                </div>
                <div class="mb-3">
                    <span class="fw-bolder" style="font-size: 3rem; color: var(--bs-heading-color); line-height: 1;">@Model.TotalContratos</span>
                    <span class="fw-bold" style="color: #f89223; font-size: 1.2rem;"> ativos</span>
                </div>
                <p class="-50 small" style="color: var(--bs-heading-color) !important;">contratos em vigor e monitorização de expiração</p>
            </div>
            <div class="p-4 pt-0">
                <a asp-page="/Clients/Private/Contracts" class="btn w-100 py-2 fw-bold" style="background: #f89223; color: var(--bs-heading-color); border-radius: 8px;">Gerir Contratos</a>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card chart-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3"><i class='bx bx-trending-up' style="color:var(--asnet-blue);"></i> Evolução de Tickets</div>
            <div class="card-body pt-4"><canvas id="monthlyTicketChart" style="max-height: 250px;"></canvas></div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card chart-card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3"><i class='bx bx-pie-chart-alt-2' style="color:var(--asnet-orange);"></i> Visão Geral da Empresa</div>
            <div class="card-body pt-4 d-flex flex-column align-items-center justify-content-center">
                <canvas id="overviewChart" style="max-height: 250px;"></canvas>
                <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                    <span class="-50" style="color: var(--bs-heading-color) !important;"><i class='bx bxs-circle me-1' style="color:#ff3e1d;font-size:.6rem;"></i> Tickets</span>
                    <span class="-50" style="color: var(--bs-heading-color) !important;"><i class='bx bxs-circle me-1' style="color:#f89223;font-size:.6rem;"></i> Stock</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity Table (Tickets) -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card h-100 shadow-sm border-0" style="background: var(--tk-card-solid) !important;">
            <div class="card-header d-flex justify-content-between align-items-center p-4 border-bottom border-secondary">
                <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color) !important;"><i class="bx bx-wrench me-2 text-info"></i>Tickets de Manutenção Recentes</h5>
                <a asp-page="/Clients/Private/Tickets" class="btn btn-sm btn-outline-primary fw-bold">Ver todos</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-label-secondary">
                        <tr>
                            <th class="-50" style="color: var(--bs-heading-color) !important;">TICKET</th>
                            <th class="-50" style="color: var(--bs-heading-color) !important;">EQUIPAMENTO</th>
                            <th class="-50" style="color: var(--bs-heading-color) !important;">TÉCNICO</th>
                            <th class="-50" style="color: var(--bs-heading-color) !important;">DATA</th>
                            <th class="-50" style="color: var(--bs-heading-color) !important;">ESTADO</th>
                            <th class="-50 text-center" style="color: var(--bs-heading-color) !important;">AÇÕES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentTickets != null && Model.RecentTickets.Any()) {
                            @foreach (var ticket in Model.RecentTickets.Take(3)) {
                                <tr>
                                    <td><span class="badge bg-label-secondary">#@ticket.Id</span></td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            @{
                                                var etype = ticket.Equipamento?.Type ??"";
                                                var ename = ticket.Equipamento?.Name ??"";
                                                var eemoji = etype.ToLower() switch {
                                                    var s when s.Contains("monitor") =>"🖥️",
                                                    var s when s.Contains("computador") || s.Contains("desktop") || s.Contains("portátil") || s.Contains("pc") =>"💻",
                                                    var s when s.Contains("impressora") =>"🖨️",
                                                    var s when s.Contains("rede") || s.Contains("network") || s.Contains("switch") || s.Contains("router") =>"🌐",
                                                    var s when s.Contains("projetor") =>"📽️",
                                                    var s when s.Contains("rato") || s.Contains("mouse") =>"🖱️",
                                                    var s when s.Contains("teclado") =>"⌨️",
                                                    var s when s.Contains("servidor") =>"🗄️",
                                                    var s when s.Contains("ups") || s.Contains("bateria") =>"🔋",
                                                    var s when s.Contains("quadro") || s.Contains("interativo") =>"📺",
                                                    _ => ename.Contains("Monitor") ?"🖥️" : (ename.Contains("Computador") ?"💻" : (ename.Contains("Impressora") ?"🖨️" :"📦"))
                                                };
                                            }
                                            <span class="fw-bold" style="color: var(--bs-heading-color) !important;">@eemoji @ticket.Equipamento?.Name</span>
                                            <small class="-50 small" style="color: var(--bs-heading-color) !important;">
                                                @(ticket.Equipamento?.Brand ??"Genérico") @(ticket.Equipamento?.Model ??"")
                                                @if (!string.IsNullOrEmpty(ticket.Equipamento?.SerialNumber))
                                                {
                                                    <span class="ms-1">(S/N: @ticket.Equipamento.SerialNumber)</span>
                                                }
                                            </small>
                                        </div>
                                    </td>
                                    <td>
                                        @if (ticket.Technician != null)
                                        {
                                            <a asp-page="/Profile" asp-route-id="@ticket.Technician.Id" class="d-flex align-items-center text-body">
                                                 <div class="avatar avatar-xs me-2">
                                                     <span class="avatar-initial rounded-circle bg-label-primary" style="font-size: 0.6rem;">@(ticket.Technician.Username?.Substring(0, 1).ToUpper())</span>
                                                 </div>
                                                 <span class="fw-medium" style="color: var(--bs-heading-color) !important;">@ticket.Technician.Username</span>
                                             </a>
                                        }
                                        else
                                        {
                                            <span class="text-warning small italic">A aguardar técnico...</span>
                                        }
                                    </td>
                                    <td class="-50" style="color: var(--bs-heading-color) !important;">@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @{
                                            var statusLabel = ticket.Status switch {"Pendente" or"Pedido" =>"badge bg-label-warning","Em Reparação" or"EmResolução" or"Em andamento" =>"badge bg-label-info","Concluído" =>"badge bg-label-success",
                                                _ =>"badge bg-label-secondary"
                                            };
                                            var statusDisplayName = (ticket.Status =="Pedido" || ticket.Status =="Pendente") ?"A aguardar" : ticket.Status;
                                        }
                                        <span class="@statusLabel text-uppercase" style="font-size: 0.65rem;">@statusDisplayName</span>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                            onclick="showQRCode('@ticket.Equipamento?.Id', 'equip', '@(ticket.Equipamento?.Name?.Replace("'","\\'"))', '@(ticket.Equipamento?.SerialNumber ??"S/N N/A")')">
                                        <i class="ri-qr-code-line"></i>
                                    </button>
                                    </td>
                                </tr>
                            }
                        } else {
                            <tr>
                                <td colspan="5" class="text-center py-5  -50" style="color: var(--bs-heading-color) !important;">Sem tickets recentes a reportar.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>



<!-- Map Row -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card map-card h-100">
            <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3"><i class='bx bx-map-pin' style="color:#f89223;"></i> Localização da Empresa</div>
            <div class="card-body p-0"><div id="clientMap" style="height: 400px; width: 100%; border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;"></div></div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // ===== Evolution Ticket Chart =====
    const ticketCtx = document.getElementById('monthlyTicketChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels)),
            datasets: [{
                label: 'Tickets por Mês',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData)),
                borderColor: '#696cff',
                backgroundColor: 'rgba(105, 108, 255, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { 
                    beginAtZero: true, 
                    suggestedMax: 5,
                    ticks: { stepSize: 1, precision: 0 } 
                },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== Overview Chart =====
    const overviewCtx = document.getElementById('overviewChart').getContext('2d');
    new Chart(overviewCtx, {
        type: 'bar',
        data: {
            labels: ['Tickets', 'Stock'],
            datasets: [{
                label: 'Total',
                data: [@Model.PendingTicketsCount, @Model.LowStockAlertsCount],
                backgroundColor: ['#ff3e1d', '#f89223'],
                borderRadius: 8,
                maxBarThickness: 50
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { 
                    beginAtZero: true, 
                    suggestedMax: 5,
                    ticks: { stepSize: 1, precision: 0 } 
                },
                x: { grid: { display: false } }
            }
        }
    });
</script>
<partial name="Shared/_QrModal" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        initMap();
    });

    async function initMap() {
        // Default center: Braga
        var map = L.map('clientMap').setView([41.5454, -8.4265], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw) {
            var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
            
            for (let i = 0; i < locations.length; i++) {
                const loc = locations[i];
                if (loc.address) {
                    try {
                        const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(loc.address +", Portugal")}`);
                        const data = await response.json();
                        
                        if (data && data.length > 0) {
                            const result = data[0];
                            const latLng = [result.lat, result.lon];
                            L.marker(latLng)
                             .addTo(map)
                             .bindPopup(`<b>${loc.name}</b><br>${loc.address}`);
                            
                            if (i === 0) map.setView(latLng, 14); // Center on first location (usually the main company)
                        }
                    } catch (error) {
                        console.error('Geocoding error:', error);
                    }
                    if (locations.length > 1) await new Promise(resolve => setTimeout(resolve, 1000));
                }
            }
        }
    }
</script>


}





