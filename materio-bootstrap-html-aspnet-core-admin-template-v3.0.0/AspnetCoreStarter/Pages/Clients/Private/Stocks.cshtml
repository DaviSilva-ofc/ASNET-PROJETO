@page
@model AspnetCoreStarter.Pages.Clients.Private.PrivateStocksModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Stock";
}

@section PageStyles {
<style>
    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: #2b2c40 !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .dark-style h4, .dark-style h6, .dark-style h5,
    [data-bs-theme="dark"] h4, [data-bs-theme="dark"] h6, [data-bs-theme="dark"] h5 {
        color: #f5f5f9 !important;
    }

    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    .dark-style .bg-label-primary, [data-bs-theme="dark"] .bg-label-primary { background-color: rgba(105, 108, 255, 0.25) !important; color: #8592ff !important; }
    .dark-style .bg-label-success, [data-bs-theme="dark"] .bg-label-success { background-color: rgba(113, 221, 55, 0.25) !important; color: #71dd37 !important; }
    .dark-style .bg-label-warning, [data-bs-theme="dark"] .bg-label-warning { background-color: rgba(255, 171, 0, 0.25) !important; color: #ffab00 !important; }
    .dark-style .bg-label-info, [data-bs-theme="dark"] .bg-label-info { background-color: rgba(3, 195, 236, 0.25) !important; color: #03c3ec !important; }

    .dark-style .table th, [data-bs-theme="dark"] .table th { color: #cbcbe2 !important; }
    .dark-style .table td, [data-bs-theme="dark"] .table td { color: #a1acb8 !important; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    @if (!string.IsNullOrEmpty(Request.Query["success"]))
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center mb-4" role="alert">
            <i class="ri-checkbox-circle-line me-2"></i>
            <div>@Request.Query["success"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Cliente /</span> Stock Empresa</h4>
    </div>

    @{
        var hasAnyFilter = Model.FilterSalaId.HasValue ||
                          !string.IsNullOrEmpty(Model.FilterArticle) || !string.IsNullOrEmpty(Model.FilterType) ||
                          !string.IsNullOrEmpty(Model.FilterStatus);
    }

    <div class="row">
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="avatar me-2">
                            <span class="avatar-initial rounded bg-label-primary"><i class="ri-building-line"></i></span>
                        </div>
                        <h6 class="mb-0">Acessos da Empresa</h6>
                    </div>
                    <h4 class="ms-1 mb-1">@(Model.Empresa?.Name ?? "Empresa")</h4>
                    <p class="text-muted small mb-0">Ativo</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="avatar me-2">
                            <span class="avatar-initial rounded bg-label-success"><i class="ri-door-open-line"></i></span>
                        </div>
                        <h6 class="mb-0">Salas/Departamentos</h6>
                    </div>
                    <h4 class="ms-1 mb-1">@Model.CountSalas</h4>
                    <p class="text-muted small mb-0">Total mapeado para a empresa</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="avatar me-2">
                            <span class="avatar-initial rounded bg-label-warning"><i class="ri-computer-line"></i></span>
                        </div>
                        <h6 class="mb-0">Inventário Total</h6>
                    </div>
                    <h4 class="ms-1 mb-1">@Model.CountEquipamentos</h4>
                    <p class="text-muted small mb-0">Total de itens registados na conta</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="avatar me-2">
                            <span class="avatar-initial rounded bg-label-info"><i class="ri-ticket-2-line"></i></span>
                        </div>
                        <h6 class="mb-0">Histórico/Tickets</h6>
                    </div>
                    <h4 class="ms-1 mb-1">@Model.CountTickets</h4>
                    <p class="text-muted small mb-0">Intervenções de manutenção</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Navigation Actions ===== -->
    <div class="d-flex justify-content-end align-items-center gap-3 mb-4">
        <button type="button" class="btn btn-outline-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#modalFiltros">
            <i class="ri-filter-3-line me-1"></i> Filtros
        </button>
        <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNovoPedido">
            <i class="ri-add-line me-1"></i> Solicitar stock
        </button>
    </div>

    @if (hasAnyFilter)
    {
        <div class="alert alert-info d-flex justify-content-between align-items-center mb-4 shadow-sm" role="alert">
            <div class="d-flex align-items-center">
                <i class="ri-information-line me-2 ri-xl"></i>
                <div>
                    <span class="fw-semibold">Filtros ativos:</span>
                    <span class="small ms-1">
                        @{
                            var filtersList = new List<string>();
                            if (!string.IsNullOrEmpty(Model.FilterArticle)) filtersList.Add($"Artigo: {Model.FilterArticle}");
                            if (!string.IsNullOrEmpty(Model.FilterType)) filtersList.Add($"Tipo: {Model.FilterType}");
                            if (!string.IsNullOrEmpty(Model.FilterStatus)) filtersList.Add($"Estado: {Model.FilterStatus}");
                            if (Model.FilterSalaId.HasValue) filtersList.Add("Localização específica");
                            @Html.Raw(string.Join(", ", filtersList))
                        }
                    </span>
                </div>
            </div>
            <a asp-page="./Stocks" class="btn btn-sm btn-info border-1 border-white text-white">Limpar Filtros</a>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center border-bottom">
            <h5 class="mb-0">Mapa Global de Equipamentos da Empresa</h5>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead class="table-light text-uppercase small fw-bold">
                    <tr>
                        <th>Artigo</th>
                        <th>Categoria/Tipo</th>
                        <th>Localização</th>
                        <th>Quantidade</th>
                        <th>Estado</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bx bx-package fs-1 text-muted mb-2"></i>
                                <p class="mb-0">Nenhum equipamento listado para os filtros apresentados.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td><span class="fw-bold text-heading">@item.Name</span></td>
                                <td><span class="badge bg-label-secondary">@item.Category</span></td>
                                <td>@item.Location</td>
                                <td>
                                    <span class="fw-semibold">@item.Quantity</span> unidade(s)
                                </td>
                                <td>
                                    @if (item.Status != null && item.Status.Trim().Equals("A funcionar", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-label-success">A funcionar</span>
                                    }
                                    else if (item.Status != null && item.Status.Trim().Equals("Armazenado", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-label-info">Stock de Reserva</span>
                                    }
                                    else if (item.Status != null && (item.Status.Trim().Equals("Avariado", StringComparison.OrdinalIgnoreCase) ||
                                             item.Status.Trim().Equals("Indisponível", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <span class="badge bg-label-danger">Avariado</span>
                                    }
                                    else if (item.Status != null && item.Status.Trim().Equals("Em reparo", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-label-warning">Instalação/Reparo</span>
                                    }
                                    else if (item.Status != null && item.Status.Trim().Equals("Emprestado", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-label-primary">Emprestado</span>
                                    }
                                    else if (item.Status != null && item.Status.Trim().Equals("Associado", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-label-warning">Associado (Em Intervenção)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary">@item.Status</span>
                                    }
                                </td>
                                <td class="text-center px-3" style="width: 1px; white-space: nowrap;">
                                    <button type="button" class="btn btn-sm btn-icon text-info p-0" 
                                            onclick="showQRCode('@item.IdWithPrefix', 'stock', '@item.Name.Replace("'", "\\'")', '@item.Location.Replace("'", "\\'")')" 
                                            title="Código QR">
                                        <i class="ri-qr-code-line"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Artigos Emprestados Card -->
    <div class="card shadow-sm mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Artigos Emprestados</h5>
            <span class="badge bg-label-primary">@Model.BorrowedItems.Count artigo(s)</span>
        </div>
        <div class="table-responsive text-nowrap">
            @if (!Model.BorrowedItems.Any())
            {
                <div class="text-center py-4 text-muted">
                    <p class="mb-0">Não existem artigos emprestados no momento.</p>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light text-uppercase small fw-bold">
                        <tr>
                            <th>Artigo</th>
                            <th>Categoria/Tipo</th>
                            <th>Localização</th>
                            <th>Quantidade</th>
                            <th>Estado</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.BorrowedItems)
                        {
                            <tr>
                                <td><span class="fw-bold text-heading">@item.Name</span></td>
                                <td><span class="badge bg-label-secondary">@item.Category</span></td>
                                <td>@item.Location</td>
                                <td><span class="fw-semibold">@item.Quantity</span> unidade(s)</td>
                                <td><span class="badge bg-label-primary">@item.Status</span></td>
                                <td class="text-center px-3" style="width: 1px; white-space: nowrap;">
                                    <div class="d-flex align-items-center gap-2 justify-content-center">
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-info" 
                                                onclick="showQRCode('@item.IdWithPrefix', 'stock', '@item.Name.Replace("'", "\\'")', '@item.Location.Replace("'", "\\'")')" 
                                                title="Código QR">
                                            <i class="ri-qr-code-line"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-warning"
                                                onclick="openReturnLoanModal('@Uri.EscapeDataString(item.Name ?? "")', @item.Id, @item.Quantity)"
                                                title="Devolver Empréstimo">
                                            <i class="ri-arrow-go-back-line"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Meus Pedidos de Stock Card -->
    <div class="card shadow-sm mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Meus Pedidos de Stock</h5>
            <span class="badge bg-label-primary">@Model.MyRequests.Count pedido(s)</span>
        </div>
        <div class="table-responsive text-nowrap">
            @if (!Model.MyRequests.Any())
            {
                <div class="text-center py-4 text-muted">
                    <p class="mb-0">Ainda não efetuou nenhum pedido de stock.</p>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light text-uppercase small fw-bold">
                        <tr>
                            <th>Data</th>
                            <th>Artigo</th>
                            <th>Quantidade</th>
                            <th>Observações</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model.MyRequests)
                        {
                            <tr>
                                <td>@req.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="fw-bold text-heading">@req.ItemName</span> <small class="text-muted">(@req.ItemType)</small></td>
                                <td>@req.Quantity</td>
                                <td><small class="fst-italic text-muted">@(string.IsNullOrWhiteSpace(req.Notes) ? "Sem notas adicionais" : req.Notes)</small></td>
                                <td>
                                    @if (req.Status == "Pendente_Admin")
                                    {
                                        <span class="badge bg-label-warning">Pendente Admin</span>
                                    }
                                    else if (req.Status == "Atendido")
                                    {
                                        <span class="badge bg-label-success">Atendido</span>
                                    }
                                    else if (req.Status == "Recusado")
                                    {
                                        <span class="badge bg-label-danger">Recusado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary">@req.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>


    <!-- Modal Filtros -->
    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="get" class="modal-content">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title">Filtrar Inventário</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Artigo</label>
                            <select id="filterArtigo" asp-for="FilterArticle" class="form-select" onchange="filterTypesByArtigo()">
                                <option value="">Todos os artigos</option>
                                <option value="Computador">Computadores/Desktops</option>
                                <option value="Monitor">Monitores</option>
                                <option value="Impressora">Impressoras</option>
                                <option value="Projetor">Projetores</option>
                                <option value="Networking">Networking (Switches, Routers)</option>
                                <option value="Componente">Servidores/Componentes</option>
                                <option value="Periférico">Acessórios/Periféricos</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Categoria</label>
                            <select id="filterTipo" asp-for="FilterType" class="form-select">
                                <option value="">Todas as categorias</option>
                                <option value="Desktop" data-art="Computador">Desktop</option>
                                <option value="Portátil" data-art="Computador">Portátil</option>
                                <option value="Monitor" data-art="Monitor">Monitor</option>
                                <option value="Teclado" data-art="Periférico">Teclado</option>
                                <option value="Rato" data-art="Periférico">Rato</option>
                                <option value="Impressora" data-art="Impressora">Impressora</option>
                                <option value="Server" data-art="Componente">Servidor</option>
                                <option value="Router" data-art="Networking">Router</option>
                                <option value="Switch" data-art="Networking">Switch</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Localização Específica (Sala/Dpt)</label>
                            <select asp-for="FilterSalaId" class="form-select" id="filtSala">
                                <option value="">Qualquer localização</option>
                                @foreach (var sala in Model.AvailableRooms)
                                {
                                    <option value="@sala.Id">@sala.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold small text-uppercase mb-1">Situação / Estado</label>
                            <select asp-for="FilterStatus" class="form-select">
                                <option value="">Todos</option>
                                @foreach (var stat in Model.UniqueStatuses)
                                {
                                    <option value="@stat">@stat</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Aplicar Pesquisa</button>
                </div>
            </form>
        </div>
    </div>


    <!-- Modal Novo Pedido de Aquisição -->
    <div class="modal fade" id="modalNovoPedido" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="post" asp-page-handler="RequestStock" class="modal-content">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title">Submeter Proposta de Equipamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase">Artigo Principal</label>
                        <select name="NewRequestEquipmentName" id="newReqArtigo" class="form-select" required onchange="filterNewRequestTypes()">
                            <option value="">Selecione o artigo...</option>
                            <option value="Computador">Computadores/Desktops</option>
                            <option value="Monitor">Monitores</option>
                            <option value="Impressora">Impressoras</option>
                            <option value="Projetor">Projetores</option>
                            <option value="Networking">Networking (Switches, Routers)</option>
                            <option value="Componente">Servidores/Componentes</option>
                            <option value="Periférico">Acessórios/Periféricos</option>
                            <option value="Outro">Outro...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase">Categoria / Especulação</label>
                        <select name="NewRequestItemType" id="newReqTipo" class="form-select" required>
                            <option value="">Selecione o tipo...</option>
                            <option value="Desktop" data-reqart="Computador">Desktop</option>
                            <option value="Portátil" data-reqart="Computador">Portátil</option>
                            <option value="Monitor" data-reqart="Monitor">Monitor</option>
                            <option value="Teclado" data-reqart="Periférico">Teclado</option>
                            <option value="Rato" data-reqart="Periférico">Rato</option>
                            <option value="Impressora" data-reqart="Impressora">Impressora</option>
                            <option value="Projetor" data-reqart="Projetor">Projetor</option>
                            <option value="Router" data-reqart="Networking">Router</option>
                            <option value="Switch" data-reqart="Networking">Switch</option>
                            <option value="Server" data-reqart="Componente">Servidor</option>
                            <option value="Outro..." data-reqart="Outro">Especifique nas notas</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase">Quantidade</label>
                        <input type="number" asp-for="NewRequestQuantity" class="form-control" value="1" min="1" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase">Justificação/Necessidade</label>
                        <textarea asp-for="NewRequestReason" class="form-control" rows="4" placeholder="Descreva tecnicamente ou funcionalmente porque necessita deste reforço de stock para a sua empresa..." required></textarea>
                        <div class="form-text">A ASNET receberá este ticket e entrará em contacto para prosseguir com a emissão do pedido.</div>
                    </div>
                </div>
                <div class="modal-footer border-top bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="ri-send-plane-line me-1"></i> Submeter à ASNET</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Devolver Empréstimo -->
    <div class="modal fade" id="modalReturnLoan" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <form method="post" asp-page-handler="ReturnLoan" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="ri-arrow-go-back-line me-2"></i>Devolver Empréstimo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="sampleId" id="returnSampleId" />
                    
                    <div class="alert alert-warning mb-3">
                        Deseja notificar a ASNET e disponibilizar este material para a sua recolha?
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Artigo</label>
                        <input type="text" id="returnItemNameDisplay" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantidade a Devolver</label>
                        <input type="number" name="quantity" id="returnQuantityInput" class="form-control" min="1" value="1" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Devolver ao Admin</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function filterTypesByArtigo() {
        const artName = document.getElementById('filterArtigo').value;
        const tipoSelect = document.getElementById('filterTipo');
        const options = tipoSelect.querySelectorAll('option');

        tipoSelect.value = "";

        options.forEach(opt => {
            if (opt.value === "") return;

            const artData = opt.getAttribute('data-art');
            if (artName === "" || artData === artName) {
                opt.style.display = "";
            } else {
                opt.style.display = "none";
            }
        });
    }

    // Inicializar no carregamento caso haja valor no artigo
    document.addEventListener("DOMContentLoaded", function() {
        if (document.getElementById('filterArtigo').value !== "") {
            filterTypesByArtigo();
            // Repor o valor do tipo que foi recebido do backend
            var selTipo = '@Model.FilterType';
            if (selTipo) document.getElementById('filterTipo').value = selTipo;
        }
    });

    function filterNewRequestTypes() {
        const artName = document.getElementById('newReqArtigo').value;
        const tipoSelect = document.getElementById('newReqTipo');
        const options = tipoSelect.querySelectorAll('option');

        tipoSelect.value = "";

        options.forEach(opt => {
            if (opt.value === "") return;

            const artData = opt.getAttribute('data-reqart');
            if (artName === "" || artData === artName) {
                opt.style.display = "";
            } else {
                opt.style.display = "none";
            }
        });
    }

    function openReturnLoanModal(encodedName, sampleId, maxQtd) {
        document.getElementById('returnSampleId').value = sampleId;
        document.getElementById('returnItemNameDisplay').value = decodeURIComponent(encodedName);
        
        const qInput = document.getElementById('returnQuantityInput');
        qInput.max = maxQtd;
        qInput.value = maxQtd;

        new bootstrap.Modal(document.getElementById('modalReturnLoan')).show();
    }
</script>
<partial name="Shared/_QrModal" />
}
