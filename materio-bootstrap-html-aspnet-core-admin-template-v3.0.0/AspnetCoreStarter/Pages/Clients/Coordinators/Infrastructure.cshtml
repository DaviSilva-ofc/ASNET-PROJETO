@page
@model AspnetCoreStarter.Pages.Clients.Coordinators.CoordinatorInfrastructureModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Infraestrutura da Unidade";
}

@section PageStyles {
<style>
    /* Theme Parity with Admin Infrastructure */
    .dark-style .card-header h5,
    [data-bs-theme="dark"] .card-header h5 { color: var(--bs-heading-color) !important; }

    .dark-style .list-group-item,
    [data-bs-theme="dark"] .list-group-item {
        background-color: transparent;
        color: #cbcbe2;
        border-color: rgba(255,255,255,0.1);
    }

    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: var(--tk-card-solid) !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .bg-light-section {
        background-color: rgba(67, 89, 113, 0.02);
        transition: all 0.3s ease;
        border-radius: 8px;
    }
    .dark-style .bg-light-section,
    [data-bs-theme="dark"] .bg-light-section {
        background-color: rgba(255, 255, 255, 0.03);
    }

    .bg-light-section:hover {
        background-color: rgba(67, 89, 113, 0.05);
    }

    .infra-tree .tree-node {
        position: relative;
        padding: 4px 0;
    }

    .tree-node i {
        font-size: 1.1rem;
        vertical-align: middle;
        opacity: 0.8;
    }

    .cursor-pointer { cursor: pointer; }

    /* Animation for arrows */
    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold;
        color: var(--bs-primary);
        font-size: 1.4rem;
        display: inline-block;
        line-height: 1;
        background-color: rgba(105, 108, 255, 0.15);
        border: 1px solid rgba(105, 108, 255, 0.3);
        border-radius: 4px;
        padding: 4px;
        margin-right: 8px;
    }

    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: var(--bs-primary);
        color: var(--bs-heading-color);
    }

    .school-node { color: var(--bs-success); }
    .bloc-node { color: var(--bs-info); }
    .room-node { color: var(--bs-warning); }
    .director-node { color: #8592a3; }
    .equip-node { color: #a1acb8; }

    .dark-style .school-node { color: #71dd37; }
    .dark-style .bloc-node { color: #03c3ec; }
    .dark-style .room-node { color: #ffab00; }
    .dark-style .director-node { color: #e1e1e3; }
    .dark-style .equip-node { color: #707186; }

    .infra-header-orange {
        background-color: #f89223 !important;
        color: white !important;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-4 d-flex align-items-center justify-content-between">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Coordenador /</span> Infraestrutura</h4>
        <div class="d-flex gap-2">
             <a href="/Clients/Coordinators/Dashboard" class="btn btn-label-secondary">
                <i class="ri-arrow-left-line me-1"></i> Voltar ao Dashboard
            </a>
        </div>
    </div>

    @if (Model.MySchool != null)
    {
        <div class="col-12 mb-4">
            <div class="card shadow-sm border-0">
                <!-- Header Laranja Estilo Admin -->
                <div class="card-header infra-header-orange d-flex justify-content-between align-items-center cursor-pointer"
                     data-bs-toggle="collapse" data-bs-target="#school-@Model.MySchool.Id">
                    <div class="d-flex align-items-center">
                        <i class="ri-government-line fs-3 me-3"></i>
                        <h5 class="mb-0" style="color: var(--bs-heading-color) !important;">
                            <strong>@Model.MySchool.Name</strong>
                        </h5>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-white text-dark">@Model.MyBlocks.Count Blocos</span>
                        <i class="icon-base ri-arrow-down-s-line  fs-4 ms-2" style="color: var(--bs-heading-color) !important;"></i>
                    </div>
                </div>

                <div id="school-@Model.MySchool.Id" class="collapse show">
                    <div class="card-body pt-4">
                        <div class="row">
                            <!-- Coluna 1: Tickets -->
                            <div class="col-md-4 mb-3">
                                <div class="border rounded p-3 h-100 bg-light-section">
                                    <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                         data-bs-toggle="collapse" data-bs-target="#tickets-school">
                                        <h6 class="mb-0 fw-bold"><i class="ri-ticket-2-line me-2"></i>Tickets Ativos</h6>
                                        <i class="ri-arrow-down-s-line"></i>
                                    </div>
                                    <div id="tickets-school" class="collapse show">
                                        <h3 class="mb-1 text-primary">@Model.TicketCount</h3>
                                        <p class="text-muted small mb-2">Pedidos de suporte pendentes na escola</p>
                                        <a href="/Clients/Coordinators/Tickets" class="btn btn-sm btn-outline-primary w-100 mt-2">
                                            Gerir Tickets
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Coluna 2: Infraestrutura (Resumo) -->
                            <div class="col-md-4 mb-3">
                                <div class="border rounded p-3 h-100 bg-light-section">
                                    <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                         data-bs-toggle="collapse" data-bs-target="#stats-school">
                                        <h6 class="mb-0 fw-bold"><i class="ri-building-line me-2"></i>Recursos</h6>
                                        <i class="ri-arrow-down-s-line"></i>
                                    </div>
                                    <div id="stats-school" class="collapse show">
                                        <h3 class="mb-1 text-success">@Model.RoomCount</h3>
                                        <p class="text-muted small mb-2">Salas de aula e espaços registados</p>
                                        <a href="/Clients/Coordinators/Equipment" class="btn btn-sm btn-outline-success w-100 mt-2">
                                            Gerir Equipamentos
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Coluna 3: Árvore Hierárquica -->
                            <div class="col-md-4 mb-3">
                                <div class="border rounded p-3 h-100 bg-light-section">
                                    <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                         data-bs-toggle="collapse" data-bs-target="#tree-school">
                                        <h6 class="mb-0 fw-bold"><i class="ri-node-tree me-2"></i>Estrutura</h6>
                                        <i class="ri-arrow-down-s-line"></i>
                                    </div>
                                    <div id="tree-school" class="collapse show mt-3">
                                        <div class="infra-tree" style="max-height: 400px; overflow-y: auto;">
                                            <!-- Director Info -->
                                            <div class="tree-node director-node mb-2 d-flex align-items-center">
                                                <i class="ri-user-star-line me-2"></i> <strong>Diretor: @Model.DirectorName</strong>
                                            </div>
                                            
                                            <!-- School Node -->
                                            <div class="tree-node school-node">
                                                <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-content">
                                                    <i class="ri-arrow-right-s-line"></i>
                                                    <i class="ri-community-line me-1"></i> <strong>@Model.MySchool.Name</strong>
                                                </div>

                                                <div id="tree-content" class="collapse show">
                                                    @foreach (var bloco in Model.MyBlocks)
                                                    {
                                                        <div class="tree-node bloc-node ms-4 mt-2">
                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-bloc-@bloco.Id">
                                                                <i class="ri-arrow-right-s-line"></i>
                                                                <i class="ri-building-2-line me-1"></i> <strong>@bloco.Name</strong>
                                                                <span class="ms-2 text-muted small">(@bloco.Rooms.Count salas)</span>
                                                            </div>

                                                            <div id="tree-bloc-@bloco.Id" class="collapse">
                                                                @foreach (var sala in bloco.Rooms)
                                                                {
                                                                    <div class="tree-node room-node ms-4 mt-1">
                                                                        <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-room-@sala.Id">
                                                                            <i class="ri-arrow-right-s-line"></i>
                                                                            <i class="ri-door-open-line me-1"></i> @sala.Name
                                                                            <a href="/Clients/Coordinators/Equipment?FilterRoomId=@sala.Id" class="ms-auto btn btn-sm btn-icon text-muted" title="Listar Equipamentos">
                                                                                <i class="ri-search-line small"></i>
                                                                            </a>
                                                                        </div>

                                                                        <div id="tree-room-@sala.Id" class="collapse">
                                                                            @if (sala.Equipments != null && sala.Equipments.Any())
                                                                            {
                                                                                var groupedEquips = sala.Equipments
                                                                                    .GroupBy(e => e.Name)
                                                                                    .Select(g => new { Name = g.Key, Count = g.Count() })
                                                                                    .OrderBy(g => g.Name)
                                                                                    .ToList();

                                                                                @foreach (var group in groupedEquips)
                                                                                {
                                                                                    <div class="tree-node equip-node ms-4 mt-1 small">
                                                                                        <a href="/Clients/Coordinators/Equipment?FilterRoomId=@sala.Id&FilterName=@group.Name" 
                                                                                           class="text-secondary text-decoration-none d-flex align-items-center">
                                                                                            <i class="ri-computer-line me-2"></i> 
                                                                                            <span>@group.Name (@group.Count)</span>
                                                                                        </a>
                                                                                    </div>
                                                                                }
                                                                            }
                                                                            else
                                                                            {
                                                                                <div class="ms-4 mt-1 small text-muted italic" style="font-size: 0.8rem;">
                                                                                    <i class="ri-information-line me-1"></i> Sem equipamentos
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card p-5 text-center shadow-none border">
            <div class="avatar avatar-xl bg-label-secondary mx-auto mb-3">
                <i class="ri-error-warning-line fs-1"></i>
            </div>
            <h5>Escola não atribuída</h5>
            <p class="text-muted">Ainda não tem uma escola associada ao seu perfil de coordenador.</p>
        </div>
    }

    <!-- Help Alert -->
    <div class="alert alert-info d-flex align-items-center mt-4 border-0 shadow-sm" role="alert">
        <span class="alert-icon me-3 bg-info  p-2 rounded" style="color: var(--bs-heading-color) !important;">
            <i class="ri-question-line fs-4"></i>
        </span>
        <div>
            <strong>Dica de Navegação:</strong> O layout agora fornece uma visão consolidada da sua escola. Use os cartões à esquerda para métricas rápidas e a árvore à direita para navegar detalhadamente entre salas e inventário.
        </div>
    </div>
</div>



