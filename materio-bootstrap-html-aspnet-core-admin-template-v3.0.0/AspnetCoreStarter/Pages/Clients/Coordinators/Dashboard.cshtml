@page
@model AspnetCoreStarter.Pages.Clients.Coordinators.CoordinatorDashboardModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Dashboard Coordenador";
}

@section PageStyles {
<style>
    .stat-card { border: none; border-radius: 14px; overflow: hidden; transition: transform .2s, box-shadow .2s; }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(30,33,48,.12); }
    .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: #fff; }
    .dark-style .card, [data-bs-theme="dark"] .card { background-color: #2b2c40; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-4 d-flex align-items-center justify-content-between">
        <div>
            <h4 class="fw-bold mb-0"><span class="text-muted fw-light">Coordenador /</span> Dashboard</h4>
            @if (!string.IsNullOrEmpty(Model.SchoolName)) {
                <small class="text-muted"><i class="ri-building-line me-1"></i>@Model.SchoolName</small>
            }
        </div>
    </div>

    @* Stat Cards *@
    <div class="row g-4 mb-4">
        <div class="col-6 col-md-3">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary"><i class="ri-door-line"></i></div>
                    <div>
                        <div class="fs-4 fw-bold text-primary">@Model.TotalSalas</div>
                        <div class="text-muted small">Salas</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success"><i class="ri-computer-line"></i></div>
                    <div>
                        <div class="fs-4 fw-bold text-success">@Model.TotalEquipamentos</div>
                        <div class="text-muted small">Equipamentos</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-danger"><i class="ri-error-warning-line"></i></div>
                    <div>
                        <div class="fs-4 fw-bold text-danger">@Model.DamagedCount</div>
                        <div class="text-muted small">Avariados</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-warning"><i class="ri-ticket-line"></i></div>
                    <div>
                        <div class="fs-4 fw-bold text-warning">@Model.PendingTickets</div>
                        <div class="text-muted small">Tickets Pendentes</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Chart *@
        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header border-bottom pb-3">
                    <h5 class="mb-0"><i class="ri-bar-chart-2-line me-2 text-primary"></i>Tickets por Mês</h5>
                </div>
                <div class="card-body">
                    <canvas id="ticketChart" height="110"></canvas>
                </div>
            </div>
        </div>

        @* Quick Stats *@
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center">
                    <div class="fs-1 fw-bold text-info">@Model.TotalProfessores</div>
                    <div class="text-muted"><i class="ri-user-2-line me-1"></i>Professores na Escola</div>
                </div>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-header border-bottom pb-2">
                    <h6 class="mb-0"><i class="ri-chat-3-line me-2 text-primary"></i>Mensagens Não Lidas
                        @if (Model.TotalUnreadMessages > 0) {
                            <span class="badge bg-danger ms-2">@Model.TotalUnreadMessages</span>
                        }
                    </h6>
                </div>
                <div class="card-body p-2">
                    @if (Model.RecentSenders == null || !Model.RecentSenders.Any()) {
                        <div class="text-center text-muted py-3 small">Sem mensagens por ler</div>
                    } else {
                        @foreach (var s in Model.RecentSenders) {
                            <a asp-page="./Chat" asp-route-userId="@s.Id" class="d-flex align-items-center gap-2 p-2 rounded text-decoration-none hover-bg">
                                <div class="avatar avatar-sm bg-label-primary rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <span class="fw-bold" style="font-size:0.75rem;">@(s.Username?.Substring(0, 1).ToUpper())</span>
                                </div>
                                <span class="small fw-semibold">@s.Username</span>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    }
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('ticketChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels)),
            datasets: [{
                label: 'Tickets',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData)),
                borderColor: '#696cff',
                backgroundColor: 'rgba(105,108,255,0.12)',
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#696cff'
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
    });
</script>
}
