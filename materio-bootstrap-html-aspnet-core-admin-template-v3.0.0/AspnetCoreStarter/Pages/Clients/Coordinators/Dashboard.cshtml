@page
@model AspnetCoreStarter.Pages.Clients.Coordinators.CoordinatorDashboardModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Dashboard Coordenador";
}

@section PageStyles {
<style>
    :root {
        --asnet-navy: #1e2130;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
        
        /* Theme aware variables */
        --dash-card-bg: #fff;
        --dash-text: #566a7f;
        --dash-title: #566a7f;
        --dash-subtitle: #a1acb8;
        --dash-border: rgba(67, 89, 113, 0.1);
        --dash-shadow: 0 2px 6px 0 rgba(67, 89, 113, 0.12);
    }

    .dark-style, [data-bs-theme="dark"] {
        --dash-card-bg: #2b2e44;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-subtitle: #7071a4;
        --dash-border: rgba(255, 255, 255, 0.05);
        --dash-shadow: 0 4px 18px rgba(0,0,0,0.2);
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--dash-title);
    }

    .stat-card, .tree-card, .pending-card, .chart-card {
        background: var(--dash-card-bg) !important;
        border: none !important;
        border-radius: 16px !important;
        box-shadow: var(--dash-shadow) !important;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
    }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; color: var(--dash-title); }
    .stat-label  { font-size: .8rem; color: var(--dash-subtitle); margin: 0; }

    .chart-card .card-header, .tree-card .card-header {
        background: transparent !important;
        border-bottom: 1px solid var(--dash-border) !important;
        font-weight: 600;
        color: var(--dash-title);
    }

    .tree-tabs .nav-link {
        font-size: .85rem;
        padding: .45rem .9rem;
        border-radius: 8px !important;
        color: var(--dash-text);
        font-weight: 500;
    }
    .tree-tabs .nav-link.active {
        background: var(--asnet-blue);
        color: #fff;
    }

    .tree-list { list-style: none; padding-left: 0; }
    .tree-list ul {
        list-style: none;
        padding-left: 1.6rem;
        border-left: 1px solid var(--dash-border);
    }
    .tree-item { position: relative; padding: .35rem 0; color: var(--dash-text); }
    .tree-toggle { cursor: pointer; user-select: none; }

    .tree-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px; height: 26px;
        border-radius: 8px;
        font-size: .7rem;
        font-weight: 700;
        color: #fff;
        margin-right: .4rem;
    }
    .tree-badge-school { background: var(--asnet-green); }
    .tree-badge-bloco  { background: var(--asnet-teal); }
    .tree-badge-sala   { background: var(--asnet-orange); }

    .tree-label { font-weight: 500; font-size: .88rem; }
    .tree-children { display: none; }
    .tree-children.show { display: block; }

    .tree-toggle .tree-arrow {
        display: inline-block;
        width: 20px; height: 20px;
        text-align: center;
        line-height:20px;
        font-size: .65rem;
        color: var(--dash-text);
        background: var(--dash-border);
        border-radius: 6px;
        margin-left: .3rem;
        transition: transform .15s;
    }
    .tree-toggle.open .tree-arrow { transform: rotate(90deg); }

    .pending-big-number {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dash-title);
        line-height: 1;
    }
    .pending-subtitle { font-size: .85rem; color: var(--dash-subtitle); }

    .pending-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: rgba(var(--asnet-blue-rgb), 0.1);
        color: var(--asnet-blue);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem;
        font-weight: 600;
        margin-right: -8px;
        border: 2px solid var(--dash-card-bg);
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- Title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="dash-title mb-1">Coordenador / Dashboard</h4>
            <p class="text-muted mb-0">Escola: <span class="fw-bold text-primary">@Model.SchoolName</span></p>
        </div>
    </div>


    <!-- ===== Stat mini-cards ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--asnet-blue);">
                        <i class='bx bx-user-voice'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalProfessores</p>
                        <p class="stat-label">Professores</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ff3e1d;">
                        <i class='bx bx-support'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.PendingTicketsCount</p>
                        <p class="stat-label">Tickets pendentes</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#03c3ec;">
                        <i class='bx bx-door-open'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalSalas</p>
                        <p class="stat-label">Salas</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#fd7e14;">
                        <i class='bx bx-package'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.LowStockAlertsCount</p>
                        <p class="stat-label">Alertas de Stock</p>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <div class="row g-4 mb-4">

        <!-- Infrastructure Tree (Scoped to School) -->
        <div class="col-lg-4">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-blue);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <h5 class="mb-0">Infraestrutura</h5>
                </div>
                <div class="card-body" style="max-height:380px; overflow-y:auto;">
                    <ul class="tree-list">
                        @if (Model.MySchool != null)
                        {
                            <li class="tree-item">
                                <div class="tree-toggle open" onclick="toggleTree(this)">
                                    <span class="tree-badge tree-badge-school">@Model.Blocos?.Count</span>
                                    <span class="tree-label">@Model.MySchool.Name</span>
                                    <span class="tree-arrow">▶</span>
                                </div>
                                <ul class="tree-children show">
                                    @if (Model.Blocos != null)
                                    {
                                        @foreach (var bloco in Model.Blocos)
                                        {
                                            var blocoSalas = Model.Salas?.Where(s => s.BlockId == bloco.Id).ToList();
                                            <li class="tree-item">
                                                <div class="tree-toggle" onclick="toggleTree(this)">
                                                    <span class="tree-badge tree-badge-bloco">@blocoSalas?.Count</span>
                                                    <span class="tree-label">@bloco.Name</span>
                                                    @if (blocoSalas != null && blocoSalas.Any()) { <span class="tree-arrow">▶</span> }
                                                </div>
                                                @if (blocoSalas != null && blocoSalas.Any())
                                                {
                                                    <ul class="tree-children">
                                                        @foreach (var sala in blocoSalas)
                                                        {
                                                            <li class="tree-item px-2 py-1">
                                                                <span class="tree-badge tree-badge-sala"><i class='bx bx-door-open' style="font-size:.7rem;"></i></span>
                                                                <span class="tree-label">@sala.Name</span>
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                            </li>
                                        }
                                    }
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Chat Notifications Card -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid #71dd37;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:#71dd37;">
                                <i class='bx bx-chat'></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Mensagens</h6>
                        </div>
                        <p class="pending-big-number">@Model.TotalUnreadMessages<span style="font-size:1rem;color:#71dd37;"> novas</span></p>
                        <p class="pending-subtitle">mensagens no chat aguardam resposta</p>

                        @if (Model.RecentMessageSenders != null && Model.RecentMessageSenders.Any())
                        {
                            <div class="d-flex mt-3 mb-3">
                                @foreach (var u in Model.RecentMessageSenders)
                                {
                                    <div class="pending-avatar" style="width:32px;height:32px;border-radius:50%;background:rgba(113,221,55,0.1);color:#71dd37;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:600;margin-right:-8px;border:2px solid var(--dash-card-bg);" title="@u.Username">
                                        @(u.Username?.Substring(0, Math.Min(2, u.Username.Length)).ToUpper())
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <a href="/Clients/Coordinators/Chat" class="btn w-100" style="background:#71dd37;color:#fff;font-weight:600;">
                        <i class='bx bx-reply me-1'></i> Responder
                    </a>
                </div>
            </div>
        </div>

        <!-- Pedir Reparo (Support) -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid #ff4d4d;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:#ff4d4d;">
                                <i class='bx bx-wrench'></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Pedir Reparo</h6>
                        </div>
                        <p class="pending-big-number">Suporte</p>
                        <p class="pending-subtitle">Existem @Model.DamagedEquipmentCount equipamentos avariados na sua escola.</p>
                    </div>
                    <a href="/Clients/Coordinators/Tickets" class="btn w-100" style="background:#ff4d4d;color:#fff;font-weight:600;">
                        <i class='bx bx-plus-circle me-1'></i> Novo Pedido
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Low Stock Alerts Row ===== -->
    @if (Model.StockAlerts.Any())
    {
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card shadow-sm" style="border-left: 5px solid #ffab00;">
                    <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                        <div class="d-flex align-items-center gap-2">
                            <i class='bx bx-error text-warning' style="font-size: 1.5rem;"></i>
                            <h5 class="mb-0 fw-bold">Alertas de Stock Baixo</h5>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                            @foreach (var item in Model.StockAlerts)
                            {
                                <div class="col">
                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-label-secondary">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="stat-icon bg-warning" style="width: 32px; height: 32px; font-size: 1rem;">
                                                <i class='bx bx-box'></i>
                                            </div>
                                            <span class="fw-semibold">@item.Name</span>
                                        </div>
                                        <span class="badge bg-label-danger">@item.AvailableCount disponíveis</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ===== Charts Row ===== -->
    <div class="row g-4 mb-4">
        <!-- Monthly Ticket Comparison Chart -->
        <div class="col-lg-7">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-trending-up' style="color:var(--asnet-blue);"></i>
                    Comparação Mensal de Tickets
                </div>
                <div class="card-body">
                    <div style="height: 250px; position: relative;">
                        <canvas id="monthlyTicketChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <!-- System Overview -->
        <div class="col-lg-5">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-pie-chart-alt-2' style="color:var(--asnet-orange);"></i>
                    Visão Geral do Sistema
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div style="height: 250px; width: 100%; position: relative;">
                        <canvas id="overviewChart"></canvas>
                    </div>
                    <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                        <span><i class='bx bxs-circle' style="color:#ff3e1d;font-size:.6rem;"></i> Tickets</span>
                        <span><i class='bx bxs-circle' style="color:#f89223;font-size:.6rem;"></i> Stock</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Table (Tickets) -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header d-flex justify-content-between align-items-center p-4 border-bottom">
                    <h5 class="mb-0 fw-bold"><i class="bx bx-wrench me-2 text-info"></i>Tickets de Manutenção Recentes</h5>
                    <a href="/Clients/Coordinators/Tickets" class="btn btn-sm btn-outline-primary fw-bold">Ver todos</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-label-info">
                            <tr>
                                <th>TICKET</th>
                                <th>EQUIPAMENTO / SALA</th>
                                <th>TÉCNICO</th>
                                <th>DATA</th>
                                <th>ESTADO</th>
                                <th class="text-center">AÇÕES</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTickets != null && Model.RecentTickets.Any()) {
                                @foreach (var ticket in Model.RecentTickets.Take(3)) {
                                    <tr>
                                        <td><span class="badge bg-label-secondary">#@ticket.Id</span></td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold">@ticket.Equipamento?.Name</span>
                                                <small class="text-muted small">
                                                    @(ticket.Equipamento?.Brand ?? "Genérico") @(ticket.Equipamento?.Model ?? "")
                                                    @if (!string.IsNullOrEmpty(ticket.Equipamento?.SerialNumber))
                                                    {
                                                        <span class="ms-1">(S/N: @ticket.Equipamento.SerialNumber)</span>
                                                    }
                                                </small>
                                            </div>
                                            <small class="text-muted">@ticket.Equipamento?.Room?.Name</small>
                                        </td>
                                        <td>
                                            @if (ticket.Technician != null)
                                            {
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar avatar-xs me-2">
                                                        <span class="avatar-initial rounded-circle bg-label-primary" style="font-size: 0.6rem;">@(ticket.Technician.Username?.Substring(0, 1).ToUpper())</span>
                                                    </div>
                                                    <span class="fw-medium">@ticket.Technician.Username</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-warning small italic">A aguardar técnico...</span>
                                            }
                                        </td>
                                        <td class="text-muted">@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @{
                                                var statusLabel = ticket.Status switch {
                                                    "Pendente" or "Pedido" => "badge bg-label-warning",
                                                    "Em Reparação" or "EmResolução" or "Em andamento" => "badge bg-label-warning",
                                                    "Concluído" => "badge bg-label-success",
                                                    _ => "badge bg-label-secondary"
                                                };
                                                var statusDisplayName = (ticket.Status == "Pedido" || ticket.Status == "Pendente") ? "A aguardar" : ticket.Status;
                                            }
                                            <span class="@statusLabel text-uppercase" style="font-size: 0.65rem;">@statusDisplayName</span>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                                    onclick="showQRCode('@ticket.Equipamento?.Id', 'equip', '@(ticket.Equipamento?.Name?.Replace("'", "\\'"))', '@(ticket.Equipamento?.SerialNumber ?? "S/N N/A")')">
                                                <i class="ri-qr-code-line"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            } else {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">Sem tickets recentes a reportar.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>


    <!-- ===== My Requests Row ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-orange);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <h5 class="mb-0"><i class='bx bx-list-ul me-2'></i>Meus Pedidos de Stock</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Artigo</th>
                                    <th>Tipo</th>
                                    <th>Qtd</th>
                                    <th>Data</th>
                                    <th>Status</th>
                                    <th>Notas Diretor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.MyRequests == null || !Model.MyRequests.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Nenhum pedido realizado.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var r in Model.MyRequests)
                                    {
                                        <tr>
                                            <td><span class="fw-bold">@r.ItemName</span></td>
                                            <td><span class="badge bg-label-secondary">@r.ItemType</span></td>
                                            <td>@r.Quantity</td>
                                            <td style="font-size: 0.85rem;">@r.CreatedAt.ToString("g")</td>
                                            <td>
                                                @switch (r.Status)
                                                {
                                                    case "Pendente_Diretor":
                                                        <span class="badge bg-label-warning text-uppercase">Pendente (Diretor)</span>
                                                        break;
                                                    case "Pendente_Admin":
                                                        <span class="badge bg-label-info text-uppercase">Pendente (Admin)</span>
                                                        break;
                                                    case "Atendido":
                                                        <span class="badge bg-label-success text-uppercase">Atendido</span>
                                                        break;
                                                    case "Recusado":
                                                        <span class="badge bg-label-danger text-uppercase">Recusado</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-label-secondary text-uppercase">@r.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td><small>@(string.IsNullOrEmpty(r.DirectorNotes) ? "-" : r.DirectorNotes)</small></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Solicitar Stock -->
    <div class="modal fade" id="modalRequestStock" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post" asp-page-handler="RequestStock">
                    <div class="modal-header bg-primary py-3">
                        <h5 class="modal-title text-white fw-bold"><i class='bx bx-package me-2'></i>Solicitar Novo Equipamento</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold">Artigo / Nome</label>
                                <input type="text" name="itemName" class="form-control" placeholder="Ex: Portátil, Rato, Monitor..." required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tipo</label>
                                <select name="itemType" class="form-select">
                                    <option value="Portátil">Portátil</option>
                                    <option value="Desktop">Desktop</option>
                                    <option value="Monitor">Monitor</option>
                                    <option value="Rato/Teclado">Rato/Teclado</option>
                                    <option value="Impressora">Impressora</option>
                                    <option value="Cabos/Adaptadores">Cabos/Adaptadores</option>
                                    <option value="Outros">Outros</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Quantidade</label>
                                <input type="number" name="quantity" class="form-control" value="1" min="1" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Notas Adicionais (Justificação)</label>
                                <textarea name="notes" class="form-control" rows="3" placeholder="Porquê precisa deste equipamento?"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Enviar Pedido</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    function toggleTree(el) {
        el.classList.toggle('open');
        var children = el.parentElement.querySelector('.tree-children');
        if (children) children.classList.toggle('show');
    }

    // ===== Monthly Ticket Chart =====
    const ticketCtx = document.getElementById('monthlyTicketChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels)),
            datasets: [{
                label: 'Número de Tickets',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData)),
                backgroundColor: '#696cff',
                borderRadius: 6,
                maxBarThickness: 40
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== System Overview Chart (Bar) =====
    const overviewCtx = document.getElementById('overviewChart').getContext('2d');
    new Chart(overviewCtx, {
        type: 'bar',
        data: {
            labels: ['Tickets', 'Stock'],
            datasets: [{
                label: 'Total',
                data: [@Model.PendingTicketsCount, @Model.LowStockAlertsCount],
                backgroundColor: ['#ff3e1d', '#f89223'],
                borderRadius: 8,
                maxBarThickness: 50
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });
</script>
<partial name="Shared/_QrModal" />
}
