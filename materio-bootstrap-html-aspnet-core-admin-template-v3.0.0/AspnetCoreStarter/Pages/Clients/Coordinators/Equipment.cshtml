    // Filter select options by search input or selected article
    function filterSelect(input, selectId) {
        var filterText = (input ? input.value : "").toLowerCase().trim();
        var select = document.getElementById(selectId);
        if (!select) return;
        
        var options = select.querySelectorAll('option');
        
        var currentArtigo = null;
        if (selectId === 'regTipo' || selectId === 'reqEqTipo') {
            currentArtigo = document.getElementById(selectId.replace('Tipo', 'Artigo')).value.toLowerCase().trim();
        } else if (selectId === 'editTipo') {
            currentArtigo = document.getElementById('editArtigo').value.toLowerCase().trim();
        } else if (selectId === 'filterTipo') {
            currentArtigo = document.getElementById('filterArtigo').value.toLowerCase().trim();
        }

        options.forEach(function(opt) {
            if (opt.value === "") return;
            var text = opt.textContent.toLowerCase();
            var matchesSearch = filterText === "" || text.includes(filterText);
            
            var matchesArtigo = true;
            if (currentArtigo && currentArtigo !== "") {
                var targetArtigo = (opt.getAttribute('data-artigo') || opt.getAttribute('data-art') || "").toLowerCase().trim();
                matchesArtigo = (targetArtigo === currentArtigo);
            }

            opt.style.display = (matchesSearch && matchesArtigo) ? '' : 'none';
        });
    }

    function updateFilterTypes() {
        const select = document.getElementById('filterTipo');
        select.value = "";
        filterSelect(null, 'filterTipo');
    }

    function updateSpecificTypes(prefix = 'reg') {
        const tipoSelect = document.getElementById(prefix + 'Tipo');
        if (!tipoSelect) return;
        tipoSelect.value = "";
        
        // Trigger filterSelect to update display based on BOTH artigo AND any current search
        const wrapper = tipoSelect.closest('.select-search-wrapper');
        const searchInput = wrapper ? wrapper.querySelector('.select-search-input') : null;
        filterSelect(searchInput, prefix + 'Tipo');
    }

    function updateBrandsModels(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const marcaSelect = document.getElementById(prefix + 'Marca');
        const modeloSelect = document.getElementById(prefix + 'Modelo');
        const tipoSelect = document.getElementById(prefix + 'Tipo');
        
        if (marcaSelect) marcaSelect.innerHTML = '<option value="">Selecione...</option>';
        if (modeloSelect) modeloSelect.innerHTML = '<option value="">Selecione a marca primeiro...</option>';

        // Filter specific types in the dropdown
        if (tipoSelect) {
            filterSelect(null, prefix + 'Tipo');
        }

        if (artigo && brandModelData[artigo]) {
            Object.keys(brandModelData[artigo]).forEach(m => marcaSelect.add(new Option(m, m)));
        }
    }

    function updateModels(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const marca = document.getElementById(prefix + 'Marca').value;
        const modeloSelect = document.getElementById(prefix + 'Modelo');
        modeloSelect.innerHTML = '<option value="">Selecione...</option>';

        if (artigo && marca && brandModelData[artigo][marca]) {
            brandModelData[artigo][marca].forEach(m => modeloSelect.add(new Option(m, m)));
        }
    }

    function regFilterSalas() {
        const blcId = document.getElementById('regBloco').value;
        const salaSelect = document.getElementById('regSala');
        Array.from(salaSelect.options).forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = opt.getAttribute('data-blc') === blcId ? 'block' : 'none';
        });
        salaSelect.value = "";
    }


    function openEditModal(id, name, type, brand, model, serial, roomId) {
        document.getElementById('editId').value = id;
        
        // Set Artigo with normalization
        const artSelect = document.getElementById('editArtigo');
        const cleanName = (name || '').toLowerCase().trim();
        
        // Try to find a matching option (case insensitive)
        let matchingOpt = Array.from(artSelect.options).find(o => o.value.toLowerCase().trim() === cleanName);
        
        // Specific normalization rules
        if (!matchingOpt) {
            if (cleanName === 'computador') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Computadores');
            else if (cleanName === 'monitor' || cleanName === 'televisão' || cleanName === 'tv') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Monitores');
            else if (cleanName === 'impressora') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Impressoras');
            else if (cleanName === 'componente') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Componentes');
            else if (cleanName === 'periférico' || cleanName === 'rato' || cleanName === 'teclado') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Periféricos');
            else if (cleanName === 'projetor') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Projetores');
            else if (cleanName.includes('quadro') || cleanName.includes('board')) matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Quadros Interativos');
        }

        if (matchingOpt) {
            artSelect.value = matchingOpt.value;
        } else {
            artSelect.value = 'Outros'; 
        }

        // Trigger updates
        updateBrandsModels('edit');
        updateSpecificTypes('edit');

        // Set Marca and trigger models update
        const marcaSelect = document.getElementById('editMarca');
        marcaSelect.value = brand;
        updateModels('edit');

        // Set others
        document.getElementById('editModelo').value = model;
        
        // Set type (Tipo Específico)
        const tipoSelect = document.getElementById('editTipo');
        const cleanType = (type || '').toLowerCase().trim();
        let matchedType = Array.from(tipoSelect.options).find(o => o.value.toLowerCase().trim() === cleanType);
        if (matchedType) {
            tipoSelect.value = matchedType.value;
        } else {
            tipoSelect.value = type || ""; 
        }

        document.getElementById('editSerial').value = serial;
        document.getElementById('editSala').value = roomId;

        var modal = new bootstrap.Modal(document.getElementById('modalEditarEquipamento'));
        modal.show();
    }

    function filterSalas(resetValue = true) {
        const blcId = document.getElementById('filterBloco').value;
        const salaSelect = document.getElementById('filterSala');
        const options = salaSelect.querySelectorAll('option');

        if (resetValue) salaSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (blcId === "" || opt.getAttribute('data-blc') === blcId) ? 'block' : 'none';
        });
    }

    // Ensure filters are applied on load
    document.addEventListener('DOMContentLoaded', function() {
        if (document.getElementById('filterBloco').value !== "") {
            filterSalas(false); 
        }
        if (document.getElementById('filterArtigo').value !== "") {
            updateFilterTypes();
        }
    });

    function filterReqEqTypes() {
        filterSelect(null, 'reqEqTipo');
    }
</script>
}

