@page
@model AspnetCoreStarter.Pages.Clients.Coordinators.CoordinatorEquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Equipamentos";
}

@section PageStyles {
<style>
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Coordenador /</span> Equipamentos</h4>

    <!-- Navegação por Abas -->
    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-inventario">
                    Inventário Geral
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-devolucoes">
                    Pedidos e Devoluções
                </button>
            </li>
        </ul>
        <div class="tab-content" style="background: transparent; padding: 0; box-shadow: none;">
        <!-- Aba Inventário -->
        <div class="tab-pane fade show active" id="tab-inventario" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Inventário de Equipamentos</h5>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                            <i class="bx bx-filter me-1"></i> Filtros
                        </button>
                        <button class="btn btn-warning text-white" data-bs-toggle="modal" data-bs-target="#modalRequisitarEq">
                            <i class="bx bx-hand me-1"></i> Requisitar Equipamento
                        </button>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNovoEquipamento">
                            <i class="bx bx-plus me-1"></i> Novo Equipamento
                        </button>
                    </div>
                </div>

        @{
            var activeFilterText = "";
            if (Model.ActiveFilterRoom != null) activeFilterText = $"sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) activeFilterText = $"bloco: {Model.ActiveFilterBloco.Name}";
            else if (!string.IsNullOrEmpty(Model.FilterName)) activeFilterText = $"artigo: {Model.FilterName}";
            else if (!string.IsNullOrEmpty(Model.FilterType)) activeFilterText = $"tipo: {Model.FilterType}";
            else if (!string.IsNullOrEmpty(Model.FilterSerialNumber)) activeFilterText = $"série: {Model.FilterSerialNumber}";
        }

        @if (!string.IsNullOrEmpty(activeFilterText) || !string.IsNullOrEmpty(Model.FilterStatus))
        {
            <div class="card-body">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert">
                    <span>A visualizar equipamentos do <strong>@activeFilterText</strong></span>
                    @if (!string.IsNullOrEmpty(Model.FilterStatus))
                    {
                        <span class="badge bg-label-info me-1">Status: @Model.FilterStatus</span>
                    }
                    <a asp-page="./Equipment" class="btn btn-sm btn-outline-secondary ms-2">Limpar Tudo</a>
                </div>
            </div>
        }

                <div class="table-responsive text-nowrap">
                    <table class="table table-hover">
                        <thead class="bg-light bg-opacity-10">
                            <tr>
                                <th>Artigo</th>
                                <th>Tipo</th>
                                <th>Nº Série</th>
                                <th>Localização</th>
                                <th style="width: 1%; white-space: nowrap;">Estado</th>
                                <th style="width: 1%; white-space: nowrap;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Equipments)
                            {
                                <tr class="border-light border-opacity-10">
                                    <td>
                                        <div class="d-flex flex-column">
                                            <strong class="text-white">@item.Name</strong>
                                            <small class="text-white-50" style="font-size: 0.75rem;">
                                                @(item.Brand ?? "Genérico") @(item.Model ?? "")
                                            </small>
                                        </div>
                                    </td>
                                    <td class="text-white-50">@item.Type</td>
                                    <td><span class="badge bg-label-secondary border-light border-opacity-10">@item.SerialNumber</span></td>
                                    <td>
                                        @if (item.Room != null)
                                        {
                                            <div class="d-flex flex-column">
                                                <span class="fw-semibold">@item.Room.Name (@item.Room.Block?.Name)</span>
                                                <small class="text-muted">@item.Room.Block?.School?.Name</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td style="width: 1%; white-space: nowrap;">
                                        @if (item.Status != null && (item.Status.Trim().Equals("A funcionar", StringComparison.OrdinalIgnoreCase) || 
                                            item.Status.Trim().Equals("Disponível", StringComparison.OrdinalIgnoreCase) || 
                                            item.Status.Trim().Equals("A funcionar", StringComparison.OrdinalIgnoreCase) || 
                                            item.Status.Trim().Equals("Em uso", StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <span class="badge bg-label-success">A funcionar</span>
                                        }
                                        else if (item.Status != null && (item.Status.Trim().Equals("Avariado", StringComparison.OrdinalIgnoreCase) || 
                                                 item.Status.Trim().Equals("Indisponível", StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <span class="badge bg-label-danger">Avariado</span>
                                        }
                                        else if (item.Status != null && (item.Status.Trim().Equals("Em reparação", StringComparison.OrdinalIgnoreCase) || item.Status.Trim().Equals("Em Reparação", StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <span class="badge bg-label-warning">Em reparação</span>
                                        }
                                        else if (item.Status != null && item.Status.Trim().Equals("Associado", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-label-warning">Associado (Em Intervenção)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-label-secondary">@(item.Status ?? "Indefinido")</span>
                                        }
                                    </td>
                                    <td style="width: 1%; white-space: nowrap;">
                                        <div class="d-flex align-items-center gap-1">
                                            @if (item.Status == null || (!item.Status.Contains("repara", StringComparison.OrdinalIgnoreCase) && !item.Status.Contains("manutenção", StringComparison.OrdinalIgnoreCase)))
                                            {
                                                <a href="/Clients/Coordinators/Tickets?eqId=@item.Id" class="btn btn-sm btn-icon text-primary p-0" title="Solicitar Ticket">
                                                    <i class="ri-ticket-line"></i>
                                                </a>
                                            }
                                            
                                            <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                                @if (item.Status == "Avariado" || item.Status == "Indisponível" || item.Status == "Danificado")
                                                {
                                                    <button type="submit" class="btn btn-sm btn-icon text-success p-0" title="Marcar como A funcionar"><i class="ri-check-line"></i></button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-icon text-warning p-0" title="Marcar como Avariado"><i class="ri-error-warning-line"></i></button>
                                                }
                                            </form>

                                            <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                                    onclick="showQRCode('@item.Id', 'Equipamento', '@item.Name', '@(item.SerialNumber ?? "S/N N/A")')">
                                                <i class="ri-qr-code-line"></i>
                                            </button>

                                            <button type="button" class="btn btn-sm btn-icon text-primary p-0" title="Editar"
                                                    onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@item.Brand', '@item.Model', '@item.SerialNumber', '@item.RoomId')">
                                                <i class="ri-edit-line"></i>
                                            </button>

                                            <form method="post" asp-page-handler="DeleteEquipment" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?');" style="display:inline-block;">
                                                <button type="submit" class="btn btn-sm btn-icon text-danger p-0" title="Eliminar"><i class="ri-delete-bin-line"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-devolucoes" role="tabpanel">
            <!-- Seção de Pedidos Pendentes -->
            <div class="card shadow-sm mb-4">
                <div class="card-header border-bottom bg-label-warning py-3">
                    <h5 class="mb-0 text-dark"><i class="bx bx-time me-2"></i>Pedidos em Processamento</h5>
                </div>
                <div class="table-responsive text-nowrap">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Solicitante</th>
                                <th>Status</th>
                                <th>Data</th>
                                <th>Observações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.MyStockRequests.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">Nenhum pedido pendente para esta escola.</td>
                                </tr>
                            }
                            @foreach (var req in Model.MyStockRequests)
                            {
                                <tr class="border-light border-opacity-10">
                                    <td>
                                        @{
                                            var firstLine = req.Description?.Split('\n').FirstOrDefault() ?? "Pedido Stock";
                                            var cleanDesc = firstLine.Replace("PEDIDO DE EQUIPAMENTO", "").Replace("PEDIDO DE STOCK", "").Trim(':').Trim();
                                        }
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-white">#@req.Id - @cleanDesc</span>
                                            <small class="text-info">Empréstimo</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar avatar-xs me-2">
                                                <span class="avatar-initial rounded-circle bg-label-info">@req.RequestedBy?.Username?.Substring(0, 1).ToUpper()</span>
                                            </div>
                                            <span>@req.RequestedBy?.Username</span>
                                        </div>
                                    </td>
                                    <td>
                                        @{
                                            var stClass = req.Status switch {
                                                "Pedido" => "badge-soft-info",
                                                "Pendente" => "badge-soft-warning",
                                                "Atendido" or "Concluído" => "badge-soft-success",
                                                _ => "bg-label-secondary"
                                            };
                                        }
                                        <span class="badge @stClass">@req.Status</span>
                                    </td>
                                    <td class="text-white-50 small">@req.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-white-50 small text-truncate" style="max-width: 200px;">@req.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Seção de Itens na Posse -->
            <div class="card shadow-sm">
                <div class="card-header border-bottom">
                    <h5 class="mb-0">Os Meus Equipamentos (Na Posse)</h5>
                </div>
                <div class="table-responsive text-nowrap">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Equipamento</th>
                                <th>Tipo</th>
                                <th>Marca/Modelo</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.MyBorrowedItems.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">A escola não possui itens de stock central atualmente.</td>
                                </tr>
                            }
                            @foreach (var item in Model.MyBorrowedItems)
                            {
                                <tr class="border-light border-opacity-10 text-white-50">
                                    <td class="text-white fw-bold">@item.EquipmentName</td>
                                    <td>@item.Type</td>
                                    <td>@item.Description</td>
                                    <td>
                                        <form method="post" asp-page-handler="ReturnItem" asp-route-id="@item.Id">
                                            <button type="submit" class="btn btn-sm btn-label-warning">
                                                <i class="bx bx-undo me-1"></i> Devolver
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal Requisitar Equipamento *@
<div class="modal fade" id="modalRequisitarEq" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="CreateStockRequest" class="modal-content border-0" style="background: rgba(43, 44, 64, 0.9) !important; backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.1) !important; box-shadow: 0 8px 32px 0 rgba(0,0,0,0.37);">
            <div class="modal-header border-bottom border-light border-opacity-10">
                <h5 class="modal-title text-white"><i class="bx bx-hand me-2 text-warning"></i>Requisitar Equipamento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label text-white-50 small text-uppercase">Artigo</label>
                    <select name="itemName" id="reqEqArtigo" class="form-select bg-dark text-white border-light border-opacity-10" required onchange="filterReqEqTypes()">
                        <option value="">Selecione o artigo...</option>
                        <option value="Computador">Computadores</option>
                        <option value="Monitor">Monitores</option>
                        <option value="Impressora">Impressoras</option>
                        <option value="Projetor">Projetores</option>
                        <option value="Networking">Networking</option>
                        <option value="Componente">Componentes</option>
                        <option value="Periférico">Periféricos</option>
                        <option value="Quadro Interativo">Quadros Interativos</option>
                        <option value="Outro">Outros</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label text-white-50 small text-uppercase">Tipo</label>
                    <select name="itemType" id="reqEqTipo" class="form-select bg-dark text-white border-light border-opacity-10">
                        <option value="">Selecione o tipo...</option>
                        <option value="Desktop" data-artigo="Computadores">Desktop</option>
                        <option value="Portátil" data-artigo="Computadores">Portátil</option>
                        <option value="AIO" data-artigo="Computadores">AIO</option>
                        <option value="Monitor" data-artigo="Monitores">Monitor</option>
                        <option value="Televisão" data-artigo="Monitores">Televisão</option>
                        <option value="Impressora" data-artigo="Impressoras">Impressora</option>
                        <option value="Projetor" data-artigo="Projetores">Projetor</option>
                        <option value="Router" data-artigo="Networking">Router</option>
                        <option value="Switch" data-artigo="Networking">Switch</option>
                        <option value="Access Point" data-artigo="Networking">Access Point</option>
                        <option value="Motherboard" data-artigo="Componentes">Motherboard</option>
                        <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
                        <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
                        <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
                        <option value="Processador (CPU)" data-artigo="Componentes">Processador (CPU)</option>
                        <option value="Teclado" data-artigo="Periféricos">Teclado</option>
                        <option value="Rato" data-artigo="Periféricos">Rato</option>
                        <option value="Headphones" data-artigo="Periféricos">Headphones</option>
                        <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
                        <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
                        <option value="Outro" data-artigo="Outros">Outro</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label text-white-50 small text-uppercase">Quantidade</label>
                    <input type="number" name="quantity" class="form-control bg-dark text-white border-light border-opacity-10" value="1" min="1" required />
                </div>
                <div class="mb-3">
                    <label class="form-label text-white-50 small text-uppercase">Motivo do Pedido</label>
                    <textarea name="notes" class="form-control bg-dark text-white border-light border-opacity-10" rows="3" placeholder="Descreva a necessidade..." required></textarea>
                </div>
            </div>
            <div class="modal-footer border-top border-light border-opacity-10">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-warning text-dark fw-bold shadow-sm">Solicitar Equipamento</button>
            </div>
        </form>
    </div>
</div>

@* Modal Editar Equipamento *@
<div class="modal fade" id="modalEditarEquipamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form method="post" asp-page-handler="EditEquipment" class="modal-content border-0 shadow-lg" style="background: rgba(43, 44, 64, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.1) !important;">
            <input type="hidden" asp-for="NewEquipment.Id" id="editId" />
            <div class="modal-header border-bottom border-light border-opacity-10">
                <h5 class="modal-title text-white"><i class="bx bx-edit me-2 text-primary"></i>Editar Equipamento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-white">
                <div class="row g-3">
                    <!-- Conteúdo omitido para brevidade, mantendo funcionalidade -->
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Artigo</label>
                        <select asp-for="NewEquipment.Name" id="editArtigo" class="form-select bg-dark text-white border-light border-opacity-10" required>
                             <option value="">Selecione...</option>
                             <option value="Computadores">Computadores</option>
                             <option value="Monitores">Monitores</option>
                             <option value="Impressoras">Impressoras</option>
                             <option value="Networking">Networking</option>
                             <option value="Componentes">Componentes</option>
                             <option value="Projetores">Projetores</option>
                             <option value="Outros">Outros</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Tipo</label>
                        <input type="text" asp-for="NewEquipment.Type" class="form-control bg-dark text-white border-light border-opacity-10" placeholder="Ex: Laptop..." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Marca</label>
                        <input type="text" asp-for="NewEquipment.Brand" class="form-control bg-dark text-white border-light border-opacity-10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Modelo</label>
                        <input type="text" asp-for="NewEquipment.Model" class="form-control bg-dark text-white border-light border-opacity-10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Nº Série</label>
                        <input type="text" asp-for="NewEquipment.SerialNumber" id="editSerial" class="form-control bg-dark text-white border-light border-opacity-10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Sala</label>
                        <select asp-for="NewEquipment.RoomId" id="editSala" class="form-select bg-dark text-white border-light border-opacity-10" required>
                            @foreach (var sala in Model.Rooms)
                            {
                                <option value="@sala.Id">@sala.Name (@sala.Block?.Name)</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top border-light border-opacity-10">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-primary shadow-sm">Guardar Alterações</button>
            </div>
        </form>
    </div>
</div>

@* Modal Novo Equipamento - Glassmorphism *@
<div class="modal fade" id="modalNovoEquipamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form method="post" asp-page-handler="CreateEquipment" class="modal-content border-0 shadow-lg" style="background: rgba(43, 44, 64, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.1) !important;">
            <div class="modal-header border-bottom border-light border-opacity-10">
                <h5 class="modal-title text-white"><i class="bx bx-plus-circle me-2 text-success"></i>Registar Novo Equipamento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-white">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Artigo</label>
                        <select asp-for="NewEquipment.Name" class="form-select bg-dark text-white border-light border-opacity-10" required>
                            <option value="">Selecione...</option>
                            <option value="Computadores">Computadores</option>
                            <option value="Monitores">Monitores</option>
                            <option value="Impressoras">Impressoras</option>
                            <option value="Networking">Networking</option>
                            <option value="Componentes">Componentes</option>
                            <option value="Projetores">Projetores</option>
                            <option value="Outros">Outros</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Tipo</label>
                        <input type="text" asp-for="NewEquipment.Type" class="form-control bg-dark text-white border-light border-opacity-10" required placeholder="Ex: Portátil..." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Marca</label>
                        <input type="text" asp-for="NewEquipment.Brand" class="form-control bg-dark text-white border-light border-opacity-10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Modelo</label>
                        <input type="text" asp-for="NewEquipment.Model" class="form-control bg-dark text-white border-light border-opacity-10" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label text-white-50 small text-uppercase">Número de Série</label>
                        <input type="text" asp-for="NewEquipment.SerialNumber" class="form-control bg-dark text-white border-light border-opacity-10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Bloco</label>
                        <select id="regBloco" class="form-select bg-dark text-white border-light border-opacity-10" required onchange="regFilterSalas()">
                            <option value="">Selecione...</option>
                            @foreach(var b in Model.AvailableBlocos) {
                                <option value="@b.Id">@b.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Sala</label>
