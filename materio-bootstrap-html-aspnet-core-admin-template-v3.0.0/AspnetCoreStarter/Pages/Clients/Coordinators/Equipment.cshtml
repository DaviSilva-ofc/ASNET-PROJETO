@page
@model AspnetCoreStarter.Pages.Clients.Coordinators.CoordinatorEquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Equipamentos";
}

@section PageStyles {
<style>
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Coordenador /</span> Equipamentos</h4>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class='bx bx-check-circle me-1'></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Inventário de Equipamentos</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    🔍 Filtros
                </button>
                <button class="btn btn-warning text-white" data-bs-toggle="modal" data-bs-target="#modalRequisitarEq">
                    <i class="ri-hand-coin-line me-1"></i> Requisitar Equipamento
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNovoEquipamento">Novo Equipamento</button>
            </div>
        </div>

        @{
            var activeFilterText = "";
            if (Model.ActiveFilterRoom != null) activeFilterText = $"sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) activeFilterText = $"bloco: {Model.ActiveFilterBloco.Name}";
            else if (!string.IsNullOrEmpty(Model.FilterName)) activeFilterText = $"artigo: {Model.FilterName}";
            else if (!string.IsNullOrEmpty(Model.FilterType)) activeFilterText = $"tipo: {Model.FilterType}";
            else if (!string.IsNullOrEmpty(Model.FilterSerialNumber)) activeFilterText = $"série: {Model.FilterSerialNumber}";
        }

        @if (!string.IsNullOrEmpty(activeFilterText) || !string.IsNullOrEmpty(Model.FilterStatus))
        {
            <div class="card-body">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert">
                    <span>A visualizar equipamentos do <strong>@activeFilterText</strong></span>
                    @if (!string.IsNullOrEmpty(Model.FilterStatus))
                    {
                        <span class="badge bg-label-info me-1">Status: @Model.FilterStatus</span>
                    }
                    <a asp-page="./Equipment" class="btn btn-sm btn-outline-secondary ms-2">Limpar Tudo</a>
                </div>
            </div>
        }

        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th>Tipo</th>
                        <th>Nº Série</th>
                        <th>Localização (Sala)</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Equipments)
                    {
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <strong class="text-dark">@item.Name</strong>
                                    <small class="text-muted" style="font-size: 0.75rem;">
                                        @(item.Brand ?? "Genérico") @(item.Model ?? "")
                                    </small>
                                </div>
                            </td>
                            <td>@item.Type</td>
                            <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                            <td>
                                @if (item.Room != null)
                                {
                                    <span>@item.Room.Name (@item.Room.Block?.Name)</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == "Avariado") {
                                    <span class="badge bg-label-danger">Avariado</span>
                                } else {
                                    <span class="badge bg-label-success">@(item.Status == "Funcionando" || string.IsNullOrEmpty(item.Status) ? "A funcionar" : item.Status)</span>
                                }
                            </td>
                            <td style="white-space: nowrap;">
                                <div class="d-flex align-items-center gap-2">
                                    @if (item.Status == null || (!item.Status.Contains("repara", StringComparison.OrdinalIgnoreCase) && !item.Status.Contains("manutenção", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <a asp-page="./Tickets" asp-route-EqId="@item.Id" class="btn btn-sm text-primary" title="Solicitar Ticket"><i class="ri-add-circle-line"></i> Solicitar Ticket</a>
                                    }
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                        @if (item.Status == "Avariado" || item.Status == "Indisponível" || item.Status == "Danificado")
                                        {
                                            <button type="submit" class="btn btn-sm text-success" title="Marcar como Funcional"><i class="ri-check-line"></i> Funcional</button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm text-warning" title="Marcar como Avariado"><i class="ri-error-warning-line"></i> Avariar</button>
                                        }
                                    </form>
                                    <div class="d-flex align-items-center gap-1">
                                        <button type="button" class="btn btn-sm text-primary p-1" title="Editar"
                                                onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@item.Brand', '@item.Model', '@item.SerialNumber', '@item.RoomId')">
                                            <i class="bx bx-edit"></i> ✏️
                                        </button>
                                        <form method="post" asp-page-handler="DeleteEquipment" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?');" style="display:inline-block;">
                                            <button type="submit" class="btn btn-sm text-danger p-1" title="Eliminar"><i class="bx bx-trash"></i> 🗑️</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal Requisitar Equipamento *@
<div class="modal fade" id="modalRequisitarEq" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page="/Clients/Coordinators/Stocks" asp-page-handler="CreateStockRequest" class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title"><i class="ri-hand-coin-line me-2 text-warning"></i>Requisitar Equipamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Artigo</label>
                    <select name="itemName" id="reqEqArtigo" class="form-select" required onchange="filterReqEqTypes()">
                        <option value="">Selecione o artigo...</option>
                        <option value="Computador">Computadores</option>
                        <option value="Monitor">Monitores</option>
                        <option value="Impressora">Impressoras</option>
                        <option value="Projetor">Projetores</option>
                        <option value="Networking">Networking</option>
                        <option value="Componente">Componentes</option>
                        <option value="Periférico">Periféricos</option>
                        <option value="Quadro Interativo">Quadros Interativos</option>
                        <option value="Outro">Outros</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Tipo</label>
                    <select name="itemType" id="reqEqTipo" class="form-select">
                        <option value="">Selecione o tipo...</option>
                        <option value="Desktop" data-art="Computador">Desktop</option>
                        <option value="Portátil" data-art="Computador">Portátil</option>
                        <option value="AIO" data-art="Computador">AIO</option>
                        <option value="Monitor" data-art="Monitor">Monitor</option>
                        <option value="Televisão" data-art="Monitor">Televisão</option>
                        <option value="Impressora" data-art="Impressora">Impressora</option>
                        <option value="Projetor" data-art="Projetor">Projetor</option>
                        <option value="Router" data-art="Networking">Router</option>
                        <option value="Switch" data-art="Networking">Switch</option>
                        <option value="Access Point" data-art="Networking">Access Point</option>
                        <option value="Motherboard" data-art="Componente">Motherboard</option>
                        <option value="Disco HDD" data-art="Componente">Disco HDD</option>
                        <option value="Disco SSD" data-art="Componente">Disco SSD</option>
                        <option value="Memória RAM" data-art="Componente">Memória RAM</option>
                        <option value="Processador (CPU)" data-art="Componente">Processador (CPU)</option>
                        <option value="Teclado" data-art="Periférico">Teclado</option>
                        <option value="Rato" data-art="Periférico">Rato</option>
                        <option value="Headphones" data-art="Periférico">Headphones</option>
                        <option value="Quadro Interativo" data-art="Quadro Interativo">Quadro Interativo</option>
                        <option value="Mesa Interativa" data-art="Quadro Interativo">Mesa Interativa</option>
                        <option value="Outro" data-art="Outro">Outro</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Quantidade</label>
                    <input type="number" name="quantity" class="form-control" value="1" min="1" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Motivo do Pedido</label>
                    <textarea name="notes" class="form-control" rows="3" placeholder="Descreva a necessidade..." required></textarea>
                </div>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-warning text-white">Solicitar Equipamento</button>
            </div>
        </form>
    </div>
</div>

@* Modal Editar Equipamento *@
<div class="modal fade" id="modalEditarEquipamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditEquipment">
                <input type="hidden" asp-for="NewEquipment.Id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bx bx-edit me-2"></i>Editar Equipamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase">Artigo</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar artigo..." onkeyup="filterSelect(this, 'editArtigo')">
                                <select asp-for="NewEquipment.Name" id="editArtigo" class="form-select" required onchange="updateBrandsModels('edit'); updateSpecificTypes('edit');">
                                    <option value="">Selecione o artigo...</option>
                                    <option value="Computadores">Computadores</option>
                                    <option value="Monitores">Monitores</option>
                                    <option value="Impressoras">Impressoras</option>
                                    <option value="Networking">Networking</option>
                                    <option value="Servidores/Infra">Servidores/Infra</option>
                                    <option value="Componentes">Componentes</option>
                                    <option value="Periféricos">Periféricos</option>
                                    <option value="Projetores">Projetores</option>
                                    <option value="Quadros Interativos">Quadros Interativos</option>
                                    <option value="Outros">Outros</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase">Tipo Específico</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar tipo..." onkeyup="filterSelect(this, 'editTipo')">
                                <select asp-for="NewEquipment.Type" id="editTipo" class="form-select" required>
                                    <option value="">Selecione o tipo...</option>
                                    <!-- Computadores -->
                                    <option value="Desktop" data-artigo="Computadores">Desktop</option>
                                    <option value="Portátil" data-artigo="Computadores">Portátil</option>
                                    <option value="AIO" data-artigo="Computadores">AIO</option>
                                    <option value="Laptop" data-artigo="Computadores">Laptop</option>
                                    <!-- Monitores -->
                                    <option value="Monitor" data-artigo="Monitores">Monitor</option>
                                    <option value="Televisão" data-artigo="Monitores">Televisão</option>
                                    <option value="TV" data-artigo="Monitores">TV</option>
                                    <!-- Impressoras -->
                                    <option value="Impressora" data-artigo="Impressoras">Impressora</option>
                                    <!-- Networking -->
                                    <option value="Router" data-artigo="Networking">Router</option>
                                    <option value="Switch" data-artigo="Networking">Switch</option>
                                    <option value="Access Point" data-artigo="Networking">Access Point</option>
                                    <option value="Firewall" data-artigo="Networking">Firewall</option>
                                    <!-- Servidores/Infra -->
                                    <option value="Servidor" data-artigo="Servidores/Infra">Servidor</option>
                                    <option value="Storage" data-artigo="Servidores/Infra">Storage</option>
                                    <option value="NAS" data-artigo="Servidores/Infra">NAS</option>
                                    <!-- Componentes -->
                                    <option value="Motherboard" data-artigo="Componentes">Motherboard</option>
                                    <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
                                    <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
                                    <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
                                    <option value="Processador (CPU)" data-artigo="Componentes">Processador (CPU)</option>
                                    <option value="Placa Gráfica" data-artigo="Componentes">Placa Gráfica</option>
                                    <option value="Fonte Alimentação" data-artigo="Componentes">Fonte Alimentação</option>
                                    <!-- Periféricos -->
                                    <option value="Teclado" data-artigo="Periféricos">Teclado</option>
                                    <option value="Rato" data-artigo="Periféricos">Rato</option>
                                    <option value="Headphones" data-artigo="Periféricos">Headphones</option>
                                    <option value="Colunas" data-artigo="Periféricos">Colunas</option>
                                    <!-- Projetores -->
                                    <option value="Projetor" data-artigo="Projetores">Projetor</option>
                                    <!-- Quadros Interativos -->
                                    <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
                                    <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
                                    <!-- Outros -->
                                    <option value="Cabo/Adaptador" data-artigo="Outros">Cabo/Adaptador</option>
                                    <option value="Outro" data-artigo="Outros">Outro</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase">Marca</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar marca..." onkeyup="filterSelect(this, 'editMarca')">
                                <select asp-for="NewEquipment.Brand" id="editMarca" class="form-select" required onchange="updateModels('edit')">
                                    <option value="">Selecione...</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase">Modelo</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar modelo..." onkeyup="filterSelect(this, 'editModelo')">
                                <select asp-for="NewEquipment.Model" id="editModelo" class="form-select" required>
                                    <option value="">Selecione a marca primeiro...</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase">Nº Série</label>
                            <input type="text" asp-for="NewEquipment.SerialNumber" id="editSerial" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase">Sala</label>
                            <select asp-for="NewEquipment.RoomId" id="editSala" class="form-select" required>
                                <option value="">Selecione a sala...</option>
                                @foreach (var sala in Model.Rooms)
                                {
                                    <option value="@sala.Id">@sala.Name (@sala.Block?.Name)</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

