@* Modal Filtros - Admin Style *@
<div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="get" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ri-search-line me-2"></i>Filtrar Equipamentos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-bold small text-uppercase">Artigo</label>
                        <select asp-for="FilterName" class="form-select">
                            <option value="">Todos os Artigos</option>
                            @foreach (var name in Model.UniqueEquipmentNames)
                            {
                                <option value="@name">@name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase">Tipo</label>
                        <select asp-for="FilterType" class="form-select">
                            <option value="">Todos os Tipos</option>
                            <option value="Desktop">Desktop</option>
                            <option value="Portátil">Portátil</option>
                            <option value="Monitor">Monitor</option>
                            <option value="Impressora">Impressora</option>
                            <option value="Router">Router</option>
                            <option value="Switch">Switch</option>
                            <option value="Componente">Componente</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase">Estado</label>
                        <select asp-for="FilterStatus" class="form-select">
                            <option value="">Todos os Estados</option>
                            <option value="A funcionar">A funcionar</option>
                            <option value="Avariado">Avariado</option>
                            <option value="Em Reparação">Em Reparação</option>
                            <option value="Indisponível">Indisponível</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold small text-uppercase">Nº Série</label>
                        <input type="text" asp-for="FilterSerialNumber" class="form-control" placeholder="Pesquisar por número de série...">
                    </div>

                    <div class="divider">
                        <div class="divider-text small text-uppercase">Localização Interna</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase">Bloco</label>
                        <select id="filterBloco" asp-for="FilterBlocoId" class="form-select" onchange="filterSalas()">
                            <option value="">Todos os Blocos</option>
                            @foreach (var blc in Model.AvailableBlocos)
                            {
                                <option value="@blc.Id">@blc.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase">Sala</label>
                        <select id="filterSala" asp-for="FilterRoomId" class="form-select">
                            <option value="">Todas as Salas</option>
                            @foreach (var sala in Model.Rooms)
                            {
                                <option value="@sala.Id" data-blc="@sala.BlockId">@sala.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <a asp-page="./Equipment" class="btn btn-outline-secondary">Limpar</a>
                <button type="submit" class="btn btn-primary shadow-sm">Aplicar Filtros</button>
            </div>
        </form>
    </div>
</div>

@section PageScripts {
<script>
    const brandModelData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object> {
        ["Computadores"] = new { HP = new[]{"ProDesk 400", "ProDesk 600", "ZBook", "EliteOne 800 (AIO)"}, Dell = new[]{"OptiPlex 3090", "Latitude 3520", "OptiPlex 7490 (AIO)"}, Lenovo = new[]{"ThinkCentre M70q", "ThinkPad T14", "IdeaCentre AIO"} },
        ["Monitores"] = new { HP = new[]{"P22h", "E24"}, Dell = new[]{"P2422H", "U2422H"}, Samsung = new[]{"F24T350", "Smart TV 4K"}, LG = new[]{"Monitor 24\"", "TV NanoCell"} },
        ["Impressoras"] = new { HP = new[]{"LaserJet Pro", "DeskJet"}, Brother = new[]{"HL-L2350DW"}, Epson = new[]{"EcoTank"} },
        ["Networking"] = new { Cisco = new[]{"Catalyst 1000", "Firepower 1010"}, Ubiquiti = new[]{"UniFi U6"}, Fortinet = new[]{"FortiGate 40F", "FortiGate 60F"} },
        ["Servidores/Infra"] = new { Dell = new[]{"PowerEdge T150", "PowerEdge R250"}, HP = new[]{"ProLiant ML30", "DL360"}, Synology = new[]{"DS220+", "RS820+"} },
        ["Componentes"] = new { Kingston = new[]{"DDR4 8GB", "SSD 480GB"}, Samsung = new[]{"980 NVMe"} },
