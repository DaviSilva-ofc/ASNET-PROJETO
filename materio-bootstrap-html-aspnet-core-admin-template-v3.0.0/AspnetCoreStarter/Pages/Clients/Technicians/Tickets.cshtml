@page
@model AspnetCoreStarter.Pages.Clients.Technicians.TicketsModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Gestão de Trabalhos - Técnico";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

@section PageStyles {
<link rel="stylesheet" href="~/css/tickets-v2.css" asp-append-version="true" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .tk-page { padding-top: 0; }
    .tk-filters { margin-top: 20px; }
    .preventive-check-item:hover { background: rgba(105, 108, 255, 0.05) !important; border-color: rgba(105, 108, 255, 0.4) !important; transform: translateX(5px); }
    .bg-label-primary { background-color: rgba(105, 108, 255, 0.1) !important; color: #696cff !important; }
    .cursor-pointer { cursor: pointer; }
    .transition-all { transition: all 0.2s ease-in-out; }

    /* Fix for modal appearing behind the slide-over panel */
    #modalOrcamento { z-index: 10010 !important; }
    .modal-backdrop { z-index: 10005 !important; }
</style>
}

<div class="tk-page">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold" style="color: var(--bs-heading-color);">Os Meus Trabalhos</h1>
            <p class="text-muted mb-0">@Model.Tickets.Count tickets atribuídos • @Model.AvailableTickets.Count novos disponíveis</p>
        </div>
    </div>

    <!-- Stats -->
    <!-- Stats -->
    <div class="tk-stats">
        <div class="tk-stat @(Model.FilterStatus=="Pendente"?"active-grey":"")" onclick="toggleFilter('Pendente')">
            <div class="tk-stat-label">Pendente</div>
            <div class="tk-stat-num num-grey">@Model.AvailableTickets.Count</div>
        </div>
        <div class="tk-stat @(Model.FilterStatus=="Aceite"?"active-blue":"")" onclick="toggleFilter('Aceite')">
            <div class="tk-stat-label">Aceite</div>
            <div class="tk-stat-num num-blue">@Model.Tickets.Count(t => t.Status =="Aceite")</div>
        </div>
        <div class="tk-stat @(Model.FilterStatus=="Em reparação"?"active-amber":"")" onclick="toggleFilter('Em reparação')">
            <div class="tk-stat-label">Em Reparação</div>
            <div class="tk-stat-num num-amber">@Model.Tickets.Count(t => t.Status =="Em reparação")</div>
        </div>
        <div class="tk-stat @(Model.FilterStatus=="Concluído"?"active-green":"")" onclick="toggleFilter('Concluído')">
            <div class="tk-stat-label">Concluído</div>
            <div class="tk-stat-num num-green">@Model.Tickets.Count(t => t.Status =="Concluído")</div>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="tk-filters">
        <input type="hidden" name="FilterStatus" id="filterStatusHidden" value="@Model.FilterStatus" />
        <input type="text" name="SearchQuery" class="tk-search" placeholder="Pesquisar por ID ou descrição..." value="@Model.SearchQuery" id="tkSearch">
        
        <button type="button" class="tk-send-btn" style="padding: 10px 24px; background: #ffab00; color: #000; font-weight: bold; border: none;" data-bs-toggle="modal" data-bs-target="#modalFiltros">
            <i class='bx bx-filter-alt me-1'></i> Filtros
        </button>
    </form>
    
    @{
        var activeFilters = new List<string>();
        if (!string.IsNullOrEmpty(Model.FilterStatus) && Model.FilterStatus !="Todos os Estados") activeFilters.Add($"Estado: {Model.FilterStatus}");
        if (!string.IsNullOrEmpty(Model.FilterType)) activeFilters.Add($"Tipo: {Model.FilterType}");
        if (!string.IsNullOrEmpty(Model.FilterArticle)) activeFilters.Add($"Artigo: {Model.FilterArticle}");
        if (Model.FilterSchoolId.HasValue) activeFilters.Add("Escola selecionada");
        if (Model.FilterAgrupamentoId.HasValue) activeFilters.Add("Agrupamento selecionado");
        if (Model.FilterEmpresaId.HasValue) activeFilters.Add("Empresa selecionada");
        if (Model.FilterBlocoId.HasValue) activeFilters.Add("Bloco selecionado");
        if (!string.IsNullOrEmpty(Model.SearchQuery)) activeFilters.Add($"Pesquisa: \"{Model.SearchQuery}\"");
    }

    @if (activeFilters.Any())
    {
        <div class="d-flex align-items-center gap-3 p-3 mb-4 rounded-3" style="background: rgba(0, 123, 255, 0.1); border: 1px solid rgba(0, 123, 255, 0.2);">
            <div class="d-flex align-items-center gap-2 flex-grow-1 overflow-hidden">
                <i class="ri-filter-fill text-primary" style="font-size: 1.2rem;"></i>
                <div class="text-muted small text-truncate">
                    <span class="text-primary fw-bold me-1">Filtros ativos:</span>
                    @string.Join(" •", activeFilters)
                </div>
            </div>
            <a href="/Clients/Technicians/Tickets" class="btn btn-sm btn-outline-primary text-nowrap" style="border-radius: 20px; font-size: 0.75rem; padding: 4px 12px;">
                <i class="ri-close-line me-1"></i> Limpar Filtros
            </a>
        </div>
    }

    <!-- Ticket List -->
    <div class="tk-list">
        @if (!Model.Tickets.Any() && !Model.AvailableTickets.Any())
        {
            <div class="tk-row" style="justify-content:center; cursor:default;">
                <p class="text-muted mb-0 py-4">Nenhum trabalho encontrado com os critérios selecionados.</p>
            </div>
        }

        @* Se o filtro for"Pendente" ou"Todos", mostrar os disponíveis primeiro *@
        @if (string.IsNullOrEmpty(Model.FilterStatus) || Model.FilterStatus =="Pendente" || Model.FilterStatus =="Todos")
        {
            @foreach (var t in Model.AvailableTickets)
            {
                <div class="tk-row" onclick="openPanel(@t.Id)" style="border-left: 4px solid var(--tk-primary);">
                    <div class="tk-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.2rem;">
                        @{
                            var type = t.Equipamento?.Type ??"";
                            var name = t.Equipamento?.Name ??"";
                            var emoji = type switch {
                                var s when s.Contains("Monitor") =>"🖥️",
                                var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") =>"💻",
                                var s when s.Contains("Impressora") =>"🖨️",
                                var s when s.Contains("Rede") || s.Contains("Network") =>"🌐",
                                var s when s.Contains("Projetor") =>"📽️",
                                var s when s.Contains("Rato") || s.Contains("Mouse") =>"🖱️",
                                var s when s.Contains("Teclado") =>"⌨️",
                                _ => name.Contains("Monitor") ?"🖥️" : (name.Contains("Computador") ?"💻" :"🔧")
                            };
                        }
                        @emoji
                    </div>
                    <div class="tk-main">
                        <div class="tk-meta">
                            <span class="tk-id">#@t.Id</span>
                            <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">NOVO DISPONÍVEL</span>
                            @if (!string.IsNullOrEmpty(t.Level)) {
                                var c = t.Level.Contains("Alt") || t.Level.Contains("Crít") ?"var(--tk-red)" :"var(--tk-amber)";
                                <span class="badge-tk" style="color: @c; border-color: @c; background: @(c)11;">@t.Level</span>
                            }
                        </div>
                        <div class="tk-title">@(t.Equipamento?.Name ??"Avaria Geral")</div>
                        <div class="tk-sub">
                            <i class="ri-map-pin-line me-1"></i> @(t.School?.Name ??"Sede") • @(t.Equipamento?.Room?.Name ??"N/A")
                        </div>
                    </div>
                    <div class="tk-right" style="display: flex; gap: 10px; align-items: center;">
                        <form method="post" asp-page-handler="Accept" asp-route-id="@t.Id">
                            <button type="submit" class="tk-advance-btn" style="padding: 6px 14px; font-size: 12px; height: auto;" onclick="event.stopPropagation();">
                                Aceitar Ticket
                            </button>
                        </form>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </div>
                </div>
            }
        }

        @* Mostrar os atribuídos *@
        @foreach (var t in Model.Tickets)
        {
            <div class="tk-row" onclick="openPanel(@t.Id)">
                <div class="tk-icon" style="background: rgba(255, 171, 0, 0.05); color: var(--tk-muted); font-size: 1.2rem;">
                    @{
                        var type = t.Equipamento?.Type ??"";
                        var name = t.Equipamento?.Name ??"";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") =>"🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") =>"💻",
                            var s when s.Contains("Impressora") =>"🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") =>"🌐",
                            var s when s.Contains("Projetor") =>"📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") =>"🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") =>"⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") =>"🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") =>"🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") =>"🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") =>"📷",
                            _ => name.Contains("Monitor") ?"🖥️" : (name.Contains("Computador") ?"💻" : (name.Contains("Impressora") ?"🖨️" :"🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-main">
                    <div class="tk-meta">
                        <span class="tk-id">#@t.Id</span>
                        <span class="badge-tk" style="background: rgba(255,255,255,0.05); color: var(--tk-muted); border-color: var(--tk-border);">
                            @(t.Equipamento?.Type ??"Geral")
                        </span>
                        @if (!string.IsNullOrEmpty(t.Level)) {
                            var c = t.Level.Contains("Alt") || t.Level.Contains("Crít") ?"var(--tk-red)" :"var(--tk-amber)";
                            <span class="badge-tk" style="color: @c; border-color: @c; background: @(c)11;">@t.Level</span>
                        }
                    </div>
                    <div class="tk-title">@(t.Equipamento?.Name ??"Avaria Geral")</div>
                    <div class="tk-sub">
                        <i class="ri-map-pin-line me-1"></i> @(t.School?.Name ??"Sede") • @(t.Equipamento?.Room?.Name ??"N/A")
                    </div>
                </div>
                <div class="tk-right">
                    @{
                        var statusVal = t.Status?.Trim().ToLower() ??"";
                        var stCol = statusVal switch {
                            "concluído" => "#71dd37", // Green
                            "em reparação" or "em resolução" or "em reparacao" or "em resolucao" => "#ffab00", // Amber/Yellow
                            "aceite" => "#696cff", // Blue
                            _ => "#a1acb8" // Muted
                        };
                    }
                    <span class="badge-tk" style="color: @stCol; border-color: @stCol; background: @(stCol)22;">@t.Status</span>
                    <i class="ri-arrow-right-s-line text-muted"></i>
                </div>
            </div>
        }
    </div>

    <!-- Map Section -->
    <div class="row mt-5 mb-4">
        <div class="col-12">
            <div class="card bg-transparent border-0 shadow-none">
                <div class="card-header px-0 d-flex align-items-center gap-2 pb-3">
                    <i class="ri-map-pin-line" style="color: var(--tk-primary); font-size: 1.2rem;"></i>
                    <h5 class="mb-0 fw-bold" style="color: var(--bs-heading-color);">Mapa de Intervenções</h5>
                </div>
                <div class="card-body p-0 rounded-4 overflow-hidden border border-secondary border-opacity-10">
                    <div id="clientMap" style="height: 400px; width: 100%;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Filtros Avançados -->
<div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form method="get" class="modal-content" style="background:#0d1520;border:1px solid #1e3a4a;color:#e2e8f0">
            <div class="modal-header" style="border-color:#1e3a4a">
                <h5 class="modal-title">Filtros Avançados</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-4">
                    <!-- Informação Principal -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Pesquisa Geral</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#1a232e; border:1px solid #1e3a4a; color:#6b7280;"><i class="ri-search-line"></i></span>
                            <input type="text" name="SearchQuery" class="form-control" style="background:#1a232e; border:1px solid #1e3a4a; color: var(--bs-heading-color);" value="@Model.SearchQuery" placeholder="ID do ticket, descrição...">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Estado do Ticket</label>
                        <select name="FilterStatus" class="form-select select2-modal">
                            <option value="">Todos os Estados</option>
                            <option value="Pendente" selected="@(Model.FilterStatus =="Pendente")">Pendente</option>
                            <option value="Aceite" selected="@(Model.FilterStatus =="Aceite")">Aceite</option>
                            <option value="Em reparação" selected="@(Model.FilterStatus =="Em reparação")">Em reparação</option>
                            <option value="Concluído" selected="@(Model.FilterStatus =="Concluído")">Concluído</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Tipo de Equipamento</label>
                        <select name="FilterType" class="form-select select2-modal">
                            <option value="">Todos os Tipos</option>
                            <option value="Computador" selected="@(Model.FilterType =="Computador")">Computador</option>
                            <option value="Monitor" selected="@(Model.FilterType =="Monitor")">Monitor</option>
                            <option value="Impressora" selected="@(Model.FilterType =="Impressora")">Impressora</option>
                            <option value="Rede" selected="@(Model.FilterType =="Rede")">Rede</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Artigo Específico</label>
                        <select name="FilterArticle" class="form-select select2-modal">
                            <option value="">Todos os Artigos</option>
                            @foreach (var art in Model.UniqueEquipmentNames) {
                                <option value="@art" selected="@(Model.FilterArticle == art)">@art</option>
                            }
                        </select>
                    </div>

                    <div class="col-12"><hr style="border-color:#1e3a4a; opacity: 0.5;"></div>
                    <div class="col-12 mb-1"><small class="text-uppercase fw-bold text-primary">📍 Localização</small></div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Agrupamento</label>
                        <select id="prevFilterAgrupamento" name="FilterAgrupamentoId" class="form-select select2-modal" onchange="prevFilterEscolas()">
                            <option value="">Todos</option>
                            @foreach (var agr in Model.AvailableAgrupamentos) {
                                <option value="@agr.Id" selected="@(Model.FilterAgrupamentoId == agr.Id)">@agr.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Escola</label>
                        <select id="prevFilterEscola" name="FilterSchoolId" class="form-select select2-modal" onchange="prevFilterBlocos()">
                            <option value="">Todas</option>
                            @foreach (var esc in Model.AvailableSchools) {
                                <option value="@esc.Id" data-agr="@esc.AgrupamentoId" selected="@(Model.FilterSchoolId == esc.Id)">@esc.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Bloco</label>
                        <select id="prevFilterBloco" name="FilterBlocoId" class="form-select select2-modal">
                            <option value="">Todos</option>
                            @foreach (var blc in Model.AvailableBlocos) {
                                <option value="@blc.Id" data-esc="@blc.SchoolId" selected="@(Model.FilterBlocoId == blc.Id)">@blc.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Empresa (Privado)</label>
                        <select name="FilterEmpresaId" class="form-select select2-modal">
                            <option value="">Todas</option>
                            @foreach (var emp in Model.AvailableEmpresas) {
                                <option value="@emp.Id" selected="@(Model.FilterEmpresaId == emp.Id)">@emp.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer p-4" style="border-color:#1e3a4a">
                <a href="/Clients/Technicians/Tickets" class="btn btn-outline-secondary px-4">Limpar Filtros</a>
                <button type="submit" class="btn btn-warning px-4 fw-bold" style="background:#ffab00; border:none; color:#000;">Aplicar Filtros</button>
            </div>
        </form>
    </div>
</div>

@section VendorScripts {
    <script src="~/vendor/libs/select2/select2.dist.js"></script>
}

<!-- Modal Orçamento -->
<div class="modal fade" id="modalOrcamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="SubmitBudget" class="modal-content" style="background: rgba(13, 21, 32, 0.85); backdrop-filter: blur(12px); color: #fff; border: 1px solid rgba(255,255,255,0.15); box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
            <input type="hidden" name="ticketId" id="orcamentoTicketId" />
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title fw-bold">Orçamento para Arranjo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <h4 class="fw-bold">Registar Orçamento</h4>
                    <p class="text-muted small">Descreva os custos ou detalhes necessários para a reparação externa ou substituição deste equipamento.</p>
                </div>
                
                <div class="mb-3">
                    <label class="form-label small text-uppercase fw-bold text-muted">Detalhes do Orçamento</label>
                    <textarea name="budgetDetails" class="form-control" rows="4" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); color: #fff;" 
                              placeholder="Ex: Necessário substituição de motherboard. Custo estimado: 150€. Fornecedor: ASNET..." required></textarea>
                </div>

                <div class="alert alert-warning border-0 small">
                    <i class="ri-information-line me-1"></i> Ao submeter, o ticket será concluído com o estado "Sem Reparação" e o orçamento ficará registado no histórico.
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-warning fw-bold px-4" style="background:#ffab00; border:none; color:#000;">Submeter Orçamento</button>
            </div>
        </form>
    </div>
</div>

<!-- Panel Overlay & Slide-over Panel -->
<div class="tk-overlay" id="tkOverlay" onclick="closePanel()"></div>

<div class="tk-panel" id="tkPanel">
    @if (Model.SelectedTicket != null)
    {
        var t = Model.SelectedTicket;
        var mainEq = t.Equipamento ?? t.UtilizedEquipments?.FirstOrDefault() ?? Model.AssociatedEquipment.FirstOrDefault();
        
        <div class="tk-ph">
            <div class="tk-ph-top">
                <div class="tk-ph-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.5rem; display: flex; align-items: center; justify-content: center;">
                    @{
                        var type = mainEq?.Type ??"";
                        var name = mainEq?.Name ??"";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") =>"🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") =>"💻",
                            var s when s.Contains("Impressora") =>"🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") =>"🌐",
                            var s when s.Contains("Projetor") =>"📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") =>"🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") =>"⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") =>"🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") =>"🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") =>"🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") =>"📷",
                            _ => name.Contains("Monitor") ?"🖥️" : (name.Contains("Computador") ?"💻" : (name.Contains("Impressora") ?"🖨️" :"🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-ph-info">
                    <div class="tk-ph-badges">
                        <span class="badge-tk" style="color: var(--tk-muted); border-color: var(--tk-border);">TK-@t.Id.ToString("D3")</span>
                        @if(!string.IsNullOrEmpty(t.Type)) {
                            <span class="badge-tk" style="color: var(--tk-amber); border-color: var(--tk-amber); background: rgba(245, 158, 11, 0.1);">@t.Type</span>
                        }
                        <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">@t.Status</span>
                    </div>
                    <h2 class="tk-ph-title">@(mainEq?.Name ??"Avaria Geral"): @(t.Description != null && t.Description.Length > 30 ? t.Description.Substring(0, 30) +"..." : t.Description)</h2>
                </div>
                <button class="tk-close" onclick="closePanel()">✕</button>
            </div>

            <div class="tk-stepper">
                @{
                    var steps = new[] {"Pendente","Aceite","Em reparação","Concluído" };
                    int si = Array.IndexOf(steps, t.Status);
                    
                    var nextLabel = si < 3 ? (si == 0 ?"Aceite" : si == 1 ?"Em reparação" :"Concluído") :"";
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i < si || t.Status =="Concluído";
                    bool active = i == si && t.Status !="Concluído";
                    <div class="tk-step">
                        @if (i < steps.Length - 1) {
                            <div class="tk-step-line @(i < si || t.Status =="Concluído" ?"done" :"")"></div>
                        }
                        <div class="tk-step-dot @(done ?"done" :"") @(active ?"active" :"")">
                            @(done ?"✓" : (i + 1).ToString())
                        </div>
                        <div class="tk-step-label @(active ?"active" :"")">@steps[i]</div>
                    </div>
                }
            </div>

            @if (t.Status !="Concluído" && si < 3)
            {
                <div class="tk-advance-row">
                    @if (t.Status =="Em reparação" || t.Status =="Em andamento" || t.Status =="Em resolução")
                    {
                        <div class="d-flex gap-2 w-100">
                            <form method="post" asp-page-handler="CompleteRepaired" asp-route-ticketId="@t.Id" class="flex-grow-1">
                                <button type="submit" class="tk-advance-btn w-100" style="background: #28a745 !important; color: white !important;">
                                    <i class="ri-checkbox-circle-line me-1"></i> Reparado
                                </button>
                            </form>
                            <button type="button" class="tk-advance-btn flex-grow-1" style="background: #dc3545 !important; color: white !important;" 
                                    data-bs-toggle="modal" data-bs-target="#modalOrcamento" onclick="setOrcamentoTicketId(@t.Id)">
                                <i class="ri-close-circle-line me-1"></i> Sem Reparação
                            </button>
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="AdvanceStatus" asp-route-ticketId="@t.Id" asp-route-SelectedTicketId="@t.Id">
                            <button type="submit" class="tk-advance-btn">
                                @if (si == 0) {
                                    <text>Aceitar Ticket (Para mim)</text>
                                } else {
                                    <text>→ Avançar para"@nextLabel"</text>
                                }
                            </button>
                        </form>
                    }
                </div>
            }
        </div>

        <div class="tk-tabs">
            <div class="tk-tab active" data-tab="tab-0" onclick="showTab('tab-0')">📁 Detalhes</div>
            @if (t.Type == "Manutenção Preventiva")
            {
                <div class="tk-tab" data-tab="tab-3" onclick="showTab('tab-3')">✅ Checklist</div>
            }
            <div class="tk-tab" data-tab="tab-1" onclick="showTab('tab-1')">📦 Stock (@Model.CountStock)</div>
            <div class="tk-tab" data-tab="tab-2" onclick="showTab('tab-2')">🕒 Histórico</div>
        </div>

        <div class="tk-body">
            <!-- Tab: Detalhes -->
            <div class="tk-tab-content" id="tab-0">
                <div class="tk-info-grid">
                    <div class="tk-info-card"><div class="tk-info-label">Solicitante</div><div class="tk-info-val">@(t.RequestedBy?.Username ??"—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Técnico Responsável</div><div class="tk-info-val">@(t.Technician?.Username ??"—")</div></div>
                    <div class="tk-info-card">
                        <div class="tk-info-label">Escola</div>
                        <div class="tk-info-val d-flex align-items-center justify-content-between">
                            <span>@(t.School?.Name ??"—")</span>
                            @if (t.School != null) {
                                <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(t.School.Name + (string.IsNullOrEmpty(t.School.Address) ?"" :"," + t.School.Address) +", Portugal")" 
                                   target="_blank" class="btn btn-sm btn-outline-primary" style="font-size: 10px; padding: 2px 8px; border-radius: 4px;">
                                    <i class="ri-map-pin-2-line me-1"></i> Ver no Mapa
                                </a>
                            }
                        </div>
                    </div>
                    <div class="tk-info-card"><div class="tk-info-label">Agrupamento</div><div class="tk-info-val">@(t.School?.Agrupamento?.Name ??"—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Criado em</div><div class="tk-info-val">@t.CreatedAt.ToString("dd/MM/yyyy, HH:mm")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Atualizado em</div><div class="tk-info-val">@DateTime.Now.ToString("dd/MM/yyyy, HH:mm")</div></div>

                    @if (mainEq != null) {
                        <div class="tk-info-card">
                            <div class="tk-info-label">Nº de Série</div>
                            <div class="tk-info-val text-primary fw-bold">@(mainEq.SerialNumber ??"N/A")</div>
                        </div>
                        <div class="tk-info-card" style="grid-row: span 2; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; padding: 10px; border-radius: 8px;">
                            <div class="tk-info-label" style="color: #000; margin-bottom: 5px;">QR CODE</div>
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=@(mainEq.SerialNumber ?? t.Id.ToString())" alt="QR Code" style="width: 80px; height: 80px;" />
                        </div>
                    }
                </div>
                
                <div class="tk-desc-card">
                    <div class="tk-info-label">Descrição</div>
                    <div style="margin-top:6px;font-size:14px;line-height:1.6">@t.Description</div>
                </div>


                @{ var comments = Model.TicketHistory.Where(h => h.TipoAcao == TipoAcaoHistorico.Comentario).ToList(); }
                <div style="margin-top:20px;margin-bottom:20px">
                    <div class="tk-info-label">Notas Técnicas</div>
                    @if (!comments.Any()) {
                        <div style="color:var(--tk-muted);font-size:13px;padding:10px 0">Sem notas registadas.</div>
                    } else {
                        <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px">
                            @foreach(var c in comments) {
                                var isAvaria = c.Acao?.IndexOf("AVARIA", StringComparison.OrdinalIgnoreCase) >= 0;
                                var borderCol = isAvaria ? "#ef4444 !important" : "var(--tk-primary)";
                                var textCol = isAvaria ? "#ef4444 !important" : "var(--bs-body-color)";

                                <div style="background: var(--bs-body-bg); padding:10px 14px; border-radius:0 8px 8px 0; border: 1px solid var(--bs-border-color); border-left: 3px solid @borderCol; position: relative;">
                                    <div style="font-size:13px;line-height:1.5; color: @textCol; @(isAvaria ? "font-weight: 500;" : "")">@c.Acao</div>
                                    <div style="font-size:11px;color:var(--tk-muted);margin-top:4px">@c.Autor · @c.Data.ToString("dd/MM HH:mm")</div>
                                    
                                    @if(t.Status != "Concluído") {
                                        <form method="post" asp-page-handler="DeleteComment" asp-route-ticketId="@t.Id" asp-route-historyId="@c.Id" style="position: absolute; top: 8px; right: 8px;">
                                            <button type="submit" style="background:none; border:none; color:var(--tk-muted); cursor:pointer; font-size:14px;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--tk-muted)'">
                                                <i class="ri-delete-bin-line"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (Model.AssociatedEquipment.Any())
                {
                    <div class="tk-eq-card">
                        <div class="tk-eq-header">@Model.AssociatedEquipment.Count equipamento(s) associado(s)</div>
                        @foreach (var eq in Model.AssociatedEquipment)
                        {
                            <div class="tk-eq-item">
                                <span><strong>@eq.Name</strong> · <span style="color:#6b7280;font-size:12px">@eq.SerialNumber</span></span>
                                @if(t.Status !="Concluído") {
                                    <form method="post" asp-page-handler="RemoveEquipment" asp-route-ticketId="@t.Id" asp-route-equipmentId="@eq.Id" asp-route-SelectedTicketId="@t.Id" style="display:inline">
                                        <button type="submit" class="btn-remove" style="background:transparent;border:none;color:var(--tk-red);font-size:12px;cursor:pointer">Remover</button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Tab: Checklist (Dynamic) -->
            <div class="tk-tab-content d-none" id="tab-3">
                <div class="p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center" style="color: var(--tk-primary);"><i class="ri-checkbox-multiple-line me-2"></i> Checklist de Manutenção</h5>
                    
                    @{
                        mainEq = t.Equipamento ?? t.UtilizedEquipments?.FirstOrDefault() ?? Model.AssociatedEquipment.FirstOrDefault();
                        var allEqsChecklist = Model.SchoolEquipment.Any() ? Model.SchoolEquipment : (Model.AssociatedEquipment.Any() ? Model.AssociatedEquipment : new List<Equipamento> { mainEq }.Where(x => x != null).ToList());
                        if (!allEqsChecklist.Any()) allEqsChecklist.Add(new Equipamento { Name = "Geral", Type = "Intervenção Geral" });
                    }

                    <div class="mb-4">
                        <label class="form-label small text-uppercase fw-bold text-muted mb-2">Equipamento em Intervenção</label>
                        <select class="form-select bg-dark text-white border-secondary" style="border-radius: 10px;" onchange="switchChecklist(this.value)">
                            @foreach (var eq in allEqsChecklist)
                            {
                                <option value="@eq.Id">@eq.Name (@(eq.Type ?? "Equipamento"))</option>
                            }
                        </select>
                    </div>

                    @foreach (var eq in allEqsChecklist)
                    {
                        <div class="eq-checklist-container @(eq == allEqsChecklist.First() ? "" : "d-none")" id="checklist-@eq.Id">
                            <div class="tk-checklist-list d-flex flex-column gap-2 mb-4">
                                @{
                                    var eqType = (eq.Type ?? "").ToLower();
                                    var items = new List<string> { "Limpeza física geral", "Verificação de cabos e conectores" };
                                    
                                    if (eqType.Contains("computador") || eqType.Contains("laptop") || eqType.Contains("pc") || eqType.Contains("portátil"))
                                    {
                                        items.AddRange(new[] { "Verificação de temperaturas (Cooling)", "Diagnóstico de Disco (S.M.A.R.T)", "Atualização de Segurança / SO", "Otimização de arranque" });
                                    }
                                    else if (eqType.Contains("impressora"))
                                    {
                                        items.AddRange(new[] { "Limpeza de roletes e sensores", "Verificação/Limpeza de cabeças", "Alinhamento e teste de qualidade", "Verificação de níveis de consumíveis" });
                                    }
                                    else if (eqType.Contains("rede") || eqType.Contains("switch") || eqType.Contains("router"))
                                    {
                                        items.AddRange(new[] { "Verificação de portas ativas", "Atualização de Firmware", "Organização de cabos (Patching)", "Verificação de redundância" });
                                    }
                                    else if (eqType.Contains("projetor"))
                                    {
                                        items.AddRange(new[] { "Limpeza de filtros de ar", "Verificação de horas da lâmpada", "Ajuste de focagem e alinhamento", "Teste de entradas (HDMI/VGA)" });
                                    }
                                    else if (eqType.Contains("ups") || eqType.Contains("bateria"))
                                    {
                                        items.AddRange(new[] { "Teste de carga e autonomia", "Verificação de tensões", "Inspeção física (inchaço/corrosão)", "Teste de bypass" });
                                    }
                                    else if (eqType.Contains("servidor") || eqType.Contains("server"))
                                    {
                                        items.AddRange(new[] { "Verificação de Backups", "Análise de logs de erro", "Estado dos discos (RAID)", "Atualizações críticas do SO" });
                                    }
                                    else if (eqType.Contains("monitor") || eqType.Contains("ecrã") || eqType.Contains("screen"))
                                    {
                                        items.AddRange(new[] { "Teste de pixéis mortos", "Calibração de brilho e contraste", "Limpeza de ecrã com produto adequado", "Verificação de cabos de vídeo (HDMI/DP/VGA)" });
                                    }
                                    
                                    items.Add("Teste final de funcionamento");
                                }

                                @foreach (var item in items)
                                {
                                    <label class="d-flex align-items-center gap-3 p-3 border rounded cursor-pointer preventive-check-item transition-all" 
                                           style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important; border-radius: 12px;">
                                        <input type="checkbox" class="form-check-input mt-0" style="width:1.4rem; height:1.4rem; border-color: rgba(255,255,255,0.2);" />
                                        <span style="font-size:0.95rem; font-weight: 500; color: #fff;">@item</span>
                                    </label>
                                }
                            </div>

                            <div class="p-3 rounded-3 border mt-5" style="background: rgba(255, 171, 0, 0.05); border-color: rgba(255, 171, 0, 0.2) !important;">
                                <h6 class="fw-bold mb-3 text-warning d-flex align-items-center text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="ri-error-warning-line me-2 fs-5"></i>Reportar Avaria Encontrada</h6>
                                <p class="small text-muted mb-3">Descreva anomalias detetadas durante a manutenção deste equipamento:</p>
                                
                                <form method="post" asp-page-handler="AddAnomaly" asp-route-ticketId="@t.Id" asp-route-SelectedTicketId="@t.Id">
                                    <input type="hidden" name="eqName" value="@eq.Name" />
                                    <textarea name="comment" class="form-control mb-3 text-white border-secondary" style="background: rgba(0,0,0,0.2) !important; border-radius: 8px;" rows="2" placeholder="Ex: @eq.Name apresenta ruído excessivo na ventoinha..."></textarea>
                                    <button type="submit" class="btn btn-warning btn-sm w-100 fw-bold">
                                        <i class="ri-alert-line me-1"></i> Registar Anomalia em @eq.Name
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Tab: Stock -->
            <div class="tk-tab-content d-none" id="tab-1">
                <div class="tk-stock-top">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="tk-info-label">Material Disponível</div>
                        <div class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary);">@Model.CountStock itens</div>
                    </div>
                    <div class="tk-scope-row">
                        <button class="tk-scope-btn @(Model.StockScope =="Escola" ?"active" :"")" onclick="setStockScope('Escola')">Escola</button>
                        <button class="tk-scope-btn @(Model.StockScope =="Global" ?"active" :"")" onclick="setStockScope('Global')">Global</button>
                    </div>
                    <div class="tk-stock-list">
                        @foreach (var eq in Model.AvailableEquipment)
                        {
                            <div class="tk-avail-item">
                                <div class="tk-avail-icon"><i class="ri-cpu-line"></i></div>
                                <div class="tk-avail-info">
                                    <div class="tk-avail-name">@eq.Name</div>
                                    <div class="tk-avail-sub">S/N: @eq.SerialNumber</div>
                                </div>
                                @if(t.Status !="Concluído") {
                                    <form method="post" asp-page-handler="AssociateEquipment" asp-route-ticketId="@t.Id" asp-route-equipmentId="@eq.Id" asp-route-SelectedTicketId="@t.Id">
                                        <button type="submit" class="btn-assoc">Associar</button>
                                    </form>
                                } else {
                                    <div class="small text-muted">Ticket Fechado</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Tab: Histórico -->
            <div class="tk-tab-content d-none" id="tab-2">
                <div class="tk-timeline">
                    @foreach (var h in Model.TicketHistory)
                    {
                        <div class="tk-hist-item">
                            @{
                                var dotCol = h.TipoAcao switch {
                                    TipoAcaoHistorico.Status =>"var(--tk-primary)",
                                    TipoAcaoHistorico.Comentario =>"var(--tk-purple)",
                                    TipoAcaoHistorico.Equipamento =>"var(--tk-green)",
                                    _ =>"var(--tk-muted)"
                                };
                            }
                            <div class="tk-hist-dot" style="color: @dotCol; border-color: @dotCol;"><i class="ri-record-circle-line"></i></div>
                            <div class="tk-hist-top">
                                @{
                                    var isAvaria = h.Acao?.ToUpper().Contains("[AVARIA]") ?? false;
                                    if (isAvaria) dotCol = "#ef4444";
                                }
                                <span class="tk-hist-action" style="@(isAvaria ? "color: #ef4444; font-weight: bold;" : "")">@h.Acao</span>
                                <span class="tk-hist-date">@h.Data.ToString("dd/MM HH:mm")</span>
                            </div>
                            <div class="tk-hist-by">Por @h.Autor</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if(t.Status !="Concluído") {
            <div class="tk-footer">
                <form method="post" asp-page-handler="AddComment" asp-route-ticketId="@t.Id" asp-route-SelectedTicketId="@t.Id" class="d-flex w-100 gap-2">
                    <input type="text" name="comment" class="tk-comment" placeholder="Adicionar nota técnica ou comentário..." required autocomplete="off">
                    <button type="submit" class="tk-send-btn">✈ Enviar</button>
                </form>
            </div>
        } else {
            <div class="tk-footer" style="background: rgba(0,0,0,0.2); justify-content: center; opacity: 0.6;">
                <span class="small text-muted"><i class="ri-lock-line me-1"></i> Este ticket está concluído e não permite mais alterações.</span>
            </div>
        }
    }
</div>

@section PageScripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const panelEl = document.getElementById('tkPanel');
    const overlayEl = document.getElementById('tkOverlay');

    function switchChecklist(id) {
        if (!id) return;
        document.querySelectorAll('.eq-checklist-container').forEach(c => c.classList.add('d-none'));
        const target = document.getElementById('checklist-' + id);
        if (target) target.classList.remove('d-none');
        
        // Update selectors if any buttons remain
        document.querySelectorAll('.eq-selector').forEach(b => {
            if (b.getAttribute('onclick')?.includes(id)) b.classList.add('active');
            else b.classList.remove('active');
        });
    }

    function setOrcamentoTicketId(id) {
        document.getElementById('orcamentoTicketId').value = id;
    }

    function openPanel(id) {
        const url = new URL(window.location.href);
        url.searchParams.set('SelectedTicketId', id);
        window.location.href = url.toString();
    }

    function closePanel() {
        if (panelEl) panelEl.classList.remove('open');
        if (overlayEl) overlayEl.classList.remove('open');
        const url = new URL(window.location.href);
        url.searchParams.delete('SelectedTicketId');
        history.replaceState(null, '', url.toString());
    }

    function updateCheckSpecificTypes() {
        const artigo = document.getElementById('checkAnomalyArtigo').value;
        const divTipo = document.getElementById('divCheckAnomalyTipo');
        const tipoSelect = document.getElementById('checkAnomalyTipo');
        const submitBtn = document.querySelector('button[type="submit"].btn-primary.w-100.mt-4');
        
        if (!artigo) {
            divTipo.style.display = 'none';
            tipoSelect.value = '';
            return;
        }

        divTipo.style.display = 'block';
        tipoSelect.value ="";
        
        let visibleCount = 0;
        Array.from(tipoSelect.options).forEach(opt => {
            if (!opt.value) return;
            const dataArt = opt.getAttribute('data-artigo');
            const match = (dataArt === artigo);
            opt.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        if (visibleCount === 0) divTipo.style.display = 'none';
    }

    function showTab(id) {
        document.querySelectorAll('.tk-tab-content').forEach(c => c.classList.add('d-none'));
        const target = document.getElementById(id);
        if (target) target.classList.remove('d-none');
        
        document.querySelectorAll('.tk-tab').forEach(t => {
            t.classList.toggle('active', t.getAttribute('data-tab') === id);
        });
    }

    function toggleFilter(status) {
        const current = document.getElementById('filterStatusHidden').value;
        document.getElementById('filterStatusHidden').value = (current === status) ? '' : status;
        document.querySelector('.tk-filters').submit();
    }

    // Cascading Filters for Modal
    function prevFilterEscolas() {
        const agrId = document.getElementById('prevFilterAgrupamento').value;
        const escSelect = document.getElementById('prevFilterEscola');
        
        Array.from(escSelect.options).forEach(opt => {
            if (!opt.value) return;
            const match = (!agrId || opt.getAttribute('data-agr') === agrId);
            opt.style.display = match ? '' : 'none';
            if (!match && escSelect.value === opt.value) escSelect.value ="";
        });
        
        if ($(escSelect).data('select2')) $(escSelect).trigger('change.select2');
        prevFilterBlocos();
    }

    function prevFilterBlocos() {
        const escId = document.getElementById('prevFilterEscola').value;
        const blcSelect = document.getElementById('prevFilterBloco');
        
        Array.from(blcSelect.options).forEach(opt => {
            if (!opt.value) return;
            const match = (!escId || opt.getAttribute('data-esc') === escId);
            opt.style.display = match ? '' : 'none';
            if (!match && blcSelect.value === opt.value) blcSelect.value ="";
        });

        if ($(blcSelect).data('select2')) $(blcSelect).trigger('change.select2');
    }

    function setStockScope(scope) {
        const url = new URL(window.location.href);
        url.searchParams.set('StockScope', scope);
        window.location.href = url.toString();
    }

    function applyStockSearch() {
        const val = document.getElementById('stockSearchInput').value;
        const url = new URL(window.location.href);
        url.searchParams.set('StockSearch', val);
        window.location.href = url.toString();
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Initialize Select2
        $('.select2-modal').each(function() {
            var $this = $(this);
            $this.select2({
                dropdownParent: $this.closest('.modal-content')
            });
        });

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('SelectedTicketId')) {
            if (panelEl) panelEl.classList.add('open');
            if (overlayEl) overlayEl.classList.add('open');
        }
        if (urlParams.has('StockSearch') || urlParams.has('StockScope')) {
            showTab('tab-1');
        }

        initMap();
        setTimeout(() => { if(window.mapInstance) window.mapInstance.invalidateSize(); }, 500);

        // Initialize cascading states
        if (document.getElementById('prevFilterAgrupamento')) {
            prevFilterEscolas();
        }
    });

    async function initMap() {
        const mapDiv = document.getElementById('clientMap');
        if (!mapDiv) return;
        var map = L.map('clientMap').setView([41.5454, -8.4265], 11);
        window.mapInstance = map;
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
            maxZoom: 19
        }).addTo(map);

        // Define custom icons
        var greenIcon = new L.Icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        });

        var yellowIcon = new L.Icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-yellow.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        });

        var blueIcon = new L.Icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-blue.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        });

        const geoCacheKey = 'asnet_geocache';
        let geoCache = {};
        try {
            geoCache = JSON.parse(localStorage.getItem(geoCacheKey) || '{}');
        } catch (e) { console.error('Cache parse error', e); }

        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw && locationsRaw !== 'null') {
            try {
                var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
                
                // Add debug counter if header exists
                const header = document.querySelector('.card-header h5');
                if (header) { header.innerHTML += ` <small class="text-muted">(${locations.length} locais detetados)</small>`; }

                for (let i = 0; i < locations.length; i++) {
                    const loc = locations[i];
                    if (loc.address) {
                        const cacheEntry = geoCache[loc.address];
                        if (cacheEntry && cacheEntry.lat && cacheEntry.lon) {
                            addMarkerToMap(loc, cacheEntry.lat, cacheEntry.lon);
                        } else {
                            try {
                                // Try 1: Full address with context
                                let q1 = loc.address +", Braga, Portugal";
                                let response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(q1)}`);
                                let data = await response.json();
                                
                                // Try 2: If fail, try just the name with context
                                if (!data || data.length === 0) {
                                    let q2 = loc.name +", Braga, Portugal";
                                    response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(q2)}`);
                                    data = await response.json();
                                }

                                if (data && data.length > 0) {
                                    const result = data[0];
                                    geoCache[loc.address] = { lat: result.lat, lon: result.lon };
                                    localStorage.setItem(geoCacheKey, JSON.stringify(geoCache));
                                    addMarkerToMap(loc, result.lat, result.lon);
                                } else {
                                    console.warn('Could not find location:', loc.name);
                                }
                            } catch (error) {
                                console.error('Geocoding error:', error);
                            }
                            if (locations.length > 1) await new Promise(resolve => setTimeout(resolve, 1000));
                        }
                    }
                }
            } catch (e) { console.error("Map data error:", e); }
        }

        function addMarkerToMap(loc, lat, lon) {
            let markerIcon = blueIcon;
            let statusLabel ="";
            let debugInfo =""; 
            
            const isInProgress = loc.hasInProgress || loc.hasInProgress ==="True" || loc.hasInProgress === true;
            const isCompleted = loc.hasCompleted || loc.hasCompleted ==="True" || loc.hasCompleted === true;
            const isPending = loc.hasPending || loc.hasPending ==="True" || loc.hasPending === true;

            if (isInProgress) {
                markerIcon = yellowIcon;
                statusLabel ="<br><span class='badge bg-label-warning mt-2'>Em Progresso</span>";
            } else if (isCompleted) {
                markerIcon = greenIcon;
                statusLabel ="<br><span class='badge bg-label-success mt-2'>Concluído</span>";
            } else if (isPending) {
                markerIcon = blueIcon;
                statusLabel ="<br><span class='badge bg-label-info mt-2'>Pendente</span>";
            } else {
                debugInfo ="<br><small style='color:gray'>(Sem estado detetado)</small>";
            }

            L.marker([lat, lon], {icon: markerIcon})
             .addTo(map)
             .bindPopup(`<b>${loc.name}</b><br>${loc.address}${statusLabel}${debugInfo}<br><small class="text-muted">Tickets: ${loc.ticketCount || 1}</small>`);
        }
    }
</script>
}



