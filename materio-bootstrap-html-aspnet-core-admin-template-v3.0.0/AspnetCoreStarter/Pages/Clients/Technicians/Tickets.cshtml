@page
@model AspnetCoreStarter.Pages.Clients.Technicians.TicketsModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Trabalhos - Técnico";
}

@section PageStyles {
<link rel="stylesheet" href="~/css/tickets-v2.css" asp-append-version="true" />
<style>
    .tk-page { padding-top: 0; }
    .tk-filters { margin-top: 20px; }
</style>
}

<div class="tk-page">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-white">Os Meus Trabalhos</h1>
            <p class="text-muted mb-0">@Model.Tickets.Count tickets atribuídos • @Model.AvailableTickets.Count novos disponíveis</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="tk-stats">
        <div class="tk-stat @(Model.FilterStatus == "Aberto" ? "active-blue" : "active-grey")" onclick="setFilter('Aberto')">
            <div class="tk-stat-label">Disponíveis</div>
            <div class="tk-stat-num num-blue">@Model.AvailableTickets.Count</div>
        </div>
        <div class="tk-stat @(Model.FilterStatus == "Em Reparação" ? "active-amber" : "active-grey")" onclick="setFilter('Em Reparação')">
            <div class="tk-stat-label">Em Curso</div>
            <div class="tk-stat-num num-amber">@Model.Tickets.Count(t => t.Status != "Concluído")</div>
        </div>
        <div class="tk-stat @(Model.FilterStatus == "Concluído" ? "active-green" : "active-grey")" onclick="setFilter('Concluído')">
            <div class="tk-stat-label">Concluídos</div>
            <div class="tk-stat-num num-green">@Model.Tickets.Count(t => t.Status == "Concluído")</div>
        </div>
        <div class="tk-stat @(string.IsNullOrEmpty(Model.FilterStatus) || Model.FilterStatus == "Todos" ? "active-blue" : "active-grey")" onclick="setFilter('Todos')">
            <div class="tk-stat-label">Total Atribuídos</div>
            <div class="tk-stat-num text-white">@Model.Tickets.Count</div>
        </div>
    </div>

    <!-- Filters -->
    <div class="tk-filters">
        <input type="text" class="tk-search" placeholder="Pesquisar trabalhos por ID, escola ou equipamento..." id="tkSearch">
        
        <select class="tk-select" id="filterArtigo" onchange="applyFilters()">
            <option value="">Todos os tipos</option>
            <option value="Computadores">Computadores</option>
            <option value="Monitores">Monitores</option>
            <option value="Impressoras">Impressoras</option>
            <option value="Networking">Networking</option>
        </select>

        <button class="tk-send-btn" style="padding: 10px 20px;" onclick="applyFilters()">Filtrar</button>
    </div>

    <!-- Ticket List -->
    <div class="tk-list">
        @if (!Model.Tickets.Any() && !Model.AvailableTickets.Any())
        {
            <div class="tk-row" style="justify-content:center; cursor:default; background: rgba(255,255,255,0.02);">
                <p class="text-white-50 mb-0 py-4">Nenhum trabalho encontrado com os critérios selecionados.</p>
            </div>
        }

        @* Se o filtro for "Aberto" ou "Todos", mostrar os disponíveis primeiro *@
        @if (string.IsNullOrEmpty(Model.FilterStatus) || Model.FilterStatus == "Aberto" || Model.FilterStatus == "Todos")
        {
            @foreach (var t in Model.AvailableTickets)
            {
                <div class="tk-row" onclick="openTicketPanel(@t.Id)" style="border-left: 4px solid var(--tk-primary);">
                    <div class="tk-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.2rem;">
                        @{
                            var type = t.Equipamento?.Type ?? "";
                            var name = t.Equipamento?.Name ?? "";
                            var emoji = type switch {
                                var s when s.Contains("Monitor") => "🖥️",
                                var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") => "💻",
                                var s when s.Contains("Impressora") => "🖨️",
                                var s when s.Contains("Rede") || s.Contains("Network") => "🌐",
                                var s when s.Contains("Projetor") => "📽️",
                                var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                                var s when s.Contains("Teclado") => "⌨️",
                                _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : "🔧")
                            };
                        }
                        @emoji
                    </div>
                    <div class="tk-main">
                        <div class="tk-meta">
                            <span class="tk-id">#@t.Id</span>
                            <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">NOVO DISPONÍVEL</span>
                            @if (!string.IsNullOrEmpty(t.Level)) {
                                var c = t.Level.Contains("Alt") || t.Level.Contains("Crít") ? "var(--tk-red)" : "var(--tk-amber)";
                                <span class="badge-tk" style="color: @c; border-color: @c; background: @(c)11;">@t.Level</span>
                            }
                        </div>
                        <div class="tk-title">@(t.Equipamento?.Name ?? "Avaria Geral")</div>
                        <div class="tk-sub">
                            <i class="ri-map-pin-line me-1"></i> @(t.School?.Name ?? "Sede") • @(t.Equipamento?.Room?.Name ?? "N/A")
                        </div>
                    </div>
                    <div class="tk-right">
                        <span class="badge-tk" style="color: var(--tk-muted); border-color: var(--tk-border);">Aguardando Técnico</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </div>
                </div>
            }
        }

        @* Mostrar os atribuídos *@
        @foreach (var t in Model.Tickets)
        {
            <div class="tk-row" onclick="openTicketPanel(@t.Id)">
                <div class="tk-icon" style="background: rgba(255, 171, 0, 0.05); color: var(--tk-muted); font-size: 1.2rem;">
                    @{
                        var type = t.Equipamento?.Type ?? "";
                        var name = t.Equipamento?.Name ?? "";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") => "🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                            var s when s.Contains("Impressora") => "🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                            var s when s.Contains("Projetor") => "📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                            _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-main">
                    <div class="tk-meta">
                        <span class="tk-id">#@t.Id</span>
                        <span class="badge-tk" style="background: rgba(255,255,255,0.05); color: var(--tk-muted); border-color: var(--tk-border);">
                            @(t.Equipamento?.Type ?? "Geral")
                        </span>
                        @if (!string.IsNullOrEmpty(t.Level)) {
                            var c = t.Level.Contains("Alt") || t.Level.Contains("Crít") ? "var(--tk-red)" : "var(--tk-amber)";
                            <span class="badge-tk" style="color: @c; border-color: @c; background: @(c)11;">@t.Level</span>
                        }
                    </div>
                    <div class="tk-title">@(t.Equipamento?.Name ?? "Avaria Geral")</div>
                    <div class="tk-sub">
                        <i class="ri-map-pin-line me-1"></i> @(t.School?.Name ?? "Sede") • @(t.Equipamento?.Room?.Name ?? "N/A")
                    </div>
                </div>
                <div class="tk-right">
                    @{
                        var stCol = t.Status switch {
                            "Concluído" => "var(--tk-green)",
                            "Em Reparação" or "Em Resolução" => "var(--tk-primary)",
                            _ => "var(--tk-muted)"
                        };
                    }
                    <span class="badge-tk" style="color: @stCol; border-color: @stCol; background: @(stCol)11;">@t.Status</span>
                    <i class="ri-arrow-right-s-line text-muted"></i>
                </div>
            </div>
        }
    </div>

    <!-- Map Section -->
    <div class="row mt-5 mb-4">
        <div class="col-12">
            <div class="card bg-transparent border-0 shadow-none">
                <div class="card-header px-0 d-flex align-items-center gap-2 text-white pb-3">
                    <i class="ri-map-pin-line" style="color: var(--tk-primary); font-size: 1.2rem;"></i>
                    <h5 class="mb-0 text-white fw-bold">Mapa de Intervenções</h5>
                </div>
                <div class="card-body p-0 rounded-4 overflow-hidden border border-secondary border-opacity-10">
                    <div id="clientMap" style="height: 400px; width: 100%;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Panel Overlay & Slide-over Panel -->
<div class="tk-overlay @(Model.SelectedTicketId.HasValue ? "open" : "")" onclick="closeTicketPanel()"></div>

<div class="tk-panel @(Model.SelectedTicketId.HasValue ? "open" : "")" id="ticketPanel">
    @if (Model.SelectedTicket != null)
    {
        var t = Model.SelectedTicket;
        
        <div class="tk-ph">
            <div class="tk-ph-top">
                <div class="tk-ph-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.5rem; display: flex; align-items: center; justify-content: center;">
                    @{
                        var type = t.Equipamento?.Type ?? "";
                        var name = t.Equipamento?.Name ?? "";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") => "🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                            var s when s.Contains("Impressora") => "🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                            var s when s.Contains("Projetor") => "📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                            _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-ph-info">
                    <div class="tk-ph-badges">
                        <span class="badge-tk" style="color: var(--tk-muted); border-color: var(--tk-border);">TK-@t.Id.ToString("D3")</span>
                        @if(!string.IsNullOrEmpty(t.Type)) {
                            <span class="badge-tk" style="color: var(--tk-amber); border-color: var(--tk-amber); background: rgba(245, 158, 11, 0.1);">@t.Type</span>
                        }
                        <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">@t.Status</span>
                    </div>
                    <h2 class="tk-ph-title">@(t.Equipamento?.Name ?? "Avaria Geral"): @(t.Description?.Length > 30 ? t.Description.Substring(0, 30) + "..." : t.Description)</h2>
                </div>
                <button class="tk-close" onclick="closeTicketPanel()">✕</button>
            </div>

            <div class="tk-stepper">
                @{
                    var steps = new[] { "Aberto", "Aceite", "Em Reparação", "Concluído" };
                    int si = Array.IndexOf(steps, t.Status);
                    if (si == -1 && t.Status == "Pedido") si = 0;
                    if (si == -1 && t.Status == "Em Resolução") si = 2;
                    if (si == -1 && t.Status == "Pendente") si = 0;
                    
                    var nextLabel = si < 3 ? (si == 0 ? "Aceite" : si == 1 ? "Em Reparação" : "Concluído") : "";
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i < si || t.Status == "Concluído";
                    bool active = i == si && t.Status != "Concluído";
                    <div class="tk-step">
                        @if (i < steps.Length - 1) {
                            <div class="tk-step-line @(i < si || t.Status == "Concluído" ? "done" : "")"></div>
                        }
                        <div class="tk-step-dot @(done ? "done" : "") @(active ? "active" : "")">
                            @(done ? "✓" : (i + 1).ToString())
                        </div>
                        <div class="tk-step-label @(active ? "active" : "")">@steps[i]</div>
                    </div>
                }
            </div>

            @if (t.Status != "Concluído" && si < 3)
            {
                <div class="tk-advance-row">
                    @if (t.Status == "Em Reparação" || t.Status == "Em andamento" || t.Status == "Em Resolução")
                    {
                        <div class="d-flex gap-2 w-100">
                            <form method="post" asp-page-handler="CompleteRepaired" asp-route-ticketId="@t.Id" class="flex-grow-1">
                                <button type="submit" class="tk-advance-btn w-100" style="background: #28a745 !important; color: white !important;">
                                    <i class="ri-checkbox-circle-line me-1"></i> Reparado
                                </button>
                            </form>
                            <form method="post" asp-page-handler="CompleteUnrepairable" asp-route-ticketId="@t.Id" class="flex-grow-1">
                                <button type="submit" class="tk-advance-btn w-100" style="background: #dc3545 !important; color: white !important;">
                                    <i class="ri-close-circle-line me-1"></i> Sem Reparação
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="AdvanceStatus" asp-route-ticketId="@t.Id">
                            <button type="submit" class="tk-advance-btn">→ Avançar para "@nextLabel"</button>
                        </form>
                    }
                </div>
            }
        </div>

        <div class="tk-tabs">
            <div class="tk-tab active" onclick="showTab(0)">📁 Detalhes</div>
            <div class="tk-tab" onclick="showTab(1)">📦 Stock (@Model.AssociatedEquipment.Count)</div>
            <div class="tk-tab" onclick="showTab(2)">🕒 Histórico</div>
        </div>

        <div class="tk-body">
            <!-- Tab: Detalhes -->
            <div class="tk-tab-content" id="tab-0">
                <div class="tk-info-grid">
                    <div class="tk-info-card"><div class="tk-info-label">Solicitante</div><div class="tk-info-val">@(t.RequestedBy?.Username ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Técnico Responsável</div><div class="tk-info-val">@(t.Technician?.Username ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Escola</div><div class="tk-info-val">@(t.School?.Name ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Agrupamento</div><div class="tk-info-val">@(t.School?.Agrupamento?.Name ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Criado em</div><div class="tk-info-val">@t.CreatedAt.ToString("dd/MM/yyyy, HH:mm")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Atualizado em</div><div class="tk-info-val">@DateTime.Now.ToString("dd/MM/yyyy, HH:mm")</div></div>
                </div>
                
                <div class="tk-desc-card">
                    <div class="tk-info-label">Descrição</div>
                    <div style="margin-top:6px;font-size:14px;line-height:1.6">@t.Description</div>
                </div>

                @{ var comments = Model.TicketHistory.Where(h => h.TipoAcao == TipoAcaoHistorico.Comentario).ToList(); }
                <div style="margin-top:20px;margin-bottom:20px">
                    <div class="tk-info-label">Notas Técnicas</div>
                    @if (!comments.Any()) {
                        <div style="color:var(--tk-muted);font-size:13px;padding:10px 0">Sem notas registadas.</div>
                    } else {
                        <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px">
                            @foreach(var c in comments) {
                                <div style="background:#1a232e;border-left:3px solid var(--tk-primary);padding:10px 14px;border-radius:0 8px 8px 0">
                                    <div style="font-size:13px;line-height:1.5">@c.Acao</div>
                                    <div style="font-size:11px;color:var(--tk-muted);margin-top:4px">@c.Autor · @c.Data.ToString("dd/MM HH:mm")</div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (Model.AssociatedEquipment.Any())
                {
                    <div class="tk-eq-card">
                        <div class="tk-eq-header">@Model.AssociatedEquipment.Count equipamento(s) associado(s)</div>
                        @foreach (var eq in Model.AssociatedEquipment)
                        {
                            <div class="tk-eq-item">
                                <span><strong>@eq.Name</strong> · <span style="color:#6b7280;font-size:12px">@eq.SerialNumber</span></span>
                                @if(t.Status != "Concluído") {
                                    <form method="post" asp-page-handler="RemoveEquipment" asp-route-ticketId="@t.Id" asp-route-equipmentId="@eq.Id" style="display:inline">
                                        <button type="submit" class="btn-remove" style="background:transparent;border:none;color:var(--tk-red);font-size:12px;cursor:pointer">Remover</button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Tab: Stock -->
            <div class="tk-tab-content d-none" id="tab-1">
                <div class="tk-stock-top">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="tk-info-label">Material Disponível</div>
                        <div class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary);">@Model.CountStock itens</div>
                    </div>
                    <div class="tk-scope-row">
                        <button class="tk-scope-btn @(Model.StockScope == "Escola" ? "active" : "")" onclick="setStockScope('Escola')">Escola</button>
                        <button class="tk-scope-btn @(Model.StockScope == "Global" ? "active" : "")" onclick="setStockScope('Global')">Global</button>
                    </div>
                    <div class="tk-stock-list">
                        @foreach (var eq in Model.AvailableEquipment)
                        {
                            <div class="tk-avail-item">
                                <div class="tk-avail-icon"><i class="ri-cpu-line"></i></div>
                                <div class="tk-avail-info">
                                    <div class="tk-avail-name">@eq.Name</div>
                                    <div class="tk-avail-sub">S/N: @eq.SerialNumber</div>
                                </div>
                                @if(t.Status != "Concluído") {
                                    <form method="post" asp-page-handler="AssociateEquipment" asp-route-ticketId="@t.Id" asp-route-equipmentId="@eq.Id">
                                        <button type="submit" class="btn-assoc">Associar</button>
                                    </form>
                                } else {
                                    <div class="small text-muted">Ticket Fechado</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Tab: Histórico -->
            <div class="tk-tab-content d-none" id="tab-2">
                <div class="tk-timeline">
                    @foreach (var h in Model.TicketHistory)
                    {
                        <div class="tk-hist-item">
                            @{
                                var dotCol = h.TipoAcao switch {
                                    TipoAcaoHistorico.Status => "var(--tk-primary)",
                                    TipoAcaoHistorico.Comentario => "var(--tk-purple)",
                                    TipoAcaoHistorico.Equipamento => "var(--tk-green)",
                                    _ => "var(--tk-muted)"
                                };
                            }
                            <div class="tk-hist-dot" style="color: @dotCol; border-color: @dotCol;"><i class="ri-record-circle-line"></i></div>
                            <div class="tk-hist-top">
                                <span class="tk-hist-action">@h.Acao</span>
                                <span class="tk-hist-date">@h.Data.ToString("dd/MM HH:mm")</span>
                            </div>
                            <div class="tk-hist-by">Por @h.Autor</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if(t.Status != "Concluído") {
            <div class="tk-footer">
                <form method="post" asp-page-handler="AddComment" asp-route-ticketId="@t.Id" class="d-flex w-100 gap-2">
                    <input type="text" name="comment" class="tk-comment" placeholder="Adicionar nota técnica ou comentário..." required autocomplete="off">
                    <button type="submit" class="tk-send-btn">✈ Enviar</button>
                </form>
            </div>
        } else {
            <div class="tk-footer" style="background: rgba(0,0,0,0.2); justify-content: center; opacity: 0.6;">
                <span class="small text-muted"><i class="ri-lock-line me-1"></i> Este ticket está concluído e não permite mais alterações.</span>
            </div>
        }
    }
</div>

@section PageScripts {
<script>
    function openTicketPanel(id) {
        const url = new URL(window.location);
        url.searchParams.set('SelectedTicketId', id);
        window.location.href = url.toString();
    }
    function closeTicketPanel() {
        const url = new URL(window.location);
        url.searchParams.delete('SelectedTicketId');
        window.location.href = url.toString();
    }
    function showTab(idx) {
        document.querySelectorAll('.tk-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
        document.querySelectorAll('.tk-tab-content').forEach((c, i) => c.classList.toggle('d-none', i !== idx));
    }
    function setFilter(status) {
        const url = new URL(window.location);
        if (status === 'Todos') url.searchParams.delete('FilterStatus');
        else url.searchParams.set('FilterStatus', status);
        window.location.href = url.toString();
    }
    function setStockScope(scope) {
        const url = new URL(window.location);
        url.searchParams.set('StockScope', scope);
        window.location.href = url.toString();
    }

    // Map Init
    function initMap() {
        var myLatLng = { lat: 41.5454, lng: -8.4265 };
        var map = new google.maps.Map(document.getElementById('clientMap'), {
            zoom: 11, center: myLatLng,
            styles: [{ elementType: 'geometry', stylers: [{ color: '#242f3e' }] }, { elementType: 'labels.text.fill', stylers: [{ color: '#746855' }] }]
        });
        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw && locationsRaw !== 'null') {
            var locations = JSON.parse(locationsRaw);
            var geocoder = new google.maps.Geocoder();
            locations.forEach(loc => {
                if (loc.address) {
                    geocoder.geocode({ 'address': loc.address + ", Portugal" }, function(results, status) {
                        if (status === 'OK') {
                            new google.maps.Marker({ map: map, position: results[0].geometry.location, title: loc.name, icon: 'https://maps.google.com/mapfiles/ms/icons/yellow-dot.png' });
                        }
                    });
                }
            });
        }
    }
</script>
<script async defer src="https://maps.googleapis.com/maps/api/js?key=&callback=initMap"></script>
}
