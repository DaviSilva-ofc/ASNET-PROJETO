@page
@model AspnetCoreStarter.Pages.Clients.Technicians.TechnicianInfrastructureModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Explorador de Infraestrutura";
}

@section PageStyles {
<style>
    :root {
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-dark: #2b2c40;
    }

    .dark-style .card, [data-bs-theme="dark"] .card {
        background: var(--asnet-dark) !important;
        border: none !important;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2) !important;
    }

    .bg-light-section {
        background-color: rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.2s;
    }
    .bg-light-section:hover {
        background-color: rgba(255, 255, 255, 0.06);
    }

    .infra-tree .tree-node {
        position: relative;
        padding: 4px 0;
    }

    .tree-node i {
        font-size: 1.1rem;
        vertical-align: middle;
        opacity: 0.8;
    }

    .cursor-pointer { cursor: pointer; }

    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold;
        color: #696cff;
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        padding: 3px;
        margin-right: 8px;
    }
    
    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: #696cff;
        color: #fff;
    }

    .school-node { color: #71dd37; }
    .bloc-node { color: #03c3ec; }
    .room-node { color: #ffab00; }
    .director-node { color: #e1e1e3; }
    .equip-node { color: #707186; }

    /* Orange Banner Styling to match Admin */
    .banner-header {
        background: #f89223 !important; /* The precise orange from the screenshot */
        color: white !important;
        padding: 1rem 1.5rem;
        border-radius: 8px 8px 0 0;
        cursor: pointer;
    }
    .banner-header h5 { color: white !important; font-weight: 700; margin-bottom: 0; }

    .nav-tabs .nav-link.active {
        background-color: rgba(105, 108, 255, 0.1) !important;
        border-bottom: 3px solid #696cff !important;
        color: #696cff !important;
        font-weight: 600;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="row align-items-center mb-4">
        <div class="col-12">
            <h4 class="fw-bold py-3 mb-0">
                <span class="text-white-50 fw-light">Técnico /</span> Gestão da Infraestrutura
            </h4>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#navs-schools">
                    <i class="ri-organization-chart me-1"></i> Agrupamentos
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#navs-companies">
                    <i class="ri-building-line me-1"></i> Empresas
                </button>
            </li>
        </ul>

        <div class="tab-content bg-transparent p-0 border-0 mt-4">
            <!-- Agrupamentos Tab -->
            <div class="tab-pane fade show active" id="navs-schools" role="tabpanel">
                <div class="row g-4">
                    @foreach (var client in Model.Clients)
                    {
                        <div class="col-12 mb-3">
                            <div class="card shadow-sm border-0">
                                <div class="banner-header d-flex justify-content-between align-items-center"
                                     data-bs-toggle="collapse" data-bs-target="#client-@client.Agrupamento.Id">
                                    <h5 class="mb-0">@client.Agrupamento.Name - @client.DirectorName</h5>
                                    <i class="ri-arrow-down-s-line fs-4"></i>
                                </div>
                                <div id="client-@client.Agrupamento.Id" class="collapse show">
                                    <div class="card-body pt-4">
                                        <div class="row">
                                            <!-- Coluna Tickets -->
                                            <div class="col-md-4 mb-3">
                                                <div class="p-4 h-100 bg-light-section">
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <h6 class="mb-0 fw-bold text-white"><i class="ri-ticket-2-line me-2 text-primary"></i>Tickets</h6>
                                                    </div>
                                                    <h3 class="mb-1 text-primary fw-bold">@client.TicketCount</h3>
                                                    <p class="text-white-50 small mb-3">Tickets ativos em todas as escolas</p>
                                                    <a asp-page="/Clients/Technicians/Tickets" asp-route-FilterAgrupamentoId="@client.Agrupamento.Id" class="btn btn-sm btn-outline-primary w-100">Gerir Tickets</a>
                                                </div>
                                            </div>

                                            <!-- Coluna Equipamento Avariado -->
                                            <div class="col-md-4 mb-3">
                                                <div class="p-4 h-100 bg-light-section">
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <h6 class="mb-0 fw-bold text-white"><i class="ri-error-warning-line me-2 text-danger"></i>Avariados</h6>
                                                    </div>
                                                    <h3 class="mb-1 text-danger fw-bold">@client.DamagedEquipCount</h3>
                                                    <p class="text-white-50 small mb-3">Equipamentos com estado "Avariado"</p>
                                                    <a asp-page="/Clients/Technicians/Equipment" asp-route-FilterAgrupamentoId="@client.Agrupamento.Id" asp-route-FilterStatus="Avariado" class="btn btn-sm btn-outline-danger w-100">Ver Avariados</a>
                                                </div>
                                            </div>

                                            <!-- Coluna Agrupamento (Árvore) -->
                                            <div class="col-md-4 mb-3">
                                                <div class="p-4 h-100 bg-light-section">
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <h6 class="mb-0 fw-bold text-white"><i class="ri-node-tree me-2 text-warning"></i>Agrupamento</h6>
                                                    </div>
                                                    <div class="infra-tree mt-3">
                                                        <div class="tree-node director-node mb-2 d-flex align-items-center">
                                                            <i class="ri-user-star-line me-1"></i> <strong>Diretor: @client.DirectorName</strong>
                                                        </div>
                                                        @foreach (var schoolVm in client.Schools)
                                                        {
                                                            <div class="tree-node school-node ms-2">
                                                                <div class="d-flex align-items-center cursor-pointer p-1" 
                                                                     data-bs-toggle="collapse" data-bs-target="#tree-school-@schoolVm.School.Id">
                                                                    <i class="ri-arrow-right-s-line"></i>
                                                                    <i class="ri-building-line me-1"></i> <strong>@schoolVm.School.Name</strong>
                                                                </div>
                                                                <div id="tree-school-@schoolVm.School.Id" class="collapse">
                                                                    @foreach (var bloc in schoolVm.Blocos)
                                                                    {
                                                                        <div class="tree-node bloc-node ms-4 mt-2">
                                                                            <div class="d-flex align-items-center cursor-pointer p-1" 
                                                                                 data-bs-toggle="collapse" data-bs-target="#tree-rooms-@bloc.Id">
                                                                                <i class="ri-arrow-right-s-line"></i>
                                                                                <i class="ri-box-3-line me-1"></i> @bloc.Name
                                                                            </div>
                                                                            <div id="tree-rooms-@bloc.Id" class="collapse">
                                                                                @{ var rooms = Model.Salas.Where(s => s.BlockId == bloc.Id).ToList(); }
                                                                                @foreach (var room in rooms)
                                                                                {
                                                                                    <div class="tree-node room-node ms-4 mt-1">
                                                                                        <div class="d-flex align-items-center p-1 cursor-pointer" 
                                                                                             data-bs-toggle="collapse" data-bs-target="#tree-equips-@room.Id">
                                                                                            <i class="ri-arrow-right-s-line"></i>
                                                                                            <i class="ri-door-open-line me-1"></i> @room.Name
                                                                                            <a asp-page="/Clients/Technicians/Equipment" asp-route-FilterRoomId="@room.Id" 
                                                                                               class="btn btn-sm btn-icon btn-outline-warning border-0 ms-auto" title="Ver Equipamentos">
                                                                                                <i class="ri-computer-line"></i>
                                                                                            </a>
                                                                                        </div>
                                                                                        
                                                                                        <div id="tree-equips-@room.Id" class="collapse">
                                                                                            @if (room.Equipments != null && room.Equipments.Any())
                                                                                            {
                                                                                                var groupedEquips = room.Equipments
                                                                                                    .GroupBy(e => !string.IsNullOrEmpty(e.Type) ? e.Type : "Outros")
                                                                                                    .Select(g => new { TypeName = g.Key, Count = g.Count() })
                                                                                                    .OrderBy(g => g.TypeName)
                                                                                                    .ToList();

                                                                                                @foreach (var group in groupedEquips)
                                                                                                {
                                                                                                    <div class="tree-node equip-node ms-4 mt-1 small">
                                                                                                        <a asp-page="/Clients/Technicians/Equipment"
                                                                                                           asp-route-FilterRoomId="@room.Id"
                                                                                                           asp-route-FilterType="@group.TypeName"
                                                                                                           class="text-secondary text-decoration-none">
                                                                                                            <i class="ri-computer-line me-1"></i> @group.TypeName (@group.Count)
                                                                                                        </a>
                                                                                                    </div>
                                                                                                }
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <div class="ms-4 mt-1 small text-white-50 italic">Sem equipamentos registados.</div>
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Empresas Tab -->
            <div class="tab-pane fade" id="navs-companies" role="tabpanel">
                <div class="row g-4">
                    @foreach (var empVm in Model.EmpresasInfra)
                    {
                        <div class="col-12 mb-3">
                            <div class="card shadow-sm border-0">
                                <div class="banner-header d-flex justify-content-between align-items-center" style="background: #2b2c40 !important; border-bottom: 3px solid #71dd37 !important;"
                                     data-bs-toggle="collapse" data-bs-target="#emp-@empVm.Empresa.Id">
                                    <h5 class="mb-0 text-white">@empVm.Empresa.Name</h5>
                                    <i class="ri-arrow-down-s-line fs-4 text-white"></i>
                                </div>
                                <div id="emp-@empVm.Empresa.Id" class="collapse show">
                                    <div class="card-body pt-4">
                                        <div class="row">
                                            <div class="col-md-4 mb-3">
                                                <div class="p-4 h-100 bg-light-section">
                                                    <h6 class="mb-3 fw-bold text-white"><i class="ri-ticket-2-line me-2 text-primary"></i>Tickets</h6>
                                                    <h3 class="mb-1 text-primary fw-bold">@empVm.TicketCount</h3>
                                                    <a asp-page="/Clients/Technicians/Tickets" asp-route-FilterEmpresaId="@empVm.Empresa.Id" class="btn btn-sm btn-outline-primary w-100 mt-2">Gerir Tickets</a>
                                                </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <div class="p-4 h-100 bg-light-section">
                                                    <h6 class="mb-3 fw-bold text-white"><i class="ri-error-warning-line me-2 text-danger"></i>Avariados</h6>
                                                    <h3 class="mb-1 text-danger fw-bold">@empVm.DamagedEquipCount</h3>
                                                    <a asp-page="/Clients/Technicians/Equipment" asp-route-FilterEmpresaId="@empVm.Empresa.Id" asp-route-FilterStatus="Avariado" class="btn btn-sm btn-outline-danger w-100 mt-2">Ver Avariados</a>
                                                </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <div class="p-4 h-100 bg-light-section">
                                                    <h6 class="mb-3 fw-bold text-white"><i class="ri-node-tree me-2 text-warning"></i>Empresa</h6>
                                                    <div class="infra-tree mt-2">
                                                        <div class="tree-node school-node">
                                                            <div class="d-flex align-items-center cursor-pointer p-1"
                                                                 data-bs-toggle="collapse" data-bs-target="#tree-departamentos-emp-@empVm.Empresa.Id">
                                                                <i class="ri-arrow-right-s-line"></i>
                                                                <i class="ri-building-line me-1"></i> <strong>@empVm.Empresa.Name</strong>
                                                            </div>

                                                            <div id="tree-departamentos-emp-@empVm.Empresa.Id" class="collapse">
                                                                @if (empVm.Departamentos.Any())
                                                                {
                                                                    @foreach (var dept in empVm.Departamentos.OrderBy(d => d.Name))
                                                                    {
                                                                        <div class="tree-node bloc-node ms-4 mt-1">
                                                                            <div class="d-flex align-items-center cursor-pointer p-1"
                                                                                 data-bs-toggle="collapse" data-bs-target="#tree-setores-emp-@dept.Id">
                                                                                <i class="ri-arrow-right-s-line"></i>
                                                                                <i class="ri-building-4-line me-1"></i> @dept.Name
                                                                            </div>

                                                                            <div id="tree-setores-emp-@dept.Id" class="collapse">
                                                                                @foreach (var setor in dept.Setores.OrderBy(s => s.Name))
                                                                                {
                                                                                    <div class="tree-node school-node ms-4 mt-1">
                                                                                        <div class="d-flex align-items-center cursor-pointer p-1"
                                                                                             data-bs-toggle="collapse" data-bs-target="#tree-salas-emp-@setor.Id">
                                                                                            <i class="ri-arrow-right-s-line"></i>
                                                                                            <i class="ri-layout-grid-line me-1"></i> @setor.Name
                                                                                        </div>

                                                                                        <div id="tree-salas-emp-@setor.Id" class="collapse">
                                                                                            @foreach (var sala in setor.Salas.OrderBy(s => s.Name))
                                                                                            {
                                                                                                <div class="tree-node room-node ms-4 mt-1">
                                                                                                    <div class="d-flex align-items-center cursor-pointer p-1"
                                                                                                         data-bs-toggle="collapse" data-bs-target="#tree-equip-sala-emp-@sala.Id">
                                                                                                        <i class="ri-arrow-right-s-line"></i>
                                                                                                        <i class="ri-door-open-line me-1"></i> @sala.Name
                                                                                                        <span class="ms-2 text-white-50 small">(@(sala.Equipments?.Count ?? 0))</span>
                                                                                                    </div>

                                                                                                    <div id="tree-equip-sala-emp-@sala.Id" class="collapse">
                                                                                                        @if (sala.Equipments != null && sala.Equipments.Any())
                                                                                                        {
                                                                                                            var groupedByType = sala.Equipments
                                                                                                                .GroupBy(e => !string.IsNullOrWhiteSpace(e.Type) ? e.Type : (!string.IsNullOrWhiteSpace(e.Name) ? e.Name : "Outros"))
                                                                                                                .Select(g => new { TypeName = g.Key, Count = g.Count() })
                                                                                                                .OrderBy(g => g.TypeName)
                                                                                                                .ToList();

                                                                                                            @foreach (var group in groupedByType)
                                                                                                            {
                                                                                                                <div class="tree-node equip-node ms-4 mt-1 small">
                                                                                                                    <a asp-page="/Clients/Technicians/Equipment"
                                                                                                                       asp-route-FilterEmpresaId="@empVm.Empresa.Id"
                                                                                                                       asp-route-FilterRoomId="@sala.Id"
                                                                                                                       asp-route-FilterType="@group.TypeName"
                                                                                                                       class="text-secondary text-decoration-none">
                                                                                                                        <i class="ri-computer-line me-1"></i> @group.TypeName (@group.Count)
                                                                                                                    </a>
                                                                                                                </div>
                                                                                                            }
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <div class="ms-4 mt-1 small text-white-50">Sem equipamentos nesta sala.</div>
                                                                                                        }
                                                                                                    </div>
                                                                                                </div>
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <div class="ms-4 mt-1 small text-white-50">Sem departamentos registados.</div>
                                                                }

                                                                @if (empVm.Equipments.Any())
                                                                {
                                                                    <div class="tree-node equip-node ms-4 mt-2">
                                                                        <div class="small fw-semibold text-white-50 mb-1">Equipamentos sem sala</div>
                                                                        @{
                                                                            var groupedDirect = empVm.Equipments
                                                                                .GroupBy(e => !string.IsNullOrWhiteSpace(e.Type) ? e.Type : (!string.IsNullOrWhiteSpace(e.Name) ? e.Name : "Outros"))
                                                                                .Select(g => new { TypeName = g.Key, Count = g.Count() })
                                                                                .OrderBy(g => g.TypeName)
                                                                                .ToList();
                                                                        }
                                                                        @foreach (var group in groupedDirect)
                                                                        {
                                                                            <div class="tree-node equip-node ms-2 mt-1 small">
                                                                                <a asp-page="/Clients/Technicians/Equipment"
                                                                                   asp-route-FilterEmpresaId="@empVm.Empresa.Id"
                                                                                   asp-route-FilterType="@group.TypeName"
                                                                                   class="text-secondary text-decoration-none">
                                                                                    <i class="ri-computer-line me-1"></i> @group.TypeName (@group.Count)
                                                                                </a>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
