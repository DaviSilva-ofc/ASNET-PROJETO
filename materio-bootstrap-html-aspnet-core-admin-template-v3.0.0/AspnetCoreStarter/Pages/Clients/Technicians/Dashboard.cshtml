@page
@model AspnetCoreStarter.Pages.Clients.Technicians.DashboardModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Visão Geral - Técnico";
    ViewData["container"] = "container-fluid";
    ViewData["containerNav"] = "container-fluid";
}

@section PageStyles {
<link rel="stylesheet" href="~/css/tickets-v2.css" asp-append-version="true" />
<style>
    :root {
        --asnet-navy: #1e2130;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;

        /* Theme aware variables */
        --dash-card-bg: #fff;
        --dash-text: #566a7f;
        --dash-title: #566a7f;
        --dash-subtitle: #a1acb8;
        --dash-border: rgba(67, 89, 113, 0.1);
        --dash-shadow: 0 2px 6px 0 rgba(67, 89, 113, 0.12);
    }

    .dark-style, [data-bs-theme="dark"] {
        --dash-card-bg: #2b2e44;
        --dash-text: #a3adbb;
        --dash-title: #f5f5f9;
        --dash-subtitle: #7071a4;
        --dash-border: rgba(255, 255, 255, 0.05);
        --dash-shadow: 0 4px 18px rgba(0,0,0,0.2);
    }

    .dash-title { font-size: 1.75rem; font-weight: 700; color: var(--dash-title); }

    .stat-card, .tree-card, .pending-card, .chart-card, .map-card {
        background: var(--dash-card-bg) !important;
        border: none !important;
        border-radius: 16px !important;
        box-shadow: var(--dash-shadow) !important;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover { transform: translateY(-4px); }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: #fff;
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; color: var(--dash-title); }
    .stat-label  { font-size: .8rem; color: var(--dash-subtitle); margin: 0; }

    .chart-card .card-header, .tree-card .card-header, .map-card .card-header {
        background: transparent !important;
        border-bottom: 1px solid var(--dash-border) !important;
        font-weight: 600;
        color: var(--dash-title);
    }

    /* Forced Full Width Layout */
    .container-xxl, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
    }
    .layout-page, .content-wrapper, .layout-container { width: 100% !important; }

    .nav-pills .nav-link {
        background: transparent !important;
        color: rgba(255,255,255,0.6) !important;
        transition: all 0.2s ease;
    }
    .nav-pills .nav-link.active {
        background: var(--asnet-orange) !important;
        color: #fff !important;
    }
    .nav-pills .nav-link:hover:not(.active) {
        background: rgba(255,255,255,0.1) !important;
        color: #fff !important;
    }

    /* FullCalendar Custom Styling */
    .fc { font-family: 'Public Sans', sans-serif; }
    .fc-header-toolbar { margin-bottom: 1.5rem !important; }
    .fc-toolbar-title { font-size: 1.25rem !important; font-weight: 600 !important; color: #fff !important; }
    .fc-button-primary { background-color: #696cff !important; border-color: #696cff !important; }
    .fc-button-primary:hover { background-color: #5f61e6 !important; border-color: #5f61e6 !important; }
    .fc-daygrid-event { border-radius: 4px; padding: 2px 5px; font-size: 0.75rem; border: none !important; }
    .fc-theme-standard td, .fc-theme-standard th { border-color: rgba(255, 255, 255, 0.05) !important; }
    .fc-col-header-cell-cushion { color: rgba(255, 255, 255, 0.8) !important; font-weight: 500; font-size: 0.85rem; }
    .fc-daygrid-day-number { color: rgba(255, 255, 255, 0.6) !important; font-size: 0.85rem; }
    .fc-day-today { background: rgba(105, 108, 255, 0.05) !important; }
</style>
}

<!-- Title -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="dash-title mb-1">Painel do Técnico</h4>
        <p class="text-muted mb-0">Bem-vindo, <span class="fw-bold text-primary">@User.Identity?.Name</span></p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Clients/Technicians/Tickets" class="btn btn-primary d-flex align-items-center gap-2">
            <i class='bx bx-list-ul'></i> Gestão de Tickets
        </a>
    </div>
</div>

<!-- ======================= TOP MINI CARDS ======================= -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: #2b2c40 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:var(--asnet-blue); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                    <i class='bx bx-support text-white'></i>
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold text-white fs-5">@Model.MyTicketsCount</p>
                    <p class="stat-label mb-0 text-white-50 small">Meus Trabalhos</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: #2b2c40 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#ff3e1d; width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                    <i class='bx bx-task-x text-white'></i>
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold text-white fs-5">@Model.PendingTicketsCount</p>
                    <p class="stat-label mb-0 text-white-50 small">Trabalhos Ativos</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: #2b2c40 !important; border: 1px dashed #71dd37 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#71dd37; width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                    <i class='bx bx-plus-circle text-white'></i>
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold text-white fs-5">@Model.AvailableTicketsCount</p>
                    <p class="stat-label mb-0 text-white-50 small">Pedidos Novos</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: #2b2c40 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:var(--asnet-orange); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                    <i class='bx bx-package text-white'></i>
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold text-white fs-5">@Model.MyStockAlertsCount</p>
                    <p class="stat-label mb-0 text-white-50 small">Peças em Uso</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="card stat-card h-100 shadow-sm border-0" style="background: #2b2c40 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:var(--asnet-teal); width: 42px; height: 42px; border-radius: 10px; display:flex; align-items:center; justify-content:center;">
                    <i class='bx bx-message-rounded-dots text-white'></i>
                </div>
                <div>
                    <p class="stat-number mb-0 fw-bold text-white fs-5">@Model.UnreadMessagesCount</p>
                    <p class="stat-label mb-0 text-white-50 small">Mensagens</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ======================= 3 COLUMN MIDDLE SECTION ======================= -->
<div class="row g-4 mb-4">
    <!-- Col 1: Locais Atendidos -->
    <div class="col-lg-4">
        <div class="card h-100 shadow-sm border-0" style="background: #2b2c40 !important; border-left: 4px solid var(--asnet-blue) !important;">
            <div class="card-header border-bottom-0 pb-0">
                <ul class="nav nav-pills gap-2 mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active py-2 px-3 fw-bold" style="font-size: 0.8rem;">Locais com Tickets Abertos</button>
                    </li>
                </ul>
            </div>
            <div class="card-body pt-0" style="max-height: 400px; overflow-y: auto;">
                <div class="d-flex flex-column gap-3 mt-2">
                    @if (!Model.LocaisAtendimento.Any())
                    {
                        <p class="text-white-50 small">Não tens tickets ativos para nenhuma localização no momento.</p>
                    }
                    else
                    {
                        @foreach (var loc in Model.LocaisAtendimento)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 28px; height: 28px; background: #696cff; border-radius: 6px; color: #fff; font-weight: bold; font-size: 0.75rem;">
                                    @(loc.Name?.Substring(0, 1).ToUpper() ?? "L")
                                </div>
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold text-white" style="font-size: 0.85rem;">@loc.Name</span>
                                    <i class='bx bx-building-house text-white-50' style="font-size: 0.9rem;"></i>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Col 2: Mensagens -->
    <div class="col-lg-4">
        <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="background: #2b2c40 !important; border-left: 4px solid #71dd37 !important;">
            <div class="card-body p-4 flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div style="width: 40px; height: 40px; background: #71dd37; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class='bx bx-chat text-white fs-4'></i>
                    </div>
                    <h5 class="mb-0 fw-bold text-white">Comunicações</h5>
                </div>
                <div class="mb-3">
                    <span class="fw-bolder" style="font-size: 3rem; color: #fff; line-height: 1;">@Model.UnreadMessagesCount</span>
                    <span class="fw-bold" style="color: #71dd37; font-size: 1.2rem;"> novas</span>
                </div>
                <p class="text-white-50 small">mensagens aguardam resposta para andamento de tickets</p>

                @if (Model.RecentMessageSenders.Any())
                {
                    <div class="d-flex mt-3">
                        @foreach (var sender in Model.RecentMessageSenders)
                        {
                            <div class="rounded-circle text-white d-flex align-items-center justify-content-center me-1"
                                style="width:32px; height:32px; border:2px solid #2b2c40; background:#696cff; margin-right:-8px;"
                                title="@sender.Username">
                                @(sender.Username?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="p-4 pt-0">
                <a href="/Clients/Technicians/Chat" class="btn w-100 py-2 fw-bold" style="background: #71dd37; color: #fff; border-radius: 8px;">Responder no Chat</a>
            </div>
        </div>
    </div>

    <!-- Col 3: Mala de Ferramentas / Alertas Stock -->
    <div class="col-lg-4">
        <div class="card h-100 shadow-sm border-0 d-flex flex-column" style="background: #2b2c40 !important; border-left: 4px solid #f89223 !important;">
            <div class="card-body p-4 flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div style="width: 40px; height: 40px; background: #f89223; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class='bx bx-briefcase-alt-2 text-white fs-4'></i>
                    </div>
                    <h5 class="mb-0 fw-bold text-white">Mala de Peças</h5>
                </div>
                    <div class="d-flex align-items-baseline gap-2">
                        <span class="fw-bolder" style="font-size: 3rem; color: #fff; line-height: 1;">@Model.MyStock.Count()</span>
                        <p class="text-white mb-0 opacity-75">itens em stock pessoal</p>
                    </div>
                </div>
                <div class="card-body p-0 px-4">
                    <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                        <table class="table table-sm table-borderless table-dark mb-0" style="background: transparent;">
                            <tbody class="small text-white-50">
                                @if (!Model.MyStock.Any())
                                {
                                    <tr><td class="py-3 italic">Mala vazia</td></tr>
                                }
                                @foreach (var item in Model.MyStock.Take(5))
                                {
                                    <tr class="border-bottom border-light border-opacity-10">
                                        <td class="py-2">
                                            <div class="fw-bold text-white">@item.EquipmentName</div>
                                            <div class="text-xs text-white-50">@item.Description</div>
                                        </td>
                                         <td class="text-end py-2">
                                            <div class="d-flex align-items-center justify-content-end gap-2">
                                                <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                                        onclick="showQRCode('@item.Id', 'stock', '@item.EquipmentName?.Replace("'", "\\'")', 'Mala de Ferramentas')">
                                                    📱
                                                </button>
                                                @if (item.IsAvailable || item.Status == "Disponível")
                                                {
                                                    <button type="button" class="btn btn-sm btn-icon text-success p-0" 
                                                            onclick="openAssignModal(@item.Id, '@item.EquipmentName?.Replace("'", "\\'")', 'Stock')" 
                                                            title="Associar a Trabalho">
                                                        🔗
                                                    </button>
                                                }
                                                else if (item.Status == "Usado na Intervenção")
                                                {
                                                    <span class="badge bg-label-info p-1" title="Usado no Trabalho #@item.TicketId">#@item.TicketId</span>
                                                }
                                            </div>
                                         </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 p-4 pt-0">
                    <a href="/Clients/Technicians/Stocks" class="btn btn-warning w-100 fw-bold py-2 shadow-sm text-white" style="background: var(--asnet-orange) !important; border:none;">
                        Gerir Stock Completo <i class="ri-arrow-right-s-line"></i>
                    </a>
                </div>
        </div>
    </div>
</div>

<!-- ======================= FULL WIDTH TICKETS LIST ======================= -->
<div class="card mb-4" style="background: transparent; border:none; box-shadow:none;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 text-white">Os meus Trabalhos Recentes</h5>
        <a href="/Clients/Technicians/Tickets" class="btn btn-sm text-primary p-0">Ver Todos <i class="ri-arrow-right-s-line"></i></a>
    </div>
    
    <div class="tk-list">
        @if (!Model.RecentTickets.Any())
        {
            <div class="tk-row" style="justify-content:center; cursor:default;">
                <p class="text-white-50 mb-0 py-2">Nenhum ticket atribuído recentemente.</p>
            </div>
        }
        else
        {
            @foreach (var t in Model.RecentTickets)
            {
                <div class="tk-row" onclick="openTicketPanel(@t.Id)">
                    <div class="tk-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.2rem;">
                        @{
                            var type = t.Equipamento?.Type ?? "";
                            var name = t.Equipamento?.Name ?? "";
                            var emoji = type switch {
                                var s when s.Contains("Monitor") => "🖥️",
                                var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                                var s when s.Contains("Impressora") => "🖨️",
                                var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                                var s when s.Contains("Projetor") => "📽️",
                                var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                                var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                                var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                                var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                                var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                                var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                                _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                            };
                        }
                        @emoji
                    </div>
                    <div class="tk-main">
                        <div class="tk-meta">
                            <span class="tk-id">#@t.Id</span>
                            <span class="badge-tk" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); border-color: rgba(255, 171, 0, 0.2);">
                                @(t.Equipamento?.Type ?? "Geral")
                            </span>
                            @if (!string.IsNullOrEmpty(t.Level))
                            {
                                var color = t.Level.Contains("Alt") || t.Level.Contains("Crít") ? "var(--tk-red)" : "var(--tk-amber)";
                                <span class="badge-tk" style="color: @color; border-color: @color; background: @(color)11;">
                                    @t.Level
                                </span>
                            }
                        </div>
                        <div class="tk-title">@(t.Equipamento?.Name ?? "Avaria Geral")</div>
                        <div class="tk-sub">
                            <i class="ri-map-pin-line me-1"></i> @(t.School?.Name ?? "Sede") • @(t.Equipamento?.Room?.Name ?? "N/A")
                        </div>
                    </div>
                    <div class="tk-right">
                        @{
                            var stCol = t.Status switch {
                                "Concluído" => "var(--tk-green)",
                                "Em Reparação" or "Em Resolução" => "var(--tk-primary)",
                                _ => "var(--tk-muted)"
                            };
                        }
                        <span class="badge-tk" style="color: @stCol; border-color: @stCol; background: @(stCol)11;">
                            @t.Status
                        </span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </div>
                </div>
            }
        }
    </div>
</div>



<!-- ======================= CHARTS SECTION ======================= -->
<div class="row g-4 mb-4">
    <!-- Line Chart -->
    <div class="col-lg-7">
        <div class="card chart-card h-100 shadow-sm border-0" style="background: #2b2c40 !important;">
            <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3 text-white">
                <i class='bx bx-trending-up' style="color:var(--asnet-blue);"></i> Tendência de Resolução de Avárias
            </div>
            <div class="card-body pt-4">
                <canvas id="monthlyTicketChart" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
    <!-- Bar Chart Overview -->
    <div class="col-lg-5">
        <div class="card chart-card h-100 shadow-sm border-0" style="background: #2b2c40 !important;">
            <div class="card-header d-flex align-items-center gap-2 border-bottom border-secondary pb-3 text-white">
                <i class='bx bx-bar-chart-alt-2' style="color:var(--asnet-green);"></i> Tickets Atendidos por Mês
            </div>
            <div class="card-body pt-4 d-flex flex-column align-items-center justify-content-center">
                <canvas id="overviewChart" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>


<!-- ======================= MAP SECTION ======================= -->
<div class="row g-4 mt-2 mb-4">
    <div class="col-12">
    <div class="card map-card h-100 border-0 shadow-sm" style="background: #2b2c40 !important;">
        <div class="card-header d-flex align-items-center gap-2 text-white border-bottom border-secondary pb-3">
            <i class='bx bx-map-pin' style="color:#f89223;"></i> Mapa de Locais de Atendimento
        </div>
        <div class="card-body p-0">
            <div id="clientMap" style="height: 400px; width: 100%; border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;"></div>
        </div>
    </div>
</div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // Configurações do Line Chart (Tickets)
    const ticketCtx = document.getElementById('monthlyTicketChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels)),
            datasets: [
                {
                    label: 'Pendentes',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData.Pendente)),
                    borderColor: '#696cff',
                    backgroundColor: 'rgba(105, 108, 255, 0.1)',
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'Em Resolução',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData.EmResolucao)),
                    borderColor: '#ff3e1d',
                    backgroundColor: 'transparent',
                    tension: 0.4
                },
                {
                    label: 'Concluídos',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartMonthlyData.Concluido)),
                    borderColor: '#71dd37',
                    backgroundColor: 'transparent',
                    tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.7)' } }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1, color: 'rgba(255,255,255,0.7)' },
                    grid: { color: 'rgba(255,255,255,0.05)' }
                },
                x: {
                    ticks: { color: 'rgba(255,255,255,0.7)' },
                    grid: { display: false }
                }
            }
        }
    });

    // Bar Chart Overview (Produtividade Mensal - 1 Ano)
    const overviewCtx = document.getElementById('overviewChart').getContext('2d');
    new Chart(overviewCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BarChartLabels)),
            datasets: [{
                label: 'Tickets Solucionados',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BarChartData)),
                backgroundColor: '#71dd37',
                borderRadius: 4,
                maxBarThickness: 30
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1, color: 'rgba(255,255,255,0.7)' },
                    grid: { color: 'rgba(255,255,255,0.05)' }
                },
                x: {
                    ticks: { color: 'rgba(255,255,255,0.7)' },
                    grid: { display: false }
                }
            }
        }
    });

    // Função de Inicialização do Mapa
    function initMap() {
        var myLatLng = { lat: 41.5454, lng: -8.4265 }; // Centro em Braga (padrão)
        var map = new google.maps.Map(document.getElementById('clientMap'), {
            zoom: 11,
            center: myLatLng,
            styles: [
                { elementType: 'geometry', stylers: [{ color: '#242f3e' }] },
                { elementType: 'labels.text.stroke', stylers: [{ color: '#242f3e' }] },
                { elementType: 'labels.text.fill', stylers: [{ color: '#746855' }] },
                {
                    featureType: 'administrative.locality',
                    elementType: 'labels.text.fill',
                    stylers: [{ color: '#d59563' }]
                },
                {
                    featureType: 'poi',
                    elementType: 'labels.text.fill',
                    stylers: [{ color: '#d59563' }]
                },
                {
                    featureType: 'poi.park',
                    elementType: 'geometry',
                    stylers: [{ color: '#263c3f' }]
                },
                {
                    featureType: 'poi.park',
                    elementType: 'labels.text.fill',
                    stylers: [{ color: '#6b9a76' }]
                },
                {
                    featureType: 'road',
                    elementType: 'geometry',
                    stylers: [{ color: '#38414e' }]
                },
                {
                    featureType: 'road',
                    elementType: 'geometry.stroke',
                    stylers: [{ color: '#212a37' }]
                },
                {
                    featureType: 'road',
                    elementType: 'labels.text.fill',
                    stylers: [{ color: '#9ca5b3' }]
                },
                {
                    featureType: 'road.highway',
                    elementType: 'geometry',
                    stylers: [{ color: '#746855' }]
                },
                {
                    featureType: 'road.highway',
                    elementType: 'geometry.stroke',
                    stylers: [{ color: '#1f2835' }]
                },
                {
                    featureType: 'road.highway',
                    elementType: 'labels.text.fill',
                    stylers: [{ color: '#f3d19c' }]
                },
                {
                    featureType: 'water',
                    elementType: 'geometry',
                    stylers: [{ color: '#17263c' }]
                },
                {
                    featureType: 'water',
                    elementType: 'labels.text.fill',
                    stylers: [{ color: '#515c6d' }]
                },
                {
                    featureType: 'water',
                    elementType: 'labels.text.stroke',
                    stylers: [{ color: '#17263c' }]
                }
            ]
        });

        // Adicionar os marcadores para Escolas onde o técnico tem serviço
        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw && locationsRaw !== 'null') {
            var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
            var geocoder = new google.maps.Geocoder();

            locations.forEach(function(loc) {
                if (loc.address) {
                    geocoder.geocode({ 'address': loc.address + ", Portugal" }, function(results, status) {
                        if (status === 'OK') {
                            new google.maps.Marker({
                                map: map,
                                position: results[0].geometry.location,
                                title: loc.name,
                                icon: 'http://maps.google.com/mapfiles/ms/icons/orange-dot.png'
                            });
                        }
                    });
                }
            });
        }
    }
</script>
<script async defer src="https://maps.googleapis.com/maps/api/js?key=&callback=initMap"></script>
<!-- Panel Overlay & Slide-over Panel -->
<div class="tk-overlay @(Model.SelectedTicketId.HasValue ? "open" : "")" onclick="closeTicketPanel()"></div>

<div class="tk-panel @(Model.SelectedTicketId.HasValue ? "open" : "")" id="ticketPanel">
    @if (Model.SelectedTicket != null)
    {
        var t = Model.SelectedTicket;
        
        <!-- Header -->
        <div class="tk-ph">
            <div class="tk-ph-top">
                <div class="tk-ph-icon" style="background: rgba(255, 171, 0, 0.1); color: var(--tk-primary); font-size: 1.5rem; display: flex; align-items: center; justify-content: center;">
                    @{
                        var type = t.Equipamento?.Type ?? "";
                        var name = t.Equipamento?.Name ?? "";
                        var emoji = type switch {
                            var s when s.Contains("Monitor") => "🖥️",
                            var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                            var s when s.Contains("Impressora") => "🖨️",
                            var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                            var s when s.Contains("Projetor") => "📽️",
                            var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                            var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                            var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                            var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                            var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                            var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                            _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                        };
                    }
                    @emoji
                </div>
                <div class="tk-ph-info">
                    <div class="tk-ph-badges">
                        <span class="badge-tk" style="color: var(--tk-muted); border-color: var(--tk-border);">TK-@t.Id.ToString("D3")</span>
                        @if(!string.IsNullOrEmpty(t.Type)) {
                            <span class="badge-tk" style="color: var(--tk-amber); border-color: var(--tk-amber); background: rgba(245, 158, 11, 0.1);">@t.Type</span>
                        }
                        <span class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary); background: rgba(255, 171, 0, 0.1);">@t.Status</span>
                    </div>
                    <h2 class="tk-ph-title">@(t.Equipamento?.Name ?? "Avaria Geral"): @(t.Description?.Length > 30 ? t.Description.Substring(0, 30) + "..." : t.Description)</h2>
                </div>
                <button class="tk-close" onclick="closeTicketPanel()">✕</button>
            </div>

            <!-- Stepper -->
            <div class="tk-stepper">
                @{
                    var steps = new[] { "Aberto", "Aceite", "Em Reparação", "Concluído" };
                    int si = Array.IndexOf(steps, t.Status);
                    if (si == -1 && t.Status == "Pedido") si = 0;
                    if (si == -1 && t.Status == "Em Resolução") si = 2;
                    if (si == -1 && t.Status == "Pendente") si = 0;
                    
                    var nextLabel = si < 3 ? (si == 0 ? "Aceite" : si == 1 ? "Em Reparação" : "Concluído") : "";
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i < si || t.Status == "Concluído";
                    bool active = i == si && t.Status != "Concluído";
                    <div class="tk-step">
                        @if (i < steps.Length - 1) {
                            <div class="tk-step-line @(i < si || t.Status == "Concluído" ? "done" : "")"></div>
                        }
                        <div class="tk-step-dot @(done ? "done" : "") @(active ? "active" : "")">
                            @(done ? "✓" : (i + 1).ToString())
                        </div>
                        <div class="tk-step-label @(active ? "active" : "")">@steps[i]</div>
                    </div>
                }
            </div>

            @if (t.Status != "Concluído" && !string.IsNullOrEmpty(nextLabel))
            {
                <div class="tk-advance-row">
                    <form method="post" asp-page-handler="AdvanceStatus" asp-route-ticketId="@t.Id">
                        <button type="submit" class="tk-advance-btn">→ Avançar para "@nextLabel"</button>
                    </form>
                </div>
            }
        </div>

        <!-- Tabs -->
        <div class="tk-tabs">
            <div class="tk-tab active" onclick="showTab(0)">📁 Detalhes</div>
            <div class="tk-tab" onclick="showTab(1)">📦 Stock (@Model.AssociatedEquipment.Count)</div>
            <div class="tk-tab" onclick="showTab(2)">🕒 Histórico</div>
        </div>

        <!-- Body -->
        <div class="tk-body">
            <!-- Tab: Detalhes -->
            <div class="tk-tab-content" id="tab-0">
                <div class="tk-info-grid">
                    <div class="tk-info-card"><div class="tk-info-label">Solicitante</div><div class="tk-info-val">@(t.RequestedBy?.Username ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Técnico Responsável</div><div class="tk-info-val">@(t.Technician?.Username ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Escola</div><div class="tk-info-val">@(t.School?.Name ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Agrupamento</div><div class="tk-info-val">@(t.School?.Agrupamento?.Name ?? "—")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Criado em</div><div class="tk-info-val">@t.CreatedAt.ToString("dd/MM/yyyy, HH:mm")</div></div>
                    <div class="tk-info-card"><div class="tk-info-label">Atualizado em</div><div class="tk-info-val">@DateTime.Now.ToString("dd/MM/yyyy, HH:mm")</div></div>
                </div>
                
                <div class="tk-desc-card">
                    <div class="tk-info-label">Descrição</div>
                    <div style="margin-top:6px;font-size:14px;line-height:1.6">@t.Description</div>
                </div>

                @{ var comments = Model.TicketHistory.Where(h => h.TipoAcao == TipoAcaoHistorico.Comentario).ToList(); }
                <div style="margin-top:20px;margin-bottom:20px">
                    <div class="tk-info-label">Notas Técnicas</div>
                    @if (!comments.Any()) {
                        <div style="color:var(--tk-muted);font-size:13px;padding:10px 0">Sem notas registadas.</div>
                    } else {
                        <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px">
                            @foreach(var c in comments) {
                                <div style="background:#1a232e;border-left:3px solid var(--tk-primary);padding:10px 14px;border-radius:0 8px 8px 0">
                                    <div style="font-size:13px;line-height:1.5">@c.Acao</div>
                                    <div style="font-size:11px;color:var(--tk-muted);margin-top:4px">@c.Autor · @c.Data.ToString("dd/MM HH:mm")</div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (Model.AssociatedEquipment.Any())
                {
                    <div class="tk-eq-card">
                        <div class="tk-eq-header">@Model.AssociatedEquipment.Count equipamento(s) associado(s)</div>
                        @foreach (var eq in Model.AssociatedEquipment)
                        {
                            <div class="tk-eq-item">
                                <span><strong>@eq.Name</strong> · <span style="color:#6b7280;font-size:12px">@eq.SerialNumber</span></span>
                                @if(t.Status != "Concluído") {
                                    <form method="post" asp-page-handler="RemoveEquipment" asp-route-ticketId="@t.Id" asp-route-equipmentId="@eq.Id" style="display:inline">
                                        <button type="submit" class="btn-remove" style="background:transparent;border:none;color:var(--tk-red);font-size:12px;cursor:pointer">Remover</button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Tab: Stock -->
            <div class="tk-tab-content d-none" id="tab-1">
                <div class="tk-stock-top">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="tk-info-label">Material Disponível</div>
                        <div class="badge-tk" style="color: var(--tk-primary); border-color: var(--tk-primary);">@Model.CountStock itens</div>
                    </div>
                    
                    <div class="tk-scope-row">
                        <button class="tk-scope-btn @(Model.StockScope == "Escola" ? "active" : "")" onclick="setStockScope('Escola')">Nesta Escola</button>
                        <button class="tk-scope-btn @(Model.StockScope == "Agrupamento" ? "active" : "")" onclick="setStockScope('Agrupamento')">No Agrupamento</button>
                        <button class="tk-scope-btn @(Model.StockScope == "Global" ? "active" : "")" onclick="setStockScope('Global')">Global</button>
                    </div>

                    <div class="tk-stock-filters">
                        <input type="text" class="tk-stock-search" id="stockSearchInput" placeholder="Procurar no stock..." value="@Model.StockSearch" onkeydown="if(event.key==='Enter') applyStockSearch()">
                    </div>

                    <div class="tk-stock-list">
                        @if (!Model.AvailableEquipment.Any())
                        {
                            <div class="text-center py-4 text-muted small">Nenhum material encontrado com estes filtros.</div>
                        }
                        else
                        {
                            @foreach (var eq in Model.AvailableEquipment)
                            {
                                <div class="tk-avail-item">
                                    <div class="tk-avail-icon"><i class="ri-cpu-line"></i></div>
                                    <div class="tk-avail-info">
                                        <div class="tk-avail-name">@eq.Name</div>
                                        <div class="tk-avail-sub">S/N: @eq.SerialNumber • @(eq.Room?.Block?.School?.Name ?? "Sede")</div>
                                    </div>
                                    @if(t.Status != "Concluído") {
                                        <form method="post" asp-page-handler="AssociateEquipment" asp-route-ticketId="@t.Id" asp-route-equipmentId="@eq.Id">
                                            <button type="submit" class="btn-assoc">Associar</button>
                                        </form>
                                    } else {
                                        <div class="small text-muted">Ticket Fechado</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
                
                <div class="text-center mt-3">
                    <a href="/Clients/Technicians/Stocks" class="small text-primary" style="text-decoration: none;">Ver gestão de stock completa →</a>
                </div>
            </div>

            <!-- Tab: Histórico -->
            <div class="tk-tab-content d-none" id="tab-2">
                <div class="tk-timeline">
                    @foreach (var h in Model.TicketHistory)
                    {
                        <div class="tk-hist-item">
                            @{
                                var dotCol = h.TipoAcao switch {
                                    TipoAcaoHistorico.Status => "var(--tk-primary)",
                                    TipoAcaoHistorico.Comentario => "var(--tk-purple)",
                                    TipoAcaoHistorico.Equipamento => "var(--tk-green)",
                                    _ => "var(--tk-muted)"
                                };
                                var icon = h.TipoAcao switch {
                                    TipoAcaoHistorico.Status => "ri-refresh-line",
                                    TipoAcaoHistorico.Comentario => "ri-chat-1-line",
                                    TipoAcaoHistorico.Equipamento => "ri-cpu-line",
                                    _ => "ri-checkbox-blank-circle-line"
                                };
                            }
                            <div class="tk-hist-dot" style="color: @dotCol; border-color: @dotCol;"><i class="@icon"></i></div>
                            <div class="tk-hist-top">
                                <span class="tk-hist-action">@h.Acao</span>
                                <span class="tk-hist-date">@h.Data.ToString("dd/MM HH:mm")</span>
                            </div>
                            <div class="tk-hist-by">Por @h.Autor</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Footer -->
        @if(t.Status != "Concluído") {
            <div class="tk-footer">
                <form method="post" asp-page-handler="AddComment" asp-route-ticketId="@t.Id" class="d-flex w-100 gap-2">
                    <input type="text" name="comment" class="tk-comment" placeholder="Adicionar nota técnica ou comentário..." required autocomplete="off">
                    <button type="submit" class="tk-send-btn">✈ Enviar</button>
                </form>
            </div>
        } else {
            <div class="tk-footer" style="background: rgba(0,0,0,0.2); justify-content: center; opacity: 0.6;">
                <span class="small text-muted"><i class="ri-lock-line me-1"></i> Este ticket está concluído e não permite mais alterações.</span>
            </div>
        }
    }
</div>

<script>
    function openTicketPanel(id) {
        const url = new URL(window.location);
        url.searchParams.set('SelectedTicketId', id);
        window.location.href = url.toString();
    }

    function closeTicketPanel() {
        const url = new URL(window.location);
        url.searchParams.delete('SelectedTicketId');
        window.location.href = url.toString();
    }

    function showTab(idx) {
        document.querySelectorAll('.tk-tab').forEach((t, i) => {
            t.classList.toggle('active', i === idx);
        });
        document.querySelectorAll('.tk-tab-content').forEach((c, i) => {
            c.classList.toggle('d-none', i !== idx);
        });
    }

    function setStockScope(scope) {
        const url = new URL(window.location);
        url.searchParams.set('StockScope', scope);
        window.location.href = url.toString();
    }

    function applyStockSearch() {
        const val = document.getElementById('stockSearchInput').value;
        const url = new URL(window.location);
        url.searchParams.set('StockSearch', val);
        window.location.href = url.toString();
    }

    // Preserve scroll position or auto-open tab 1 if we just searched stock
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('StockSearch') || urlParams.has('StockScope')) {
            showTab(1);
        }
    });
</script>

<partial name="Shared/_QrModal" />
}
