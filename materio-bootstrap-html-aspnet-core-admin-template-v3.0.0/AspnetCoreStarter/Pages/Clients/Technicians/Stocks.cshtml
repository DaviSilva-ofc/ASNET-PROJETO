@page
@model AspnetCoreStarter.Pages.Clients.Technicians.StocksModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Explorador de Stocks";
}

@section PageStyles {
    <style>
        .card-bg { background-color: #2b2c40 !important; }
        .table-dark-custom th { color: rgba(255,255,255,0.5) !important; font-size: 0.75rem; text-transform: uppercase; border-bottom: 2px solid rgba(255,255,255,0.1); }
        .table-dark-custom td { color: #fff !important; border-bottom: 1px solid rgba(255,255,255,0.05); vertical-align: middle; }

        /* Tree Styles */
        .infra-tree .tree-node {
            position: relative;
            padding: 4px 0;
        }

        .tree-node i {
            font-size: 1.1rem;
            vertical-align: middle;
            opacity: 0.8;
        }

        .cursor-pointer { cursor: pointer; }

        /* Animation for arrows */
        [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
            transition: transform 0.3s ease;
            font-weight: bold;
            color: #696cff;
            font-size: 1.4rem;
            display: inline-block;
            line-height: 1;
            background-color: rgba(105, 108, 255, 0.15);
            border: 1px solid rgba(105, 108, 255, 0.3);
            border-radius: 4px;
            padding: 4px;
            margin-right: 8px;
        }
        
        [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
            transform: rotate(90deg);
            background-color: #696cff;
            color: #fff;
        }

        .agrupamento-node { color: #696cff; }
        .school-node { color: #03c3ec; }
        .bloc-node { color: #71dd37; }
        .room-node { color: #ffab00; }
        .equip-node { color: #a1acb8; }
        
        .tree-node i.ri-arrow-right-s-line {
            background-color: rgba(105, 108, 255, 0.1);
            border-radius: 4px;
            padding: 4px;
            font-weight: bold;
            transition: all 0.2s;
        }
        
        .dark-style .agrupamento-node { color: #696cff; }
        .dark-style .school-node { color: #03c3ec; }
        .dark-style .bloc-node { color: #71dd37; }
        .dark-style .room-node { color: #ffab00; }
        .dark-style .equip-node { color: #707186; }
    </style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-white-50 fw-light">Técnico /</span> Explorador de Stocks
    </h4>

    <div class="alert alert-info border-0 mb-4 bg-label-info d-flex align-items-center">
        <i class="ri-information-line fs-4 me-3"></i>
        <div>
            Bem-vindo ao Explorador de Stocks. Aqui podes consultar o teu stock pessoal de peças. Adicionalmente, tens acesso temporário de visualização aos stocks da <strong>Escola</strong> e <strong>Agrupamento</strong> aos quais tens tickets pendentes para reparação.
        </div>
    </div>

    <!-- Technician's Personal Stock -->
    <div class="card shadow-sm border-0 mb-4 card-bg">
        <div class="card-header border-bottom border-light border-opacity-10 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-white"><i class="ri-user-settings-line me-2 text-warning"></i> Meu Stock Pessoal</h5>
            <span class="badge bg-label-warning">@Model.MyStock.Count() itens</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-dark-custom mb-0">
                <thead>
                    <tr>
                        <th>Artigo / Peça</th>
                        <th>Categoria / Tipo</th>
                        <th>Estado Actual</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.MyStock.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-white-50 italic">Não possuis stock diretamente atribuído à tua conta.</td>
                        </tr>
                    }
                    @foreach (var item in Model.MyStock)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm me-2">
                                        <span class="avatar-initial rounded bg-label-secondary"><i class="ri-price-tag-3-line"></i></span>
                                    </div>
                                    <strong class="text-white">@item.EquipmentName</strong>
                                </div>
                            </td>
                            <td><span class="text-white-50 small">@item.Type</span></td>
                            <td><span class="badge bg-label-success">@item.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row g-4">
        <!-- School Stocks (Linked via Active Tickets) -->
        <div class="col-xl-6">
            <div class="card shadow-sm border-0 h-100 card-bg">
                <div class="card-header border-bottom border-light border-opacity-10 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white"><i class="ri-school-line me-2 text-info"></i> Stock das Escolas</h5>
                    <span class="badge bg-label-secondary" title="Acesso devido a tickets em aberto">Acesso Temporário</span>
                </div>
                <div class="card-body p-0">
                    <div class="infra-tree p-3">
                        @if (!Model.AccessibleSchools.Any())
                        {
                            <div class="text-center py-5 text-white-50 italic">
                                Sem detalhe de escola acessível.
                            </div>
                        }
                        else
                        {
                            foreach(var school in Model.AccessibleSchools.Where(s => Model.ActiveSchoolIds.Contains(s.Id)))
                            {
                                var schBase = Model.SchoolBaseStock.Where(s => s.SchoolId == school.Id).ToList();
                                <div class="tree-node school-node">
                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-sch-@school.Id">
                                        <i class="ri-arrow-right-s-line me-1"></i>
                                        <i class="ri-school-line me-1 text-info"></i> <strong class="text-white">@school.Name</strong>
                                    </div>
                                    <div id="tree-sch-@school.Id" class="collapse">
                                        
                                        @foreach(var item in schBase)
                                        {
                                            <div class="tree-node equip-node ms-4 mt-1 border-bottom border-secondary border-opacity-25 pb-2 pt-1">
                                                <span class="d-block text-white">@item.EquipmentName <span class="badge bg-label-info ms-2" style="font-size:0.6rem;">Stock Geral / @item.Type</span></span>
                                            </div>
                                        }

                                        @{ var blocosEscola = Model.AccessibleBlocos.Where(b => b.SchoolId == school.Id).ToList(); }
                                        @foreach(var bloco in blocosEscola)
                                        {
                                            var blockId = $"b{bloco.Id}";
                                            <div class="tree-node bloc-node ms-4 mt-2">
                                                <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-@blockId">
                                                    <i class="ri-arrow-right-s-line me-1"></i>
                                                    <i class="ri-building-4-line me-1 text-success"></i> <strong class="text-white">@bloco.Name</strong>
                                                </div>
                                                <div id="tree-@blockId" class="collapse">
                                                    @{ var salasBloco = Model.AccessibleSalas.Where(s => s.BlockId == bloco.Id).ToList(); }
                                                    @foreach(var sala in salasBloco)
                                                    {
                                                        var roomId = $"r{sala.Id}";
                                                        <div class="tree-node room-node ms-4 mt-1">
                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-@roomId">
                                                                <i class="ri-arrow-right-s-line me-1"></i>
                                                                <i class="ri-door-open-line me-1 text-warning"></i> <span class="text-white">@sala.Name</span>
                                                            </div>
                                                            <div id="tree-@roomId" class="collapse">
                                                                @if (!sala.Equipments.Any())
                                                                {
                                                                    <div class="ms-4 mt-1 small text-white-50 italic">Sem equipamentos</div>
                                                                }
                                                                @foreach(var equip in sala.Equipments)
                                                                {
                                                                    <div class="tree-node equip-node ms-4 mt-1 border-bottom border-light border-opacity-10 pb-2 pt-1">
                                                                        <span class="d-block text-white">@equip.Name <span class="badge bg-label-primary ms-2" style="font-size:0.6rem;">@equip.Type</span>
                                                                        <span class="badge bg-label-@(equip.Status == "Disponível" || equip.Status == "Armazenado" || equip.Status == "A funcionar" ? "success" : "danger") ms-1" style="font-size:0.6rem;">@equip.Status</span>
                                                                        </span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Agrupamento Stocks (Linked via Active Tickets) -->
        <div class="col-xl-6">
            <div class="card shadow-sm border-0 h-100 card-bg">
                <div class="card-header border-bottom border-light border-opacity-10 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white"><i class="ri-government-line me-2 text-primary"></i> Stock dos Agrupamentos</h5>
                    <span class="badge bg-label-secondary" title="Acesso devido a tickets em aberto">Acesso Temporário</span>
                </div>
                <div class="card-body p-0">
                    <div class="infra-tree p-3">
                        @if (!Model.AccessibleAgrupamentos.Any())
                        {
                            <div class="text-center py-5 text-white-50 italic">
                                Sem stock de agrupamento acessível.
                            </div>
                        }
                        else
                        {
                            foreach(var agrp in Model.AccessibleAgrupamentos)
                            {
                                var agBase = Model.AgrupamentoBaseStock.Where(s => s.AgrupamentoId == agrp.Id).ToList();
                                <div class="tree-node agrupamento-node">
                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-agrp-@agrp.Id">
                                        <i class="ri-arrow-right-s-line me-1"></i>
                                        <i class="ri-government-line me-1 text-primary"></i> <strong class="text-white">@agrp.Name</strong>
                                    </div>
                                    <div id="tree-agrp-@agrp.Id" class="collapse">

                                        @foreach(var item in agBase)
                                        {
                                            <div class="tree-node equip-node ms-4 mt-1 border-bottom border-secondary border-opacity-25 pb-2 pt-1">
                                                <span class="d-block text-white">@item.EquipmentName <span class="badge bg-label-info ms-2" style="font-size:0.6rem;">Stock Central / @item.Type</span></span>
                                            </div>
                                        }

                                        @{ var schoolsAgrp = Model.AccessibleSchools.Where(s => s.AgrupamentoId == agrp.Id).ToList(); }
                                        @foreach(var school in schoolsAgrp)
                                        {
                                            <div class="tree-node school-node ms-4 mt-2">
                                                <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-agrp-sch-@school.Id">
                                                    <i class="ri-arrow-right-s-line me-1"></i>
                                                    <i class="ri-school-line me-1 text-info"></i> <strong class="text-white">@school.Name</strong>
                                                </div>
                                                <div id="tree-agrp-sch-@school.Id" class="collapse">
                                                    @{ var blocosEscola = Model.AccessibleBlocos.Where(b => b.SchoolId == school.Id).ToList(); }
                                                    @foreach(var bloco in blocosEscola)
                                                    {
                                                        var blockId = $"a{agrp.Id}s{school.Id}b{bloco.Id}";
                                                        <div class="tree-node bloc-node ms-4 mt-2">
                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-@blockId">
                                                                <i class="ri-arrow-right-s-line me-1"></i>
                                                                <i class="ri-building-4-line me-1 text-success"></i> <span class="text-white">@bloco.Name</span>
                                                            </div>
                                                            <div id="tree-@blockId" class="collapse">
                                                                @{ var salasBloco = Model.AccessibleSalas.Where(s => s.BlockId == bloco.Id).ToList(); }
                                                                @foreach(var sala in salasBloco)
                                                                {
                                                                    var roomId = $"a{agrp.Id}s{school.Id}b{bloco.Id}r{sala.Id}";
                                                                    <div class="tree-node room-node ms-4 mt-1">
                                                                        <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed" data-bs-toggle="collapse" data-bs-target="#tree-@roomId">
                                                                            <i class="ri-arrow-right-s-line me-1"></i>
                                                                            <i class="ri-door-open-line me-1 text-warning"></i> <span class="text-white">@sala.Name</span>
                                                                        </div>
                                                                        <div id="tree-@roomId" class="collapse">
                                                                            @if (!sala.Equipments.Any())
                                                                            {
                                                                                <div class="ms-4 mt-1 small text-white-50 italic">Sem equipamentos</div>
                                                                            }
                                                                            @foreach(var equip in sala.Equipments)
                                                                            {
                                                                                <div class="tree-node equip-node ms-4 mt-1 border-bottom border-light border-opacity-10 pb-2 pt-1">
                                                                                    <span class="d-block text-white">@equip.Name <span class="badge bg-label-primary ms-2" style="font-size:0.6rem;">@equip.Type</span>
                                                                                    <span class="badge bg-label-@(equip.Status == "Disponível" || equip.Status == "Armazenado" || equip.Status == "A funcionar" ? "success" : "danger") ms-1" style="font-size:0.6rem;">@equip.Status</span>
                                                                                    </span>
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
