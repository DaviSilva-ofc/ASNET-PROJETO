<div class="modal fade" id="assignStockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="AssignStock" class="modal-content card-bg border-light border-opacity-10" style="background: #2b2c40 !important;">
            <div class="modal-header border-bottom border-light border-opacity-10">
                <h5 class="modal-title text-white">Associar Stock a Trabalho</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalStockId" name="stockId" value="" />
                <input type="hidden" id="modalItemType" name="itemType" value="" />
                
                <p class="text-white-50">Estás prestes a aplicar <strong id="modalStockName" class="text-white"></strong> numa intervenção ativa.</p>
                
                <div class="mb-3">
                    <label class="form-label text-white-50">Trabalho Associado</label>
                    <select class="form-select bg-dark text-white border-secondary" name="ticketId" required>
                        <option value="" disabled selected>Selecionar o trabalho...</option>
                        @foreach(var ticket in Model.ActiveTickets)
                        {
                            <option value="@ticket.Id">
                                #@ticket.Id - @(ticket.Equipamento?.Name ?? "Outro") (@(ticket.School?.Name ?? "Indefinida"))
                            </option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer border-top border-light border-opacity-10">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-success">✅ Associar Artigo</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openAssignModal(stockId, stockName, itemType) {
        document.getElementById('modalStockId').value = stockId;
        document.getElementById('modalStockName').textContent = stockName;
        document.getElementById('modalItemType').value = itemType;
        
        var modal = new bootstrap.Modal(document.getElementById('assignStockModal'));
        modal.show();
    }
</script>

