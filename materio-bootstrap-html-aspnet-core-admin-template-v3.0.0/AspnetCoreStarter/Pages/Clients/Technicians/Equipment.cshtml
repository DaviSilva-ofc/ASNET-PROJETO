    function updateBrandsModels(mode) {
        const artigoId = mode === 'edit' ? 'editArtigo' : 'regArtigo';
        const marcaId = mode === 'edit' ? 'editMarca' : 'regMarca';
        const modeloId = mode === 'edit' ? 'editModelo' : 'regModelo';
        const artigo = document.getElementById(artigoId).value;
        const marcaSelect = document.getElementById(marcaId);
        const modeloSelect = document.getElementById(modeloId);

        marcaSelect.innerHTML = '<option value="">Selecione a marca...</option>';
        modeloSelect.innerHTML = '<option value="">Selecione o modelo...</option>';

        if (artigo && brandModelData[artigo]) {
            Object.keys(brandModelData[artigo]).sort().forEach(function(brand) {
                marcaSelect.add(new Option(brand, brand));
            });
        }
    }

    function updateModels(mode) {
        const artigoId = mode === 'edit' ? 'editArtigo' : 'regArtigo';
        const marcaId = mode === 'edit' ? 'editMarca' : 'regMarca';
        const modeloId = mode === 'edit' ? 'editModelo' : 'regModelo';
        const artigo = document.getElementById(artigoId).value;
        const marca = document.getElementById(marcaId).value;
        const modeloSelect = document.getElementById(modeloId);

        modeloSelect.innerHTML = '<option value="">Selecione o modelo...</option>';
        if (artigo && marca && brandModelData[artigo] && brandModelData[artigo][marca]) {
            brandModelData[artigo][marca].forEach(function(model) {
                modeloSelect.add(new Option(model, model));
            });
        }
    }

    function updateSpecificTypes(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const tipoSelect = document.getElementById(prefix + 'Tipo');
        const options = tipoSelect.querySelectorAll('option');

        tipoSelect.value = "";
        
        // Trigger filterSelect to update display based on BOTH artigo AND any current search
        const wrapper = tipoSelect.closest('.select-search-wrapper');
        const searchInput = wrapper ? wrapper.querySelector('.select-search-input') : null;
        filterSelect(searchInput, prefix + 'Tipo');
    }

    function filterTypesByFilterArtigo(selectedArtigo = null) {
        const articleValue = selectedArtigo ?? document.getElementById('filterArtigo')?.value ?? '';
        const tipoSelect = document.getElementById('filterTipo');
        if (!tipoSelect) return;
        tipoSelect.value = "";
        const typeOptions = tipoSelect.querySelectorAll('option');
        typeOptions.forEach(opt => {
            if (opt.value === "") return;
            const optArticle = opt.getAttribute('data-artigo') || "";
            const matchesArticle = !articleValue || optArticle === articleValue;
            opt.style.display = matchesArticle ? '' : 'none';
            opt.hidden = !matchesArticle;
            opt.disabled = !matchesArticle;
        });
        const wrapper = tipoSelect.closest('.select-search-wrapper');
        const searchInput = wrapper ? wrapper.querySelector('.select-search-input') : null;
        filterSelect(searchInput, 'filterTipo');
        updateFilterBrandsAndModels();
    }

    function updateFilterBrandsAndModels() {
        const artigo = document.getElementById('filterArtigo')?.value || '';
        const brandSelect = document.getElementById('filterBrand');
        const modelSelect = document.getElementById('filterModel');
        if (!brandSelect || !modelSelect) return;

        const selectedBrand = brandSelect.getAttribute('data-selected') || brandSelect.value || '';
        const selectedModel = modelSelect.getAttribute('data-selected') || modelSelect.value || '';

        brandSelect.innerHTML = '<option value="">Qualquer Marca</option>';
        modelSelect.innerHTML = '<option value="">Qualquer Modelo</option>';

        if (artigo && brandModelData[artigo]) {
            const brands = Object.keys(brandModelData[artigo]).sort();
            brands.forEach(brand => brandSelect.add(new Option(brand, brand)));
            if (selectedBrand && brands.includes(selectedBrand)) {
                brandSelect.value = selectedBrand;
            }
            updateFilterModels(selectedModel);
        }
    }

    function updateFilterModels(preferredModel = '') {
        const artigo = document.getElementById('filterArtigo')?.value || '';
        const brand = document.getElementById('filterBrand')?.value || '';
        const modelSelect = document.getElementById('filterModel');
        if (!modelSelect) return;

        const remembered = preferredModel || modelSelect.getAttribute('data-selected') || modelSelect.value || '';
        modelSelect.innerHTML = '<option value="">Qualquer Modelo</option>';

        if (artigo && brand && brandModelData[artigo] && brandModelData[artigo][brand]) {
            brandModelData[artigo][brand].forEach(model => modelSelect.add(new Option(model, model)));
            if (remembered && brandModelData[artigo][brand].includes(remembered)) {
                modelSelect.value = remembered;
            }
        }
    }

    // Cascading filters for Edit modal sala
