@page
@model AspnetCoreStarter.Pages.Clients.Technicians.TechnicianEquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Explorador de Equipamento";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

@section PageStyles {
<style>
    /* Estilos de Pesquisa (Admin Style) */
    .select-search-wrapper { position: relative; margin-bottom: 0.75rem; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.4375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid rgba(255,255,255,0.15);
        border-bottom: none;
        border-radius: 6px 6px 0 0 !important;
        background-color: #2b2c40 !important;
        color: #fff !important;
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff !important;
        box-shadow: 0 0 0 0.1rem rgba(105,108,255,0.25);
    }
    .select-search-wrapper select {
        border-radius: 0 0 6px 6px !important;
        background-color: #2b2c40 !important;
        color: #fff !important;
        border: 1px solid rgba(255,255,255,0.15) !important;
        appearance: none;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 0.75rem center;
        background-size: 16px 12px;
    }
    .select-search-wrapper select:focus {
        border-color: #696cff !important;
    }

    .status-pill {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.25rem 0.75rem;
        border-radius: 50rem;
    }

    .btn-xs { padding: 0.125rem 0.25rem; font-size: 0.75rem; }

    .stock-stat-card {
        background: linear-gradient(135deg, #32344d 0%, #2b2c40 100%);
        border-radius: 12px;
        transition: transform 0.2s;
    }
    .stock-stat-card:hover { transform: translateY(-3px); }

    .btn-asnet {
        background: #f89223 !important;
        color: #fff !important;
        border: none !important;
        font-weight: 600;
    }
    .btn-asnet:hover { background: #e07f1d !important; }

    .badge-soft-warning { background: rgba(255, 171, 0, 0.1); color: #ffab00; }
    .badge-soft-success { background: rgba(113, 221, 55, 0.1); color: #71dd37; }
    .badge-soft-info { background: rgba(3, 195, 236, 0.1); color: #03c3ec; }

    .modal-content {
        color-scheme: dark !important;
        background-color: #323249 !important; /* Cor exata do Admin */
        border: 1px solid rgba(255,255,255,0.1) !important;
    }
    
    .modal-header, .modal-footer {
        border-color: rgba(255,255,255,0.1) !important;
    }

    .form-control, .form-select {
        background-color: #2b2c40 !important;
        color: #fff !important;
        border-color: rgba(255,255,255,0.15) !important;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #696cff !important;
        box-shadow: 0 0 0 0.1rem rgba(105,108,255,0.25) !important;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-white-50 fw-light">T&eacute;cnico /</span> 🔧 Explorador de Equipamentos
    </h4>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show bg-success text-white border-0" role="alert">
            <i class="ri-checkbox-circle-line me-1"></i> @Model.SuccessMessage
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-inventario">
                    Inventário Geral
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-minha-mala">
                    Pedidos e Devoluções
                </button>
            </li>
        </ul>
        <div class="tab-content" style="background: transparent; padding: 0; box-shadow: none;">
            <!-- Aba Inventário -->
            <div class="tab-pane fade show active" id="tab-inventario" role="tabpanel">
                <div class="card shadow-sm border-0" style="background: #2b2c40;">
        <div class="card-header d-flex justify-content-between align-items-center border-bottom border-light border-opacity-10">
            <h5 class="mb-0 text-white">Invent&aacute;rio de Equipamentos</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    <i class="ri-filter-3-line me-1"></i> Filtros
                </button>
                <button class="btn btn-warning text-dark fw-bold" data-bs-toggle="modal" data-bs-target="#modalRequisitarEq">
                    <i class="ri-hand-coin-line me-1"></i> Requisitar Equipamento
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEquipamento">Novo Equipamento</button>
            </div>
        </div>

        @{
            var activeFilterText = "";
            if (Model.ActiveFilterRoom != null) activeFilterText = $"sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) activeFilterText = $"bloco: {Model.ActiveFilterBloco.Name}";
            else if (Model.ActiveFilterEscola != null) activeFilterText = $"escola: {Model.ActiveFilterEscola.Name}";
            else if (Model.ActiveFilterAgrupamento != null) activeFilterText = $"agrupamento: {Model.ActiveFilterAgrupamento.Name}";
            else if (Model.ActiveFilterEmpresa != null) activeFilterText = $"empresa: {Model.ActiveFilterEmpresa.Name}";
        }

        @if (!string.IsNullOrEmpty(activeFilterText) || !string.IsNullOrEmpty(Model.FilterStatus) || !string.IsNullOrEmpty(Model.FilterType) || !string.IsNullOrEmpty(Model.FilterArticle) || !string.IsNullOrEmpty(Model.FilterBrand) || !string.IsNullOrEmpty(Model.FilterModel))
        {
            <div class="card-body">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0 bg-label-info border-0" role="alert">
                    <div>
                        <i class="ri-information-line me-1"></i>
                        <span>A visualizar: <strong>@(activeFilterText ?? "Tudo")</strong></span>
                        @if (!string.IsNullOrEmpty(Model.FilterArticle)) { <span class="badge bg-primary ms-2">Artigo: @Model.FilterArticle</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterStatus)) { <span class="badge bg-info ms-2">Estado: @Model.FilterStatus</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterType)) { <span class="badge bg-secondary ms-1">Tipo: @Model.FilterType</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterBrand)) { <span class="badge bg-warning ms-1">Marca: @Model.FilterBrand</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterModel)) { <span class="badge bg-dark ms-1">Modelo: @Model.FilterModel</span> }
                    </div>
                    <a asp-page="./Equipment" class="btn btn-xs btn-outline-info">Limpar Filtros</a>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr class="text-white-50 small text-uppercase">
                        <th>Artigo</th>
                        <th>Tipo</th>
                        <th>N&ordm; S&eacute;rie</th>
                        <th>Localiza&ccedil;&atilde;o (Sala)</th>
                        <th>Status</th>
                        <th style="min-width: 180px;">A&ccedil;&otilde;es</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @if (!Model.Equipments.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-white-50 italic">Nenhum equipamento encontrado.</td>
                        </tr>
                    }
                    @foreach (var item in Model.Equipments)
                    {
                        var normalizedStatus = (item.Status ?? "").ToLowerInvariant();
                        var isRepair = normalizedStatus.Contains("repara");
                        var isBroken = normalizedStatus.Contains("avari");
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <strong class="text-white">@item.Name</strong>
                                    <small class="text-white-50" style="font-size: 0.75rem;">
                                        @(item.Brand ?? "Genérico") @(item.Model ?? "")
                                    </small>
                                </div>
                            </td>
                            <td class="text-white-50">@item.Type</td>
                            <td><span class="badge bg-label-secondary font-monospace">@item.SerialNumber</span></td>
                            <td>
                                @if (item.Room != null)
                                {
                                    <span class="text-white-50 small">@item.Room.Name (@item.Room.Block?.School?.Name)</span>
                                }
                                else if (item.Empresa != null)
                                {
                                    <span class="text-warning small"><i class="ri-building-4-line me-1"></i> @item.Empresa.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted small italic">N/A</span>
                                }
                            </td>
                            <td>
                                @if (isBroken) { <span class="badge bg-label-danger status-pill">❌ Avariado</span> }
                                else if (isRepair) { <span class="badge bg-label-info status-pill">🛠️ Em Reparação</span> }
                                else if (normalizedStatus.Contains("funciona")) { <span class="badge bg-label-success status-pill">✅ A funcionar</span> }
                                else if (normalizedStatus == "armazenado") { <span class="badge bg-label-warning status-pill">📦 @item.Status</span> }
                                else { <span class="badge @(normalizedStatus == "disponivel" || normalizedStatus == "disponível" ? "bg-label-success" : "bg-label-secondary") status-pill">📦 @item.Status</span> }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    @* Menu de Mudança de Estado *@
                                    <div class="dropdown">
                                        <button class="border-0 bg-transparent p-1 lh-1" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Mudar estado">
                                            ⚙️
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary shadow-lg">
                                            <form method="post" asp-page-handler="UpdateStatus" asp-route-id="@item.Id">
                                                @if (isBroken)
                                                {
                                                    <li><button type="submit" name="status" value="Em Repara&ccedil;&atilde;o" class="dropdown-item text-warning py-2">🛠️ Em Repara&ccedil;&atilde;o</button></li>
                                                    <li><button type="submit" name="status" value="A funcionar" class="dropdown-item text-success py-2">✅ Funcional</button></li>
                                                }
                                                else if (isRepair)
                                                {
                                                    <li><button type="submit" name="status" value="A funcionar" class="dropdown-item text-success py-2">✅ Conclu&iacute;do</button></li>
                                                    <li><button type="submit" name="status" value="Avariado" class="dropdown-item text-danger py-2">❌ Voltar a Avariado</button></li>
                                                }
                                                else
                                                {
                                                    <li><button type="submit" name="status" value="Avariado" class="dropdown-item text-danger py-2">⚠️ Marcar como Avariado</button></li>
                                                    <li><button type="submit" name="status" value="Em Repara&ccedil;&atilde;o" class="dropdown-item text-warning py-2">🛠️ Enviar para Repara&ccedil;&atilde;o</button></li>
                                                }
                                            </form>
                                        </ul>
                                    </div>
                                    
                                    @if (!isRepair)
                                    {
                                        <form method="post" asp-page-handler="UpdateStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                            <input type="hidden" name="status" value="Em Reparação" />
                                            <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Enviar para Reparação">
                                                🛠️
                                            </button>
                                        </form>
                                    }

                                    <button type="button" class="border-0 bg-transparent p-1 lh-1" title="Código QR" 
                                            onclick="showQRCode('@item.Id', 'equip', '@(item.Name?.Replace("'", "\\'"))', '@(item.SerialNumber ?? "S/N N/A")')">
                                        📱
                                    </button>

                                    <button type="button" class="border-0 bg-transparent p-1 lh-1" title="Editar"
                                            onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@(item.Brand ?? "")', '@(item.Model ?? "")', '@item.SerialNumber', '@item.RoomId', '@item.EmpresaId', '@item.Status')">
                                        ✏️
                                    </button>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?');" style="display:inline-block;">
                                        <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Eliminar">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
                </div>
            </div>
            
            <div class="tab-pane fade" id="tab-minha-mala" role="tabpanel">
                <!-- Seção de Pedidos Pendentes (Paridade com Prof/Dir) -->
                <div class="card shadow-sm border-0 mb-4" style="background: #2b2c40;">
                    <div class="card-header border-bottom border-light border-opacity-10 bg-label-warning py-3">
                        <h5 class="mb-0 text-dark"><i class="ri-time-line me-2"></i>Pedidos em Processamento</h5>
                    </div>
                    <div class="table-responsive text-nowrap">
                        <table class="table table-hover">
                            <thead>
                                <tr class="border-light border-opacity-10">
                                    <th class="text-white-50">Artigo Pedido</th>
                                    <th class="text-white-50">Estado</th>
                                    <th class="text-white-50">Data do Pedido</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.MyStockRequests == null || !Model.MyStockRequests.Any(t => t.Status == "Pedido"))
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted small">
                                            Não tem pedidos de equipamento pendentes.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var ticket in Model.MyStockRequests.Where(t => t.Status == "Pedido"))
                                    {
                                        <tr class="border-light border-opacity-10">
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="fw-bold text-white">@ticket.Description.Split('\n').FirstOrDefault()?.Replace("PEDIDO DE EQUIPAMENTO (TÉCNICO):", "").Replace("PEDIDO DE STOCK (TÉCNICO):", "").Trim()</span>
                                                    <small class="text-white-50">Aguardando disponibilidade no stock central</small>
                                                </div>
                                            </td>
                                            <td><span class="badge bg-label-warning">Pendente</span></td>
                                            <td><span class="small text-white-50">@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-end mb-4">
                    <button class="btn btn-asnet shadow-sm" data-bs-toggle="modal" data-bs-target="#modalRequestStock">
                        <i class="ri-add-line me-1"></i> Requisitar à Empresa
                    </button>
                </div>
                <div class="row g-4">
                    <div class="col-xl-8">
                        <div class="card shadow-none h-100" style="background: #2b2c40;">
                            <div class="card-header border-bottom border-light border-opacity-10 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 text-white"><i class="ri-archive-line me-2 text-warning"></i>Minha Mala</h5>
                                <span class="badge bg-label-primary px-3">@Model.MyStock.Count() itens</span>
                            </div>
                            <div class="table-responsive text-nowrap">
                                <table class="table table-hover">
                                    <thead>
                                        <tr class="text-white-50 small text-uppercase">
                                            <th>Artigo</th>
                                            <th>Categoria</th>
                                            <th>Origem</th>
                                            <th>Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody class="table-border-bottom-0">
                                        @if (!Model.MyStock.Any())
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-5 text-muted">Sem itens na mala. Requisita stock à empresa.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var item in Model.MyStock)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="avatar avatar-sm me-2">
                                                                <span class="avatar-initial rounded bg-label-secondary"><i class="ri-settings-4-line"></i></span>
                                                            </div>
                                                            <span class="fw-bold text-white">@item.EquipmentName</span>
                                                        </div>
                                                    </td>
                                                    <td><span class="text-white-50 small">@item.Description</span></td>
                                                    <td><span class="badge badge-soft-info">Stock Empresa</span></td>
                                                    <td>
                                                        <div class="d-flex gap-2">
                                                            <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                                                    onclick="showQRCode('@item.Id', 'stock', '@(item.EquipmentName?.Replace("'", "\\'"))', 'Minha Mala')">
                                                                <i class="ri-qr-code-line"></i>
                                                            </button>
                                                            <form method="post" asp-page-handler="ReturnToHQ">
                                                                <input type="hidden" name="id" value="@item.Id" />
                                                                <button type="submit" class="btn btn-sm btn-icon text-info p-0" title="Devolver para Empresa">
                                                                    <i class="ri-arrow-go-back-line"></i>
                                                                </button>
                                                            </form>
                                                            @if (item.IsAvailable || item.Status == "Disponível")
                                                            {
                                                                <button type="button" class="btn btn-sm btn-icon text-success p-0" 
                                                                        onclick="openAssignModal(@item.Id, '@item.EquipmentName?.Replace("'", "\\'")', 'Stock')" 
                                                                        title="Associar a Trabalho">
                                                                    🔗
                                                                </button>
                                                            }
                                                            else if (item.Status == "Usado na Intervenção")
                                                            {
                                                                <span class="badge bg-label-info p-1" title="Usado no Trabalho #@item.TicketId">#@item.TicketId</span>
                                                            }
                                                            <form method="post" asp-page-handler="FinalDisposal" onsubmit="return confirm('Confirmas a baixa definitiva deste item? Ele será removido do inventário.')">
                                                                <input type="hidden" name="id" value="@item.Id" />
                                                                <button type="submit" class="btn btn-sm btn-icon text-danger p-0" title="Baixa Definitiva">
                                                                    <i class="ri-delete-bin-line"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-4">
                        <div class="card shadow-none mb-4" style="background: #2b2c40;">
                            <div class="card-header border-bottom border-light border-opacity-10">
                                <h5 class="mb-0 text-white"><i class="ri-history-line me-2 text-info"></i>Requisições</h5>
                            </div>
                            <div class="card-body pt-4">
                                @if (!Model.MyStockRequests.Any())
                                {
                                    <div class="text-center py-3 text-muted small">Sem requisições recentes.</div>
                                }
                                else
                                {
                                    <div class="list-group list-group-flush">
                                        @foreach (var req in Model.MyStockRequests.Take(5))
                                        {
                                            <div class="list-group-item bg-transparent px-0 border-light border-opacity-10">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="fw-bold text-white small">Pedido #@req.Id</span>
                                                    @{
                                                        var stClass = req.Status switch {
                                                            "Pedido" => "badge-soft-info",
                                                            "Pendente" => "badge-soft-warning",
                                                            "Concluído" => "badge-soft-success",
                                                            _ => "bg-label-secondary"
                                                        };
                                                    }
                                                    <span class="badge @stClass" style="font-size: 0.65rem;">@req.Status</span>
                                                </div>
                                                <div class="text-white-50 small text-truncate">@(req.Description?.Split('\n').FirstOrDefault() ?? "Sem detalhes")</div>
                                                <div class="text-muted" style="font-size: 0.65rem;">@req.CreatedAt.ToString("dd MMM, HH:mm")</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="card shadow-none stock-stat-card">
                            <div class="card-body">
                                <h6 class="text-white mb-3">Resumo</h6>
                                <div class="d-flex align-items-center mb-3">
                                    <div class="flex-shrink-0 avatar bg-label-warning rounded me-3">
                                        <i class="ri-hand-coin-line fs-4"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-0 text-white">@Model.MyStock.Count</h5>
                                        <small class="text-white-50">Itens emprestados na tua mala</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Request Stock -->
<div class="modal fade" id="modalRequestStock" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="RequestStock" class="modal-content border-0" style="background: transparent !important; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); color: #fff;">
            <div class="modal-header border-bottom border-light border-opacity-25">
                <h5 class="modal-title text-white">Solicitar Reposição de Mala</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label text-white-50 small text-uppercase">Artigo / Peça</label>
                        <select name="stockId" class="form-select" required>
                            <option value="">Selecione um artigo disponível</option>
                            @foreach (var opt in Model.AvailableRequestItems)
                            {
                                <option value="@opt.StockId">@opt.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Quantidade</label>
                        <input type="number" name="quantity" class="form-control" value="1" min="1" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50 small text-uppercase">Origem</label>
                        <input type="text" class="form-control" value="Stock Empresa" disabled />
                    </div>
                    <div class="col-12">
                        <label class="form-label text-white-50 small text-uppercase">Notas Adicionais</label>
                        <textarea name="notes" class="form-control" rows="2" placeholder="Explica brevemente o motivo da requisição..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top border-light border-opacity-25">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
