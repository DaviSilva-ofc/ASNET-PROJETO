    function openEditModal(id, name, type, brand, model, serial, roomId, empresaId, status) {
        document.getElementById('editId').value = id;

        // Set Artigo with normalization
        const artSelect = document.getElementById('editArtigo');
        const cleanName = (name || '').toLowerCase().trim();
        
        // Try to find a matching option (case insensitive)
        let matchingOpt = Array.from(artSelect.options).find(o => o.value.toLowerCase().trim() === cleanName);
        
        // Specific normalization rules
        if (!matchingOpt) {
            if (cleanName === 'computador') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Computadores');
            else if (cleanName === 'monitor' || cleanName === 'televisão' || cleanName === 'tv') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Monitores');
            else if (cleanName === 'impressora') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Impressoras');
            else if (cleanName === 'componente') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Componentes');
            else if (cleanName === 'periférico' || cleanName === 'rato' || cleanName === 'teclado') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Periféricos');
            else if (cleanName === 'projetor') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Projetores');
            else if (cleanName.includes('quadro') || cleanName.includes('board')) matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Quadros Interativos');
        }

        if (matchingOpt) {
            artSelect.value = matchingOpt.value;
        } else {
            artSelect.value = 'Outros'; 
        }

        // Trigger updates
        updateBrandsModels('edit');
        updateSpecificTypes('edit');

        // Set Marca and trigger models update
        const marcaSelect = document.getElementById('editMarca');
        marcaSelect.value = brand;
        updateModels('edit');

        // Set others
        document.getElementById('editModelo').value = model;
        
        // Set type (Tipo Específico)
        const tipoSelect = document.getElementById('editTipo');
        const cleanType = (type || '').toLowerCase().trim();
        let matchedType = Array.from(tipoSelect.options).find(o => o.value.toLowerCase().trim() === cleanType);
        if (matchedType) {
            tipoSelect.value = matchedType.value;
        } else {
            tipoSelect.value = type || ""; 
        }

        document.getElementById('editSerial').value = serial;
        document.getElementById('editStatus').value = status || 'A funcionar';
        document.getElementById('editSala').value = roomId || '';
        document.getElementById('editEmpresa').value = empresaId || '';
        document.getElementById('editLocationType').value = empresaId ? 'empresa' : 'escola';

        var modal = new bootstrap.Modal(document.getElementById('modalEditarEquipamento'));
        modal.show();
    }

    function filterReqEqTypes() {
        const artName = document.getElementById('reqEqArtigo').value;
        const tipoSelect = document.getElementById('reqEqTipo');
        const options = tipoSelect.querySelectorAll('option');
        tipoSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            const art = (opt.getAttribute('data-art') || "");
            opt.style.display = (artName === "" || art === artName) ? '' : 'none';
        });
    }
</script>
