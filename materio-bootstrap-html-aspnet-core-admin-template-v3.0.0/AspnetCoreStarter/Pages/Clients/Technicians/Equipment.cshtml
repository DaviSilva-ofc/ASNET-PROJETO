@section PageScripts {
<script>
    function toggleLocationType() {
        const isEmpresa = document.getElementById('locEmpresa').checked;
        const hdnLocType = document.getElementById('hdnLocationType');
        const divEscola = document.getElementById('divLocEscola');
        const divEmpresa = document.getElementById('divLocEmpresa');
        const empresaSelect = document.getElementById('regEmpresaLoc');
        const salaSelect = document.querySelector('[name="NewEquipment.RoomId"]');

        if (isEmpresa) {
            hdnLocType.value = 'empresa';
            divEscola.style.display = 'none';
            divEmpresa.style.display = 'block';
            empresaSelect.disabled = false;
            if (salaSelect) salaSelect.value = '';
        } else {
            hdnLocType.value = 'escola';
            divEscola.style.display = 'block';
            divEmpresa.style.display = 'none';
            empresaSelect.disabled = true;
            empresaSelect.value = '';
        }
    }

    // Filter select options by search input
    function filterSelect(input, selectId) {
        var filter = (input ? input.value : "").toLowerCase().trim();
        var select = document.getElementById(selectId);
        var options = select.querySelectorAll('option');
        
        var currentArtigo = null;
        if (selectId === 'regTipo') {
            currentArtigo = document.getElementById('regArtigo').value.toLowerCase().trim();
        } else if (selectId === 'editTipo') {
            currentArtigo = document.getElementById('editArtigo').value.toLowerCase().trim();
        } else if (selectId === 'filterTipo') {
            currentArtigo = document.getElementById('filterArtigo').value.toLowerCase().trim();
        }

        options.forEach(function(opt) {
            if (opt.value === "") return;
            var text = opt.textContent.toLowerCase();
            var matchesSearch = text.includes(filter);
            
            var matchesArtigo = true;
            if (currentArtigo) {
                var targetArtigo = (opt.getAttribute('data-artigo') || "").toLowerCase().trim();
                matchesArtigo = (targetArtigo === currentArtigo);
            }

            const shouldShow = (matchesSearch && matchesArtigo);
            opt.style.display = shouldShow ? '' : 'none';
            opt.hidden = !shouldShow;
            opt.disabled = !shouldShow;
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        if (typeof jQuery !== 'undefined' && typeof jQuery.fn.select2 !== 'undefined') {
            $('.select2').select2({ dropdownParent: $('#modalFiltros'), width: '100%' });
        }
        var filterBrand = document.getElementById('filterBrand');
        var filterModel = document.getElementById('filterModel');
        var filterArtigo = document.getElementById('filterArtigo');
        if (filterBrand) filterBrand.setAttribute('data-selected', '@(Model.FilterBrand ?? "")');
        if (filterModel) filterModel.setAttribute('data-selected', '@(Model.FilterModel ?? "")');
        filterTypesByFilterArtigo();
        updateFilterBrandsAndModels();
        if (filterArtigo) {
            filterArtigo.addEventListener('change', function() { filterTypesByFilterArtigo(this.value); });
        }
        if (filterBrand) {
            filterBrand.addEventListener('change', function() { updateFilterModels(); });
        }
        document.querySelectorAll('.modal').forEach(function(modal) {
            modal.addEventListener('hidden.bs.modal', function() {
                modal.querySelectorAll('.select-search-input').forEach(function(inp) {
                    inp.value = '';
                    var wrapper = inp.closest('.select-search-wrapper');
                    if (wrapper) {
                        wrapper.querySelectorAll('select option').forEach(function(opt) {
                            opt.style.display = '';
                            opt.hidden = false;
                            opt.disabled = false;
                        });
                    }
                });
            });
        });
    });

