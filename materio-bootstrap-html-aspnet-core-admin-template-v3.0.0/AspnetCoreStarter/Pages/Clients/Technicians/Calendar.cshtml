@page
@model AspnetCoreStarter.Pages.Clients.Technicians.CalendarModel
@{
    Layout ="Layouts/_ContentNavbarLayout";
    ViewData["Title"] ="Calendário de Atividades - Técnico";
}

@section PageStyles {
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />
<style>
    :root {
        --fc-border-color: rgba(255, 255, 255, 0.05);
        --fc-daygrid-event-dot-width: 8px;
        --fc-text-title: #fff;
        --fc-text-strong: rgba(255, 255, 255, 0.8);
        --fc-text-muted: rgba(255, 255, 255, 0.5);
    }
    
    [data-bs-theme="light"] {
        --fc-border-color: rgba(0, 0, 0, 0.1);
        --fc-text-title: #334155;
        --fc-text-strong: #475569;
        --fc-text-muted: #94a3b8;
    }

    .dark-style .card {
        background-color: var(--tk-card-solid) !important;
    }

    #calendar {
        height: calc(100vh - 250px);
        min-height: 600px;
    }

    /* FullCalendar Custom Premium Styling */
    .fc { font-family: 'Public Sans', sans-serif; }
    .fc-header-toolbar { margin-bottom: 2rem !important; flex-wrap: wrap; gap: 10px; }
    .fc-toolbar-title { font-size: 1.5rem !important; font-weight: 700 !important; color: var(--fc-text-title) !important; }
    
    .fc-button-primary { 
        background-color: #f89223 !important; 
        border-color: #f89223 !important; 
        text-transform: capitalize;
        font-weight: 500;
        padding: 0.5rem 1rem;
    }
    .fc-button-primary:hover { background-color: #e67e1a !important; border-color: #e67e1a !important; }
    .fc-button-active { background-color: #d46f14 !important; }

    .fc-daygrid-event { 
        border-radius: 6px; 
        padding: 3px 8px; 
        font-size: 0.8rem; 
        border: none !important;
        margin-top: 2px;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    .fc-daygrid-event:hover {
        transform: scale(1.02);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }

    .fc-theme-standard td, .fc-theme-standard th { border-color: var(--fc-border-color) !important; }
    .fc-col-header-cell-cushion { color: var(--fc-text-strong) !important; font-weight: 600; padding: 10px 0; }
    .fc-daygrid-day-number { color: var(--fc-text-muted) !important; padding: 10px !important; }
    
    .fc-day-today { background: rgba(248, 146, 35, 0.08) !important; }

    /* Popover fix for many events */
    .fc-popover {
        border: 1px solid var(--fc-border-color) !important;
        box-shadow: 0 4px 14px rgba(0,0,0,0.15) !important;
        background-color: var(--bs-body-bg) !important;
        border-radius: 8px !important;
        z-index: 1050 !important;
    }
    .fc-popover-header {
        background-color: var(--bs-tertiary-bg) !important;
        color: var(--bs-heading-color) !important;
        border-radius: 8px 8px 0 0 !important;
        padding: 8px 12px !important;
    }
    .fc-popover-body {
        max-height: 300px !important;
        overflow-y: auto !important;
        padding: 8px !important;
    }

    /* Custom Orange Event Classes */
    .bg-label-primary { background-color: rgba(248, 146, 35, 0.16) !important; color: #f89223 !important; }
    .bg-label-success { background-color: rgba(255, 126, 0, 0.2) !important; color: #ff8c00 !important; }
    .bg-label-secondary { background-color: rgba(133, 146, 163, 0.16) !important; color: #8592a3 !important; }
    .bg-label-warning { background-color: rgba(255, 193, 7, 0.16) !important; color: #ffc107 !important; }

    /* Transparent Form Inputs */
    .form-control-transparent {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: var(--bs-heading-color) !important;
    }
    .form-control-transparent:focus {
        background-color: rgba(255, 255, 255, 0.1) !important;
        border-color: #f89223 !important;
        box-shadow: none !important;
    }

    .fc-list-event-title { color: var(--fc-text-title) !important; }
    .fc-list-day-text, .fc-list-day-side-text { color: #f89223 !important; font-weight: 600; }

    /* Clean calendar view - Match other days to background */
    .fc-theme-standard td, .fc-theme-standard th { 
        border-color: rgba(255, 255, 255, 0.05) !important; 
    }

    .fc-day-other {
        background-color: var(--tk-card-solid) !important;
        opacity: 0.1;
    }
    
    .fc-daygrid-day.fc-day-other {
        background: none !important;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="fw-bold mb-1">Calendário de Atividades</h4>
            <p class="text-muted mb-0">Rastreio visual de entrada, aceitação e conclusão de tickets.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Modal de Detalhes (Simples) -->
<div class="modal fade" id="eventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--bs-body-bg);">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title" id="eventTitle" style="color: var(--bs-heading-color);">Detalhes do Evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="eventDescription" class="mb-4" style="color: var(--bs-body-color);"></p>
                <div id="eventActions" class="d-none">
                    <a href="#" id="viewDashboardBtn" class="btn btn-warning w-100">
                        <i class="ri-dashboard-line me-1"></i>Ver no Dashboard
                    </a>
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Adicionar Atividade -->
<div class="modal fade" id="addActivityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--bs-body-bg);">
            <form method="post" asp-page-handler="AddActivity">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title" style="color: var(--bs-heading-color);">Agendar Atividade / Nota</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" style="color: var(--bs-body-color);">Título / Local</label>
                        <input type="text" name="title" class="form-control" placeholder="Ex: Visita à Escola de Braga" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color: var(--bs-body-color);">Descrição (Opcional)</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Detalhes da intervenção ou nota..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color: var(--bs-body-color);">Data</label>
                        <input type="date" name="date" id="activityDateInput" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Gravar no Calendário</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var eventModal = new bootstrap.Modal(document.getElementById('eventModal'));
        var addModal = new bootstrap.Modal(document.getElementById('addActivityModal'));
        
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            selectable: true,
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,listMonth'
            },
            buttonText: {
                today: 'Hoje',
                month: 'Mês',
                week: 'Semana',
                list: 'Lista'
            },
            locale: 'pt-pt',
            events: @Html.Raw(Model.CalendarEventsJson ??"[]"),
            select: function(info) {
                // Ao selecionar um dia, abre o modal de adição
                document.getElementById('activityDateInput').value = info.startStr;
                addModal.show();
            },
            eventClick: function(info) {
                document.getElementById('eventTitle').innerText = info.event.title;
                document.getElementById('eventDescription').innerText = info.event.extendedProps.description ||"Sem descrição adicional.";
                
                const ticketId = info.event.extendedProps.ticketId;
                const actionsDiv = document.getElementById('eventActions');
                const dashboardBtn = document.getElementById('viewDashboardBtn');
                
                if (ticketId) {
                    actionsDiv.classList.remove('d-none');
                    dashboardBtn.href = '/Clients/Technicians/Dashboard?SelectedTicketId=' + ticketId;
                } else {
                    actionsDiv.classList.add('d-none');
                }
                
                eventModal.show();
            },
            height: 'auto',
            themeSystem: 'standard',
            dayMaxEvents: true,
            navLinks: true,
            showNonCurrentDates: false,
            fixedWeekCount: true,
        });
        calendar.render();
    });
</script>
}



