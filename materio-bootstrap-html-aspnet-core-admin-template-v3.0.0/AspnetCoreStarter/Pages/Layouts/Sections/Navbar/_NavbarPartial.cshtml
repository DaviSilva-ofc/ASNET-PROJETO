@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@* ! Brand demo (display only for navbar-full and hide on below xl) *@
@if (ViewData["navbarFull"] != null)
{
  <div class="navbar-brand app-brand demo d-none d-xl-flex py-0 me-6">
    <a asp-page="/frontpages/LandingPage" class="app-brand-link gap-2">
      <span class="app-brand-logo demo">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
      <span class="app-brand-text demo menu-text fw-bold">@TempData.Peek("appName")</span>
    </a>

    @* ! Display menu close icon only for horizontal-menu with navbar-full *@
    @if (Convert.ToBoolean(@TempData.Peek("menuHorizontal")).ToString() == "True")
    {
      <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto d-xl-none">
        <i class="icon-base ri ri-close-line icon-sm"></i>
      </a>
    }
  </div>
}

@* ! Not required for layout-without-menu *@
@if (ViewData["navbarHideToggle"] == null)
{
  <div class='layout-menu-toggle navbar-nav align-items-xl-center me-4 me-xl-0  @((Convert.ToBoolean(@TempData.Peek("menuHorizontal")).ToString() == "True") ? "d-xl-none" : "") @((@ViewData["contentNavbar"] != null && Convert.ToBoolean(@ViewData["contentNavbar"])) ? "" : "d-xl-none")'>
    <a class="nav-item nav-link px-0 me-xl-6" href="javascript:void(0)">
      <i class="icon-base ri ri-menu-line icon-md"></i>
    </a>
  </div>
}

<div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">

  <ul class="navbar-nav flex-row align-items-center me-3">
    <!-- Style Switcher -->
    <li class="nav-item dropdown dropdown-style-switcher me-2" style="position: relative; z-index: 2000;">
      <a class="nav-link dropdown-toggle hide-arrow" id="nav-theme" href="javascript:void(0);" data-bs-toggle="dropdown">
        <i class="icon-base ri ri-sun-line icon-md theme-icon-active"></i>
        <span class="d-none ms-2" id="nav-theme-text">Toggle theme</span>
      </a>
      <ul class="dropdown-menu" aria-labelledby="nav-theme-text" style="z-index: 3000;">
        <li>
          <button type="button" class="dropdown-item align-items-center active" data-bs-theme-value="light" aria-pressed="false">
            <span> <i class="icon-base ri ri-sun-line icon-md me-3" data-icon="sun-line"></i>Light</span>
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item align-items-center" data-bs-theme-value="dark" aria-pressed="true">
            <span> <i class="icon-base ri ri-moon-clear-line icon-md me-3" data-icon="moon-clear-line"></i>Dark</span>
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item align-items-center" data-bs-theme-value="system" aria-pressed="false">
            <span> <i class="icon-base ri ri-computer-line icon-md me-3" data-icon="computer-line"></i>System</span>
          </button>
        </li>
      </ul>
    </li>
    <!-- / Style Switcher-->
  </ul>



  <ul class="navbar-nav flex-row align-items-center ms-auto">
    @* ! Hide User dropdown for front pages and show Login button instead *@
    @inject AspnetCoreStarter.Data.AppDbContext _context
    @{
      var isAuthenticated = User.Identity.IsAuthenticated;
      var userIdStr = User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
      AspnetCoreStarter.Models.User dbUser = null;
      if (isAuthenticated && !string.IsNullOrEmpty(userIdStr))
      {
          try 
          {
              if (int.TryParse(userIdStr, out int userId))
              {
                  dbUser = _context.Users.FirstOrDefault(u => u.Id == userId);
              }
          }
          catch { /* Fallback to default if DB fails */ }
      }

      var username = dbUser?.Username ?? User.Identity.Name ?? "Utilizador";
      var profilePhoto = dbUser?.ProfilePhotoPath ?? "/img/avatars/1.png";
      var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Membro";
    }
    @if (ViewData["isFront"] != null && Convert.ToBoolean(ViewData["isFront"]))
    {
      <li class="nav-item">
        <a class="nav-link fw-medium" href="/frontpages/LandingPage" style="position: relative; z-index: 1000;">Início</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-medium" href="/frontpages/LandingPage#landingFeatures" style="position: relative; z-index: 1000;">Serviços</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-medium me-2" href="/frontpages/LandingPage#landingContact" style="position: relative; z-index: 1000;">Contacto</a>
      </li>
    }

    <!-- Notification Bell (Admins only) -->
    @if (userRole == "Admin")
    {
        var pendingUsers = _context.Users.Where(u => u.AccountStatus == "Pendente").OrderByDescending(u => u.CreatedAt).ToList();
        var pendingCount = pendingUsers.Count;
        
        <li class="nav-item dropdown-notifications navbar-dropdown dropdown me-3">
          <a class="nav-link dropdown-toggle hide-arrow" href="javascript:void(0);" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
            <div class="position-relative" style="display: inline-block;">
              <span style="font-size: 1.6rem; filter: drop-shadow(0 0 2px rgba(255,171,0,0.5));">🔔</span>
              @if (pendingCount > 0)
              {
                <span class="badge rounded-pill bg-danger" style="position: absolute; top: -8px; right: -10px; font-size: 0.7rem; padding: 3px 6px; border: 2px solid white;">@pendingCount</span>
              }
            </div>
          </a>
          <ul class="dropdown-menu dropdown-menu-end py-0 shadow-lg border-0" style="width: 300px; border-radius: 12px; overflow: hidden;">
            <li class="dropdown-menu-header border-bottom bg-primary">
              <div class="dropdown-header d-flex align-items-center py-3">
                <h6 class="mb-0 me-auto text-white">Notificações</h6>
                @if (pendingCount > 0)
                {
                  <span class="badge rounded-pill bg-white text-primary">@pendingCount Novos</span>
                }
              </div>
            </li>
            <li class="dropdown-notifications-list scrollable-container" style="max-height: 350px; overflow-y: auto;">
              <ul class="list-group list-group-flush">
                @if (pendingCount == 0)
                {
                  <li class="list-group-item list-group-item-action dropdown-notifications-item border-0">
                    <div class="d-flex py-3 align-items-center justify-content-center text-center">
                      <div class="flex-grow-1">
                        <i class="ri-check-double-line mb-2 d-block text-muted" style="font-size: 1.5rem;"></i>
                        <h6 class="mb-0 small text-muted">Tudo em dia! Sem pendentes.</h6>
                      </div>
                    </div>
                  </li>
                }
                else
                {
                  @foreach (var u in pendingUsers.Take(8))
                  {
                    <li class="list-group-item list-group-item-action dropdown-notifications-item border-bottom-0">
                      <a href="/Admin/Dashboard?openPending=true" class="d-flex py-2 text-decoration-none">
                        <div class="flex-shrink-0 me-3">
                          <div class="avatar avatar-sm">
                            <span class="avatar-initial rounded-circle bg-label-warning fw-bold">@u.Username.Substring(0, 1).ToUpper()</span>
                          </div>
                        </div>
                        <div class="flex-grow-1">
                          <h6 class="mb-1 small fw-bold text-dark">Novo registo: @u.Username</h6>
                          <p class="mb-0 small text-muted">Aguardando aprovação de conta.</p>
                        </div>
                        <div class="flex-shrink-0">
                          <small class="text-muted" style="font-size: 0.7rem;">@u.CreatedAt.ToString("dd/MM")</small>
                        </div>
                      </a>
                    </li>
                  }
                }
              </ul>
            </li>
            <li class="dropdown-menu-footer border-top">
              <a href="/Admin/Dashboard?openPending=true" class="dropdown-item d-flex justify-content-center text-primary fw-semibold py-2">
                Ver todos os pedidos de registo
              </a>
            </li>
          </ul>
        </li>
    }

    @if (isAuthenticated)
    {
      <!-- User -->
      <li class="nav-item navbar-dropdown dropdown-user dropdown">
        <a class="nav-link dropdown-toggle hide-arrow p-0" href="javascript:void(0);" data-bs-toggle="dropdown">
          <div class="avatar avatar-online">
            <img src="@profilePhoto" alt="Avatar" class="rounded-circle" />
          </div>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-3 py-2">
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <div class="d-flex align-items-center">
                <div class="flex-shrink-0 me-2">
                  <div class="avatar avatar-online">
                    <img src="@profilePhoto" alt="Avatar" class="w-px-40 h-auto rounded-circle" />
                  </div>
                </div>
                <div class="flex-grow-1">
                  <h6 class="mb-0 small">@username</h6>
                  <small class="text-body-secondary">@userRole</small>
                </div>
              </div>
            </a>
          </li>
          <li>
            <div class="dropdown-divider"></div>
          </li>
          <li>
            <a class="dropdown-item" href="/Profile">
              <i class="icon-base ri ri-user-3-line icon-22px me-2"></i>
              <span class="align-middle">O Meu Perfil</span>
            </a>
          </li>
          <li>
            <div class="d-grid px-4 pt-2 pb-1">
              <a href="/Auth/Logout" class="btn btn-danger w-100 d-flex align-items-center justify-content-center">
                <small class="align-middle">Sair</small>
                <i class="icon-base ri ri-logout-box-r-line ms-2 icon-16px"></i>
              </a>
            </div>
          </li>
        </ul>
      </li>
      <!--/ User -->
    }
    else if (ViewData["isFront"] == null || !Convert.ToBoolean(ViewData["isFront"]))
    {
      <!-- User -->
      <li class="nav-item navbar-dropdown dropdown-user dropdown">
        <a class="nav-link dropdown-toggle hide-arrow p-0" href="javascript:void(0);" data-bs-toggle="dropdown">
          <div class="avatar avatar-online">
            <img src="~/img/avatars/1.png" alt="alt" class="rounded-circle" />
          </div>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-3 py-2">
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <div class="d-flex align-items-center">
                <div class="flex-shrink-0 me-2">
                  <div class="avatar avatar-online">
                    <img src="~/img/avatars/1.png" alt="alt" class="w-px-40 h-auto rounded-circle" />
                  </div>
                </div>
                <div class="flex-grow-1">
                  <h6 class="mb-0 small">John Doe</h6>
                  <small class="text-body-secondary">Admin</small>
                </div>
              </div>
            </a>
          </li>
          <li>
            <div class="dropdown-divider"></div>
          </li>
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <i class="icon-base ri ri-user-3-line icon-22px me-2"></i>
              <span class="align-middle">My Profile</span>
            </a>
          </li>
          <li>
            <a class="dropdown-item" href="/Auth/Login">
              <i class="icon-base ri ri-logout-box-r-line icon-22px me-2"></i>
              <span class="align-middle">Login</span>
            </a>
          </li>
        </ul>
      </li>
      <!--/ User -->
    }
    else
    {
      <li class="nav-item me-2">
        <a class="btn btn-outline-primary" href="/Auth/Register" style="position: relative; z-index: 2000;">
          <span class="tf-icons ri ri-user-add-line me-1"></span>Criar conta
        </a>
      </li>
      <li class="nav-item">
        <a class="btn btn-primary" href="/Auth/Login" style="position: relative; z-index: 2000;">
          <span class="tf-icons ri-login-box-line me-1"></span>Entrar
        </a>
      </li>
    }


  </ul>
</div>
