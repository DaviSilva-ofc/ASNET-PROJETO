@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@* ! Brand demo (display only for navbar-full and hide on below xl) *@
@if (ViewData["navbarFull"] != null)
{
  <div class="navbar-brand app-brand demo d-none d-xl-flex py-0 me-6">
    <a asp-page="/frontpages/LandingPage" class="app-brand-link gap-2">
      <span class="app-brand-logo demo">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
      <span class="app-brand-text demo menu-text fw-bold">@TempData.Peek("appName")</span>
    </a>

    @* ! Display menu close icon only for horizontal-menu with navbar-full *@
    @if (Convert.ToBoolean(@TempData.Peek("menuHorizontal")).ToString() == "True")
    {
      <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto d-xl-none">
        <i class="icon-base ri ri-close-line icon-sm"></i>
      </a>
    }
  </div>
}

@* ! Not required for layout-without-menu *@
@if (ViewData["navbarHideToggle"] == null)
{
  <div class='layout-menu-toggle navbar-nav align-items-xl-center me-4 me-xl-0  @((Convert.ToBoolean(@TempData.Peek("menuHorizontal")).ToString() == "True") ? "d-xl-none" : "") @((@ViewData["contentNavbar"] != null && Convert.ToBoolean(@ViewData["contentNavbar"])) ? "" : "d-xl-none")'>
    <a class="nav-item nav-link px-0 me-xl-6" href="javascript:void(0)">
      <i class="icon-base ri ri-menu-line icon-md"></i>
    </a>
  </div>
}

<div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
    <a href="/frontpages/LandingPage" class="app-brand-link gap-2 me-3" style="position: relative; z-index: 1000;">
      <span class="app-brand-logo demo">
        <img src="~/img/branding/logo-asnet.png" alt="ASNET Logo" height="30" />
      </span>
    </a>

  <!-- Style Switcher -->
  <div class="navbar-nav align-items-center">
    <div class="nav-item dropdown dropdown-style-switcher me-2 me-xl-0">
      <a class="nav-link dropdown-toggle hide-arrow" id="nav-theme" href="javascript:void(0);" data-bs-toggle="dropdown">
        <i class="icon-base ri ri-sun-line icon-md theme-icon-active"></i>
        <span class="d-none ms-2" id="nav-theme-text">Toggle theme</span>
      </a>
      <ul class="dropdown-menu dropdown-menu-start" aria-labelledby="nav-theme-text">
        <li>
          <button type="button" class="dropdown-item align-items-center active" data-bs-theme-value="light" aria-pressed="false">
            <span> <i class="icon-base ri ri-sun-line icon-md me-3" data-icon="sun-line"></i>Light</span>
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item align-items-center" data-bs-theme-value="dark" aria-pressed="true">
            <span> <i class="icon-base ri ri-moon-clear-line icon-md me-3" data-icon="moon-clear-line"></i>Dark</span>
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item align-items-center" data-bs-theme-value="system" aria-pressed="false">
            <span> <i class="icon-base ri ri-computer-line icon-md me-3" data-icon="computer-line"></i>System</span>
          </button>
        </li>
      </ul>
    </div>
  </div>
  <!-- / Style Switcher-->


  <ul class="navbar-nav flex-row align-items-center ms-auto">
    @* ! Hide User dropdown for front pages and show Login button instead *@
    @{
      var userId = HttpContextAccessor.HttpContext.Session.GetString("UserId");
      var username = HttpContextAccessor.HttpContext.Session.GetString("Username") ?? "Utilizador";
      var profilePhoto = HttpContextAccessor.HttpContext.Session.GetString("UserProfilePhoto") ?? "/img/avatars/1.png";
    }
    @if (ViewData["isFront"] != null && Convert.ToBoolean(ViewData["isFront"]))
    {
      <li class="nav-item">
        <a class="nav-link fw-medium" href="/frontpages/LandingPage" style="position: relative; z-index: 1000;">Início</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-medium" href="/frontpages/LandingPage#landingFeatures" style="position: relative; z-index: 1000;">Serviços</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-medium me-2" href="/frontpages/LandingPage#landingContact" style="position: relative; z-index: 1000;">Contacto</a>
      </li>
    }

    @if (!string.IsNullOrEmpty(userId))
    {
      <!-- User -->
      <li class="nav-item navbar-dropdown dropdown-user dropdown">
        <a class="nav-link dropdown-toggle hide-arrow p-0" href="javascript:void(0);" data-bs-toggle="dropdown">
          <div class="avatar avatar-online">
            <img src="@profilePhoto" alt="Avatar" class="rounded-circle" />
          </div>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-3 py-2">
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <div class="d-flex align-items-center">
                <div class="flex-shrink-0 me-2">
                  <div class="avatar avatar-online">
                    <img src="@profilePhoto" alt="Avatar" class="w-px-40 h-auto rounded-circle" />
                  </div>
                </div>
                <div class="flex-grow-1">
                  <h6 class="mb-0 small">@username</h6>
                  <small class="text-body-secondary">Membro</small>
                </div>
              </div>
            </a>
          </li>
          <li>
            <div class="dropdown-divider"></div>
          </li>
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <i class="icon-base ri ri-user-3-line icon-22px me-2"></i>
              <span class="align-middle">O Meu Perfil</span>
            </a>
          </li>
          <li>
            <div class="d-grid px-4 pt-2 pb-1">
              <form method="POST" asp-page="/Auth/Logout">
                <button type="submit" class="btn btn-danger w-100 d-flex align-items-center justify-content-center">
                  <small class="align-middle">Sair</small>
                  <i class="icon-base ri ri-logout-box-r-line ms-2 icon-16px"></i>
                </button>
              </form>
            </div>
          </li>
        </ul>
      </li>
      <!--/ User -->
    }
    else if (ViewData["isFront"] == null || !Convert.ToBoolean(ViewData["isFront"]))
    {
      <!-- User -->
      <li class="nav-item navbar-dropdown dropdown-user dropdown">
        <a class="nav-link dropdown-toggle hide-arrow p-0" href="javascript:void(0);" data-bs-toggle="dropdown">
          <div class="avatar avatar-online">
            <img src="~/img/avatars/1.png" alt="alt" class="rounded-circle" />
          </div>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-3 py-2">
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <div class="d-flex align-items-center">
                <div class="flex-shrink-0 me-2">
                  <div class="avatar avatar-online">
                    <img src="~/img/avatars/1.png" alt="alt" class="w-px-40 h-auto rounded-circle" />
                  </div>
                </div>
                <div class="flex-grow-1">
                  <h6 class="mb-0 small">John Doe</h6>
                  <small class="text-body-secondary">Admin</small>
                </div>
              </div>
            </a>
          </li>
          <li>
            <div class="dropdown-divider"></div>
          </li>
          <li>
            <a class="dropdown-item" href="javascript:void(0);">
              <i class="icon-base ri ri-user-3-line icon-22px me-2"></i>
              <span class="align-middle">My Profile</span>
            </a>
          </li>
          <li>
            <a class="dropdown-item" href="/Auth/Login">
              <i class="icon-base ri ri-logout-box-r-line icon-22px me-2"></i>
              <span class="align-middle">Login</span>
            </a>
          </li>
        </ul>
      </li>
      <!--/ User -->
    }
    else
    {
      <li class="nav-item me-2">
        <a class="btn btn-primary" href="/Auth/RegisterSchool" style="position: relative; z-index: 1000;">
          Registe aqui a sua escola
        </a>
      </li>
      <li class="nav-item me-2">
        <a class="btn btn-outline-primary" href="/Auth/Register">
          <span class="tf-icons ri ri-user-add-line me-1"></span>Criar conta
        </a>
      </li>
      <li class="nav-item">
        <a class="btn btn-primary" href="/Auth/Login">
          <span class="tf-icons ri-login-box-line me-1"></span>Entrar
        </a>
      </li>
    }

  </ul>
</div>
