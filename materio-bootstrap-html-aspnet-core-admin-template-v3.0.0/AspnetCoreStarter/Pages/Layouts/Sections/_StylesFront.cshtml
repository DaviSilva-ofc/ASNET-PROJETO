<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&ampdisplay=swap" rel="stylesheet" />
<environment include="Development">
  <!-- Iconify icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@iconify/iconify@@3.1.1/dist/iconify.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/node-waves@0.7.6/dist/waves.min.css" />

  <!-- Core CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="~/css/demo.css" />

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@simonwep/pickr/dist/themes/classic.min.css" />

  <!-- Application stylesheets -->
  <link rel="stylesheet" href="~/css/site.dist.css" />
  <link rel="stylesheet" href="~/css/asnet-theme.css" />
</environment>

<environment exclude="Development">
  <!-- Fonts & Flag icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@iconify/iconify@@3.1.1/dist/iconify.min.css" asp-append-version="true" />

  <!-- Core CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/demo.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/node-waves@0.7.6/dist/waves.min.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@simonwep/pickr/dist/themes/classic.min.css" asp-append-version="true" />

  <!-- Application stylesheets -->
  <link rel="stylesheet" href="~/css/site.dist.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/asnet-theme.css" asp-append-version="true" />
<style>
/* Responsive tweaks for laptop screens */
@@media (max-width: 1366px) {
  .layout-navbar .navbar-brand {
    font-size: 1rem;
  }
  .layout-menu {
    width: 250px;
  }
  .layout-page {
    margin-left: 250px;
  }
  .layout-menu .menu-inner .menu-item .menu-link {
    padding: 0.5rem 1rem;
  }
}
</style>
</environment>
