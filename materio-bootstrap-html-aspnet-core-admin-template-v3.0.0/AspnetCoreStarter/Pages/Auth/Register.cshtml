@{
  Layout = "Layouts/_BlankLayout";
  ViewData["Title"] = "Registo";
}

@section PageStyles {
  <link rel="stylesheet" href="~/vendor/css/pages/page-auth.dist.css">
}

<div class="authentication-wrapper authentication-cover">
  <!-- /Left Text -->
  <div class="authentication-inner row m-0">
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 align-items-center justify-content-center p-12 pb-2">
      <img src="~/img/illustrations/auth-cover-register-illustration-light.png" class="auth-cover-illustration w-100" alt="auth-illustration" data-app-light-img="illustrations/auth-cover-register-illustration-light.png" data-app-dark-img="illustrations/auth-cover-register-illustration-dark.png">
      <img src="~/img/illustrations/auth-cover-mask-light.png" class="authentication-image" alt="mask" data-app-light-img="illustrations/auth-cover-mask-light.png" data-app-dark-img="illustrations/auth-cover-mask-dark.png">
    </div>
    <!-- /Left Text -->

    <!-- Register -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg position-relative p-sm-12 p-6">
      <div class="w-px-400 mx-auto pt-5 pt-lg-0">
        <!-- Logo -->
        <div class="app-brand mb-10">
          <a asp-page="/Index" class="app-brand-link gap-2">
            <span class="app-brand-logo demo">
              <img src="~/img/branding/logo-asnet.png" alt="ASNET Logo" height="40" />
            </span>
            <span class="app-brand-text demo text-heading fw-bold">@TempData.Peek("appName")</span>
          </a>
        </div>
        <!-- /Logo -->
        <h4 class="mb-1">A aventura começa aqui 🚀</h4>
        <p class="mb-5">Torne a gestão da sua organização fácil e divertida!</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <form id="formAuthentication" class="mb-5" method="POST" enctype="multipart/form-data">
          <div class="mb-5 text-center">
            <div class="d-flex align-items-center justify-content-center flex-column gap-2">
              <div class="avatar avatar-xl border border-primary border-2 rounded-circle p-1">
                <img src="~/img/avatars/1.png" alt="Avatar" class="rounded-circle" id="avatar-preview">
              </div>
              <div class="form-floating form-floating-outline w-100 mt-2">
                <input type="file" class="form-control" id="profile-photo" asp-for="Input.ProfilePhoto" accept="image/*" onchange="document.getElementById('avatar-preview').src = window.URL.createObjectURL(this.files[0])">
                <label for="profile-photo">Foto de Perfil (Opcional)</label>
              </div>
            </div>
          </div>

          <div class="form-floating form-floating-outline mb-5">
            <input type="text" class="form-control" id="username" asp-for="Input.Username" placeholder="Insira o seu nome de utilizador" autofocus>
            <label for="username">Nome de Utilizador</label>
          </div>
          <div class="form-floating form-floating-outline mb-5">
            <input type="email" class="form-control" id="email" asp-for="Input.Email" placeholder="Insira o seu email">
            <label for="email">Email</label>
          </div>
          <div class="mb-5">
            <div class="form-password-toggle">
              <div class="input-group input-group-merge">
                <div class="form-floating form-floating-outline">
                  <input type="password" id="password" class="form-control" asp-for="Input.Password" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
                  <label for="password">Palavra-passe</label>
                </div>
                <span class="input-group-text cursor-pointer"><i class="ri-eye-off-line"></i></span>
              </div>
            </div>
          </div>

          <div class="mb-5">
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="terms-conditions" asp-for="Input.Terms">
              <label class="form-check-label" for="terms-conditions">
                Eu concordo com os
                <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#termsModal">termos e condições</a>
              </label>
            </div>
          </div>
          <button class="btn btn-primary d-grid w-100">Criar conta</button>
        </form>

        <p class="text-center">
          <span>Já tens uma conta?</span>
          <a href="/Auth/Login">
            <span>Entre em vez disso</span>
          </a>
        </p>

        <div class="divider my-5">
          <div class="divider-text">ou</div>
        </div>

        <div class="d-flex justify-content-center gap-2">
          <a href="javascript:;" class="btn btn-icon btn-lg rounded-pill btn-text-google-plus">
            <i class="tf-icons ri-google-fill ri-24px"></i>
          </a>
          <a href="javascript:;" class="btn btn-icon btn-lg rounded-pill btn-text-secondary">
            <i class="tf-icons ri-microsoft-fill ri-24px"></i>
          </a>
        </div>
      </div>
    </div>
    <!-- /Register -->
  </div>
</div>

<!-- Terms Modal -->
<div class="modal fade" id="termsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Termos e Condições de Uso - ASNET</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <h6>1. Aceitação dos Termos</h6>
        <p>Ao registar-se na plataforma ASNET, o utilizador concorda em cumprir e estar vinculado aos seguintes termos e condições de uso. Se não concordar com qualquer parte destes termos, não deverá utilizar os nossos serviços.</p>

        <h6>2. Descrição do Serviço</h6>
        <p>A ASNET fornece uma plataforma de gestão de dispositivos e operações, visando otimizar a organização e segurança das atividades da sua organização.</p>

        <h6>3. Registo e Segurança da Conta</h6>
        <p>O utilizador é responsável por manter a confidencialidade dos seus dados de acesso e por todas as atividades que ocorram na sua conta. Compromete-se a fornecer informações verdadeiras e atualizadas durante o processo de registo.</p>

        <h6>4. Proteção de Dados e Privacidade</h6>
        <p>A ASNET compromete-se a proteger a privacidade dos dados dos utilizadores em conformidade com o RGPD. Os dados recolhidos (como nome, email e foto de perfil) serão utilizados exclusivamente para a prestação do serviço e melhoria da experiência do utilizador.</p>

        <h6>5. Responsabilidades do Utilizador</h6>
        <p>O utilizador compromete-se a não utilizar a plataforma para fins ilegais ou que possam prejudicar a integridade do sistema ou de outros utilizadores.</p>

        <h6>6. Propriedade Intelectual</h6>
        <p>Todo o conteúdo, logótipos e software da plataforma são propriedade da ASNET ou dos seus licenciadores e estão protegidos por leis de direitos de autor.</p>

        <h6>7. Alterações aos Termos</h6>
        <p>A ASNET reserva-se o direito de modificar estes termos a qualquer momento. As alterações entrarão em vigor assim que publicadas na plataforma.</p>

        <p class="text-muted mt-4 small">Última atualização: 04 de Março de 2026</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Compreendo e Aceito</button>
      </div>
    </div>
  </div>
</div>
