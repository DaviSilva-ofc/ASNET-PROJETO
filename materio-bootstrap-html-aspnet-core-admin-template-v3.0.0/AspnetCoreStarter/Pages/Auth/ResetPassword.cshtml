@page
@model AspnetCoreStarter.Pages.Auth.PasswordResetPageModel
@{
  Layout = "Layouts/_BlankLayout";
  ViewData["Title"] = "Repor Palavra-passe";
  ViewData["isFront"] = true;
}

@section PageStyles {
  <link rel="stylesheet" href="~/vendor/css/pages/page-auth.dist.css">
  <link rel="stylesheet" href="~/css/asnet-theme.css">
}

<div class="authentication-wrapper authentication-cover">
  <!-- /Left Text -->
  <div class="authentication-inner row m-0">
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 align-items-center justify-content-center p-12 pb-2">
      <img src="~/img/illustrations/auth-cover-reset-password-illustration-light.png" class="auth-cover-illustration w-100" alt="auth-illustration" data-app-light-img="illustrations/auth-cover-reset-password-illustration-light.png" data-app-dark-img="illustrations/auth-cover-reset-password-illustration-dark.png">
      <img src="~/img/illustrations/auth-cover-mask-light.png" class="authentication-image" alt="mask" data-app-light-img="illustrations/auth-cover-mask-light.png" data-app-dark-img="illustrations/auth-cover-mask-dark.png">
    </div>
    <!-- /Left Text -->

    <!-- Reset Password -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg position-relative p-sm-12 p-6">
      <div class="w-px-400 mx-auto pt-5 pt-lg-0">
        <!-- Logo -->
        <div class="app-brand mb-10">
          <a asp-page="/Index" class="app-brand-link gap-2">
            <span class="app-brand-logo demo">
              <img src="~/img/branding/logo-asnet.png" alt="ASNET Logo" height="40" />
            </span>
          </a>
        </div>
        <!-- /Logo -->
        <h4 class="mb-1">Repor Palavra-passe 🛠️</h4>
        <p class="mb-5">Escolha uma nova palavra-passe segura para a sua conta</p>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success d-flex align-items-center" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                <div>
                    @Model.SuccessMessage
                </div>
            </div>
            <div class="text-center mt-4">
                <a href="/Auth/Login" class="btn btn-primary w-100">Ir para o Login</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form id="formAuthentication" class="mb-5" method="POST">
                <input type="hidden" asp-for="Token" />

                <div class="mb-5">
                    <div class="form-password-toggle">
                        <div class="input-group input-group-merge">
                            <div class="form-floating form-floating-outline">
                                <input type="password" id="password" class="form-control" asp-for="NewPassword" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" autofocus required />
                                <label for="password">Nova Palavra-passe</label>
                            </div>
                            <span class="input-group-text cursor-pointer"><i class="ri-eye-off-line"></i></span>
                        </div>
                    </div>
                </div>

                <div class="mb-5">
                    <div class="form-password-toggle">
                        <div class="input-group input-group-merge">
                            <div class="form-floating form-floating-outline">
                                <input type="password" id="confirmPassword" class="form-control" asp-for="ConfirmPassword" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" required />
                                <label for="confirmPassword">Confirmar Palavra-passe</label>
                            </div>
                            <span class="input-group-text cursor-pointer"><i class="ri-eye-off-line"></i></span>
                        </div>
                    </div>
                </div>

                <button class="btn btn-primary d-grid w-100">Atualizar Palavra-passe</button>
            </form>
        }

        <div class="text-center">
          <a href="/Auth/Login" class="d-flex align-items-center justify-content-center text-primary">
            <i class="ri-arrow-left-s-line me-1"></i>
            Voltar ao Login
          </a>
        </div>
      </div>
    </div>
    <!-- /Reset Password -->
  </div>
</div>