@page
@model AspnetCoreStarter.Pages.Auth.ResetPasswordModel
@{
  Layout = "Layouts/_FrontLayout";
  ViewData["Title"] = "Repor Palavra-passe";
  ViewData["isFront"] = true;
}

@section PageStyles {
  <link rel="stylesheet" href="~/vendor/css/pages/page-auth.dist.css">
  }

  <div class="position-relative">
    <div class="authentication-wrapper authentication-basic container-p-y p-4 p-sm-0">
      <div class="authentication-inner py-6">

        <!-- Reset Password -->
        <div class="card p-md-7 p-1">
          <div class="card-body">
            <!-- Logo -->
            <div class="app-brand justify-content-center mt-5">
              <a asp-page="/Index" class="app-brand-link gap-2">
                <span class="app-brand-logo demo">
                  <img src="~/img/branding/logo-asnet.png" alt="ASNET Logo" height="30" />
                </span>
                <span class="app-brand-text demo text-heading fw-bold">@TempData.Peek("appName")</span>
              </a>
            </div>
            <!-- /Logo -->
            <h4 class="mb-1">Repor Palavra-passe</h4>
            <p class="mb-5">Escolha uma nova palavra-passe segura para a sua conta</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
              <div class="alert alert-danger" role="alert">
                @Model.ErrorMessage
              </div>
            }

            <form id="formAuthentication" class="mb-5" method="POST">
              <input type="hidden" asp-for="Token" />

              <div class="mb-5">
                <div class="form-password-toggle">
                  <div class="input-group input-group-merge">
                    <div class="form-floating form-floating-outline">
                      <input type="password" id="password" class="form-control" asp-for="NewPassword"
                             placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" autofocus
                             required />
                      <label for="password">Nova Palavra-passe</label>
                    </div>
                    <span class="input-group-text cursor-pointer ps-1 pe-0"><i
                      class="icon-base ri-eye-off-line icon-md"></i></span>
                    </div>
                  </div>
                </div>

                <div class="mb-5">
                  <div class="form-password-toggle">
                    <div class="input-group input-group-merge">
                      <div class="form-floating form-floating-outline">
                        <input type="password" id="confirmPassword" class="form-control" asp-for="ConfirmPassword"
                               placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" required />
                        <label for="confirmPassword">Confirmar Palavra-passe</label>
                      </div>
                      <span class="input-group-text cursor-pointer ps-1 pe-0"><i
                        class="icon-base ri-eye-off-line icon-md"></i></span>
                      </div>
                    </div>
                  </div>

                  <button class="btn btn-primary d-grid w-100">Atualizar Palavra-passe</button>
                </form>

                <div class="text-center">
                  <a href="/Auth/Login" class="d-flex align-items-center justify-content-center">
                    <i class="icon-base ri ri-arrow-left-s-line me-1"></i>
                    Voltar ao Login
                  </a>
                </div>
              </div>
            </div>
            <!-- /Reset Password -->
          </div>
        </div>
      </div>