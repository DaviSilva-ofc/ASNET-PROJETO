@{
  Layout = "Layouts/_BlankLayout";
  ViewData["Title"] = "Login";
}

@section PageStyles {
  <link rel="stylesheet" href="~/vendor/css/pages/page-auth.dist.css">
}

<div class="authentication-wrapper authentication-cover">
  <!-- /Left Text -->
  <div class="authentication-inner row m-0">
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 align-items-center justify-content-center p-12 pb-2">
      <img src="~/img/illustrations/auth-cover-login-illustration-light.png" class="auth-cover-illustration w-100" alt="auth-illustration" data-app-light-img="illustrations/auth-cover-login-illustration-light.png" data-app-dark-img="illustrations/auth-cover-login-illustration-dark.png">
      <img src="~/img/illustrations/auth-cover-mask-light.png" class="authentication-image" alt="mask" data-app-light-img="illustrations/auth-cover-mask-light.png" data-app-dark-img="illustrations/auth-cover-mask-dark.png">
    </div>
    <!-- /Left Text -->

    <!-- Login -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg position-relative p-sm-12 p-6">
      <div class="w-px-400 mx-auto pt-5 pt-lg-0">
        <!-- Logo -->
        <div class="app-brand mb-10">
          <a asp-page="/Index" class="app-brand-link gap-2">
            <span class="app-brand-logo demo">
              <img src="~/img/branding/logo-asnet.png" alt="ASNET Logo" height="40" />
            </span>
            <span class="app-brand-text demo text-heading fw-bold">@TempData.Peek("appName")</span>
          </a>
        </div>
        <!-- /Logo -->
        <h4 class="mb-1">Bem-vindo à @TempData.Peek("appName")! 👋</h4>
        <p class="mb-5">Por favor, inicie sessão na sua conta e comece a aventura</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <form id="formAuthentication" class="mb-5" method="POST">
          <div class="form-floating form-floating-outline mb-5">
            <input type="text" class="form-control" id="email" asp-for="Email" placeholder="Insira o seu email ou utilizador" autofocus>
            <label for="email">Email ou Utilizador</label>
          </div>
          <div class="mb-5">
            <div class="form-password-toggle">
              <div class="input-group input-group-merge">
                <div class="form-floating form-floating-outline">
                  <input type="password" id="password" class="form-control" asp-for="Password" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
                  <label for="password">Palavra-passe</label>
                </div>
                <span class="input-group-text cursor-pointer"><i class="ri-eye-off-line"></i></span>
              </div>
            </div>
          </div>
          <div class="mb-5 d-flex justify-content-between mt-5">
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="remember-me" asp-for="RememberMe">
              <label class="form-check-label" for="remember-me">
                Lembrar-me
              </label>
            </div>
            <a href="/Auth/ForgotPassword" class="float-end mb-1 mt-2">
              <span>Esqueceu-se da palavra-passe?</span>
            </a>
          </div>
          <div class="mb-5">
            <button class="btn btn-primary d-grid w-100" type="submit">Entrar</button>
          </div>
        </form>

        <p class="text-center">
          <span>Novo na nossa plataforma?</span>
          <a href="/Auth/Register">
            <span>Criar uma conta</span>
          </a>
        </p>

        <div class="divider my-5">
          <div class="divider-text">ou</div>
        </div>

        <div class="d-flex justify-content-center gap-2">
          <a href="javascript:;" class="btn btn-icon btn-lg rounded-pill btn-text-google-plus">
            <i class="tf-icons ri-google-fill ri-24px"></i>
          </a>
          <a href="javascript:;" class="btn btn-icon btn-lg rounded-pill btn-text-secondary">
            <i class="tf-icons ri-microsoft-fill ri-24px"></i>
          </a>
        </div>
      </div>
    </div>
    <!-- /Login -->
  </div>
</div>
