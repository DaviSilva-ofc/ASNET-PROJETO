<style>
  .landing-hero-carousel {
    overflow: hidden;
    position: relative;
    z-index: 1;
  }
  .landing-hero-carousel .swiper-slide {
    position: relative;
    height: 100vh;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .landing-hero-carousel .slide-content {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    padding: 3rem;
    border-radius: 1.5rem;
    color: white;
    max-width: 800px;
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-align: center;
    z-index: 2;
  }
  /* Navbar styling to differentiate from background */
  #layout-navbar {
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  /* White text for navbar links and icons */
  #layout-navbar:not(.navbar-active) .nav-link,
  #layout-navbar:not(.navbar-active) .theme-icon-active,
  #layout-navbar:not(.navbar-active) .app-brand-text {
    color: #fff !important;
  }
  /* Hover effect for navbar links */
  #layout-navbar .nav-link {
    transition: all 0.3s ease-in-out;
  }
  #layout-navbar .nav-link:hover {
    color: #f89223 !important; /* ASNET Orange */
    transform: scale(1.1);
  }
  #layout-navbar.navbar-active {
    background: var(--bs-body-bg) !important;
  }
  .landing-hero-carousel h1 {
    color: white !important;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }
  .landing-hero-carousel .swiper-button-next,
  .landing-hero-carousel .swiper-button-prev {
    color: #f89223;
    background: rgba(255, 255, 255, 0.8);
    width: 50px;
    height: 50px;
    border-radius: 50%;
  }
  .landing-hero-carousel .swiper-button-next:after,
  .landing-hero-carousel .swiper-button-prev:after {
    font-size: 20px;
  }
  .landing-hero-carousel .swiper-pagination-bullet-active {
    background: #f89223;
  }
</style>
}
