@page
@model AspnetCoreStarter.Pages.FrontPages.LandingPageModel
@{
  Layout = "Layouts/_FrontLayout";
  ViewData["Title"] = "Landing Page - Front Pages";
}

@* ************** Content ************** *@
<div data-bs-spy="scroll" class="scrollspy-example">
  <!-- Inicio iterativo: Start -->
  <section id="landingHero" class="section-py landing-hero position-relative">
    <img src="~/img/front-pages/backgrounds/hero-bg-light.png" alt="hero background" class="position-absolute top-0 start-0 w-100 h-100 z-n1" data-speed="1" data-app-light-img="front-pages/backgrounds/hero-bg-light.png" data-app-dark-img="front-pages/backgrounds/hero-bg-dark.png" />
    <div class="container">
      <div class="hero-text-box text-center">
        <h2 class="text-primary hero-title mb-4">Gestão eficaz de equipamentos</h2>
        <h2 class="h6 mb-8 lh-md">garanta segurança, organização e agilidade em cada operação.</h2>
        <a href="#landingPricing" class="btn btn-lg btn-primary">Criar conta</a>
      </div>
      <div class="position-relative hero-animation-img">
        <a href="/Ecommerce/Dashboard" target="_blank">
          <div class="hero-dashboard-img text-center">
            <img src="~/img/front-pages/landing-page/hero-dashboard-light.png" alt="hero dashboard" class="animation-img" data-speed="2" data-app-light-img="front-pages/landing-page/hero-dashboard-light.png" data-app-dark-img="front-pages/landing-page/hero-dashboard-dark.png" />
          </div>
          <div class="position-absolute hero-elements-img">
            <img src="~/img/front-pages/landing-page/hero-elements-light.png" alt="hero elements" class="animation-img" data-speed="4" data-app-light-img="front-pages/landing-page/hero-elements-light.png" data-app-dark-img="front-pages/landing-page/hero-elements-dark.png" />
          </div>
        </a>
      </div>
    </div>
  </section>
  <!-- Inicio iterativo: End -->

  <!-- utilidades: Start -->
  <section id="landingFeatures" class="section-py landing-features">
    <div class="container">
      <h6 class="text-center d-flex justify-content-center align-items-center mb-6">
        <img src="~/img/front-pages/icons/section-title-icon.png" alt="section title icon" class="me-2" height="19" />
        <span class="text-uppercase">Funcionalidades principais</span>
      </h6>
      <h5 class="text-center mb-2"><span class="h4 fw-bold">Tudo o que precisas</span> para gerir os teus equipamentos</h5>
      <p class="text-center fw-medium mb-4 mb-md-12">uma aplicação que garante segurança e organização em cada operação.</p>
      <div class="features-icon-wrapper row gx-0 gy-12 gx-sm-6">
        <div class="col-lg-4 col-sm-6 text-center features-icon-box">
          <div class="features-icon mb-4">
            <img src="~/img/front-pages/icons/laptop-charging.png" alt="laptop charging" />
          </div>
          <h5 class="mb-2">Solicitar reparos</h5>
          <p class="features-icon-description">Solicite reparos para os equipamentos da sua organização.</p>
        </div>
        <div class="col-lg-4 col-sm-6 text-center features-icon-box">
          <div class="features-icon mb-4">
            <img src="~/img/front-pages/icons/transition-up.png" alt="transition up" />
          </div>
          <h5 class="mb-2">Cadastrar equipamentos</h5>
          <p class="features-icon-description">Cadastre equipamentos da sua organização de forma simples e rápida.</p>
        </div>
        <div class="col-lg-4 col-sm-6 text-center features-icon-box">
          <div class="features-icon mb-4">
            <img src="~/img/front-pages/icons/edit.png" alt="edit" />
          </div>
          <h5 class="mb-2">Gerencie cada equipamento</h5>
          <p class="features-icon-description">mantenha-se atualizado de cada equipamento e suas informações.</p>
        </div>
        <div class="col-lg-4 col-sm-6 text-center features-icon-box">
          <div class="features-icon mb-4">
            <img src="~/img/front-pages/icons/3d-select-solid.png" alt="3d select solid" />
          </div>
          <h5 class="mb-2">Personalizável</h5>
          <p class="features-icon-description">Personalize a interface de acordo com as necessidades da sua organização.</p>
        </div>
        <div class="col-lg-4 col-sm-6 text-center features-icon-box">
          <div class="features-icon mb-4">
            <img src="~/img/front-pages/icons/lifebelt.png" alt="lifebelt" />
          </div>
          <h5 class="mb-2">Suporte contínuo</h5>
          <p class="features-icon-description">Suporte técnico contínuo para garantir o funcionamento ideal da aplicação.</p>
        </div>
        <div class="col-lg-4 col-sm-6 text-center features-icon-box">
          <div class="features-icon mb-4">
            <img src="~/img/front-pages/icons/google-docs.png" alt="google docs" />
          </div>
          <h5 class="mb-2">Documentação completa</h5>
          <p class="features-icon-description">Documentação detalhada e fácil de seguir com muitas referências e exemplos de utilização.</p>
        </div>
      </div>
    </div>
