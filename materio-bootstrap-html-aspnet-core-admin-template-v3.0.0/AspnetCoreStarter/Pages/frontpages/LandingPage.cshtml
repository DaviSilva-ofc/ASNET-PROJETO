    <!-- debug: contar slides sem precisar colar na consola -->
    <script>
      document.addEventListener('DOMContentLoaded', function(){
        const slides = document.querySelectorAll('#swiper-reviews .swiper-slide');
        const count = slides.length;
        console.log('Número de slides (debug):', count);
        slides.forEach((slide, idx) => {
          const img = slide.querySelector('img.client-logo');
          console.log(`slide ${idx+1} logo src:`, img ? img.getAttribute('src') : 'none');
        });
        // cria um indicador visível num canto da secção para facilitar
        const debugEl = document.createElement('div');
        debugEl.textContent = 'slides: ' + count;
        debugEl.style.position = 'absolute';
        debugEl.style.top = '0';
        debugEl.style.right = '0';
        debugEl.style.background = 'rgba(0,0,0,0.5)';
        debugEl.style.color = '#fff';
        debugEl.style.padding = '2px 6px';
        debugEl.style.fontSize = '0.75rem';
        debugEl.style.zIndex = '9999';
        document.querySelector('#landingReviews').style.position = 'relative';
        document.querySelector('#landingReviews').appendChild(debugEl);
      });
    </script>
