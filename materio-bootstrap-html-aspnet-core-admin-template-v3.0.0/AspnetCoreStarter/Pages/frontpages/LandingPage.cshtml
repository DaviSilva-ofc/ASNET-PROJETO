@page
@model AspnetCoreStarter.Pages.FrontPages.LandingPageModel

<h2>Login</h2>

<form method="post">
    <div>
        <label>Nome de Utilizador</label>
        <input asp-for="Input.NomeUtilizador" class="form-control" />
        <span asp-validation-for="Input.NomeUtilizador" style="color:red"></span>
    </div>

    <div class="mt-3">
        <label>Palavra-Passe</label>
        <input asp-for="Input.PalavraPasse" class="form-control" />
        <span asp-validation-for="Input.PalavraPasse" style="color:red"></span>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Entrar</button>
    </div>

    @if (!string.IsNullOrEmpty(Model.MensagemErro))
    {
        <div style="color:red; margin-top:10px;">
            @Model.MensagemErro
        </div>
    }
</form>
