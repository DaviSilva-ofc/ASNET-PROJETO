@page
@model AspnetCoreStarter.Pages.Admin.ManageContractsModel
@using AspnetCoreStarter.Pages.Admin
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Contratos";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Admin /</span> Contratos</h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible shadow-sm mb-4" role="alert">
            <i class="bx bx-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible shadow-sm mb-4" role="alert">
            <i class="bx bx-error-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Lista de Contratos</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFilters" aria-expanded="false" aria-controls="collapseFilters">
                    <i class="bx bx-filter-alt me-1"></i> Filtrar
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalContrato">Carregar Contratos</button>
            </div>
        </div>

        <div class="collapse @(Model.FilterStatus != null || Model.FilterType != null || Model.FilterPeriod != null || Model.FilterAgrupamento != null ? "show" : "")" id="collapseFilters">
            <div class="card-body border-top">
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Tipo</label>
                        <input type="text" name="FilterType" value="@Model.FilterType" class="form-control" placeholder="Filtrar por tipo" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Período (meses)</label>
                        <input type="text" name="FilterPeriod" value="@Model.FilterPeriod" class="form-control" placeholder="Filtrar por período" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Estado</label>
                        <select name="FilterStatus" class="form-select">
                            <option value="">Todos</option>
                            <option value="Ativo" selected="@(Model.FilterStatus == "Ativo" ? "selected" : null)">Ativo</option>
                            <option value="Pendente" selected="@(Model.FilterStatus == "Pendente" ? "selected" : null)">Pendente</option>
                            <option value="Finalizado" selected="@(Model.FilterStatus == "Finalizado" ? "selected" : null)">Finalizado</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Agrupamento</label>
                        <select name="FilterAgrupamento" class="form-select">
                            <option value="">Todos</option>
                            @foreach (var agrup in Model.Agrupamentos)
                            {
                                <option value="@agrup.Id" selected="@(Model.FilterAgrupamento == agrup.Id ? "selected" : null)">@agrup.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-1 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary btn-icon" title="Filtrar">🔍 <i class="bx bx-search"></i></button>
                        <a asp-page="./Contracts" class="btn btn-outline-secondary btn-icon text-nowrap" title="Limpar Filtros">❌</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Expiração</th>
                        <th>Período (meses)</th>
                        <th>Estado</th>
                        <th>Urgência</th>
                        <th>Entidade</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Contracts)
                    {
                        <tr>
                            <td><strong>@item.ContractType</strong></td>
                            <td>
                                @if (item.ExpiryDate.HasValue)
                                {
                                    var daysLeft = (item.ExpiryDate.Value - DateTime.Now).Days;
                                    var badgeClass = daysLeft < 0 ? "bg-label-danger" : (daysLeft <= 30 ? "bg-label-warning" : "bg-label-secondary");
                                    var label = daysLeft < 0 ? "Expirado" : (daysLeft == 0 ? "Expira hoje" : $"{daysLeft} dias");
                                    
                                    <div>@item.ExpiryDate.Value.ToString("dd/MM/yyyy")</div>
                                    <small class="badge @badgeClass" style="font-size: 0.75rem;">@label</small>
                                }
                                else
                                {
                                    <span class="text-muted">N/D</span>
                                }
                            </td>
                            <td>@item.Period</td>
                            <td>
                                <span class="badge @(item.ContractStatus == "Ativo" ? "bg-label-success" : "bg-label-warning")">
                                    @item.ContractStatus
                                </span>
                            </td>
                            <td>
                                @{
                                    var urgClass = item.UrgencyLevel switch {
                                        "Alto" => "bg-label-danger",
                                        "Médio" => "bg-label-warning",
                                        "Baixo" => "bg-label-success",
                                        _ => "bg-label-secondary"
                                    };
                                    var urgTime = item.UrgencyLevel switch {
                                        "Alto" => "4h",
                                        "Médio" => "24h",
                                        "Baixo" => "48h",
                                        _ => ""
                                    };
                                }
                                @if (!string.IsNullOrEmpty(item.UrgencyLevel))
                                {
                                    <span class="badge @urgClass">@item.UrgencyLevel <small class="opacity-75">(@urgTime)</small></span>
                                }
                                else
                                {
                                    <span class="text-muted">N/D</span>
                                }
                            </td>
                            <td>
                                @if (item.SchoolId.HasValue) { <span class="badge bg-label-info">🏫 @item.School?.Name</span> }
                                else if (item.AgrupamentoId.HasValue) { <span class="badge bg-label-primary">🏛️ @item.Agrupamento?.Name</span> }
                                else if (item.EmpresaId.HasValue) { <span class="badge bg-label-secondary">🏢 @item.Empresa?.Name</span> }
                                else { <span class="text-muted">Desconhecido</span> }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <button type="button" class="btn btn-sm" title="Editar Contrato"
                                            data-bs-toggle="modal" data-bs-target="#modalEditContrato"
                                            onclick="setEditContract('@item.Id', '@Html.Raw((item.ContractType ?? "").Replace("'", "\\'"))', '@Html.Raw((item.Period ?? "").Replace("'", "\\'"))', '@item.ContractStatus', '@item.AgrupamentoId', '@item.UrgencyLevel', '@Html.Raw((item.Description ?? "").Replace("'", "\\'"))', '@(item.ExpiryDate?.ToString("yyyy-MM-dd"))', '@item.SchoolId', '@item.EmpresaId')">✏️</button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza?');">
                                        <button type="submit" class="btn btn-sm" title="Eliminar Contrato">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Contracts.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">Nenhum contrato registado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Novo Contrato -->
    <div class="modal fade" id="modalContrato" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Add" enctype="multipart/form-data" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Carregar Contrato</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tipo de Contrato</label>
                        <input type="text" asp-for="NewContract.ContractType" class="form-control" placeholder="ex: Manutenção, Consultoria" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Período</label>
                        <input type="text" asp-for="NewContract.Period" class="form-control" placeholder="ex: 12 meses, Anual" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <select asp-for="NewContract.ContractStatus" class="form-select">
                            <option value="Ativo">Ativo</option>
                            <option value="Pendente">Pendente</option>
                            <option value="Finalizado">Finalizado</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Entidade (Obrigatório selecionar uma)</label>
                        <div class="row g-2">
                            <div class="col-12">
                                <select asp-for="NewContract.AgrupamentoId" id="newContractAgrupamento" class="form-select mb-2" onchange="filterSchools('newContractAgrupamento', 'newContractSchool')">
                                    <option value="">-- Selecione Agrupamento --</option>
                                    @foreach (var agrup in Model.Agrupamentos)
                                    {
                                        <option value="@agrup.Id">@agrup.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <select asp-for="NewContract.SchoolId" id="newContractSchool" class="form-select mb-2" onchange="filterSchools('newContractAgrupamento', 'newContractSchool')">
                                    <option value="">-- Selecione Escola --</option>
                                    @foreach (var school in Model.Schools)
                                    {
                                        <option value="@school.Id" data-agrupamento-id="@school.AgrupamentoId">@school.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <select asp-for="NewContract.EmpresaId" id="newContractEmpresa" class="form-select" onchange="filterSchools('newContractAgrupamento', 'newContractSchool')">
                                    <option value="">-- Selecione Empresa --</option>
                                    @foreach (var emp in Model.Empresas)
                                    {
                                        <option value="@emp.Id">@emp.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nível de Urgência</label>
                        <select asp-for="NewContract.UrgencyLevel" class="form-select" required>
                            <option value="">-- Selecione o nível --</option>
                            <option value="Baixo">&#x1F7E2; Baixo &mdash; Tempo de resposta: 48 horas</option>
                            <option value="Médio">&#x1F7E1; Médio &mdash; Tempo de resposta: 24 horas</option>
                            <option value="Alto">&#x1F534; Alto &mdash; Tempo de resposta: 4 horas</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Data de Expiração</label>
                        <input type="date" asp-for="NewContract.ExpiryDate" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Arquivo de Contrato (PDF)</label>
                        <input type="file" name="ContractFile" class="form-control" accept=".pdf" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descrição</label>
                        <textarea asp-for="NewContract.Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Carregar Contrato</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Editar Contrato -->
    <div class="modal fade" id="modalEditContrato" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Edit" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">✏️ Editar Contrato</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editContractId" asp-for="EditContract.Id" />
                    <div class="mb-3">
                        <label class="form-label">Tipo de Contrato</label>
                        <input type="text" id="editContractType" asp-for="EditContract.ContractType" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Período</label>
                        <input type="text" id="editContractPeriod" asp-for="EditContract.Period" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <select id="editContractStatus" asp-for="EditContract.ContractStatus" class="form-select">
                            <option value="Ativo">Ativo</option>
                            <option value="Pendente">Pendente</option>
                            <option value="Finalizado">Finalizado</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Entidade</label>
                        <select id="editContractAgrupamento" asp-for="EditContract.AgrupamentoId" class="form-select mb-2" onchange="filterSchools('editContractAgrupamento', 'editContractSchool')">
                            <option value="">-- Agrupamento --</option>
                            @foreach (var agrup in Model.Agrupamentos)
                            {
                                <option value="@agrup.Id">@agrup.Name</option>
                            }
                        </select>
                        <select id="editContractSchool" asp-for="EditContract.SchoolId" class="form-select mb-2" onchange="filterSchools('editContractAgrupamento', 'editContractSchool')">
                            <option value="">-- Escola --</option>
                            @foreach (var school in Model.Schools)
                            {
                                <option value="@school.Id" data-agrupamento-id="@school.AgrupamentoId">@school.Name</option>
                            }
                        </select>
                        <select id="editContractEmpresa" asp-for="EditContract.EmpresaId" class="form-select" onchange="filterSchools('editContractAgrupamento', 'editContractSchool')">
                            <option value="">-- Empresa --</option>
                            @foreach (var emp in Model.Empresas)
                            {
                                <option value="@emp.Id">@emp.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nível de Urgência</label>
                        <select id="editContractUrgency" asp-for="EditContract.UrgencyLevel" class="form-select" required>
                            <option value="Baixo">Baixo</option>
                            <option value="Médio">Médio</option>
                            <option value="Alto">Alto</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descrição</label>
                        <textarea id="editContractDescription" asp-for="EditContract.Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Data de Expiração</label>
                        <input type="date" id="editContractExpiry" asp-for="EditContract.ExpiryDate" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function setEditContract(id, type, period, status, agrupId, urgency, desc, expiry, schoolId, empresaId) {
        document.getElementById('editContractId').value = id;
        document.getElementById('editContractType').value = type;
        document.getElementById('editContractPeriod').value = period;
        document.getElementById('editContractStatus').value = status;
        document.getElementById('editContractAgrupamento').value = agrupId || '';
        document.getElementById('editContractSchool').value = schoolId || '';
        document.getElementById('editContractEmpresa').value = empresaId || '';
        document.getElementById('editContractUrgency').value = urgency || 'Baixo';
        document.getElementById('editContractDescription').value = desc;
        document.getElementById('editContractExpiry').value = expiry || '';
        
        // Trigger filter after setting values
        filterSchools('editContractAgrupamento', 'editContractSchool');
    }

    function filterSchools(agrupIdSelectId, schoolSelectId) {
        const agrupSelect = document.getElementById(agrupIdSelectId);
        const schoolSelect = document.getElementById(schoolSelectId);
        const empresaSelectId = agrupIdSelectId.includes('new') ? 'newContractEmpresa' : 'editContractEmpresa';
        const empresaSelect = document.getElementById(empresaSelectId);
        
        const agrupValue = agrupSelect.value;
        const schoolValue = schoolSelect.value;
        const empresaValue = empresaSelect.value;

        // Mutual Exclusivity Logic
        if (empresaValue) {
            agrupSelect.disabled = true;
            schoolSelect.disabled = true;
        } else if (agrupValue || schoolValue) {
            empresaSelect.disabled = true;
            agrupSelect.disabled = false;
            schoolSelect.disabled = false;
        } else {
            agrupSelect.disabled = false;
            schoolSelect.disabled = false;
            empresaSelect.disabled = false;
        }

        const options = schoolSelect.querySelectorAll('option');
        options.forEach(opt => {
            if (opt.value === "") {
                opt.style.display = "block";
                return;
            }
            const optAgrup = opt.getAttribute('data-agrupamento-id');
            if (!agrupValue || optAgrup === agrupValue) {
                opt.style.display = "block";
            } else {
                opt.style.display = "none";
            }
        });

        // If current selected school is now hidden, reset it
        const currentSelected = schoolSelect.options[schoolSelect.selectedIndex];
        if (currentSelected && currentSelected.style.display === "none") {
            schoolSelect.value = "";
        }
    }
</script>
}
