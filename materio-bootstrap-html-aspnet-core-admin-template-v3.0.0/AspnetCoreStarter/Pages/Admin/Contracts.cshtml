@page
@model AspnetCoreStarter.Pages.Admin.ManageContractsModel
@using AspnetCoreStarter.Pages.Admin
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Contratos";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Admin /</span> Contratos</h4>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Lista de Contratos</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFilters" aria-expanded="false" aria-controls="collapseFilters">
                    <i class="bx bx-filter-alt me-1"></i> Filtrar
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalContrato">Carregar Contratos</button>
            </div>
        </div>

        <div class="collapse @(Model.FilterStatus != null || Model.FilterType != null || Model.FilterPeriod != null || Model.FilterAgrupamento != null ? "show" : "")" id="collapseFilters">
            <div class="card-body border-top">
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Tipo</label>
                        <input type="text" name="FilterType" value="@Model.FilterType" class="form-control" placeholder="Filtrar por tipo" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Período (meses)</label>
                        <input type="text" name="FilterPeriod" value="@Model.FilterPeriod" class="form-control" placeholder="Filtrar por período" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Estado</label>
                        <select name="FilterStatus" class="form-select">
                            <option value="">Todos</option>
                            <option value="Ativo" selected="@(Model.FilterStatus == "Ativo" ? "selected" : null)">Ativo</option>
                            <option value="Pendente" selected="@(Model.FilterStatus == "Pendente" ? "selected" : null)">Pendente</option>
                            <option value="Finalizado" selected="@(Model.FilterStatus == "Finalizado" ? "selected" : null)">Finalizado</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Agrupamento</label>
                        <select name="FilterAgrupamento" class="form-select">
                            <option value="">Todos</option>
                            @foreach (var agrup in Model.Agrupamentos)
                            {
                                <option value="@agrup.Id" selected="@(Model.FilterAgrupamento == agrup.Id ? "selected" : null)">@agrup.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-1 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary btn-icon" title="Filtrar"><i class="bx bx-search"></i></button>
                        <a asp-page="./Contracts" class="btn btn-outline-secondary btn-icon text-nowrap" title="Limpar Filtros">❌</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Período</th>
                        <th>Estado</th>
                        <th>Agrupamento</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Contracts)
                    {
                        <tr>
                            <td><strong>@item.ContractType</strong></td>
                            <td>@item.Period</td>
                            <td>
                                <span class="badge @(item.ContractStatus == "Ativo" ? "bg-label-success" : "bg-label-warning")">
                                    @item.ContractStatus
                                </span>
                            </td>
                            <td>@(item.Agrupamento?.Name ?? "N/A")</td>
                            <td>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza?');">
                                    <button type="submit" class="btn btn-sm text-danger"><i class='bx bx-trash'></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Contracts.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4">Nenhum contrato registado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Novo Contrato -->
    <div class="modal fade" id="modalContrato" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Add" enctype="multipart/form-data" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Carregar Contrato</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tipo de Contrato</label>
                        <input type="text" asp-for="NewContract.ContractType" class="form-control" placeholder="ex: Manutenção, Consultoria" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Período</label>
                        <input type="text" asp-for="NewContract.Period" class="form-control" placeholder="ex: 12 meses, Anual" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <select asp-for="NewContract.ContractStatus" class="form-select">
                            <option value="Ativo">Ativo</option>
                            <option value="Pendente">Pendente</option>
                            <option value="Finalizado">Finalizado</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Agrupamento</label>
                        <select asp-for="NewContract.AgrupamentoId" class="form-select">
                            <option value="">Selecione um agrupamento (opcional)</option>
                            @foreach (var agrup in Model.Agrupamentos)
                            {
                                <option value="@agrup.Id">@agrup.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Arquivo de Contrato (PDF)</label>
                        <input type="file" name="ContractFile" class="form-control" accept=".pdf" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descrição</label>
                        <textarea asp-for="NewContract.Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Carregar Contrato</button>
                </div>
            </form>
        </div>
    </div>
</div>
