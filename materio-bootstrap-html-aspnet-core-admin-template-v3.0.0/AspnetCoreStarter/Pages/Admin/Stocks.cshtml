@page
@model AspnetCoreStarter.Pages.Admin.StocksModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Stocks";
}

@section PageStyles {
<style>
    .dark-style .card-header h5,
    [data-bs-theme="dark"] .card-header h5 { color: #fff !important; }

    .dark-style .list-group-item,
    [data-bs-theme="dark"] .list-group-item {
        background-color: transparent;
        color: #cbcbe2;
        border-color: rgba(255,255,255,0.1);
    }

    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: #2b2c40;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .dark-style h4.fw-bold,
    [data-bs-theme="dark"] h4.fw-bold { color: #f5f5f9 !important; }

    /* New Styles for consistency */
    .bg-light-section {
        background-color: rgba(67, 89, 113, 0.02);
        transition: all 0.3s ease;
    }
    .dark-style .bg-light-section,
    [data-bs-theme="dark"] .bg-light-section {
        background-color: rgba(255, 255, 255, 0.03);
    }

    .bg-light-section:hover {
        background-color: rgba(67, 89, 113, 0.05);
    }
    .dark-style .bg-light-section:hover,
    [data-bs-theme="dark"] .bg-light-section:hover {
        background-color: rgba(255, 255, 255, 0.06);
    }

    .infra-tree .tree-node {
        position: relative;
        padding: 4px 0;
    }

    .tree-node i {
        font-size: 1.1rem;
        vertical-align: middle;
        opacity: 0.8;
    }

    .cursor-pointer { cursor: pointer; }

    /* Animation for arrows */
    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold;
        color: var(--bs-primary);
        font-size: 1.4rem;
        display: inline-block;
        line-height: 1;
        background-color: rgba(105, 108, 255, 0.15);
        border: 1px solid rgba(105, 108, 255, 0.3);
        border-radius: 4px;
        padding: 4px;
        margin-right: 8px;
    }

    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: var(--bs-primary);
        color: #fff;
    }

    .dark-style [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }
    .dark-style [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        background-color: #696cff;
        color: #fff;
    }

    .agrupamento-node { color: var(--bs-primary); }
    .school-node { color: var(--bs-success); }
    .bloc-node { color: var(--bs-info); }
    .room-node { color: var(--bs-warning); }
    .director-node { color: #8592a3; }
    .equip-node { color: #a1acb8; }

    /* Icon Base Fix */
    .icon-base {
        font-size: 1.25rem;
        vertical-align: middle;
        line-height: 1;
    }

    .tree-node i.ri-arrow-right-s-line,
    .tree-node i.ri-arrow-down-s-line {
        background-color: rgba(105, 108, 255, 0.1);
        border-radius: 4px;
        padding: 4px;
        font-weight: bold;
        transition: all 0.2s;
    }

    .collapse.show + .d-flex i.ri-arrow-right-s-line,
    [aria-expanded="true"] i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: #696cff;
        color: white;
    }

    .dark-style .agrupamento-node { color: #696cff; }
    .dark-style .school-node { color: #71dd37; }
    .dark-style .bloc-node { color: #03c3ec; }
    .dark-style .room-node { color: #ffab00; }
    .dark-style .director-node { color: #e1e1e3; }
    .dark-style .equip-node { color: #707186; }

    /* Header buttons consistency */
    .edit-header-btn {
        background-color: rgba(255, 255, 255, 0.2);
        color: white !important;
        border: 1px solid rgba(255, 255, 255, 0.5) !important;
        padding: 5px;
    }
    .edit-header-btn:hover {
        background-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    /* Tab Styling */
    .nav-tabs .nav-link.active {
        border-bottom-color: var(--bs-primary);
        color: var(--bs-primary) !important;
        font-weight: 600;
    }
    .dark-style .nav-tabs .nav-link.active {
        background-color: rgba(105, 108, 255, 0.1);
        border-bottom-color: #696cff;
        color: #696cff !important;
    }

    /* Stat mini-cards */
    .stat-card {
        border: none;
        border-radius: 14px;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(30,33,48,.12);
    }
    .stat-icon {
        width: 42px; height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: #fff;
    }

    /* Print Styles */
    @@media print {
        .layout-navbar, .layout-menu-horizontal, .layout-menu, .footer, .btn, .nav-links, .buy-now, .btn-primary, .btn-outline-primary, .nav-tabs {
            display: none !important;
        }
        .container-xxl {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
        }
        .content-wrapper {
            margin: 0 !important;
            padding: 0 !important;
        }
        body {
            background: white !important;
            color: black !important;
        }
        .card {
            box-shadow: none !important;
            border: none !important;
        }
        .card-header h5 {
            font-size: 24pt !important;
            margin-bottom: 20px !important;
            text-align: center !important;
            width: 100% !important;
        }
        .table {
            width: 100% !important;
            border-collapse: collapse !important;
        }
        .table th, .table td {
            border: 1px solid #ddd !important;
            padding: 8px !important;
            color: black !important;
        }
        .badge {
            border: 1px solid #ccc !important;
            color: black !important;
            background: transparent !important;
        }
        .text-primary, .text-warning, .text-info, .text-success {
            color: black !important;
            font-weight: bold !important;
        }
    }
    .dark-style [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line,
    [data-bs-theme="dark"] [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        background-color: #696cff;
        color: #fff;
    }

    /* Node colors */
    .empresa-node { color: var(--bs-primary); }
    .tecnico-node { color: var(--bs-warning); }
    .tipo-node { color: #8592a3; }
    .artigo-node { color: #a1acb8; }

    .dark-style .tipo-node, [data-bs-theme="dark"] .tipo-node { color: #cbcbe2; }
    .dark-style .artigo-node, [data-bs-theme="dark"] .artigo-node { color: #a1acb8; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Admin /</span> Stocks</h4>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-checkbox-circle-line me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-error-warning-line me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Stocks Management Menu Card -->
    <div class="card mb-4 border-primary shadow-sm">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <h5 class="mb-2 mb-md-0 fw-bold text-primary"><i class="icon-base ri-archive-line me-2"></i>Gestão de Stocks</h5>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary btn-md shadow-sm" data-bs-toggle="modal" data-bs-target="#modalAddStock">
                        <i class="icon-base ri-add-line me-1"></i> Novo Artigo de Stock
                    </button>
                    <button class="btn btn-outline-secondary btn-md shadow-sm" type="button" onclick="window.print()">
                        <i class="icon-base ri-file-pdf-line me-1"></i> Exportar PDF
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#navs-empresa" aria-controls="navs-empresa" aria-selected="true">
                    <i class="tf-icons ri-building-line me-1"></i> Stock Empresa
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#navs-agrupamentos" aria-controls="navs-agrupamentos" aria-selected="false">
                    <i class="tf-icons ri-organization-chart me-1"></i> Stock Agrupamentos
                </button>
            </li>
        </ul>
        <div class="tab-content">
            <!-- Stock Empresa Tab -->
            <div class="tab-pane fade show active" id="navs-empresa" role="tabpanel">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center cursor-pointer"
                         data-bs-toggle="collapse" data-bs-target="#stock-empresa-body" aria-expanded="true">
                        <div class="d-flex align-items-center">
                            <h5 class="mb-0 text-white me-3"><strong>Stock Empresa</strong></h5>
                            <span class="badge bg-label-light text-white-50 small">Central + com técnico</span>
                        </div>
                        <div class="d-flex align-items-center gap-2" onclick="event.stopPropagation();">
                             <h4 class="mb-0 text-white fw-bold me-2">@Model.CountStockEmpresa</h4>
                             <i class="ri-arrow-down-s-line text-white fs-4 ms-2"></i>
                        </div>
                    </div>
                    <div id="stock-empresa-body" class="collapse show">
                        <div class="card-body pt-4">
                            @{
                                var empresaItems = Model.EmpresaInventory ?? new List<AspnetCoreStarter.Pages.Admin.StockItemViewModel>();
                                var centralItems = empresaItems.Where(i => i.Location == "Stock Empresa").ToList();
                                var techItems = empresaItems.Where(i => i.Location == "com técnico").ToList();
                                var lentItems = empresaItems.Where(i => i.Status == "Emprestado").ToList();
                            }

                            @if (!empresaItems.Any())
                            {
                                <div class="text-center py-5 text-muted">Nenhum artigo no stock da empresa.</div>
                            }
                            else
                            {
                                <div class="row g-3">
                                    <div class="col-12 col-md-4 mb-3">
                                        <div class="border rounded p-3 h-100 bg-light-section">
                                            <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                                 data-bs-toggle="collapse" data-bs-target="#empresa-central-collapse">
                                                <h6 class="mb-0 fw-bold"><i class="ri-home-4-line me-2"></i>Stock Central</h6>
                                                <i class="ri-arrow-down-s-line"></i>
                                            </div>
                                            <div id="empresa-central-collapse" class="collapse show mt-3">
                                                <div class="infra-tree">
                                                    @foreach (var typeGroup in centralItems.GroupBy(i => i.Type ?? "Outros").OrderBy(g => g.Key))
                                                    {
                                                        var typeId = $"empresa-central-type-{typeGroup.Key.Replace(" ", "-")}";
                                                        <div class="tree-node tipo-node">
                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed"
                                                                 data-bs-toggle="collapse" data-bs-target="#@typeId">
                                                                <i class="ri-arrow-right-s-line"></i>
                                                                <i class="ri-price-tag-3-line me-1"></i> <strong>@typeGroup.Key</strong>
                                                                <span class="badge bg-label-info ms-auto">@typeGroup.Sum(i => i.Quantity)</span>
                                                            </div>
                                                            <div id="@typeId" class="collapse">
                                                                @foreach (var item in typeGroup.OrderBy(i => i.Name))
                                                                {
                                                                    <div class="tree-node artigo-node ms-4 mt-1 small">
                                                                        <div class="d-flex align-items-center p-1 rounded">
                                                                            <i class="ri-hard-drive-2-line me-1"></i>
                                                                            <span class="fw-semibold">@item.Name</span>
                                                                            <span class="badge bg-label-info ms-auto">@item.Quantity</span>
                                                                            <div class="d-flex align-items-center gap-1 ms-2">
                                                                                @if (item.Status == "Disponível") {
                                                                                    <button type="button" class="btn btn-sm btn-outline-primary p-1 open-lend-modal border-0" data-bs-toggle="modal" data-bs-target="#modalLendReturn" data-sample-id="@item.SampleId" data-name="@item.Name" data-type="@item.Type" data-location="Stock Empresa" data-quantity="@item.Quantity" title="Requisitar">📤</button>
                                                                                }
                                                                                <button type="button" class="btn btn-sm btn-outline-danger p-1 open-delete-modal border-0" data-bs-toggle="modal" data-bs-target="#modalDeleteStock" data-sample-id="@item.SampleId" data-name="@item.Name" data-type="@item.Type" data-location="Stock Empresa" data-quantity="@item.Quantity" title="Excluir">🗑️</button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-4 mb-3">
                                        <div class="border rounded p-3 h-100 bg-light-section">
                                            <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                                 data-bs-toggle="collapse" data-bs-target="#empresa-tecnicos-collapse">
                                                <h6 class="mb-0 fw-bold"><i class="ri-tools-line me-2"></i>Com Técnico</h6>
                                                <i class="ri-arrow-down-s-line"></i>
                                            </div>
                                            <div id="empresa-tecnicos-collapse" class="collapse show mt-3">
                                                <div class="infra-tree">
                                                    @foreach (var techGroup in techItems.GroupBy(i => i.TechnicianName ?? "Geral").OrderBy(g => g.Key))
                                                    {
                                                        var techId = $"empresa-tech-{techGroup.Key.Replace(" ", "-")}";
                                                        <div class="tree-node tecnico-node">
                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed"
                                                                 data-bs-toggle="collapse" data-bs-target="#@techId">
                                                                <i class="ri-arrow-right-s-line"></i>
                                                                <i class="ri-user-3-line me-1"></i> <strong>@techGroup.Key</strong>
                                                                <span class="badge bg-label-warning ms-auto">@techGroup.Sum(i => i.Quantity)</span>
                                                            </div>
                                                            <div id="@techId" class="collapse">
                                                                @foreach (var item in techGroup.OrderBy(i => i.Name))
                                                                {
                                                                    <div class="tree-node artigo-node ms-4 mt-1 small">
                                                                        <div class="d-flex align-items-center p-1 rounded">
                                                                            <i class="ri-hard-drive-2-line me-1"></i> @item.Name
                                                                            <span class="badge bg-label-info ms-auto">@item.Quantity</span>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-4 mb-3">
                                        <div class="border rounded p-3 h-100 bg-light-section">
                                            <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                                 data-bs-toggle="collapse" data-bs-target="#empresa-requisicoes-collapse">
                                                <h6 class="mb-0 fw-bold"><i class="ri-inbox-unarchive-line me-2"></i>Requisições</h6>
                                                <i class="ri-arrow-down-s-line"></i>
                                            </div>
                                            <div id="empresa-requisicoes-collapse" class="collapse show mt-3">
                                                <div class="infra-tree">
                                                    @foreach (var destGroup in lentItems.GroupBy(i => i.Location ?? "Desconhecido").OrderBy(g => g.Key))
                                                    {
                                                        var destId = $"empresa-lent-{destGroup.Key.Replace(" ", "-")}";
                                                        <div class="tree-node tipo-node">
                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed"
                                                                 data-bs-toggle="collapse" data-bs-target="#@destId">
                                                                <i class="ri-arrow-right-s-line"></i>
                                                                <i class="ri-map-pin-line me-1"></i> <strong>@destGroup.Key</strong>
                                                                <span class="badge bg-label-info ms-auto">@destGroup.Sum(i => i.Quantity)</span>
                                                            </div>
                                                            <div id="@destId" class="collapse">
                                                                @foreach (var item in destGroup.OrderBy(i => i.Name))
                                                                {
                                                                    <div class="tree-node artigo-node ms-4 mt-1 small">
                                                                        <div class="d-flex align-items-center p-1 rounded">
                                                                            <i class="ri-hard-drive-2-line me-1"></i> @item.Name
                                                                            <span class="badge bg-label-info ms-auto">@item.Quantity</span>
                                                                            <button type="button" class="btn btn-sm btn-outline-success p-1 border-0 ms-2 open-return-modal" data-bs-toggle="modal" data-bs-target="#modalLendReturn" data-sample-id="@item.SampleId" data-name="@item.Name" data-type="@item.Type" data-location="@item.Location" data-quantity="@item.Quantity" title="Devolver">📥</button>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stock Agrupamentos Tab -->
            <div class="tab-pane fade" id="navs-agrupamentos" role="tabpanel">
                <div class="row">
                    @foreach (var agr in Model.AgrupamentoTree)
                    {
                        <div class="col-12 mb-4">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center cursor-pointer"
                                     data-bs-toggle="collapse" data-bs-target="#stock-agr-@agr.AgrupamentoId">
                                    <div class="d-flex align-items-center">
                                        <h5 class="mb-0 text-white me-3"><strong> @agr.AgrupamentoName</strong></h5>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <h4 class="mb-0 text-white fw-bold me-2">@(agr.DirectStock.Sum(s => s.Quantity) + agr.Schools.Sum(e => e.Items.Sum(i => i.Quantity) + (e.EquipmentItems?.Sum(x => x.Quantity) ?? 0)))</h4>
                                        <i class="ri-arrow-down-s-line text-white fs-4"></i>
                                    </div>
                                </div>
                                <div id="stock-agr-@agr.AgrupamentoId" class="collapse @(Model.AgrupamentoTree.First() == agr ? "show" : "")">
                                    <div class="card-body pt-4">
                                        <div class="row">
                                            <!-- Stock Direto / Resumo -->
                                            <div class="col-md-4 mb-3">
                                                <div class="border rounded p-3 h-100 bg-light-section">
                                                    <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                                         data-bs-toggle="collapse" data-bs-target="#direct-stock-@agr.AgrupamentoId">
                                                        <h6 class="mb-0 fw-bold"><i class="ri-archive-line me-2"></i>Stock do Agrupamento</h6>
                                                        <i class="ri-arrow-down-s-line"></i>
                                                    </div>
                                                    <div id="direct-stock-@agr.AgrupamentoId" class="collapse show mt-3">
                                                        @if (!agr.DirectStock.Any()) {
                                                            <p class="text-muted small">Sem stock direto.</p>
                                                        } else {
                                                            <div class="infra-tree">
                                                                @foreach (var item in agr.DirectStock) {
                                                                    <div class="tree-node artigo-node">
                                                                        <div class="d-flex align-items-center p-1 rounded">
                                                                            <i class="ri-hard-drive-2-line me-2"></i>
                                                                            <span class="text-secondary small">(@item.Type)</span>
                                                                            <span class="fw-semibold ms-1">@item.Name</span>
                                                                            <span class="badge bg-label-info ms-auto">@item.Quantity</span>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Árvore de Escolas -->
                                            <div class="col-md-8 mb-3">
                                                <div class="border rounded p-3 h-100 bg-light-section">
                                                    <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                                         data-bs-toggle="collapse" data-bs-target="#schools-stock-@agr.AgrupamentoId">
                                                        <h6 class="mb-0 fw-bold"><i class="ri-node-tree me-2"></i>Distribuição por Escolas</h6>
                                                        <i class="ri-arrow-down-s-line"></i>
                                                    </div>
                                                    <div id="schools-stock-@agr.AgrupamentoId" class="collapse show mt-3">
                                                        <div class="infra-tree">
                                                            @foreach (var esc in agr.Schools)
                                                            {
                                                                <div class="tree-node school-node">
                                                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded collapsed"
                                                                         data-bs-toggle="collapse" data-bs-target="#esc-items-@esc.EscolaId">
                                                                        <i class="ri-arrow-right-s-line"></i>
                                                                        <i class="ri-building-line me-1"></i> <strong>@esc.EscolaName</strong>
                                                                        <span class="badge bg-label-success ms-auto">@((esc.Items?.Sum(i => i.Quantity) ?? 0) + (esc.EquipmentItems?.Sum(i => i.Quantity) ?? 0)) itens</span>
                                                                    </div>
                                                                    <div id="esc-items-@esc.EscolaId" class="collapse">
                                                                        @* Equipments *@
                                                                        @if (esc.EquipmentItems != null && esc.EquipmentItems.Any()) {
                                                                            @foreach (var item in esc.EquipmentItems) {
                                                                                <div class="tree-node article-node ms-4 mt-1 small">
                                                                                    <div class="d-flex align-items-center p-1 rounded">
                                                                                        <i class="ri-computer-line me-1"></i> @item.Name
                                                                                        <span class="badge bg-label-primary ms-auto">@item.Quantity</span>
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        }
                                                                        @* Stock Items *@
                                                                        @if (esc.Items != null && esc.Items.Any()) {
                                                                            <hr class="my-1 ms-4" />
                                                                            @foreach (var item in esc.Items) {
                                                                                <div class="tree-node article-node ms-4 mt-1 small">
                                                                                    <div class="d-flex align-items-center p-1 rounded">
                                                                                        <i class="ri-hard-drive-2-line me-1"></i> @item.Name
                                                                                        <span class="badge bg-label-info ms-auto">@item.Quantity</span>
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<!-- Modal Adicionar Stock -->
<div class="modal fade" id="modalAddStock" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Solicitar / Adicionar Novo Artigo ao Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddStock">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome do Equipamento / Artigo</label>
                        <select name="name" class="form-select" required>
                            <option value="">Selecione ou escolha um artigo existente...</option>
                            @foreach (var existingName in Model.ExistingEquipmentNames)
                            {
                                <option value="@existingName">@existingName</option>
                            }
                        </select>
                        <small class="text-muted">Se o artigo não existir, escolha 'Outro' ou adicione manualmente (Dica: Se precisar de um novo nome, use a opção 'Outro Equivalente' ou peça ao Admin para registar o modelo).</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Quantidade a Adicionar</label>
                        <input type="number" name="quantity" class="form-control" value="1" min="1" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo Específico</label>
                        <select name="type" class="form-select" required>
                            <option value="">Selecione...</option>
                            <option value="Desktop">Desktop</option>
                            <option value="Portátil">Portátil</option>
                            <option value="Monitor">Monitor</option>
                            <option value="Motherboard">Motherboard</option>
                            <option value="Disco HDD">Disco HDD</option>
                            <option value="Disco SSD">Disco SSD</option>
                            <option value="Memória RAM">Memória RAM</option>
                            <option value="Processador (CPU)">Processador (CPU)</option>
                            <option value="Placa Gráfica">Placa Gráfica</option>
                            <option value="Fonte Alimentação">Fonte Alimentação</option>
                            <option value="Teclado">Teclado</option>
                            <option value="Rato">Rato</option>
                            <option value="Impressora">Impressora</option>
                            <option value="Projetor">Projetor</option>
                            <option value="Router">Router</option>
                            <option value="Switch">Switch</option>
                            <option value="Access Point">Access Point</option>
                            <option value="Cabo/Adaptador">Cabo/Adaptador</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Local de Destino</label>
                        <select name="locationCategory" class="form-select" onchange="toggleAddStockLocation(this)" required>
                            <option value="Empresa">Stock Empresa (Central)</option>
                            <option value="Tecnico">Com Técnico</option>
                            <option value="Agrupamento">Stock Agrupamento</option>
                            <option value="Escola">Stock Escola</option>
                        </select>
                    </div>

                    <div id="addStock_Tecnico" class="mb-3 add-stock-loc" style="display:none;">
                        <label class="form-label">Técnico Responsável</label>
                        <select name="technicianId" class="form-select select2">
                            <option value="">Selecione o técnico...</option>
                            @foreach (var t in Model.AvailableTecnicos) {
                                <option value="@t.Id">@t.Username</option>
                            }
                        </select>
                    </div>

                    <div id="addStock_Agrupamento" class="mb-3 add-stock-loc" style="display:none;">
                        <label class="form-label">Agrupamento</label>
                        <select name="agrupamentoId" id="addAgrupamentoId" class="form-select select2" onchange="filterAddStockSchools()">
                            <option value="">Selecione o agrupamento...</option>
                            @foreach (var a in Model.AvailableAgrupamentos) {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                    </div>

                    <div id="addStock_Escola" class="mb-3 add-stock-loc" style="display:none;">
                        <label class="form-label">Escola</label>
                        <select name="schoolId" id="addSchoolId" class="form-select select2">
                            <option value="">Selecione a escola...</option>
                            @foreach (var s in Model.AvailableSchools) {
                                <option value="@s.Id" data-agr="@s.AgrupamentoId">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descrição / Observações</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Detalhes adicionais..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Adicionar ao Stock</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Emprestar / Devolver -->
<div class="modal fade" id="modalLendReturn" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="lendReturnModalTitle">Emprestar Artigo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="lendReturnForm" method="post">
                <div class="modal-body">
                    <p id="lendReturnModalDesc">A selecionar quantidade para o artigo: <strong id="modalItemName">...</strong></p>
                    <input type="hidden" name="sampleId" id="modalInputSampleId" />
                    <input type="hidden" name="name" id="modalInputName" />
                    <input type="hidden" name="type" id="modalInputType" />
                    <input type="hidden" name="location" id="modalInputLocation" />

                    <div class="mb-3" id="lendLocationFields">
                        <label class="form-label">Local de Destino</label>
                        <select name="agrupamentoId" id="lendAgrupamentoId" class="form-select mb-2" onchange="filterLendSchools()" required>
                            <option value="">Selecione o Agrupamento...</option>
                            @foreach (var a in Model.AvailableAgrupamentos) {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                        <select name="schoolId" id="lendSchoolId" class="form-select" required>
                            <option value="">Selecione a Escola...</option>
                            @foreach (var s in Model.AvailableSchools) {
                                <option value="@s.Id" data-agr="@s.AgrupamentoId">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Quantidade</label>
                        <div class="input-group">
                            <input type="number" name="quantity" id="modalInputQuantity" class="form-control" value="1" min="1" required />
                            <span class="input-group-text">de <span id="modalMaxQuantity">1</span> disponíveis</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="modalSubmitBtn" class="btn btn-primary">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Deletar -->
<div class="modal fade" id="modalDeleteStock" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Excluir do Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="deleteStockForm" method="post" asp-page-handler="DeleteStock">
                <div class="modal-body">
                    <p>Deseja excluir unidades de <strong id="deleteItemName">...</strong>?</p>
                    <input type="hidden" name="sampleId" id="deleteInputSampleId" />
                    <input type="hidden" name="name" id="deleteInputName" />
                    <input type="hidden" name="type" id="deleteInputType" />
                    <input type="hidden" name="location" id="deleteInputLocation" />

                    <div class="mb-3">
                        <label class="form-label">Quantidade a Excluir</label>
                        <div class="input-group">
                            <input type="number" name="quantity" id="deleteInputQuantity" class="form-control" value="1" min="1" required />
                            <span class="input-group-text">de <span id="deleteMaxQuantity">1</span> totais</span>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="ri-error-warning-line me-1"></i> Esta ação removerá os equipamentos permanentemente do stock.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Excluir Permanentemente</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function toggleAddStockLocation(selectEl) {
        const category = selectEl.value;
        const modal = selectEl.closest('.modal-content');

        // Hide all sub-locations and remove required
        modal.querySelectorAll('.add-stock-loc').forEach(div => {
            div.style.display = 'none';
            div.querySelectorAll('select').forEach(s => s.required = false);
        });

        // Show target if not Empresa
        if (category !== 'Empresa') {
            if (category === 'Escola') {
                // For schools, we also show the agrupamento for filtering
                modal.querySelector('#addStock_Agrupamento').style.display = 'block';
                modal.querySelector('#addStock_Escola').style.display = 'block';
                modal.querySelector('#addAgrupamentoId').required = true;
                modal.querySelector('#addSchoolId').required = true;
            } else {
                const target = modal.querySelector('#addStock_' + category);
                if (target) {
                    target.style.display = 'block';
                    target.querySelectorAll('select').forEach(s => s.required = true);
                }
            }
        }
    }

    function filterAddStockSchools() {
        const agrId = document.getElementById('addAgrupamentoId').value;
        const schoolSelect = document.getElementById('addSchoolId');
        const options = schoolSelect.querySelectorAll('option');

        schoolSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (agrId === "" || opt.getAttribute('data-agr') === agrId) ? 'block' : 'none';
        });
    }

    function filterLendSchools() {
        const agrId = document.getElementById('lendAgrupamentoId').value;
        const schoolSelect = document.getElementById('lendSchoolId');
        const options = schoolSelect.querySelectorAll('option');

        schoolSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (agrId === "" || opt.getAttribute('data-agr') === agrId) ? 'block' : 'none';
        });
    }

    function setupModal(id, name, type, location, maxQty) {
        document.getElementById('modalItemName').innerText = name;
        document.getElementById('deleteItemName').innerText = name;

        document.getElementById('modalInputSampleId').value = id;
        document.getElementById('modalInputName').value = name;
        document.getElementById('modalInputType').value = type;
        document.getElementById('modalInputLocation').value = location;
        document.getElementById('modalMaxQuantity').innerText = maxQty;

        const lendQtyInput = document.getElementById('modalInputQuantity');
        lendQtyInput.max = maxQty;
        lendQtyInput.value = 1;

        document.getElementById('deleteInputSampleId').value = id;
        document.getElementById('deleteInputName').value = name;
        document.getElementById('deleteInputType').value = type;
        document.getElementById('deleteInputLocation').value = location;
        document.getElementById('deleteMaxQuantity').innerText = maxQty;

        const deleteQtyInput = document.getElementById('deleteInputQuantity');
        deleteQtyInput.max = maxQty;
        deleteQtyInput.value = 1;
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Modal Event for Lend/Return
        const modalLR = document.getElementById('modalLendReturn');
        if (modalLR) {
            modalLR.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-sample-id');
                const name = button.getAttribute('data-name');
                const type = button.getAttribute('data-type');
                const loc = button.getAttribute('data-location');
                const qty = button.getAttribute('data-quantity');

                document.getElementById('modalItemName').innerText = name;
                document.getElementById('modalInputSampleId').value = id;
                document.getElementById('modalInputName').value = name;
                document.getElementById('modalInputType').value = type;
                document.getElementById('modalInputLocation').value = loc;
                document.getElementById('modalMaxQuantity').innerText = qty;

                const qtyInput = document.getElementById('modalInputQuantity');
                qtyInput.max = qty;
                qtyInput.value = 1;

                const mode = button.classList.contains('open-lend-modal') ? 'lend' : 'return';
                if (mode === 'lend') {
                    document.getElementById('lendReturnModalTitle').innerText = 'Requisitar Artigo';
                    document.getElementById('lendReturnModalDesc').innerHTML = 'Selecione a quantidade de <strong>' + name + '</strong> a requisitar:';
                    document.getElementById('modalSubmitBtn').innerText = 'Requisitar';
                    document.getElementById('modalSubmitBtn').className = 'btn btn-info';
                    document.getElementById('lendReturnForm').action = '?handler=Lend';
                    document.getElementById('lendLocationFields').style.display = 'block';
                    document.getElementById('lendAgrupamentoId').required = true;
                    document.getElementById('lendSchoolId').required = true;
                } else {
                    document.getElementById('lendReturnModalTitle').innerText = 'Devolução de Artigo';
                    document.getElementById('lendReturnModalDesc').innerHTML = 'Selecione a quantidade de <strong>' + name + '</strong> que foi devolvida:';
                    document.getElementById('modalSubmitBtn').innerText = 'Confirmar Devolução';
                    document.getElementById('modalSubmitBtn').className = 'btn btn-success';
                    document.getElementById('lendReturnForm').action = '?handler=Return';
                    document.getElementById('lendLocationFields').style.display = 'none';
                    document.getElementById('lendAgrupamentoId').required = false;
                    document.getElementById('lendSchoolId').required = false;
                }
            });
        }

        // Modal Event for Delete
        const modalDel = document.getElementById('modalDeleteStock');
        if (modalDel) {
            modalDel.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-sample-id');
                const name = button.getAttribute('data-name');
                const type = button.getAttribute('data-type');
                const loc = button.getAttribute('data-location');
                const qty = button.getAttribute('data-quantity');

                document.getElementById('deleteItemName').innerText = name;
                document.getElementById('deleteInputSampleId').value = id;
                document.getElementById('deleteInputName').value = name;
                document.getElementById('deleteInputType').value = type;
                document.getElementById('deleteInputLocation').value = loc;
                document.getElementById('deleteMaxQuantity').innerText = qty;

                const qtyInput = document.getElementById('deleteInputQuantity');
                qtyInput.max = qty;
                qtyInput.value = 1;
            });
        }
    });
</script>
}
