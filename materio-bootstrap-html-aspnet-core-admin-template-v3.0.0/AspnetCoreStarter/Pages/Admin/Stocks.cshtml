@page
@model AspnetCoreStarter.Pages.Admin.StocksModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Stocks";
}

@section PageStyles {
<style>
    /* ===== Dark mode Specific Enhancements ===== */
    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: #2b2c40 !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .dark-style h4, .dark-style h6, .dark-style h5,
    [data-bs-theme="dark"] h4, [data-bs-theme="dark"] h6, [data-bs-theme="dark"] h5 { 
        color: #f5f5f9 !important; 
    }
    
    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    /* Enhance avatar labels to be more vibrant in dark mode */
    .dark-style .bg-label-primary, [data-bs-theme="dark"] .bg-label-primary { background-color: rgba(105, 108, 255, 0.25) !important; color: #8592ff !important; }
    .dark-style .bg-label-success, [data-bs-theme="dark"] .bg-label-success { background-color: rgba(113, 221, 55, 0.25) !important; color: #71dd37 !important; }
    .dark-style .bg-label-warning, [data-bs-theme="dark"] .bg-label-warning { background-color: rgba(255, 171, 0, 0.25) !important; color: #ffab00 !important; }
    .dark-style .bg-label-info, [data-bs-theme="dark"] .bg-label-info { background-color: rgba(3, 195, 236, 0.25) !important; color: #03c3ec !important; }

    /* ===== Stat mini-cards (ASNET standard) ===== */
    .stat-card {
        border: none;
        border-radius: 14px;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(30,33,48,.12);
    }
    .stat-icon {
        width: 42px; height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: #fff;
    }
    .stat-number { font-size: 1.4rem; font-weight: 700; margin: 0; }
    .dark-style .stat-number,
    [data-bs-theme="dark"] .stat-number { color: #f5f5f9; }
    .stat-label  { font-size: .75rem; color: #9e9e9e; margin: 0; }
    .dark-style .stat-label,
    [data-bs-theme="dark"] .stat-label { color: #cbcbe2; }

    /* Print Styles */
    @@media print {
        .layout-navbar, .layout-menu-horizontal, .layout-menu, .footer, .btn, .nav-links, .buy-now, .btn-primary, .btn-outline-primary {
            display: none !important;
        }
        .container-xxl {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
        }
        .content-wrapper {
            margin: 0 !important;
            padding: 0 !important;
        }
        body {
            background: white !important;
            color: black !important;
        }
        .card {
            box-shadow: none !important;
            border: none !important;
        }
        .card-header h5 {
            font-size: 24pt !important;
            margin-bottom: 20px !important;
            text-align: center !important;
            width: 100% !important;
        }
        .table {
            width: 100% !important;
            border-collapse: collapse !important;
        }
        .table th, .table td {
            border: 1px solid #ddd !important;
            padding: 8px !important;
            color: black !important;
        }
        .badge {
            border: 1px solid #ccc !important;
            color: black !important;
            background: transparent !important;
        }
        .text-primary, .text-warning, .text-info, .text-success {
            color: black !important;
            font-weight: bold !important;
        }
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb py-3 mb-0">
            <li class="breadcrumb-item"><a asp-page="/Admin/Dashboard">Admin</a></li>
            <li class="breadcrumb-item active">Stocks</li>
        </ol>
    </nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="ri-checkbox-circle-line me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="ri-error-warning-line me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

    <!-- Cards de Resumo (Standard ASNET Style) -->
    <div class="row g-3 mb-4">
        <!-- Agrupamentos -->
        <div class="col-6 col-lg-3 mt-0">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#696cff;">
                        🏢
                    </div>
                    <div>
                        <h4 class="stat-number">@Model.CountAgrupamentos</h4>
                        <p class="stat-label">Stock Agrupamentos</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Escolas -->
        <div class="col-6 col-lg-3 mt-0">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#71dd37;">
                        🏫
                    </div>
                    <div>
                        <h4 class="stat-number">@Model.CountEscolas</h4>
                        <p class="stat-label">Stock Escolas</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Técnicos -->
        <div class="col-6 col-lg-3 mt-0">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ff3e1d;">
                        🔧
                    </div>
                    <div>
                        <h4 class="stat-number">@Model.CountTecnicos</h4>
                        <p class="stat-label">Stock Técnicos</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Empresa -->
        <div class="col-6 col-lg-3 mt-0">
            <div class="card stat-card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#03c3ec;">
                        💼
                    </div>
                    <div>
                        <h4 class="stat-number">@Model.CountEmpresa</h4>
                        <p class="stat-label">Stock Central Empresa</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mt-2">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Visão Geral de Inventário</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFilters" aria-expanded="false" aria-controls="collapseFilters">
                    <i class="ri-filter-3-line me-1"></i> Filtrar
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAddStock">
                    <i class="ri-add-line me-1"></i> Adicionar Stock
                </button>
                <button class="btn btn-outline-primary" onclick="window.print()">
                    <i class="ri-file-pdf-line me-1"></i> Exportar PDF
                </button>
            </div>
        </div>

        <!-- Collapsible Filters -->
        <div class="collapse @(Model.SearchName != null || Model.FilterType != null || Model.FilterCategory != null || Model.FilterStatus != null ? "show" : "")" id="collapseFilters">
            <div class="card-body border-top">
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Artigo / Equipamento</label>
                        <input type="text" name="SearchName" value="@Model.SearchName" class="form-control" placeholder="Procurar por nome..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Tipo</label>
                        <select name="FilterType" class="form-select">
                            <option value="">Todos</option>
                            <option value="Portátil" selected="@(Model.FilterType == "Portátil" ? "selected" : null)">Portátil</option>
                            <option value="Monitor" selected="@(Model.FilterType == "Monitor" ? "selected" : null)">Monitor</option>
                            <option value="Teclado" selected="@(Model.FilterType == "Teclado" ? "selected" : null)">Teclado</option>
                            <option value="Rato" selected="@(Model.FilterType == "Rato" ? "selected" : null)">Rato</option>
                            <option value="Impressora" selected="@(Model.FilterType == "Impressora" ? "selected" : null)">Impressora</option>
                            <option value="Projetor" selected="@(Model.FilterType == "Projetor" ? "selected" : null)">Projetor</option>
                            <option value="Outro" selected="@(Model.FilterType == "Outro" ? "selected" : null)">Outro</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Localização</label>
                        <select name="FilterCategory" class="form-select">
                            <option value="">Todas</option>
                            <option value="Empresa" selected="@(Model.FilterCategory == "Empresa" ? "selected" : null)">Stock Empresa</option>
                            <option value="Tecnico" selected="@(Model.FilterCategory == "Tecnico" ? "selected" : null)">Com Técnico</option>
                            <option value="Agrupamento" selected="@(Model.FilterCategory == "Agrupamento" ? "selected" : null)">Stock Agrupamento</option>
                            <option value="Escola" selected="@(Model.FilterCategory == "Escola" ? "selected" : null)">Stock Escola</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Estado</label>
                        <select name="FilterStatus" class="form-select">
                            <option value="">Todos</option>
                            <option value="Disponível" selected="@(Model.FilterStatus == "Disponível" ? "selected" : null)">Disponível</option>
                            <option value="Emprestado" selected="@(Model.FilterStatus == "Emprestado" ? "selected" : null)">Emprestado</option>
                            <option value="Em uso" selected="@(Model.FilterStatus == "Em uso" ? "selected" : null)">Em uso</option>
                            <option value="Indisponível" selected="@(Model.FilterStatus == "Indisponível" ? "selected" : null)">Indisponível</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                        @if (Model.SearchName != null || Model.FilterType != null || Model.FilterCategory != null || Model.FilterStatus != null)
                        {
                            <a asp-page="./Stocks" class="btn btn-outline-secondary">Limpar</a>
                        }
                    </div>
                </form>
            </div>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th>Tipo</th>
                        <th>Localização</th>
                        <th>Quantidade</th>
                        <th>Estado</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Inventory.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">Nenhum artigo encontrado no stock.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Inventory)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td><span class="badge bg-label-secondary">@item.Type</span></td>
                                <td>
                                    @{
                                        var locColor = "text-body";
                                        if (item.Location.Contains("Empresa")) locColor = "text-primary fw-bold";
                                        else if (item.Location.Contains("técnico")) locColor = "text-warning fw-bold";
                                        else if (item.Location.Contains("agrupamento")) locColor = "text-info fw-bold";
                                        else if (item.Location.Contains("escola")) locColor = "text-success fw-bold";
                                    }
                                    <span class="@locColor">@item.Location</span>
                                </td>
                                <td>@item.Quantity</td>
                                <td>
                                    <span class="badge @(item.Status == "Disponível" ? "bg-label-success" : (item.Status == "Emprestado" ? "bg-label-info" : (item.Status == "Indisponível" ? "bg-label-danger" : "bg-label-warning")))">
                                        @item.Status
                                    </span>
                                </td>
                                <td>
                                    @if (item.Location == "Stock Empresa")
                                    {
                                            <button type="button" class="btn btn-sm btn-primary open-lend-modal d-flex align-items-center gap-1 mb-1"
                                                    data-bs-target="#modalLendReturn"
                                                    data-sample-id="@item.SampleId"
                                                    data-name="@item.Name"
                                                    data-type="@item.Type"
                                                    data-location="@item.Location"
                                                    data-quantity="@item.Quantity"
                                                    title="Emprestar">
                                                <span>📤 Emprestar</span>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-danger open-delete-modal d-flex align-items-center justify-content-center"
                                                    data-bs-target="#modalDeleteStock"
                                                    data-sample-id="@item.SampleId"
                                                    data-name="@item.Name"
                                                    data-type="@item.Type"
                                                    data-location="@item.Location"
                                                    data-quantity="@item.Quantity"
                                                    title="Excluir">
                                                <span>🗑️</span>
                                            </button>
                                    }
                                    @if (item.Status == "Emprestado")
                                    {
                                            <button type="button" class="btn btn-sm btn-success text-white open-return-modal d-flex align-items-center gap-1"
                                                    data-bs-target="#modalLendReturn"
                                                    data-sample-id="@item.SampleId"
                                                    data-name="@item.Name"
                                                    data-type="@item.Type"
                                                    data-location="@item.Location"
                                                    data-quantity="@item.Quantity"
                                                    title="Devolver">
                                                <span>📥 Devolver</span>
                                            </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Adicionar Stock -->
<div class="modal fade" id="modalAddStock" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Solicitar / Adicionar Novo Artigo ao Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddStock">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome do Equipamento / Artigo</label>
                        <select name="name" class="form-select" required>
                            <option value="">Selecione ou escolha um artigo existente...</option>
                            @foreach (var existingName in Model.ExistingEquipmentNames)
                            {
                                <option value="@existingName">@existingName</option>
                            }
                        </select>
                        <small class="text-muted">Se o artigo não existir, escolha 'Outro' ou adicione manualmente (Dica: Se precisar de um novo nome, use a opção 'Outro Equivalente' ou peça ao Admin para registar o modelo).</small>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Quantidade a Adicionar</label>
                        <input type="number" name="quantity" class="form-control" value="1" min="1" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo / Categoria</label>
                        <select name="type" class="form-select" required>
                            <option value="">Selecione...</option>
                            <option value="Portátil">Portátil</option>
                            <option value="Monitor">Monitor</option>
                            <option value="Teclado">Teclado</option>
                            <option value="Rato">Rato</option>
                            <option value="Impressora">Impressora</option>
                            <option value="Projetor">Projetor</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Local de Destino</label>
                        <select name="locationCategory" class="form-select" onchange="toggleAddStockLocation(this)" required>
                            <option value="Empresa">Stock Empresa (Central)</option>
                            <option value="Tecnico">Com Técnico</option>
                            <option value="Agrupamento">Stock Agrupamento</option>
                            <option value="Escola">Stock Escola</option>
                        </select>
                    </div>

                    <div id="addStock_Tecnico" class="mb-3 add-stock-loc" style="display:none;">
                        <label class="form-label">Técnico Responsável</label>
                        <select name="technicianId" class="form-select select2">
                            <option value="">Selecione o técnico...</option>
                            @foreach (var t in Model.AvailableTecnicos) {
                                <option value="@t.Id">@t.Username</option>
                            }
                        </select>
                    </div>

                    <div id="addStock_Agrupamento" class="mb-3 add-stock-loc" style="display:none;">
                        <label class="form-label">Agrupamento</label>
                        <select name="agrupamentoId" id="addAgrupamentoId" class="form-select select2" onchange="filterAddStockSchools()">
                            <option value="">Selecione o agrupamento...</option>
                            @foreach (var a in Model.AvailableAgrupamentos) {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                    </div>

                    <div id="addStock_Escola" class="mb-3 add-stock-loc" style="display:none;">
                        <label class="form-label">Escola</label>
                        <select name="schoolId" id="addSchoolId" class="form-select select2">
                            <option value="">Selecione a escola...</option>
                            @foreach (var s in Model.AvailableSchools) {
                                <option value="@s.Id" data-agr="@s.AgrupamentoId">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descrição / Observações</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Detalhes adicionais..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Adicionar ao Stock</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Emprestar / Devolver -->
<div class="modal fade" id="modalLendReturn" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="lendReturnModalTitle">Emprestar Artigo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="lendReturnForm" method="post">
                <div class="modal-body">
                    <p id="lendReturnModalDesc">A selecionar quantidade para o artigo: <strong id="modalItemName">...</strong></p>
                    <input type="hidden" name="sampleId" id="modalInputSampleId" />
                    <input type="hidden" name="name" id="modalInputName" />
                    <input type="hidden" name="type" id="modalInputType" />
                    <input type="hidden" name="location" id="modalInputLocation" />

                    <div class="mb-3" id="lendLocationFields">
                        <label class="form-label">Local de Destino</label>
                        <select name="agrupamentoId" id="lendAgrupamentoId" class="form-select mb-2" onchange="filterLendSchools()" required>
                            <option value="">Selecione o Agrupamento...</option>
                            @foreach (var a in Model.AvailableAgrupamentos) {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                        <select name="schoolId" id="lendSchoolId" class="form-select" required>
                            <option value="">Selecione a Escola...</option>
                            @foreach (var s in Model.AvailableSchools) {
                                <option value="@s.Id" data-agr="@s.AgrupamentoId">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Quantidade</label>
                        <div class="input-group">
                            <input type="number" name="quantity" id="modalInputQuantity" class="form-control" value="1" min="1" required />
                            <span class="input-group-text">de <span id="modalMaxQuantity">1</span> disponíveis</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="modalSubmitBtn" class="btn btn-primary">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Deletar -->
<div class="modal fade" id="modalDeleteStock" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Excluir do Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="deleteStockForm" method="post" asp-page-handler="DeleteStock">
                <div class="modal-body">
                    <p>Deseja excluir unidades de <strong id="deleteItemName">...</strong>?</p>
                    <input type="hidden" name="sampleId" id="deleteInputSampleId" />
                    <input type="hidden" name="name" id="deleteInputName" />
                    <input type="hidden" name="type" id="deleteInputType" />
                    <input type="hidden" name="location" id="deleteInputLocation" />

                    <div class="mb-3">
                        <label class="form-label">Quantidade a Excluir</label>
                        <div class="input-group">
                            <input type="number" name="quantity" id="deleteInputQuantity" class="form-control" value="1" min="1" required />
                            <span class="input-group-text">de <span id="deleteMaxQuantity">1</span> totais</span>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="ri-error-warning-line me-1"></i> Esta ação removerá os equipamentos permanentemente do stock.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Excluir Permanentemente</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function toggleAddStockLocation(selectEl) {
        const category = selectEl.value;
        const modal = selectEl.closest('.modal-content');
        
        // Hide all sub-locations and remove required
        modal.querySelectorAll('.add-stock-loc').forEach(div => {
            div.style.display = 'none';
            div.querySelectorAll('select').forEach(s => s.required = false);
        });

        // Show target if not Empresa
        if (category !== 'Empresa') {
            if (category === 'Escola') {
                // For schools, we also show the agrupamento for filtering
                modal.querySelector('#addStock_Agrupamento').style.display = 'block';
                modal.querySelector('#addStock_Escola').style.display = 'block';
                modal.querySelector('#addAgrupamentoId').required = true;
                modal.querySelector('#addSchoolId').required = true;
            } else {
                const target = modal.querySelector('#addStock_' + category);
                if (target) {
                    target.style.display = 'block';
                    target.querySelectorAll('select').forEach(s => s.required = true);
                }
            }
        }
    }

    function filterAddStockSchools() {
        const agrId = document.getElementById('addAgrupamentoId').value;
        const schoolSelect = document.getElementById('addSchoolId');
        const options = schoolSelect.querySelectorAll('option');
        
        schoolSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (agrId === "" || opt.getAttribute('data-agr') === agrId) ? 'block' : 'none';
        });
    }

    function filterLendSchools() {
        const agrId = document.getElementById('lendAgrupamentoId').value;
        const schoolSelect = document.getElementById('lendSchoolId');
        const options = schoolSelect.querySelectorAll('option');
        
        schoolSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (agrId === "" || opt.getAttribute('data-agr') === agrId) ? 'block' : 'none';
        });
    }

    function setupModal(id, name, type, location, maxQty) {
        document.getElementById('modalItemName').innerText = name;
        document.getElementById('deleteItemName').innerText = name;

        document.getElementById('modalInputSampleId').value = id;
        document.getElementById('modalInputName').value = name;
        document.getElementById('modalInputType').value = type;
        document.getElementById('modalInputLocation').value = location;
        document.getElementById('modalMaxQuantity').innerText = maxQty;
        
        const lendQtyInput = document.getElementById('modalInputQuantity');
        lendQtyInput.max = maxQty;
        lendQtyInput.value = 1;

        document.getElementById('deleteInputSampleId').value = id;
        document.getElementById('deleteInputName').value = name;
        document.getElementById('deleteInputType').value = type;
        document.getElementById('deleteInputLocation').value = location;
        document.getElementById('deleteMaxQuantity').innerText = maxQty;
        
        const deleteQtyInput = document.getElementById('deleteInputQuantity');
        deleteQtyInput.max = maxQty;
        deleteQtyInput.value = 1;
    }

    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.open-lend-modal, .open-return-modal, .open-delete-modal').forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.getAttribute('data-sample-id');
                const name = this.getAttribute('data-name');
                const type = this.getAttribute('data-type');
                const loc = this.getAttribute('data-location');
                const qty = this.getAttribute('data-quantity');
                
                setupModal(id, name, type, loc, qty);

                const mode = this.classList.contains('open-lend-modal') ? 'lend' : (this.classList.contains('open-return-modal') ? 'return' : 'delete');
                const modalElement = document.querySelector(this.getAttribute('data-bs-target'));
                const modal = new bootstrap.Modal(modalElement);

                if (mode === 'lend') {
                    document.getElementById('lendReturnModalTitle').innerText = 'Emprestar Artigo';
                    document.getElementById('lendReturnModalDesc').innerHTML = 'Selecione a quantidade de <strong>' + name + '</strong> a emprestar:';
                    document.getElementById('modalSubmitBtn').innerText = 'Emprestar';
                    document.getElementById('modalSubmitBtn').className = 'btn btn-info';
                    document.getElementById('lendReturnForm').action = '?handler=Lend';
                    document.getElementById('lendLocationFields').style.display = 'block';
                    document.getElementById('lendAgrupamentoId').required = true;
                    document.getElementById('lendSchoolId').required = true;
                } else if (mode === 'return') {
                    document.getElementById('lendReturnModalTitle').innerText = 'Devolução de Artigo';
                    document.getElementById('lendReturnModalDesc').innerHTML = 'Selecione a quantidade de <strong>' + name + '</strong> que foi devolvida:';
                    document.getElementById('modalSubmitBtn').innerText = 'Confirmar Devolução';
                    document.getElementById('modalSubmitBtn').className = 'btn btn-success';
                    document.getElementById('lendReturnForm').action = '?handler=Return';
                    document.getElementById('lendLocationFields').style.display = 'none';
                    document.getElementById('lendAgrupamentoId').required = false;
                    document.getElementById('lendSchoolId').required = false;
                } else if (mode === 'delete') {
                    // Delete modal has its own form and title, setupModal already handles inputs
                }
                modal.show();
            });
        });
    });
</script>
}
