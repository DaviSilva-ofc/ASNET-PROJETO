@page
@model AspnetCoreStarter.Pages.Admin.DashboardModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Dashboard Administrativo";
}

@section PageStyles {
<style>
    /* ===== ASNET Dashboard — color palette from landing page ===== */
    :root {
        --asnet-navy: #1e2130;
        --asnet-navy-light: #2a2d42;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--asnet-navy);
    }
    .dark-style .dash-title,
    [data-bs-theme="dark"] .dash-title { color: #f5f5f9 !important; }

    /* ===== Stat mini-cards ===== */
    .stat-card {
        border: none;
        border-radius: 14px;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(30,33,48,.12);
    }
    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; }
    .dark-style .stat-number,
    [data-bs-theme="dark"] .stat-number { color: #f5f5f9; }
    .stat-label  { font-size: .8rem; color: #9e9e9e; margin: 0; }
    .dark-style .stat-label,
    [data-bs-theme="dark"] .stat-label { color: #cbcbe2; }

    /* ===== Chart cards ===== */
    .chart-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .chart-card .card-header {
        background: transparent;
        border-bottom: 1px solid rgba(0,0,0,.06);
        font-weight: 600;
        font-size: .95rem;
    }

    /* ===== Tree view ===== */
    .tree-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .tree-tabs .nav-link {
        font-size: .85rem;
        padding: .45rem .9rem;
        border-radius: 8px !important;
        color: var(--asnet-navy);
        font-weight: 500;
    }
    .dark-style .tree-tabs .nav-link,
    [data-bs-theme="dark"] .tree-tabs .nav-link { color: #cbcbe2; }
    .tree-tabs .nav-link.active {
        background: var(--asnet-navy);
        color: #fff;
    }
    .dark-style .tree-tabs .nav-link.active,
    [data-bs-theme="dark"] .tree-tabs .nav-link.active {
        background: var(--asnet-orange);
        color: #fff;
    }

    .tree-list {
        list-style: none;
        padding-left: 0;
    }
    .tree-list ul {
        list-style: none;
        padding-left: 1.6rem;
        border-left: 2px solid #e0e0e0;
    }
    .tree-item {
        position: relative;
        padding: .35rem 0;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .tree-item > .tree-toggle {
        cursor: pointer;
        user-select: none;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        flex-grow: 1;
    }
    .badge-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        min-width: 26px;
    }
    /* ===== Dark mode Specific Enhancements ===== */
    .dark-style .modal-content,
    [data-bs-theme="dark"] .modal-content {
        background-color: #2b2c40 !important;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .dark-style .modal-header,
    [data-bs-theme="dark"] .modal-header {
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .dark-style .table-hover tbody tr:hover,
    [data-bs-theme="dark"] .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.05) !important;
    }
    .dark-style .form-check-label,
    [data-bs-theme="dark"] .form-check-label { color: #cbcbe2; }
    
    .dark-style .pending-big-number,
    [data-bs-theme="dark"] .pending-big-number { color: #f5f5f9; }
    
    /* Enhance colors in dark mode to overlap/stand out */
    .dark-style .badge, .dark-style .btn,
    [data-bs-theme="dark"] .badge, [data-bs-theme="dark"] .btn {
        box-shadow: 0 0 10px rgba(0,0,0,0.2) !important;
        filter: saturate(1.2);
    }
    .dark-style .bg-label-secondary,
    [data-bs-theme="dark"] .bg-label-secondary {
        background-color: #323249 !important;
        color: #cbcbe2 !important;
    }

    .tree-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px; height: 26px;
        border-radius: 8px;
        font-size: .7rem;
        font-weight: 700;
        color: #fff;
        margin-right: .4rem;
    }
    .tree-badge-agrup { background: var(--asnet-blue); }
    .tree-badge-school { background: var(--asnet-green); }
    .tree-badge-bloco  { background: var(--asnet-teal); }
    .tree-badge-sala   { background: var(--asnet-orange); }

    .tree-label { font-weight: 500; font-size: .88rem; }
    .tree-children { 
        display: none; 
        flex-basis: 100%;
    }
    .tree-children.show { display: block; }

    /* close / expand icon */
    .tree-toggle .tree-arrow {
        display: inline-block;
        width: 20px; height: 20px;
        text-align: center;
        line-height: 20px;
        border-radius: 6px;
        font-size: .65rem;
        color: #999;
        background: #f3f3f3;
        cursor: pointer;
        transition: transform .15s;
    }
    .tree-toggle.open .tree-arrow { transform: rotate(90deg); }

    /* ===== Pending card ===== */
    .pending-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .pending-big-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--asnet-navy);
        line-height: 1;
    }
    .pending-subtitle { font-size: .85rem; color: #9e9e9e; }
    .pending-avatar-stack {
        display: flex;
        margin-top: .5rem;
    }
    .pending-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: var(--asnet-navy-light);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem;
        font-weight: 600;
        margin-right: -8px;
        border: 2px solid #fff;
    }

    /* ===== Pending Users Table ===== */
    .pending-table-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .pending-table-card .card-header {
        background: var(--asnet-navy);
        color: #fff;
        border-radius: 14px 14px 0 0 !important;
        font-weight: 600;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">

    <!-- Title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="dash-title mb-0">Administrativo</h4>
        <a href="/Admin/Infrastructure" class="btn btn-sm" style="background:var(--asnet-orange);color:#fff;">
            <i class='bx bx-cog me-1'></i> Gerir Infraestrutura
        </a>
    </div>

    <!-- ===== Stat mini-cards ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--asnet-blue);">
                        <i class='bx bx-user'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalUsers</p>
                        <p class="stat-label">Utilizadores</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ffab00;"> <!-- Yellow -->
                        <i class='bx bx-file'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.ExpiringContractsCount</p>
                        <p class="stat-label">Contratos a expirar</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ff3e1d;"> <!-- Red -->
                        <i class='bx bx-support'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.PendingTicketsCount</p>
                        <p class="stat-label">Tickets pendentes</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#f89223;"> <!-- Orange -->
                        <i class='bx bx-package'></i>
                    </div>
                    <div>
                        <p class="stat-number">@Model.LowStockAlertsCount</p>
                        <p class="stat-label">Alertas de stock</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Infrastructure Tree + Pending Requests ===== -->
    <div class="row g-4 mb-4">
        <!-- Infrastructure Tree -->
        <div class="col-lg-4">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-blue);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <ul class="nav tree-tabs" role="tablist">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabTree">Agrupamentos</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabSchools">Escolas</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabBlocos">Blocos</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabSalas">Salas</a></li>
                    </ul>
                </div>
                <div class="card-body" style="max-height:380px; overflow-y:auto;">
                    <div class="tab-content">
                        <!-- Tab: Full Tree -->
                        <div class="tab-pane fade show active" id="tabTree">
                            <ul class="tree-list">
                                @foreach (var agrup in Model.Agrupamentos)
                                {
                                    var agrupSchools = Model.AllSchools.Where(s => s.AgrupamentoId == agrup.Id).ToList();
                                    <li class="tree-item">
                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                            <div class="badge-col">
                                                <span class="tree-badge tree-badge-agrup">@agrupSchools.Count</span>
                                                @if (agrupSchools.Any()) { <span class="tree-arrow">▶</span> }
                                            </div>
                                            <span class="tree-label">@agrup.Name</span>
                                        </div>
                                        @if (agrupSchools.Any())
                                        {
                                            <ul class="tree-children">
                                                @foreach (var school in agrupSchools)
                                                {
                                                    var schoolBlocos = Model.AllBlocos.Where(b => b.SchoolId == school.Id).ToList();
                                                    <li class="tree-item">
                                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                                            <div class="badge-col">
                                                                <span class="tree-badge tree-badge-school">@schoolBlocos.Count</span>
                                                                @if (schoolBlocos.Any()) { <span class="tree-arrow">▶</span> }
                                                            </div>
                                                            <span class="tree-label">@school.Name</span>
                                                        </div>
                                                        @if (schoolBlocos.Any())
                                                        {
                                                            <ul class="tree-children">
                                                                @foreach (var bloco in schoolBlocos)
                                                                {
                                                                    var blocoSalas = Model.AllSalas.Where(s => s.BlockId == bloco.Id).ToList();
                                                                    <li class="tree-item">
                                                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                                                            <div class="badge-col">
                                                                                <span class="tree-badge tree-badge-bloco">@blocoSalas.Count</span>
                                                                                @if (blocoSalas.Any()) { <span class="tree-arrow">▶</span> }
                                                                            </div>
                                                                            <span class="tree-label">@bloco.Name</span>
                                                                        </div>
                                                                        @if (blocoSalas.Any())
                                                                        {
                                                                            <ul class="tree-children">
                                                                                @foreach (var sala in blocoSalas)
                                                                                {
                                                                                    <li class="tree-item">
                                                                                        <div class="badge-col">
                                                                                            <span class="tree-badge tree-badge-sala"><i class='bx bx-door-open' style="font-size:.7rem;"></i></span>
                                                                                        </div>
                                                                                        <span class="tree-label">@sala.Name</span>
                                                                                    </li>
                                                                                }
                                                                            </ul>
                                                                        }
                                                                    </li>
                                                                }
                                                            </ul>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </li>
                                }
                                @if (!Model.Agrupamentos.Any())
                                {
                                    <li class="text-muted py-3 text-center">Nenhum agrupamento registado.</li>
                                }
                            </ul>
                        </div>

                        <!-- Tab: Schools flat list -->
                        <div class="tab-pane fade" id="tabSchools">
                            <ul class="tree-list">
                                @foreach (var school in Model.AllSchools)
                                {
                                    <li class="tree-item d-flex align-items-center gap-2 py-2">
                                        <span class="tree-badge tree-badge-school"><i class='bx bx-buildings' style="font-size:.7rem;"></i></span>
                                        <span class="tree-label">@school.Name</span>
                                        <small class="text-muted ms-auto">@(school.Agrupamento?.Name ?? "Sem Agrupamento")</small>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Tab: Blocos flat list -->
                        <div class="tab-pane fade" id="tabBlocos">
                            <ul class="tree-list">
                                @foreach (var bloco in Model.AllBlocos)
                                {
                                    <li class="tree-item d-flex align-items-center gap-2 py-2">
                                        <span class="tree-badge tree-badge-bloco"><i class='bx bx-cube' style="font-size:.7rem;"></i></span>
                                        <span class="tree-label">@bloco.Name</span>
                                        <small class="text-muted ms-auto">@(bloco.School?.Name ?? "—")</small>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Tab: Salas flat list -->
                        <div class="tab-pane fade" id="tabSalas">
                            <ul class="tree-list">
                                @foreach (var sala in Model.AllSalas)
                                {
                                    <li class="tree-item d-flex align-items-center gap-2 py-2">
                                        <span class="tree-badge tree-badge-sala"><i class='bx bx-door-open' style="font-size:.7rem;"></i></span>
                                        <span class="tree-label">@sala.Name</span>
                                        <small class="text-muted ms-auto">@(sala.Block?.Name ?? "—")</small>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Notifications Card -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid #71dd37;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:#71dd37;">
                                <i class='bx bx-chat'></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Mensagens</h6>
                        </div>
                        <p class="pending-big-number">@Model.TotalUnreadMessages<span style="font-size:1rem;color:#71dd37;"> novas</span></p>
                        <p class="pending-subtitle">mensagens no chat aguardam resposta</p>

                        @if (Model.RecentMessageSenders.Any())
                        {
                            <div class="pending-avatar-stack mb-3">
                                @foreach (var u in Model.RecentMessageSenders)
                                {
                                    <div class="pending-avatar" title="@u.Username" style="border: 2px solid #fff;">
                                        @if (!string.IsNullOrEmpty(u.ProfilePhotoPath))
                                        {
                                            <img src="@u.ProfilePhotoPath" alt="Avatar" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
                                        }
                                        else
                                        {
                                            @(u.Username?.Substring(0, Math.Min(2, u.Username.Length)).ToUpper())
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <a href="/Admin/Chat" class="btn w-100" style="background:#71dd37;color:#fff;">
                        <i class='bx bx-reply me-1'></i> Responder
                    </a>
                </div>
            </div>
        </div>

        <!-- Pending Account Requests Card -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid var(--asnet-pink);">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:var(--asnet-pink);">
                                <i class='bx bx-user-plus'></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Pedidos Pendentes</h6>
                        </div>
                        <p class="pending-big-number">@Model.PendingUsers.Count<span style="font-size:1rem;color:var(--asnet-orange);"> novos</span></p>
                        <p class="pending-subtitle">pedidos de registo aguardam aprovação</p>

                        @if (Model.PendingUsers.Any())
                        {
                            <div class="pending-avatar-stack mb-3">
                                @foreach (var u in Model.PendingUsers.Take(5))
                                {
                                    <div class="pending-avatar" title="@u.Username">
                                        @(u.Username?.Substring(0, Math.Min(2, u.Username.Length)).ToUpper())
                                    </div>
                                }
                                @if (Model.PendingUsers.Count > 5)
                                {
                                    <div class="pending-avatar" style="background:var(--asnet-orange);">+@(Model.PendingUsers.Count - 5)</div>
                                }
                            </div>
                        }
                    </div>
                    <button class="btn w-100" style="background:var(--asnet-pink);color:#fff;" data-bs-toggle="modal" data-bs-target="#modalPending">
                        <i class='bx bx-list-ul me-1'></i> Ver pedidos
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Low Stock Alerts Row ===== -->
    @if (Model.LowStockItems.Any())
    {
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card shadow-sm" style="border-left: 5px solid #ffab00;">
                    <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                        <div class="d-flex align-items-center gap-2">
                            <i class='bx bx-error text-warning' style="font-size: 1.5rem;"></i>
                            <h5 class="mb-0 fw-bold">Alertas de Stock Baixo</h5>
                        </div>
                        <a href="/Admin/Stocks" class="btn btn-xs btn-outline-warning">Gerir Stock</a>
                    </div>
                    <div class="card-body">
                        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                            @foreach (var item in Model.LowStockItems)
                            {
                                <div class="col">
                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="stat-icon bg-warning" style="width: 32px; height: 32px; font-size: 1rem;">
                                                <i class='bx bx-box'></i>
                                            </div>
                                            <span class="fw-semibold text-dark">@item.Name</span>
                                        </div>
                                        <span class="badge bg-label-danger">@item.AvailableCount disponíveis</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ===== Charts Row ===== -->
    <div class="row g-4 mb-4">
        <!-- Ticket Status Chart -->
        <div class="col-lg-7">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-support' style="color:var(--asnet-blue);"></i>
                    Estado dos Tickets
                </div>
                <div class="card-body">
                    <div style="height: 250px; position: relative;">
                        <canvas id="ticketStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <!-- Donut Chart -->
        <div class="col-lg-5">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-pie-chart-alt-2' style="color:var(--asnet-orange);"></i>
                    Visão Geral do Sistema
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div style="height: 250px; width: 100%; position: relative;">
                        <canvas id="donutChart"></canvas>
                    </div>
                    <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                        <span><i class='bx bxs-circle' style="color:#ffab00;font-size:.6rem;"></i> Contratos</span>
                        <span><i class='bx bxs-circle' style="color:#ff3e1d;font-size:.6rem;"></i> Tickets</span>
                        <span><i class='bx bxs-circle' style="color:#f89223;font-size:.6rem;"></i> Stock</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Map Row ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card map-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-map-pin' style="color:#f89223;"></i>
                    Localização dos Clientes
                </div>
                <div class="card-body p-0">
                    <div id="clientMap" style="height: 400px; width: 100%; border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== Modal: Pending Users Table ===== -->
<div class="modal fade" id="modalPending" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;overflow:hidden;">
            <div class="modal-header" style="background:var(--asnet-navy);color:#fff;">
                <h5 class="modal-title">Aprovações de Conta Pendentes</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Estado</th>
                                <th>Data</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.PendingUsers.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">Nenhum pedido pendente.</td>
                                </tr>
                            }
                            @foreach (AspnetCoreStarter.Models.User user in Model.PendingUsers)
                            {
                                <tr>
                                    <td><strong>@user.Username</strong></td>
                                    <td>@user.Email</td>
                                    <td><span class="badge" style="background:var(--asnet-orange);color:#fff;">@user.AccountStatus</span></td>
                                    <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-column gap-2">
                                            <form method="post" asp-page-handler="ProcessApproval" asp-route-id="@user.Id">
                                                <div class="mb-2">
                                                    <select name="role" class="form-select form-select-sm role-selector" onchange="toggleRoleOptions(this, @user.Id)" required>
                                                        <option value="">Cargo...</option>
                                                        <option value="Tecnico">Técnico</option>
                                                        <option value="Diretor">Diretor</option>
                                                        <option value="Coordenador">Coordenador</option>
                                                        <option value="Professor">Professor</option>
                                                        <option value="Cliente Individual">Cliente Individual</option>
                                                    </select>
                                                </div>
                                                
                                                <!-- Dynamic Fields Container -->
                                                <div id="roleFields_@user.Id" class="mb-2" style="display:none;">
                                                    <!-- Diretor: Agrupamento -->
                                                    <div class="field-Diretor" style="display:none;">
                                                        <select name="agrupamentoId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Agrupamento...</option>
                                                            @foreach (var agrup in Model.Agrupamentos) {
                                                                <option value="@agrup.Id">@agrup.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    
                                                    <!-- Tecnico: Area e Nivel -->
                                                    <div class="field-Tecnico" style="display:none;">
                                                        <label class="form-label mb-1 small fw-bold">Áreas Técnicas (Selecione múltiplas):</label>
                                                        <div class="d-flex flex-column gap-1 mb-2 p-2 border rounded bg-label-secondary" style="max-height: 200px; overflow-y: auto;">
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Redes" id="checkRedes_@user.Id">
                                                                <label class="form-check-label small" for="checkRedes_@user.Id">Redes</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Segurança" id="checkSeguranca_@user.Id">
                                                                <label class="form-check-label small" for="checkSeguranca_@user.Id">Segurança</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Infraestrutura" id="checkInfra_@user.Id">
                                                                <label class="form-check-label small" for="checkInfra_@user.Id">Infraestrutura</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Sistemas" id="checkSistemas_@user.Id">
                                                                <label class="form-check-label small" for="checkSistemas_@user.Id">Sistemas</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Telecomunicações" id="checkTele_@user.Id">
                                                                <label class="form-check-label small" for="checkTele_@user.Id">Telecomunicações</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Manutenção" id="checkManut_@user.Id">
                                                                <label class="form-check-label small" for="checkManut_@user.Id">Manutenção</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Consultoria Técnica" id="checkConsul_@user.Id">
                                                                <label class="form-check-label small" for="checkConsul_@user.Id">Consultoria</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Vendas" id="checkVendas_@user.Id">
                                                                <label class="form-check-label small" for="checkVendas_@user.Id">Vendas</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" id="checkOutros_@user.Id" onchange="toggleOthersInput(@user.Id)">
                                                                <label class="form-check-label small" for="checkOutros_@user.Id">Outros</label>
                                                            </div>
                                                        </div>
                                                        
                                                        <input type="text" name="areaTecnicaOutros" id="inputOutros_@user.Id" class="form-control form-control-sm mb-2" placeholder="Descreva outra área..." style="display:none;">

                                                        <select name="nivel" class="form-select form-select-sm">
                                                            <option value="">Nível...</option>
                                                            <option value="estagiário">estagiário</option>
                                                            <option value="Júnior">Júnior</option>
                                                            <option value="médio">médio</option>
                                                            <option value="sénior">sénior</option>
                                                            <option value="master">master</option>
                                                        </select>
                                                    </div>
                                                    
                                                    <!-- Coordenador: Escola -->
                                                    <div class="field-Coordenador" style="display:none;">
                                                        <select name="escolaId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Escola...</option>
                                                            @foreach (var school in Model.AllSchools) {
                                                                <option value="@school.Id">@school.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    
                                                    <!-- Professor: Bloco -->
                                                    <div class="field-Professor" style="display:none;">
                                                        <select name="blocoId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Bloco...</option>
                                                            @foreach (var bloco in Model.AllBlocos) {
                                                                <option value="@bloco.Id">@bloco.Name (@bloco.School?.Name)</option>
                                                            }
                                                        </select>
                                                    </div>

                                                    <!-- Cliente Individual: Empresa -->
                                                    <div class="field-Cliente-Individual" style="display:none;">
                                                        <select name="empresaId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Empresa...</option>
                                                            @foreach (var emp in Model.Empresas) {
                                                                <option value="@emp.Id">@emp.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="d-flex gap-2">
                                                    <button type="submit" id="btnApprove_@user.Id" class="btn btn-sm btn-success flex-grow-1" disabled>Aceitar</button>
                                                </div>
                                            </form>
                                            <form method="post" asp-page-handler="Reject" asp-route-id="@user.Id">
                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Recusar</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // ===== Tree toggle =====
    function toggleTree(el) {
        el.classList.toggle('open');
        var children = el.parentElement.querySelector('.tree-children');
        if (children) children.classList.toggle('show');
    }

    // ===== Ticket Status Chart (Line) =====
    const ticketCtx = document.getElementById('ticketStatusChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartLabels)),
            datasets: [
                {
                    label: 'Pedidos',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartPedidosData)),
                    borderColor: '#696cff',
                    backgroundColor: 'rgba(105, 108, 255, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: false
                },
                {
                    label: 'Pendentes',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartPendentesData)),
                    borderColor: '#ff3e1d',
                    backgroundColor: 'rgba(255, 62, 29, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: false
                },
                {
                    label: 'Concluídos',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineChartConcluidosData)),
                    borderColor: '#71dd37',
                    backgroundColor: 'rgba(113, 221, 55, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: false
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { 
                legend: { 
                    display: true, 
                    position: 'bottom',
                    labels: { boxWidth: 12, usePointStyle: true }
                } 
            },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== Bar Chart: System Overview =====
    const donutCtx = document.getElementById('donutChart').getContext('2d');
    new Chart(donutCtx, {
        type: 'bar',
        data: {
            labels: ['Contratos', 'Tickets', 'Stock'],
            datasets: [{
                label: 'Total',
                data: [@Model.ExpiringContractsCount, @Model.PendingTicketsCount, @Model.LowStockAlertsCount],
                backgroundColor: ['#ffab00', '#ff3e1d', '#f89223'],
                borderRadius: 6,
                maxBarThickness: 40
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,.04)' } },
                x: { grid: { display: false }, ticks: { font: { size: 11 } } }
            }
        }
    });

    // ===== Role toggles in Pending Modal =====
    function toggleRoleOptions(selectEl, userId) {
        const role = selectEl.value;
        const container = document.getElementById('roleFields_' + userId);
        const approveBtn = document.getElementById('btnApprove_' + userId);
        
        if (!role) {
            container.style.display = 'none';
            if (approveBtn) approveBtn.disabled = true;
            // Remove required from all potential sub-fields
            container.querySelectorAll('select, input').forEach(el => el.required = false);
            return;
        }

        if (approveBtn) approveBtn.disabled = false;
        container.style.display = 'block';
        
        // Hide all specific field groups and remove required
        container.querySelectorAll('[class^="field-"]').forEach(div => {
            div.style.display = 'none';
            div.querySelectorAll('select, input').forEach(el => el.required = false);
        });

        // Show the specific group and set required
        const targetDiv = container.querySelector('.field-' + (role === 'Cliente Individual' ? 'Cliente-Individual' : role));
        if (targetDiv) {
            targetDiv.style.display = 'block';
            // Only make selects required (since tecnico areas are checkboxes)
            targetDiv.querySelectorAll('select').forEach(el => el.required = true);
        }
    }

    function toggleOthersInput(userId) {
        const checkbox = document.getElementById('checkOutros_' + userId);
        const input = document.getElementById('inputOutros_' + userId);
        if (checkbox.checked) {
            input.style.display = 'block';
            input.focus();
        } else {
            input.style.display = 'none';
            input.value = '';
        }
    }
</script>
<script>
    function initMap() {
        // Default center: Braga
        var myLatLng = { lat: 41.5454, lng: -8.4265 };

        var map = new google.maps.Map(document.getElementById('clientMap'), {
            zoom: 10,
            center: myLatLng
        });

        // Parse locations from model
        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw) {
            var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
            var geocoder = new google.maps.Geocoder();

            locations.forEach(function(loc) {
                if (loc.address) {
                    geocoder.geocode({ 'address': loc.address + ", Portugal" }, function(results, status) {
                        if (status === 'OK') {
                            new google.maps.Marker({
                                map: map,
                                position: results[0].geometry.location,
                                title: loc.name
                            });
                        } else {
                            console.warn('Geocode failed for ' + loc.address + ': ' + status);
                        }
                    });
                }
            });
        }
    }
</script>
<script async defer src="https://maps.googleapis.com/maps/api/js?key=&callback=initMap"></script>
}
