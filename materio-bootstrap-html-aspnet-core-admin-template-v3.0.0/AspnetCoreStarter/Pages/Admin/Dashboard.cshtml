@page
@model AspnetCoreStarter.Pages.Admin.DashboardModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Dashboard Administrativo";
}

@section PageStyles {
<style>
    /* ===== ASNET Dashboard — color palette from landing page ===== */
    :root {
        --asnet-navy: #1e2130;
        --asnet-navy-light: #2a2d42;
        --asnet-orange: #f89223;
        --asnet-blue: #696cff;
        --asnet-teal: #03c3ec;
        --asnet-green: #71dd37;
        --asnet-pink: #e7305b;
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--asnet-navy);
    }
    .dark-style .dash-title,
    [data-bs-theme="dark"] .dash-title { color: #f5f5f9 !important; }

    /* ===== Stat mini-cards ===== */
    .stat-card { background: var(--tk-card-solid) !important;
        border: none;
        border-radius: 14px;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(30,33,48,.12);
    }
    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--bs-heading-color);
    }
    .stat-number { font-size: 1.5rem; font-weight: 700; margin: 0; }
    .dark-style .stat-number,
    [data-bs-theme="dark"] .stat-number { color: #f5f5f9; }
    .stat-label  { font-size: .8rem; color: #9e9e9e; margin: 0; }
    .dark-style .stat-label,
    [data-bs-theme="dark"] .stat-label { color: #cbcbe2; }

    /* ===== Chart cards ===== */
    .chart-card { background: var(--tk-card-solid) !important;
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .chart-card .card-header {
        background: transparent;
        border-bottom: 1px solid rgba(0,0,0,.06);
        font-weight: 600;
        font-size: .95rem;
    }

    /* ===== Tree view ===== */
    .tree-card { background: var(--tk-card-solid) !important;
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .tree-tabs .nav-link {
        font-size: .85rem;
        padding: .45rem .9rem;
        border-radius: 8px !important;
        color: var(--asnet-navy);
        font-weight: 500;
    }
    .dark-style .tree-tabs .nav-link,
    [data-bs-theme="dark"] .tree-tabs .nav-link { color: #cbcbe2; }
    .tree-tabs .nav-link.active {
        background: #64748b; /* A nice distinct gray instead of black */
        color: #fff !important; /* Ensure text is readable */
    }
    .dark-style .tree-tabs .nav-link.active,
    [data-bs-theme="dark"] .tree-tabs .nav-link.active {
        background: var(--asnet-orange);
        color: var(--bs-heading-color);
    }

    .tree-list {
        list-style: none;
        padding-left: 0;
    }
    .tree-list ul {
        list-style: none;
        padding-left: 1.6rem;
        border-left: 2px solid #e0e0e0;
    }
    .tree-item {
        position: relative;
        padding: .35rem 0;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .tree-item > .tree-toggle {
        cursor: pointer;
        user-select: none;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        flex-grow: 1;
    }
    .badge-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        min-width: 26px;
    }
    /* ===== Dark mode Specific Enhancements ===== */
    .dark-style .modal-content,
    [data-bs-theme="dark"] .modal-content {
        background-color: var(--tk-card-solid) !important;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .dark-style .modal-header,
    [data-bs-theme="dark"] .modal-header {
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .dark-style .table-hover tbody tr:hover,
    [data-bs-theme="dark"] .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.05) !important;
    }
    .dark-style .form-check-label,
    [data-bs-theme="dark"] .form-check-label { color: #cbcbe2; }
    
    .dark-style .pending-big-number,
    [data-bs-theme="dark"] .pending-big-number { color: #f5f5f9; }
    
    /* Enhance colors in dark mode to overlap/stand out */
    .dark-style .badge, .dark-style .btn,
    [data-bs-theme="dark"] .badge, [data-bs-theme="dark"] .btn {
        box-shadow: 0 0 10px rgba(0,0,0,0.2) !important;
        filter: saturate(1.2);
    }
    .dark-style .bg-label-secondary,
    [data-bs-theme="dark"] .bg-label-secondary {
        background-color: #323249 !important;
        color: #cbcbe2 !important;
    }

    .tree-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px; height: 26px;
        border-radius: 8px;
        font-size: .7rem;
        font-weight: 700;
        color: var(--bs-heading-color);
        margin-right: .4rem;
    }
    .tree-badge-agrup { background: var(--asnet-blue); }
    .tree-badge-school { background: var(--asnet-green); }
    .tree-badge-bloco  { background: var(--asnet-teal); }
    .tree-badge-sala   { background: var(--asnet-orange); }

    .tree-label { font-weight: 500; font-size: .88rem; }
    .tree-children { 
        display: none; 
        flex-basis: 100%;
    }
    .tree-children.show { display: block; }

    /* close / expand icon */
    .tree-toggle .tree-arrow {
        display: inline-block;
        width: 20px; height: 20px;
        text-align: center;
        line-height: 20px;
        border-radius: 6px;
        font-size: .65rem;
        color: #999;
        background: #f3f3f3;
        cursor: pointer;
        transition: transform .15s;
    }
    .tree-toggle.open .tree-arrow { transform: rotate(90deg); }

    /* ===== Pending card ===== */
    .pending-card { background: var(--tk-card-solid) !important;
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .pending-big-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--asnet-navy);
        line-height: 1;
    }
    .pending-subtitle { font-size: .85rem; color: #9e9e9e; }
    .pending-avatar-stack {
        display: flex;
        margin-top: .5rem;
    }
    .pending-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: var(--asnet-navy-light);
        color: var(--bs-heading-color);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem;
        font-weight: 600;
        margin-right: -8px;
        border: 2px solid #fff;
    }

    /* ===== Pending Users Table ===== */
    .pending-table-card { background: var(--tk-card-solid) !important;
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(30,33,48,.06);
    }
    .pending-table-card .card-header {
        background: var(--asnet-navy);
        color: var(--bs-heading-color);
        border-radius: 14px 14px 0 0 !important;
        font-weight: 600;
    }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">

    @if (!Model.IsMaintenanceScheduledThisYear)
    {
        <div class="alert alert-warning alert-dismissible shadow-sm mb-4 d-flex align-items-center" role="alert" style="border-left: 4px solid #ffab00;">
            <i class="bx bx-error-circle fs-3 me-3 text-warning"></i>
            <div>
                <strong>Atenção!</strong> A Manutenção Preventiva Anual para o ano de @DateTime.Now.Year ainda não foi agendada.
                <a href="/Admin/Equipment?Tab=preventive" class="alert-link ms-1 text-decoration-underline">Agendar Agora</a>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="dash-title mb-0">Administrativo</h4>
        <div class="d-flex gap-2">
            <a href="/Admin/Calendar" class="btn btn-sm btn-primary">
                <i class='bx bx-calendar me-1'></i> Calendário Global
            </a>
            <a href="/Admin/Infrastructure" class="btn btn-sm" style="background:var(--asnet-orange);color: var(--bs-heading-color);">
                <i class='bx bx-cog me-1'></i> Gerir Infraestrutura
            </a>
        </div>
    </div>

    <!-- ===== Stat mini-cards ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--asnet-blue);">
                        <span style="font-size: 1.5rem;">👥</span>
                    </div>
                    <div>
                        <p class="stat-number">@Model.TotalUsers</p>
                        <p class="stat-label">Utilizadores</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ffab00;"> <!-- Yellow -->
                        <span style="font-size: 1.5rem;">📄</span>
                    </div>
                    <div>
                        <p class="stat-number">@Model.ExpiringContractsCount</p>
                        <p class="stat-label">Contratos a expirar</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ff3e1d;"> <!-- Red -->
                        <span style="font-size: 1.5rem;">🚨</span>
                    </div>
                    <div>
                        <p class="stat-number">@Model.PendingTicketsCount</p>
                        <p class="stat-label">Tickets pendentes</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#f89223;"> <!-- Orange -->
                        <span style="font-size: 1.5rem;">📦</span>
                    </div>
                    <div>
                        <p class="stat-number">@Model.LowStockAlertsCount</p>
                        <p class="stat-label">Alertas de stock</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Infrastructure Tree + Pending Requests ===== -->
    <div class="row g-4 mb-4">
        <!-- Infrastructure Tree -->
        <div class="col-lg-4">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-blue);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <ul class="nav tree-tabs" role="tablist">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabTree">Agrupamentos</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabSchools">Escolas</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabBlocos">Blocos</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabSalas">Salas</a></li>
                    </ul>
                </div>
                <div class="card-body" style="max-height:380px; overflow-y:auto;">
                    <div class="tab-content">
                        <!-- Tab: Full Tree -->
                        <div class="tab-pane fade show active" id="tabTree">
                            <ul class="tree-list">
                                @foreach (var agrup in Model.Agrupamentos)
                                {
                                    var agrupSchools = Model.AllSchools.Where(s => s.AgrupamentoId == agrup.Id).ToList();
                                    <li class="tree-item">
                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                            <div class="badge-col">
                                                <span class="tree-badge tree-badge-agrup">@agrupSchools.Count</span>
                                                @if (agrupSchools.Any()) { <span class="tree-arrow">▶</span> }
                                            </div>
                                            <span class="tree-label">🏢 @agrup.Name</span>
                                        </div>
                                        @if (agrupSchools.Any())
                                        {
                                            <ul class="tree-children">
                                                @foreach (var school in agrupSchools)
                                                {
                                                    var schoolBlocos = Model.AllBlocos.Where(b => b.SchoolId == school.Id).ToList();
                                                    <li class="tree-item">
                                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                                            <div class="badge-col">
                                                                <span class="tree-badge tree-badge-school">@schoolBlocos.Count</span>
                                                                @if (schoolBlocos.Any()) { <span class="tree-arrow">▶</span> }
                                                            </div>
                                                            <span class="tree-label">🏫 @school.Name</span>
                                                        </div>
                                                        @if (schoolBlocos.Any())
                                                        {
                                                            <ul class="tree-children">
                                                                @foreach (var bloco in schoolBlocos)
                                                                {
                                                                    var blocoSalas = Model.AllSalas.Where(s => s.BlockId == bloco.Id).ToList();
                                                                    <li class="tree-item">
                                                                        <div class="tree-toggle" onclick="toggleTree(this)">
                                                                            <div class="badge-col">
                                                                                <span class="tree-badge tree-badge-bloco">@blocoSalas.Count</span>
                                                                                @if (blocoSalas.Any()) { <span class="tree-arrow">▶</span> }
                                                                            </div>
                                                                            <span class="tree-label">🧱 @bloco.Name</span>
                                                                        </div>
                                                                        @if (blocoSalas.Any())
                                                                        {
                                                                            <ul class="tree-children">
                                                                                @foreach (var sala in blocoSalas)
                                                                                {
                                                                                    <li class="tree-item">
                                                                                        <div class="badge-col">
                                                                                            <span class="tree-badge tree-badge-sala"><i class='bx bx-door-open' style="font-size:.7rem;"></i></span>
                                                                                        </div>
                                                                                        <span class="tree-label">🚪 @sala.Name</span>
                                                                                    </li>
                                                                                }
                                                                            </ul>
                                                                        }
                                                                    </li>
                                                                }
                                                            </ul>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </li>
                                }
                                @if (!Model.Agrupamentos.Any())
                                {
                                    <li class="text-muted py-3 text-center">Nenhum agrupamento registado.</li>
                                }
                            </ul>
                        </div>

                        <!-- Tab: Schools flat list -->
                        <div class="tab-pane fade" id="tabSchools">
                            <ul class="tree-list">
                                @foreach (var school in Model.AllSchools)
                                {
                                    <li class="tree-item d-flex align-items-center gap-2 py-2">
                                        <span class="tree-badge tree-badge-school"><i class='bx bx-buildings' style="font-size:.7rem;"></i></span>
                                        <span class="tree-label">🏫 @school.Name</span>
                                        <small class="text-muted ms-auto">@(school.Agrupamento?.Name ?? "Sem Agrupamento")</small>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Tab: Blocos flat list -->
                        <div class="tab-pane fade" id="tabBlocos">
                            <ul class="tree-list">
                                @foreach (var bloco in Model.AllBlocos)
                                {
                                    <li class="tree-item d-flex align-items-center gap-2 py-2">
                                        <span class="tree-badge tree-badge-bloco"><i class='bx bx-cube' style="font-size:.7rem;"></i></span>
                                        <span class="tree-label">🧱 @bloco.Name</span>
                                        <small class="text-muted ms-auto">@(bloco.School?.Name ?? "—")</small>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Tab: Salas flat list -->
                        <div class="tab-pane fade" id="tabSalas">
                            <ul class="tree-list">
                                @foreach (var sala in Model.AllSalas)
                                {
                                    <li class="tree-item d-flex align-items-center gap-2 py-2">
                                        <span class="tree-badge tree-badge-sala"><i class='bx bx-door-open' style="font-size:.7rem;"></i></span>
                                        <span class="tree-label">🚪 @sala.Name</span>
                                        <small class="text-muted ms-auto">@(sala.Block?.Name ?? "—")</small>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Notifications Card -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid #71dd37;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:#71dd37;">
                                <span style="font-size: 1.5rem;">💬</span>
                            </div>
                            <h6 class="mb-0 fw-bold">Mensagens</h6>
                        </div>
                        <p class="pending-big-number">@Model.TotalUnreadMessages<span style="font-size:1rem;color:#71dd37;"> novas</span></p>
                        <p class="pending-subtitle">mensagens no chat aguardam resposta</p>

                        @if (Model.RecentMessageSenders.Any())
                        {
                            <div class="pending-avatar-stack mb-3">
                                @foreach (var u in Model.RecentMessageSenders)
                                {
                                    <a asp-page="/Profile" asp-route-id="@u.Id" class="pending-avatar" title="@u.Username" style="border: 2px solid #fff; text-decoration:none;">
                                        @if (!string.IsNullOrEmpty(u.ProfilePhotoPath))
                                        {
                                            <img src="@u.ProfilePhotoPath" alt="Avatar" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
                                        }
                                        else
                                        {
                                            @(u.Username?.Substring(0, Math.Min(2, u.Username.Length)).ToUpper())
                                        }
                                    </a>
                                }
                            </div>
                        }
                    </div>
                    <a href="/Admin/Chat" class="btn w-100" style="background:#71dd37;color: var(--bs-heading-color);">
                        <i class='bx bx-reply me-1'></i> Responder
                    </a>
                </div>
            </div>
        </div>

        <!-- Pending Account Requests Card -->
        <div class="col-lg-4">
            <div class="card pending-card h-100" style="border-left: 5px solid var(--asnet-pink);">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="stat-icon" style="background:var(--asnet-pink);">
                                <span style="font-size: 1.5rem;">📝</span>
                            </div>
                            <h6 class="mb-0 fw-bold">Pedidos Pendentes</h6>
                        </div>
                        <p class="pending-big-number">@Model.PendingUsers.Count<span style="font-size:1rem;color:var(--asnet-orange);"> novos</span></p>
                        <p class="pending-subtitle">pedidos de registo aguardam aprovação</p>

                        @if (Model.PendingUsers.Any())
                        {
                            <div class="pending-avatar-stack mb-3">
                                @foreach (var u in Model.PendingUsers.Take(5))
                                {
                                    <div class="pending-avatar" title="@u.Username">
                                        @(u.Username?.Substring(0, Math.Min(2, u.Username.Length)).ToUpper())
                                    </div>
                                }
                                @if (Model.PendingUsers.Count > 5)
                                {
                                    <div class="pending-avatar" style="background:var(--asnet-orange);">+@(Model.PendingUsers.Count - 5)</div>
                                }
                            </div>
                        }
                    </div>
                    <button class="btn w-100" style="background:var(--asnet-pink);color: var(--bs-heading-color);" data-bs-toggle="modal" data-bs-target="#modalPending">
                        <i class='bx bx-list-ul me-1'></i> Ver pedidos
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Maintenance Tickets Row ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-teal);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <h5 class="mb-0"><i class='bx bx-wrench me-2'></i>Tickets de Manutenção Recentes</h5>
                    <a href="/Admin/Tickets" class="btn btn-sm btn-outline-info">Gerir Todos</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Equipamento / Escola</th>
                                    <th>Técnico Responsável</th>
                                    <th>Estado / Data</th>
                                    <th>Prioridade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentMaintenanceTickets == null || !Model.RecentMaintenanceTickets.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">Nenhum ticket de manutenção recente.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var t in Model.RecentMaintenanceTickets.Take(3))
                                    {
                                        <tr>
                                            <td><span class="badge bg-label-secondary">#@t.Id</span></td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                         @{ var type = t.Equipamento?.Type ?? ""; var name = t.Equipamento?.Name ?? ""; var emoji = type switch {
                                                             var s when s.Contains("Monitor") => "🖥️",
                                                             var s when s.Contains("Computador") || s.Contains("Desktop") || s.Contains("Portátil") || s.Contains("PC") => "💻",
                                                             var s when s.Contains("Impressora") => "🖨️",
                                                             var s when s.Contains("Rede") || s.Contains("Network") || s.Contains("Switch") || s.Contains("Router") => "🌐",
                                                             var s when s.Contains("Projetor") => "📽️",
                                                             var s when s.Contains("Rato") || s.Contains("Mouse") => "🖱️",
                                                             var s when s.Contains("Teclado") || s.Contains("Keyboard") => "⌨️",
                                                             var s when s.Contains("Servidor") || s.Contains("Server") => "🗄️",
                                                             var s when s.Contains("UPS") || s.Contains("Bateria") => "🔋",
                                                             var s when s.Contains("Som") || s.Contains("Coluna") || s.Contains("Speaker") => "🔊",
                                                             var s when s.Contains("Câmara") || s.Contains("Camera") => "📷",
                                                             _ => name.Contains("Monitor") ? "🖥️" : (name.Contains("Computador") ? "💻" : (name.Contains("Impressora") ? "🖨️" : "🔧"))
                                                         };
                                                     }
                                                     <span class="fw-bold">@emoji @t.Equipamento?.Name</span>
                                                    <small class="text-muted small">
                                                        @(t.Equipamento?.Brand ?? "Genérico") @(t.Equipamento?.Model ?? "")
                                                        @if (!string.IsNullOrEmpty(t.Equipamento?.SerialNumber))
                                                        {
                                                            <span class="ms-1">(S/N: @t.Equipamento.SerialNumber)</span>
                                                        }
                                                    </small>
                                                    <small class="text-muted text-truncate" style="max-width: 200px;">@t.School?.Name</small>
                                                </div>
                                            </td>
                                            <td>
                                                @if (t.Technician != null)
                                                {
                                                    <a asp-page="/Profile" asp-route-id="@t.Technician.Id" class="d-flex align-items-center text-body">
                                                        <div class="avatar avatar-xs me-2">
                                                            <span class="avatar-initial rounded-circle bg-label-primary" style="font-size: 0.6rem;">@(t.Technician.Username?.Substring(0, 1).ToUpper())</span>
                                                        </div>
                                                        <span class="fw-medium">@t.Technician.Username</span>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-warning small italic"><i class="bx bx-error-circle me-1"></i>A aguardar...</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    @{
                                                        var statusClass = t.Status switch {
                                                            "Pendente" or "Pedido" or "Aberto" => "bg-label-warning",
                                                            "Aceite" => "bg-label-primary",
                                                            "Em reparação" or "Em Reparação" or "Em Resolução" or "Em andamento" => "bg-label-info",
                                                            "Concluído" => "bg-label-success",
                                                            _ => "bg-label-secondary"
                                                        };
                                                        var statusText = (t.Status == "Pedido" || t.Status == "Pendente" || t.Status == "Aberto") ? "Pendente" : t.Status;
                                                    }
                                                    <span class="badge @statusClass mb-1" style="width:fit-content; font-size: 0.65rem;">@statusText</span>
                                                    <small class="text-muted">@t.CreatedAt.ToString("dd/MM/yyyy")</small>
                                                </div>
                                            </td>
                                            <td>
                                                @{
                                                    var prioClass = t.Level switch {
                                                        "Alto" or "Extremo" => "text-danger",
                                                        "Médio" => "text-warning",
                                                        _ => "text-info"
                                                    };
                                                }
                                                <span class="@prioClass fw-bold"><i class="bx bxs-circle me-1" style="font-size: 0.6rem;"></i> @t.Level</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Escalated Stock Requests Row ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card tree-card h-100" style="border-left: 5px solid #ffab00;">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <h5 class="mb-0"><i class='bx bx-package me-2'></i>Pedidos de Stock Pendentes</h5>
                    <a href="/Admin/Stocks" class="btn btn-sm btn-outline-warning">Ver Todos</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Solicitante</th>
                                    <th>Pedido / Descrição</th>
                                    <th>Estado</th>
                                    <th>Data</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.TechnicianStockRequests == null || !Model.TechnicianStockRequests.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">Nenhum pedido de stock pendente.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var t in Model.TechnicianStockRequests.Take(10))
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @{
                                                        var requesterName = t.Technician?.Username ?? t.RequestedBy?.Username ?? "Utilizador";
                                                        var requesterRole = t.Technician != null ? "Técnico" : "Cliente";
                                                    }
                                                    <a asp-page="/Profile" asp-route-id="@(t.Technician?.Id ?? t.RequestedBy?.Id)" class="d-flex flex-column text-body">
                                                        <span class="fw-semibold">@requesterName</span>
                                                        <small class="text-muted" style="font-size:0.7rem;">@requesterRole</small>
                                                    </a>
                                                </div>
                                            </td>
                                            <td>
                                                <small class="text-muted">@(t.Description ?? "Sem descrição")</small>
                                            </td>
                                            <td><span class="badge bg-label-warning">@t.Status</span></td>
                                            <td><small>@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small></td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <form method="post" action="/Admin/Stocks?handler=ApproveLoanRequest" class="m-0 p-0" onsubmit="return confirm('Deseja alocar equipamento(s) automaticamente para este pedido?');">
                                                        <input type="hidden" name="ticketId" value="@t.Id" />
                                                        <button type="submit" class="btn btn-sm btn-success p-1" title="Aceitar Automático">
                                                            <i class="bx bx-check"></i>
                                                        </button>
                                                    </form>
                                                    <form method="post" action="/Admin/Stocks?handler=RejectLoanRequest" class="m-0 p-0" onsubmit="return confirm('Tem certeza que deseja recusar este pedido?');">
                                                        <input type="hidden" name="ticketId" value="@t.Id" />
                                                        <button type="submit" class="btn btn-sm btn-danger p-1" title="Recusar">
                                                            <i class="bx bx-x"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card tree-card h-100" style="border-left: 5px solid var(--asnet-blue);">
                <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                    <h5 class="mb-0"><i class='bx bx-git-branch me-2'></i>Pedidos Escalados (Stock Global)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Agrupamento / Escola</th>
                                    <th>Artigo Solicitado</th>
                                    <th>Qtd</th>
                                    <th>Justificação Diretor</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.EscalatedRequests == null || !Model.EscalatedRequests.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">Nenhum pedido escalado pendente.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var r in Model.EscalatedRequests)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="fw-bold">@r.Agrupamento?.Name</span>
                                                    <small class="text-muted">@r.School?.Name</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="text-primary fw-semibold">@r.ItemName</span>
                                                    <small class="badge bg-label-secondary" style="width:fit-content;">@r.ItemType</small>
                                                </div>
                                            </td>
                                            <td><span class="badge bg-secondary">@r.Quantity</span></td>
                                            <td><small class="text-muted italic">@(string.IsNullOrEmpty(r.DirectorNotes) ? "Sem notas" : r.DirectorNotes)</small></td>
                                            <td>
                                                @if (r.Status == "Atendido")
                                                {
                                                    <span class="badge bg-label-success px-3">
                                                        <i class="ri-checkbox-circle-line me-1"></i> Emprestado
                                                    </span>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-sm btn-primary" onclick="openAdminFulfillModal(@r.Id, '@r.ItemType', @r.Quantity, '@r.ItemName', '@(r.School?.Name ?? r.Agrupamento?.Name)')">
                                                        Atender
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Admin Fulfill -->
    <div class="modal fade" id="modalAdminFulfill" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post" id="adminFulfillForm">
                    <input type="hidden" name="requestId" id="adminFulfillRequestId" />
                    <div class="modal-header bg-primary py-3">
                        <h5 class="modal-title   fw-bold" style="color: var(--bs-heading-color) !important;"><i class='bx bx-package me-2'></i>Atendimento Global: <span id="adminFulfillItemDisplay"></span></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="alert alert-info border-0 shadow-none mb-4">
                            <i class='bx bx-info-circle me-1'></i> Pedido de <strong><span id="adminFulfillQuantityDisplay"></span></strong> unidade(s) escalado para o Admin.
                        </div>

                        <h6 class="fw-bold mb-2">Stock Global Disponível</h6>
                        <div class="table-responsive border rounded mb-4" style="max-height: 250px;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;"><input type="checkbox" onclick="toggleAdminAllStock(this)" /></th>
                                        <th>Nome</th>
                                        <th>Tipo</th>
                                        <th>Localização Atual</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.GlobalStock)
                                    {
                                        <tr class="admin-stock-row" data-type="@s.Type">
                                            <td>
                                                <input type="checkbox" name="selectedStockIds" value="@s.Id" class="admin-stock-checkbox" />
                                            </td>
                                            <td>@s.EquipmentName</td>
                                            <td><span class="badge bg-label-secondary">@s.Type</span></td>
                                            <td><small>@(s.Agrupamento?.Name ?? "Stock Global")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold">Notas do Administrador</label>
                            <textarea name="adminNotes" class="form-control" rows="2" placeholder="Notas finais..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer bg-light d-flex justify-content-between">
                        <button type="submit" asp-page-handler="RejectEscalatedRequest" class="btn btn-outline-danger">Recusar</button>
                        <button type="submit" asp-page-handler="FulfillEscalatedRequest" class="btn btn-success px-4 fw-bold">Confirmar Atendimento</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ===== Low Stock Alerts Row ===== -->
    @if (Model.LowStockItems.Any())
    {
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card shadow-sm" style="border-left: 5px solid #ffab00;">
                    <div class="card-header d-flex align-items-center justify-content-between bg-transparent border-bottom">
                        <div class="d-flex align-items-center gap-2">
                            <span style="font-size: 1.5rem;">⚠️</span>
                            <h5 class="mb-0 fw-bold">Alertas de Stock Baixo</h5>
                        </div>
                        <a href="/Admin/Stocks" class="btn btn-xs btn-outline-warning">Gerir Stock</a>
                    </div>
                    <div class="card-body">
                        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                            @foreach (var item in Model.LowStockItems)
                            {
                                <div class="col">
                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light">
                                        <div class="d-flex align-items-center gap-2">
                                            @{
                                                var lowerName = item.Name?.ToLower() ?? "";
                                                var stockEmoji = lowerName switch {
                                                    var s when s.Contains("monitor") => "🖥️",
                                                    var s when s.Contains("portátil") || s.Contains("laptop") => "💻",
                                                    var s when s.Contains("ups") || s.Contains("bateria") => "🔋",
                                                    var s when s.Contains("quadro") || s.Contains("interativo") => "📺",
                                                    var s when s.Contains("impressora") => "🖨️",
                                                    var s when s.Contains("rato") || s.Contains("mouse") => "🖱️",
                                                    var s when s.Contains("teclado") => "⌨️",
                                                    var s when s.Contains("cabo") || s.Contains("rede") => "🌐",
                                                    _ => "📦"
                                                };
                                            }
                                            <div class="stat-icon bg-warning" style="width: 32px; height: 32px; font-size: 1.2rem; display: flex; align-items: center; justify-content: center;">
                                                @stockEmoji
                                            </div>
                                            <span class="fw-semibold text-dark">@item.Name</span>
                                        </div>
                                        <span class="badge bg-label-danger">@item.AvailableCount disponíveis</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-4 mb-4">
        <!-- Ticket Status Chart -->
        <div class="col-lg-7">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-support' style="color:var(--asnet-blue);"></i>
                    Tendência de Tickets (Últimos 6 meses)
                </div>
                <div class="card-body">
                    <div style="height: 250px; position: relative;">
                        <canvas id="ticketStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <!-- Donut Chart -->
        <div class="col-lg-5">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-pie-chart-alt-2' style="color:var(--asnet-orange);"></i>
                    Resumo de Alertas
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div style="height: 250px; width: 100%; position: relative;">
                        <canvas id="donutChart"></canvas>
                    </div>
                    <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                        <span><i class='bx bxs-circle' style="color:#ffab00;font-size:.6rem;"></i> Contratos</span>
                        <span><i class='bx bxs-circle' style="color:#ff3e1d;font-size:.6rem;"></i> Tickets</span>
                        <span><i class='bx bxs-circle' style="color:#f89223;font-size:.6rem;"></i> Stock</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Secondary Charts ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card chart-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-buildings' style="color:var(--asnet-teal);"></i>
                    Distribuição de Equipamentos por Escola
                </div>
                <div class="card-body">
                    <div style="height: 300px; position: relative;">
                        <canvas id="schoolEquipChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Map Row ===== -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card map-card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class='bx bx-map-pin' style="color:#f89223;"></i>
                    Localização dos Clientes
                </div>
                <div class="card-body p-0">
                    <div id="clientMap" style="height: 400px; width: 100%; border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== Modal: Pending Users Table ===== -->
<div class="modal fade" id="modalPending" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;overflow:hidden;">
            <div class="modal-header" style="background:var(--asnet-navy);color: var(--bs-heading-color);">
                <h5 class="modal-title">Aprovações de Conta Pendentes</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Estado</th>
                                <th>Data</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.PendingUsers.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">Nenhum pedido pendente.</td>
                                </tr>
                            }
                            @foreach (AspnetCoreStarter.Models.User user in Model.PendingUsers)
                            {
                                <tr>
                                    <td><strong>@user.Username</strong></td>
                                    <td>@user.Email</td>
                                    <td><span class="badge" style="background:var(--asnet-orange);color: var(--bs-heading-color);">@user.AccountStatus</span></td>
                                    <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-column gap-2">
                                            <form method="post" asp-page-handler="ProcessApproval" asp-route-id="@user.Id">
                                                <div class="mb-2">
                                                    <select name="role" class="form-select form-select-sm role-selector" onchange="toggleRoleOptions(this, @user.Id)" required>
                                                        <option value="">Cargo...</option>
                                                        <option value="Tecnico">Técnico</option>
                                                        <option value="Diretor">Diretor</option>
                                                        <option value="Coordenador">Coordenador</option>
                                                        <option value="Professor">Professor</option>
                                                        <option value="Cliente Individual">Cliente Individual</option>
                                                    </select>
                                                </div>
                                                
                                                <!-- Dynamic Fields Container -->
                                                <div id="roleFields_@user.Id" class="mb-2" style="display:none;">
                                                    <!-- Diretor: Agrupamento -->
                                                    <div class="field-Diretor" style="display:none;">
                                                        <select name="agrupamentoId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Agrupamento...</option>
                                                            @foreach (var agrup in Model.Agrupamentos) {
                                                                <option value="@agrup.Id">@agrup.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    
                                                    <!-- Tecnico: Area e Nivel -->
                                                    <div class="field-Tecnico" style="display:none;">
                                                        <label class="form-label mb-1 small fw-bold">Áreas Técnicas (Selecione múltiplas):</label>
                                                        <div class="d-flex flex-column gap-1 mb-2 p-2 border rounded bg-label-secondary" style="max-height: 200px; overflow-y: auto;">
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Redes" id="checkRedes_@user.Id">
                                                                <label class="form-check-label small" for="checkRedes_@user.Id">Redes</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Segurança" id="checkSeguranca_@user.Id">
                                                                <label class="form-check-label small" for="checkSeguranca_@user.Id">Segurança</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Infraestrutura" id="checkInfra_@user.Id">
                                                                <label class="form-check-label small" for="checkInfra_@user.Id">Infraestrutura</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Sistemas" id="checkSistemas_@user.Id">
                                                                <label class="form-check-label small" for="checkSistemas_@user.Id">Sistemas</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Telecomunicações" id="checkTele_@user.Id">
                                                                <label class="form-check-label small" for="checkTele_@user.Id">Telecomunicações</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Manutenção" id="checkManut_@user.Id">
                                                                <label class="form-check-label small" for="checkManut_@user.Id">Manutenção</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Consultoria Técnica" id="checkConsul_@user.Id">
                                                                <label class="form-check-label small" for="checkConsul_@user.Id">Consultoria</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" name="areaTecnica" value="Vendas" id="checkVendas_@user.Id">
                                                                <label class="form-check-label small" for="checkVendas_@user.Id">Vendas</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" id="checkOutros_@user.Id" onchange="toggleOthersInput(@user.Id)">
                                                                <label class="form-check-label small" for="checkOutros_@user.Id">Outros</label>
                                                            </div>
                                                        </div>
                                                        
                                                        <input type="text" name="areaTecnicaOutros" id="inputOutros_@user.Id" class="form-control form-control-sm mb-2" placeholder="Descreva outra área..." style="display:none;">

                                                        <select name="nivel" class="form-select form-select-sm">
                                                            <option value="">Nível...</option>
                                                            <option value="estagiário">estagiário</option>
                                                            <option value="Júnior">Júnior</option>
                                                            <option value="médio">médio</option>
                                                            <option value="sénior">sénior</option>
                                                            <option value="master">master</option>
                                                        </select>
                                                    </div>
                                                    
                                                    <!-- Coordenador: Escola -->
                                                    <div class="field-Coordenador" style="display:none;">
                                                        <select name="escolaId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Escola...</option>
                                                            @foreach (var school in Model.AllSchools) {
                                                                <option value="@school.Id">@school.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    
                                                    <!-- Professor: Bloco -->
                                                    <div class="field-Professor" style="display:none;">
                                                        <select name="blocoId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Bloco...</option>
                                                            @foreach (var bloco in Model.AllBlocos) {
                                                                <option value="@bloco.Id">@bloco.Name (@bloco.School?.Name)</option>
                                                            }
                                                        </select>
                                                    </div>

                                                    <!-- Cliente Individual: Empresa -->
                                                    <div class="field-Cliente-Individual" style="display:none;">
                                                        <select name="empresaId" class="form-select form-select-sm">
                                                            <option value="">Selecionar Empresa...</option>
                                                            @foreach (var emp in Model.Empresas) {
                                                                <option value="@emp.Id">@emp.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="d-flex gap-2">
                                                    <button type="submit" id="btnApprove_@user.Id" class="btn btn-sm btn-success flex-grow-1" disabled>Aceitar</button>
                                                </div>
                                            </form>
                                            <form method="post" asp-page-handler="Reject" asp-route-id="@user.Id">
                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Recusar</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // ===== Tree toggle =====
    function toggleTree(el) {
        el.classList.toggle('open');
        var children = el.parentElement.querySelector('.tree-children');
        if (children) children.classList.toggle('show');
    }

    function openAdminFulfillModal(id, type, qty, itemName, schoolName) {
        document.getElementById('adminFulfillRequestId').value = id;
        document.getElementById('adminFulfillItemDisplay').innerText = itemName;
        document.getElementById('adminFulfillQuantityDisplay').innerText = qty;

        // Auto-select
        const checkboxes = document.querySelectorAll('.admin-stock-checkbox');
        let selectedCount = 0;
        checkboxes.forEach(cb => {
            const row = cb.closest('.admin-stock-row');
            if (row.getAttribute('data-type') === type && selectedCount < qty) {
                cb.checked = true;
                selectedCount++;
            } else {
                cb.checked = false;
            }
        });

        new bootstrap.Modal(document.getElementById('modalAdminFulfill')).show();
    }

    function toggleAdminAllStock(el) {
        document.querySelectorAll('.admin-stock-checkbox').forEach(cb => cb.checked = el.checked);
    }

    // ===== Ticket Status Chart (Line) — Trend over last 6 months =====
    const ticketCtx = document.getElementById('ticketStatusChart').getContext('2d');
    new Chart(ticketCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyLabels)),
            datasets: [
                {
                    label: 'Pendentes',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyPendentesData)),
                    borderColor: '#696cff',
                    backgroundColor: 'rgba(105, 108, 255, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: false
                },
                {
                    label: 'Em Resolução',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyEmResolucaoData)),
                    borderColor: '#ff3e1d',
                    backgroundColor: 'rgba(255, 62, 29, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: false
                },
                {
                    label: 'Concluídos',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyConcluidosData)),
                    borderColor: '#71dd37',
                    backgroundColor: 'rgba(113, 221, 55, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: false
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { 
                legend: { 
                    display: true, 
                    position: 'bottom',
                    labels: { boxWidth: 12, usePointStyle: true }
                } 
            },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== Bar Chart: Equipamentos por Escola =====
    const schoolCtx = document.getElementById('schoolEquipChart').getContext('2d');
    new Chart(schoolCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SchoolNames)),
            datasets: [{
                label: 'Equipamentos',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SchoolEquipmentCounts)),
                backgroundColor: '#696cff',
                borderRadius: 6,
                maxBarThickness: 30
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 5 } },
                x: { grid: { display: false } }
            }
        }
    });

    // ===== Bar Chart: System Overview =====
    const donutCtx = document.getElementById('donutChart').getContext('2d');
    new Chart(donutCtx, {
        type: 'bar',
        data: {
            labels: ['Contratos', 'Tickets', 'Stock'],
            datasets: [{
                label: 'Total',
                data: [@Model.ExpiringContractsCount, @Model.PendingTicketsCount, @Model.LowStockAlertsCount],
                backgroundColor: ['#ffab00', '#ff3e1d', '#f89223'],
                borderRadius: 6,
                maxBarThickness: 40
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,.04)' } },
                x: { grid: { display: false }, ticks: { font: { size: 11 } } }
            }
        }
    });

    // ===== Role toggles in Pending Modal =====
    function toggleRoleOptions(selectEl, userId) {
        const role = selectEl.value;
        const container = document.getElementById('roleFields_' + userId);
        const approveBtn = document.getElementById('btnApprove_' + userId);
        
        if (!role) {
            container.style.display = 'none';
            if (approveBtn) approveBtn.disabled = true;
            // Remove required from all potential sub-fields
            container.querySelectorAll('select, input').forEach(el => el.required = false);
            return;
        }

        if (approveBtn) approveBtn.disabled = false;
        container.style.display = 'block';
        
        // Hide all specific field groups and remove required
        container.querySelectorAll('[class^="field-"]').forEach(div => {
            div.style.display = 'none';
            div.querySelectorAll('select, input').forEach(el => el.required = false);
        });

        // Show the specific group and set required
        const targetDiv = container.querySelector('.field-' + (role === 'Cliente Individual' ? 'Cliente-Individual' : role));
        if (targetDiv) {
            targetDiv.style.display = 'block';
            // Only make selects required (since tecnico areas are checkboxes)
            targetDiv.querySelectorAll('select').forEach(el => el.required = true);
        }
    }

    function toggleOthersInput(userId) {
        const checkbox = document.getElementById('checkOutros_' + userId);
        const input = document.getElementById('inputOutros_' + userId);
        if (checkbox.checked) {
            input.style.display = 'block';
            input.focus();
        } else {
            input.style.display = 'none';
            input.value = '';
        }
    }
</script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        initMap();
    });

    async function initMap() {
        // Default center: Braga
        var map = L.map('clientMap').setView([41.5454, -8.4265], 10);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        // Define custom icons
        var greenIcon = new L.Icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        });

        var yellowIcon = new L.Icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-yellow.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        });

        var blueIcon = new L.Icon({
          iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-blue.png',
          shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41]
        });

        const geoCacheKey = 'asnet_geocache';
        let geoCache = {};
        try {
            geoCache = JSON.parse(localStorage.getItem(geoCacheKey) || '{}');
        } catch (e) { console.error('Cache parse error', e); }

        var locationsRaw = '@Html.Raw(Model.ClientLocationsJson)';
        if (locationsRaw) {
            var locations = JSON.parse(locationsRaw.replace(/&quot;/g, '"'));
            
            for (let i = 0; i < locations.length; i++) {
                const loc = locations[i];
                if (loc.address) {
                    const cacheEntry = geoCache[loc.address];
                    
                    if (cacheEntry && cacheEntry.lat && cacheEntry.lon) {
                        // Use cached coordinates immediately
                        addMarkerToMap(loc, cacheEntry.lat, cacheEntry.lon);
                    } else {
                        // Geocoding with delay to respect Nominatim's limit
                        try {
                            const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(loc.address + ", Portugal")}`);
                            const data = await response.json();
                            
                            if (data && data.length > 0) {
                                const result = data[0];
                                geoCache[loc.address] = { lat: result.lat, lon: result.lon };
                                localStorage.setItem(geoCacheKey, JSON.stringify(geoCache));
                                
                                addMarkerToMap(loc, result.lat, result.lon);
                            }
                        } catch (error) {
                            console.error('Geocoding error:', error);
                        }
                        // Only delay if we actually hit the API
                        await new Promise(resolve => setTimeout(resolve, 800));
                    }
                }
            }
        }

        function addMarkerToMap(loc, lat, lon) {
            let markerIcon = blueIcon;
            let statusLabel = "";
            
            if (loc.hasInProgress || loc.hasInProgress === "True" || loc.hasInProgress === true) {
                markerIcon = yellowIcon;
                statusLabel = "<br><span class='badge bg-label-warning mt-2'>Em Progresso</span>";
            } else if (loc.hasCompleted || loc.hasCompleted === "True" || loc.hasCompleted === true) {
                markerIcon = greenIcon;
                statusLabel = "<br><span class='badge bg-label-success mt-2'>Concluído</span>";
            } else if (loc.hasPending || loc.hasPending === "True" || loc.hasPending === true) {
                statusLabel = "<br><span class='badge bg-label-info mt-2'>Pendente</span>";
            }

            L.marker([lat, lon], {icon: markerIcon})
             .addTo(map)
             .bindPopup(`<b>${loc.name}</b><br>${loc.address}${statusLabel}`);
        }
    }
</script>
}



