    function updateBrandsModels() {
        var artigo = document.getElementById('regArtigo').value;
        var marcaSelect = document.getElementById('regMarca');
        var modeloSelect = document.getElementById('regModelo');

        marcaSelect.innerHTML = '<option value="">Selecione a marca...</option>';
        modeloSelect.innerHTML = '<option value="">Selecione o modelo...</option>';

        // Clear search inputs
        var marcaWrapper = marcaSelect.closest('.select-search-wrapper');
        if (marcaWrapper) marcaWrapper.querySelector('.select-search-input').value = '';
        var modeloWrapper = modeloSelect.closest('.select-search-wrapper');
        if (modeloWrapper) modeloWrapper.querySelector('.select-search-input').value = '';

        if (artigo && brandModelData[artigo]) {
            var brands = Object.keys(brandModelData[artigo]).sort();
            brands.forEach(function(brand) {
                marcaSelect.add(new Option(brand, brand));
            });
        }
    }

    function updateModels() {
        var artigo = document.getElementById('regArtigo').value;
        var marca = document.getElementById('regMarca').value;
        var modeloSelect = document.getElementById('regModelo');

        modeloSelect.innerHTML = '<option value="">Selecione o modelo...</option>';
        var modeloWrapper = modeloSelect.closest('.select-search-wrapper');
        if (modeloWrapper) modeloWrapper.querySelector('.select-search-input').value = '';

        if (artigo && marca && brandModelData[artigo] && brandModelData[artigo][marca]) {
            brandModelData[artigo][marca].forEach(function(model) {
                modeloSelect.add(new Option(model, model));
            });
        }
    }

    // Registration Modal Filters
    function regFilterEscolas() {
        const agrId = document.getElementById('regAgrupamento').value;
        const escSelect = document.getElementById('regEscola');
        const options = escSelect.querySelectorAll('option');

        escSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (agrId === "" || opt.getAttribute('data-agr') === agrId) ? 'block' : 'none';
        });
        regFilterBlocos();
    }

    function regFilterBlocos() {
        const escId = document.getElementById('regEscola').value;
        const blcSelect = document.getElementById('regBloco');
        const options = blcSelect.querySelectorAll('option');

        blcSelect.value = "";
        options.forEach(opt => {
            if (opt.value === "") return;
            opt.style.display = (escId === "" || opt.getAttribute('data-esc') === escId) ? 'block' : 'none';
        });
        regFilterSalas();
    }

    function regFilterSalas() {
