@page
@model AspnetCoreStarter.Pages.Admin.EquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Equipamentos";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Admin /</span> Equipamentos</h4>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Inventário de Equipamentos</h5>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEquipamento">Novo Equipamento</button>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Tipo</th>
                        <th>Nº Série</th>
                        <th>Localização (Sala)</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Equipments)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Type</td>
                            <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                            <td>@item.Room?.Name (@item.Room?.Block?.Name)</td>
                            <td>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza?');">
                                    <button type="submit" class="btn btn-sm text-danger"><i class='bx bx-trash'></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="modalEquipamento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Add" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registar Equipamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input type="text" asp-for="NewEquipment.Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <input type="text" asp-for="NewEquipment.Type" class="form-control" placeholder="ex: Portátil, Projetor" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nº Série</label>
                        <input type="text" asp-for="NewEquipment.SerialNumber" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Processador</label>
                        <input type="text" asp-for="NewEquipment.Processor" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Discos/Memória</label>
                        <input type="text" asp-for="NewEquipment.Storage" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sala</label>
                        <select asp-for="NewEquipment.RoomId" class="form-select" required>
                            @foreach (var sala in Model.Rooms)
                            {
                                <option value="@sala.Id">@sala.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>
