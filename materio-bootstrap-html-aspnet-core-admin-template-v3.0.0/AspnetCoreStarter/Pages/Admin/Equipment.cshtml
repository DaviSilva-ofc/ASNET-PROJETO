    // On modal open, restore visibility based on current selections
    document.addEventListener('DOMContentLoaded', function () {
        const prevModal = document.getElementById('modalFiltrosPreventivas');
        if (prevModal) {
            prevModal.addEventListener('show.bs.modal', function () {
                // Cascade based on currently selected values (from query string pre-fill)
                const agr = document.getElementById('prevFilterAgrupamento')?.value;
                const esc = document.getElementById('prevFilterEscola')?.value;
                const blc = document.getElementById('prevFilterBloco')?.value;

                if (agr) {
                    const escSel = document.getElementById('prevFilterEscola');
                    Array.from(escSel.options).forEach(opt => {
                        if (!opt.value) return;
                        opt.style.display = (opt.getAttribute('data-agr') === agr) ? '' : 'none';
                    });
                }
                if (esc) {
                    const blcSel = document.getElementById('prevFilterBloco');
                    Array.from(blcSel.options).forEach(opt => {
                        if (!opt.value) return;
                        opt.style.display = (opt.getAttribute('data-esc') === esc) ? '' : 'none';
                    });
                }
                if (blc) {
                    const salaSel = document.getElementById('prevFilterSala');
                    Array.from(salaSel.options).forEach(opt => {
                        if (!opt.value) return;
                        opt.style.display = (opt.getAttribute('data-blc') === blc) ? '' : 'none';
                    });
                }
            });
        }
    });

    // Slide-over: Verificação Preventiva
    function openChecklist(roomId, empId, artigo, locName, escName) {
        document.getElementById('checkRoomId').value = roomId || '';
        document.getElementById('checkEmpresaId').value = empId || '';
        document.getElementById('checkArtigo').value = artigo;
        document.getElementById('checkNotes').value = '';

        // Copy options from editTipo to anomaly select if not already done
        const anomalyTipo = document.getElementById('checkAnomalyTipo');
        const editTipo = document.getElementById('editTipo');
        if (anomalyTipo && editTipo && anomalyTipo.options.length <= 5) {
            Array.from(editTipo.options).forEach(opt => {
                if (!opt.value) return;
                const newOpt = new Option(opt.text, opt.value);
                newOpt.setAttribute('data-artigo', opt.getAttribute('data-artigo'));
                anomalyTipo.add(newOpt);
            });
        }

        // Anomaly fields pre-fill logic
        const anomalyArt = document.getElementById('checkAnomalyArtigo');
        const searchArt = (artigo || "").toLowerCase().trim();
        
        // Try to find the best matching option in the anomaly select
        let matchedValue = "";
        Array.from(anomalyArt.options).forEach(opt => {
            const optVal = opt.value.toLowerCase();
            // Match if exact, or if one starts with the other (to handle singular/plural like Computador vs Computadores)
            if (optVal && (optVal.includes(searchArt) || searchArt.includes(optVal.replace(/es$/,'').replace(/s$/,'')))) {
                matchedValue = opt.value;
            }
        });
        anomalyArt.value = matchedValue;
        
        document.getElementById('lblCheckArtigo').innerText = artigo;
        document.getElementById('lblCheckLocation').innerHTML = `<i class="ri-map-pin-line me-1 text-primary"></i>${locName} — ${escName}`;

        // Reset checkboxes
        document.querySelectorAll('#checklistSlideOver input[type=checkbox]').forEach(cb => cb.checked = false);

        // Show slide-over + backdrop
        const panel = document.getElementById('checklistSlideOver');
        const backdrop = document.getElementById('checklistBackdrop');
        backdrop.style.display = 'block';
        // Force reflow then animate
        requestAnimationFrame(() => { panel.style.right = '0px'; });
        document.body.style.overflow = 'hidden';

        // Initialize anomaly type filter
        updateCheckSpecificTypes();
    }

    function updateCheckSpecificTypes() {
        const artigo = document.getElementById('checkAnomalyArtigo').value;
        const divTipo = document.getElementById('divCheckAnomalyTipo');
        const tipoSelect = document.getElementById('checkAnomalyTipo');
        
        if (!artigo) {
            divTipo.style.display = 'none';
            tipoSelect.value = '';
            return;
        }

        divTipo.style.display = 'block';
        tipoSelect.value = "";
        
        let visibleCount = 0;
        Array.from(tipoSelect.options).forEach(opt => {
            if (!opt.value) return;
            const dataArt = opt.getAttribute('data-artigo');
            const match = (dataArt === artigo);
            opt.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        // If no specific types match, hide the div
        if (visibleCount === 0) divTipo.style.display = 'none';
    }

    function closeChecklist() {
        const panel = document.getElementById('checklistSlideOver');
        const backdrop = document.getElementById('checklistBackdrop');
        panel.style.right = '-480px';
        setTimeout(() => { backdrop.style.display = 'none'; }, 350);
        document.body.style.overflow = '';
    }

