@page
@model AspnetCoreStarter.Pages.Admin.EquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Equipamentos";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

@section PageStyles {
<style>
    /* Searchable select wrapper */
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
</style>
}
<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Admin /</span> Equipamentos</h4>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Inventário de Equipamentos</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    🔍 Filtros
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEquipamento">Novo Equipamento</button>
            </div>
        </div>
        @{
            var activeFilterText = "";
            if (Model.ActiveFilterRoom != null) activeFilterText = $"sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) activeFilterText = $"bloco: {Model.ActiveFilterBloco.Name}";
            else if (Model.ActiveFilterEscola != null) activeFilterText = $"escola: {Model.ActiveFilterEscola.Name}";
            else if (Model.ActiveFilterAgrupamento != null) activeFilterText = $"agrupamento: {Model.ActiveFilterAgrupamento.Name}";
        }
        @if (!string.IsNullOrEmpty(activeFilterText))
        {
            <div class="card-body">
                <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert">
                    <span>A visualizar equipamentos do <strong>@activeFilterText</strong></span>
                    <a asp-page="./Equipment" class="btn btn-sm btn-info border-1 border-white">Limpar Filtro</a>
                </div>
            </div>
        }
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th>Tipo</th>
                        <th>Nº Série</th>
                        <th>Localização (Sala)</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Equipments)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Type</td>
                            <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                            <td>@item.Room?.Name (@item.Room?.Block?.Name)</td>
                            <td>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza?');">
                                    <button type="submit" class="btn btn-sm text-danger"><i class='bx bx-trash'></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Novo Equipamento -->
    <div class="modal fade" id="modalEquipamento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Add" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registar Equipamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Artigo</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar artigo..." oninput="filterSelect(this, 'regArtigo')" />
                            <select name="NewEquipment.Name" id="regArtigo" class="form-select" required onchange="updateBrandsModels()">
                                <option value="">Selecione o artigo...</option>
                                <option value="Computadores">Computadores</option>
                                <option value="Monitores">Monitores</option>
                                <option value="Impressoras">Impressoras</option>
                                <option value="Networking">Networking</option>
                                <option value="Componentes">Componentes</option>
                                <option value="Periféricos">Periféricos</option>
                                <option value="Projetores">Projetores</option>
                                <option value="Quadros Interativos">Quadros Interativos</option>
                                <option value="Outros">Outros</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo Específico</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar tipo..." oninput="filterSelect(this, 'regTipo')" />
                            <select name="NewEquipment.Type" id="regTipo" class="form-select" required>
                                <option value="">Selecione o tipo...</option>
                                <option value="Desktop">Desktop</option>
                                <option value="Portátil">Portátil</option>
                                <option value="Monitor">Monitor</option>
                                <option value="Motherboard">Motherboard</option>
                                <option value="Disco HDD">Disco HDD</option>
                                <option value="Disco SSD">Disco SSD</option>
                                <option value="Memória RAM">Memória RAM</option>
                                <option value="Processador (CPU)">Processador (CPU)</option>
                                <option value="Placa Gráfica">Placa Gráfica</option>
                                <option value="Fonte Alimentação">Fonte Alimentação</option>
                                <option value="Teclado">Teclado</option>
                                <option value="Rato">Rato</option>
                                <option value="Impressora">Impressora</option>
                                <option value="Projetor">Projetor</option>
                                <option value="Router">Router</option>
                                <option value="Switch">Switch</option>
                                <option value="Access Point">Access Point</option>
                                <option value="Cabo/Adatador">Cabo/Adaptador</option>
                                <option value="Outro">Outro</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Marca</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar marca..." oninput="filterSelect(this, 'regMarca')" />
                                <select name="NewEquipment.Brand" id="regMarca" class="form-select" onchange="updateModels()">
                                    <option value="">Selecione a marca...</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Modelo</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar modelo..." oninput="filterSelect(this, 'regModelo')" />
                                <select name="NewEquipment.Model" id="regModelo" class="form-select">
                                    <option value="">Selecione o modelo...</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nº Série</label>
                        <input type="text" name="NewEquipment.SerialNumber" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Agrupamento</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar agrupamento..." oninput="filterSelect(this, 'regAgrupamento')" />
                            <select id="regAgrupamento" class="form-select" onchange="regFilterEscolas()">
                                <option value="">Selecione o agrupamento...</option>
                                @foreach (var agr in Model.AvailableAgrupamentos)
                                {
                                    <option value="@agr.Id">@agr.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Escola</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar escola..." oninput="filterSelect(this, 'regEscola')" />
                            <select id="regEscola" class="form-select" onchange="regFilterBlocos()">
                                <option value="">Selecione a escola...</option>
                                @foreach (var esc in Model.AvailableEscolas)
                                {
                                    <option value="@esc.Id" data-agr="@esc.AgrupamentoId">@esc.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bloco</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar bloco..." oninput="filterSelect(this, 'regBloco')" />
                            <select id="regBloco" class="form-select" onchange="regFilterSalas()">
                                <option value="">Selecione o bloco...</option>
                                @foreach (var blc in Model.AvailableBlocos)
                                {
                                    <option value="@blc.Id" data-esc="@blc.SchoolId">@blc.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sala</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar sala..." oninput="filterSelect(this, 'regSala')" />
                            <select id="regSala" name="NewEquipment.RoomId" class="form-select" required>
                                <option value="">Selecione a sala...</option>
                                @foreach (var sala in Model.Rooms)
                                {
                                    <option value="@sala.Id" data-blc="@sala.BlockId">@sala.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Filtros -->
    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="get" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Filtrar Equipamentos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                         <div class="col-12">
                            <label class="form-label">Artigo</label>
                            <select asp-for="FilterName" class="form-select select2">
                                <option value="">Qualquer Artigo</option>
                                @foreach (var name in Model.UniqueEquipmentNames)
                                {
                                    <option value="@name">@name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tipo</label>
                            <select asp-for="FilterType" class="form-select select2">
                                <option value="">Todos</option>
                                <option value="Desktop">Desktop</option>
                                <option value="Portátil">Portátil</option>
                                <option value="Monitor">Monitor</option>
                                <option value="Motherboard">Motherboard</option>
                                <option value="Disco HDD">Disco HDD</option>
                                <option value="Disco SSD">Disco SSD</option>
                                <option value="Memória RAM">Memória RAM</option>
                                <option value="Processador (CPU)">Processador (CPU)</option>
                                <option value="Teclado">Teclado</option>
                                <option value="Rato">Rato</option>
                                <option value="Impressora">Impressora</option>
                                <option value="Projetor">Projetor</option>
                                <option value="Router">Router</option>
                                <option value="Switch">Switch</option>
                                <option value="Outro">Outro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nº Série</label>
                            <input type="text" asp-for="FilterSerialNumber" class="form-control" />
                        </div>

                        <hr class="my-3">
                        <h6>Localização</h6>

                        <div class="col-12">
                            <label class="form-label">Agrupamento</label>
                            <select id="filterAgrupamento" asp-for="FilterAgrupamentoId" class="form-select" onchange="filterEscolas()">
                                <option value="">Todos</option>
                                @foreach (var agr in Model.AvailableAgrupamentos)
                                {
                                    <option value="@agr.Id">@agr.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Escola</label>
                            <select id="filterEscola" asp-for="FilterEscolaId" class="form-select" onchange="filterBlocos()">
                                <option value="">Todas</option>
                                @foreach (var esc in Model.AvailableEscolas)
                                {
                                    <option value="@esc.Id" data-agr="@esc.AgrupamentoId">@esc.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bloco</label>
                            <select id="filterBloco" asp-for="FilterBlocoId" class="form-select" onchange="filterSalas()">
                                <option value="">Todos</option>
                                @foreach (var blc in Model.AvailableBlocos)
                                {
                                    <option value="@blc.Id" data-esc="@blc.SchoolId">@blc.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sala</label>
                            <select id="filterSala" asp-for="FilterRoomId" class="form-select">
                                <option value="">Todas</option>
                                @foreach (var sala in Model.Rooms)
                                {
                                    <option value="@sala.Id" data-blc="@sala.BlockId">@sala.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="reset" class="btn btn-outline-secondary" onclick="window.location.href='@Url.Page("./Equipment")'">Limpar Tudo</button>
                    <button type="submit" class="btn btn-warning">🔍 Aplicar Filtros</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section VendorScripts {
    <script src="~/vendor/libs/select2/select2.dist.js"></script>
}

@section PageScripts {
<script>
    // Filter select options by search input
    function filterSelect(input, selectId) {
        var filter = input.value.toLowerCase();
        var select = document.getElementById(selectId);
        var options = select.querySelectorAll('option');
        options.forEach(function(opt) {
            var text = opt.textContent.toLowerCase();
            opt.style.display = text.includes(filter) ? '' : 'none';
        });
    }

    // Reset search inputs when a modal is closed
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize Select2 for filter fields
        if (typeof jQuery !== 'undefined' && typeof jQuery.fn.select2 !== 'undefined') {
            $('.select2').select2({
                dropdownParent: $('#modalFiltros'),
                width: '100%'
            });
        }

        document.querySelectorAll('.modal').forEach(function(modal) {
            modal.addEventListener('hidden.bs.modal', function() {
                modal.querySelectorAll('.select-search-input').forEach(function(inp) {
                    inp.value = '';
                    var wrapper = inp.closest('.select-search-wrapper');
                    if (wrapper) {
                        wrapper.querySelectorAll('select option').forEach(function(opt) {
                            opt.style.display = '';
                        });
                    }
                });
            });
        });
    });

