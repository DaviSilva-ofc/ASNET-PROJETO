    function updateScheduleButtonState() {
        const btn = document.getElementById('btnConfirmSchedule');
        const checkboxes = document.querySelectorAll('.school-checkbox');
        const isAnyChecked = Array.from(checkboxes).some(cb => cb.checked);
        
        if (btn) {
            btn.disabled = !isAnyChecked;
        }
    }

    // Initialize state when modal is shown
    document.addEventListener('DOMContentLoaded', function() {
        const scheduleModal = document.getElementById('modalScheduleMaintenance');
        if (scheduleModal) {
            scheduleModal.addEventListener('show.bs.modal', function() {
                updateScheduleButtonState();
            });
        }
    });
</script>

<partial name="Shared/_QrModal" />
}


