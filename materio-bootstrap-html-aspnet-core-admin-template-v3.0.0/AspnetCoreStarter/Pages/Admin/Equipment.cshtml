@page
@model AspnetCoreStarter.Pages.Admin.EquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Equipamentos";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

@section PageStyles {
<style>
    /* Searchable select wrapper */
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }

    /* Table Compression Styles */
    .table-compact th, 
    .table-compact td { 
        padding: 0.5rem 0.5rem !important; 
        font-size: 0.85rem;
    }
    .col-tipo { width: 100px; }
    .col-serie { width: 130px; }
    .col-status { width: 100px; }
    .col-acoes { min-width: 180px !important; }
</style>
}
<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Admin /</span> Equipamentos</h4>
    
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="ri-checkbox-circle-line me-1"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Alerta de Manutenção Preventiva não agendada -->
    @if (!Model.IsMaintenanceScheduledThisYear && Model.Tab == "preventive")
    {
        <div class="alert alert-warning alert-dismissible shadow-sm mb-4 d-flex align-items-center" role="alert" style="border-left: 4px solid #ffab00;">
            <i class="bx bx-error-circle fs-3 me-3 text-warning"></i>
            <div>
                <strong>Aviso:</strong> A Manutenção Preventiva Anual para o ano de @DateTime.Now.Year ainda não foi agendada.
                <button class="btn btn-sm btn-warning ms-2" data-bs-toggle="modal" data-bs-target="#modalScheduleMaintenance">Agendar Agora</button>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link @(Model.Tab != "preventive" ? "active" : "")" role="tab" data-bs-toggle="tab" data-bs-target="#navs-inventory" aria-controls="navs-inventory" aria-selected="@(Model.Tab != "preventive" ? "true" : "false")">
                    <i class="tf-icons ri-database-2-line me-1"></i> Inventário Geral
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(Model.Tab == "preventive" ? "active" : "")" role="tab" data-bs-toggle="tab" data-bs-target="#navs-preventive" aria-controls="navs-preventive" aria-selected="@(Model.Tab == "preventive" ? "true" : "false")">
                    <i class="tf-icons ri-shield-check-line me-1"></i> Reparações Preventivas Anuais
                </button>
            </li>
        </ul>
        <div class="tab-content">
            <!-- Tab: Inventário Geral -->
            <div class="tab-pane fade @(Model.Tab != "preventive" ? "show active" : "")" id="navs-inventory" role="tabpanel">

                <div class="card shadow-sm border-0">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Inventário de Equipamentos</h5>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                                🔍 Filtros
                            </button>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEquipamento">Novo Equipamento</button>
                        </div>
                    </div>
        @{
            var hasActiveFilters = !string.IsNullOrEmpty(Model.FilterName) || 
                                  !string.IsNullOrEmpty(Model.FilterType) || 
                                  !string.IsNullOrEmpty(Model.FilterBrand) || 
                                  !string.IsNullOrEmpty(Model.FilterModel) || 
                                  !string.IsNullOrEmpty(Model.FilterStatus) || 
                                  !string.IsNullOrEmpty(Model.FilterSerialNumber) ||
                                  Model.FilterAgrupamentoId.HasValue || 
                                  Model.FilterEscolaId.HasValue || 
                                  Model.FilterBlocoId.HasValue || 
                                  Model.FilterRoomId.HasValue || 
                                  Model.FilterEmpresaId.HasValue;

            var locationText = "";
            if (Model.ActiveFilterRoom != null) locationText = $"Sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) locationText = $"Bloco: {Model.ActiveFilterBloco.Name}";
            else if (Model.ActiveFilterEscola != null) locationText = $"Escola: {Model.ActiveFilterEscola.Name}";
            else if (Model.ActiveFilterAgrupamento != null) locationText = $"Agrupamento: {Model.ActiveFilterAgrupamento.Name}";
            else if (Model.ActiveFilterEmpresa != null) locationText = $"Empresa: {Model.ActiveFilterEmpresa.Name}";
        }

        @if (hasActiveFilters)
        {
            <div class="card-body">
                <div class="alert alert-info d-flex flex-wrap justify-content-between align-items-center mb-0 gap-2" role="alert">
                    <div class="d-flex flex-wrap align-items-center gap-1">
                        <i class="ri-filter-3-line me-1"></i>
                        <span>Filtros Ativos: </span>
                        @if (!string.IsNullOrEmpty(Model.FilterName)) { <span class="badge bg-label-info">Artigo: @Model.FilterName</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterType)) { <span class="badge bg-label-info">Tipo: @Model.FilterType</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterBrand)) { <span class="badge bg-label-info">Marca: @Model.FilterBrand</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterModel)) { <span class="badge bg-label-info">Modelo: @Model.FilterModel</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterStatus)) { <span class="badge bg-label-info">Status: @Model.FilterStatus</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterSerialNumber)) { <span class="badge bg-label-info">S/N: @Model.FilterSerialNumber</span> }
                        @if (!string.IsNullOrEmpty(locationText)) { <span class="badge bg-label-info">@locationText</span> }
                    </div>
                    <a asp-page="./Equipment" class="btn btn-sm btn-outline-secondary">Limpar Todos os Filtros</a>
                </div>
            </div>
        }
        <div class="table-responsive text-nowrap">
            <table class="table table-hover table-compact">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th class="col-tipo">Tipo</th>
                        <th class="col-serie">Nº Série</th>
                        <th>Localização (Sala)</th>
                        <th class="col-status">Status</th>
                        <th class="col-acoes">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Equipments)
                    {
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <strong style="color: var(--bs-heading-color);">@item.Name</strong>
                                    <small class="text-muted" style="font-size: 0.75rem;">
                                        @(item.Brand ?? "Genérico") @(item.Model ?? "")
                                    </small>
                                </div>
                            </td>
                            <td>@item.Type</td>
                            <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                            <td>
                                @if (item.Room != null)
                                {
                                    <span>@item.Room.Name (@item.Room.Block?.Name)</span>
                                }
                                else if (item.Empresa != null)
                                {
                                    <span class="text-warning"><i class="ri-building-4-line me-1"></i> @item.Empresa.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == "Avariado") {
                                    <span class="badge bg-label-danger">🛠️ Avariado</span>
                                } else if (item.Status == "Associado" || item.Status == "Armazenado") {
                                    <span class="badge bg-label-warning">@(item.Status == "Armazenado" ? "📦 Armazenado" : "🔗 Associado")</span>
                                } else if (item.Status == "Usado na Intervenção") {
                                    <span class="badge bg-label-info">📦 Usado na Intervenção</span>
                                } else {
                                    <span class="badge bg-label-success">@(item.Status == "A funcionar" || string.IsNullOrEmpty(item.Status) ? "✅ A funcionar" : "📦 " + item.Status)</span>
                                }
                            </td>
                            <td style="white-space: nowrap; width: 1%;">
                                <div class="d-flex align-items-center gap-1">
                                    @if (item.Status == null || (!item.Status.Contains("repara", StringComparison.OrdinalIgnoreCase) && !item.Status.Contains("manutenção", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <a asp-page="./Tickets" asp-route-eqId="@item.Id" class="btn btn-sm btn-icon text-primary p-0" title="Solicitar Ticket">
                                            ➕
                                        </a>
                                    }
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                        @if (item.Status == "Avariado" || item.Status == "Indisponível" || item.Status == "Danificado")
                                        {
                                            <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Marcar como Funcional">
                                                ✅
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Marcar como Avariado">
                                                ⚠️
                                            </button>
                                        }
                                    </form>
                                    <button type="button" class="border-0 bg-transparent p-1 lh-1" title="Código QR" 
                                            onclick="showQRCode('@item.Id', 'equip', '@(item.Name?.Replace("'", "\\'"))', '@(item.Room?.Name?.Replace("'", "\\'"))')">
                                        📱
                                    </button>
                                    <button type="button" class="border-0 bg-transparent p-1 lh-1" title="Editar"
                                            onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@item.Brand', '@item.Model', '@item.SerialNumber', '@item.RoomId', '@item.EmpresaId', '@item.Status')">
                                        ✏️
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?');" style="display:inline-block;">
                                        <button type="submit" class="border-0 bg-transparent p-1 lh-1" title="Eliminar">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                </table>
            </div> <!-- End table-responsive -->
        </div> <!-- End card -->
    </div> <!-- End Tab Pane Inventário Geral -->
            
            <!-- Tab: Reparações Preventivas Anuais -->
            <div class="tab-pane fade @(Model.Tab == "preventive" ? "show active" : "")" id="navs-preventive" role="tabpanel">
                <style>
                    .preventive-item-card {
                        background-color: rgba(67, 89, 113, 0.05);
                        transition: all 0.2s ease;
                    }
                    .dark-style .preventive-item-card,
                    [data-bs-theme="dark"] .preventive-item-card {
                        background-color: rgba(255, 255, 255, 0.05);
                        border-color: rgba(255, 255, 255, 0.1) !important;
                    }
                    .preventive-item-card:hover {
                        background-color: rgba(67, 89, 113, 0.08);
                    }
                    .dark-style .preventive-item-card:hover,
                    [data-bs-theme="dark"] .preventive-item-card:hover {
                        background-color: rgba(255, 255, 255, 0.1);
                    }
                    .school-header-toggle .ri-arrow-down-s-line {
                        transition: transform 0.3s ease;
                    }
                    .school-header-toggle.collapsed .ri-arrow-down-s-line {
                        transform: rotate(-90deg);
                    }
                </style>
                <div class="card shadow-sm border-0">
                    <div class="card-header d-flex flex-wrap justify-content-between align-items-center bg-transparent border-bottom gap-3">
                        <div>
                            <h5 class="mb-0 text-primary fw-bold"><i class="ri-git-merge-line me-2"></i> Reparações Preventivas Anuais</h5>
                            <small class="text-muted">Filtre por localização ou artigo para auditar as categorias pendentes.</small>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            @{
                                bool prevHasFilters = Model.FilterAgrupamentoId.HasValue || Model.FilterEscolaId.HasValue ||
                                                     Model.FilterBlocoId.HasValue || Model.FilterRoomId.HasValue ||
                                                     Model.FilterEmpresaId.HasValue || !string.IsNullOrEmpty(Model.FilterName);
                            }
                            @if (prevHasFilters)
                            {
                                <div class="d-flex flex-wrap gap-1 align-items-center">
                                    @if (Model.ActiveFilterAgrupamento != null) { <span class="badge bg-label-primary">@Model.ActiveFilterAgrupamento.Name</span> }
                                    @if (Model.ActiveFilterEscola != null)     { <span class="badge bg-label-warning">@Model.ActiveFilterEscola.Name</span> }
                                    @if (Model.ActiveFilterBloco != null)      { <span class="badge bg-label-info">@Model.ActiveFilterBloco.Name</span> }
                                    @if (Model.ActiveFilterRoom != null)       { <span class="badge bg-label-success">@Model.ActiveFilterRoom.Name</span> }
                                    @if (Model.ActiveFilterEmpresa != null)    { <span class="badge bg-label-danger">@Model.ActiveFilterEmpresa.Name</span> }
                                    @if (!string.IsNullOrEmpty(Model.FilterName)) { <span class="badge bg-label-secondary">@Model.FilterName</span> }
                                </div>
                            }
                            <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalFiltrosPreventivas">
                                <i class="ri-filter-3-line me-1"></i>Filtros
                                @if (prevHasFilters) { <span class="badge bg-primary ms-1">!</span> }
                            </button>
                            @if (Model.IsMaintenanceScheduledThisYear)
                            {
                                <span class="badge bg-label-success px-3 py-2">
                                    <i class="ri-calendar-check-line me-1"></i> @(Model.ScheduledMaintenanceDate?.ToString("dd/MM/yyyy"))
                                </span>
                                <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#modalScheduleMaintenance">Reagendar</button>
                            }
                        </div>
                    </div>

                    @if (prevHasFilters)
                    {
                        <div class="alert alert-info d-flex flex-wrap justify-content-between align-items-center mb-0 gap-2 rounded-0 border-0 border-bottom px-4 py-3" role="alert">
                            <div class="d-flex flex-wrap align-items-center gap-2">
                                <i class="ri-filter-3-line me-1"></i>
                                <span class="fw-semibold me-1">Filtros ativos:</span>
                                @if (Model.ActiveFilterAgrupamento != null)
                                {
                                    <span class="badge bg-primary"><i class="ri-community-line me-1"></i>@Model.ActiveFilterAgrupamento.Name</span>
                                }
                                @if (Model.ActiveFilterEscola != null)
                                {
                                    <span class="badge bg-warning text-dark"><i class="ri-building-4-line me-1"></i>@Model.ActiveFilterEscola.Name</span>
                                }
                                @if (Model.ActiveFilterBloco != null)
                                {
                                    <span class="badge bg-info text-dark"><i class="ri-building-line me-1"></i>@Model.ActiveFilterBloco.Name</span>
                                }
                                @if (Model.ActiveFilterRoom != null)
                                {
                                    <span class="badge bg-success"><i class="ri-door-open-line me-1"></i>@Model.ActiveFilterRoom.Name</span>
                                }
                                @if (Model.ActiveFilterEmpresa != null)
                                {
                                    <span class="badge bg-danger"><i class="ri-building-4-line me-1"></i>@Model.ActiveFilterEmpresa.Name</span>
                                }
                                @if (!string.IsNullOrEmpty(Model.FilterName))
                                {
                                    <span class="badge bg-secondary"><i class="ri-archive-line me-1"></i>@Model.FilterName</span>
                                }
                            </div>
                            <a href="?tab=preventive" class="btn btn-sm btn-outline-primary">
                                <i class="ri-close-circle-line me-1"></i>Limpar Filtros
                            </a>
                        </div>
                    }

                    <div class="card-body p-4 bg-light-section">
                        @{
                            // Pre-compute sets of IDs that have filtered equipment for fast lookup
                            var filteredRoomIds = Model.Equipments.Where(e => e.RoomId.HasValue).Select(e => e.RoomId.Value).ToHashSet();
                            var filteredBlocoIds = Model.Rooms.Where(r => filteredRoomIds.Contains(r.Id) && r.BlockId.HasValue).Select(r => r.BlockId.Value).ToHashSet();
                            var filteredEscolaIds = Model.AvailableBlocos.Where(b => filteredBlocoIds.Contains(b.Id)).Select(b => b.SchoolId).ToHashSet();
                            var filteredAgrupIds = Model.AvailableEscolas.Where(e => filteredEscolaIds.Contains(e.Id)).Select(e => e.AgrupamentoId).ToHashSet();
                        }
                        <!-- AGRUPAMENTOS & ESCOLAS -->
                        @foreach(var agrup in Model.AvailableAgrupamentos)
                        {
                            if (!filteredAgrupIds.Contains(agrup.Id)) continue;
                            var agrupSchools = Model.AvailableEscolas.Where(s => s.AgrupamentoId == agrup.Id && filteredEscolaIds.Contains(s.Id)).ToList();
                            if(!agrupSchools.Any()) continue;

                            <div class="mb-5">
                                <h4 class="fw-bold text-primary mb-4 border-bottom pb-2">
                                    <i class="ri-community-line me-2"></i>Agrupamento: @agrup.Name
                                </h4>
                                
                                @foreach(var esc in agrupSchools)
                                {
                                    var escBlocos = Model.AvailableBlocos.Where(b => b.SchoolId == esc.Id && filteredBlocoIds.Contains(b.Id)).ToList();
                                    if(!escBlocos.Any()) continue;
                                    
                                    <div class="card mb-4 shadow-sm border-0 school-container" data-school-name="@esc.Name">
                                        <div class="card-header bg-warning cursor-pointer school-header-toggle" data-bs-toggle="collapse" data-bs-target="#collapse-escola-@esc.Id" aria-expanded="true" style="background-color: #ff9800 !important; padding: 1rem 1.5rem;">
                                            <h5 class="mb-0 text-white d-flex justify-content-between align-items-center">
                                                <span><i class="ri-building-4-line me-2"></i>@esc.Name</span>
                                                <i class="ri-arrow-down-s-line fs-4"></i>
                                            </h5>
                                        </div>
                                        <div id="collapse-escola-@esc.Id" class="collapse show">
                                            <div class="card-body p-4 bg-body">
                                                <div class="row g-4">
                                                @foreach(var blc in escBlocos)
                                                {
                                                    var blcSalas = Model.Rooms.Where(r => r.BlockId == blc.Id && filteredRoomIds.Contains(r.Id)).ToList();
                                                    @foreach(var sala in blcSalas)
                                                    {
                                                        var equipNaSala = Model.Equipments.Where(e => e.RoomId == sala.Id).ToList();
                                                        if (!equipNaSala.Any()) continue;
                                                        var categorias = equipNaSala.GroupBy(e => e.Name ?? "Desconhecido").ToList();

                                                        <!-- Sala Card -->
                                                        <div class="col-md-6 col-lg-4 room-card" data-room-name="@sala.Name @blc.Name">
                                                            <div class="card h-100 border shadow-none" style="background-color: var(--bs-paper-bg);">
                                                                <div class="card-header border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                                                                    <h6 class="mb-0 text-info fw-bold"><i class="ri-door-open-line me-1"></i> @sala.Name</h6>
                                                                    <span class="badge bg-label-secondary">@blc.Name</span>
                                                                </div>
                                                                <div class="card-body p-3">
                                                                    <div class="d-flex flex-column gap-2">
                                                                        @foreach(var cat in categorias)
                                                                        {
                                                                            var count = cat.Count();
                                                                            var name = cat.Key;
                                                                            var needsVerification = Model.ScheduledMaintenanceDate == null || cat.Any(e => !e.LastMaintenanceDate.HasValue || e.LastMaintenanceDate.Value.Year < Model.ScheduledMaintenanceDate.Value.Year);

                                                                            <div class="d-flex justify-content-between align-items-center p-2 border rounded preventive-item-card preventive-item mb-2" data-item-name="@name">
                                                                                <div>
                                                                                    <span class="fw-semibold text-body d-block" style="font-size:0.9rem;">@name (@count)</span>
                                                                                    @if(needsVerification) {
                                                                                        <span class="badge bg-label-warning" style="font-size:0.65rem;">⚠️ Pendente</span>
                                                                                    } else {
                                                                                        <span class="badge bg-label-success" style="font-size:0.65rem;">✅ Verificado</span>
                                                                                    }
                                                                                </div>
                                                                                @if (needsVerification) {
                                                                                    <button class="btn btn-sm btn-primary py-1 px-2" onclick="openChecklist('@sala.Id', null, '@name', '@sala.Name', '@esc.Name')">Verificar</button>
                                                                                } else {
                                                                                    <button class="btn btn-sm btn-outline-secondary py-1 px-2" onclick="openChecklist('@sala.Id', null, '@name', '@sala.Name', '@esc.Name')">Revisitar</button>
                                                                                }
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <!-- EMPRESAS -->
                        @if(Model.AvailableEmpresas.Any())
                        {
                            <div class="mb-5 school-container" data-school-name="Clientes Privados">
                                <h4 class="fw-bold text-success mb-4 border-bottom pb-2">
                                    <i class="ri-building-line me-2"></i>Clientes Privados (Empresas)
                                </h4>
                                <div class="row g-4">
                                    @foreach(var emp in Model.AvailableEmpresas)
                                    {
                                        <div class="col-md-6 col-lg-4 room-card" data-room-name="@emp.Name">
                                            <div class="card h-100 shadow-sm border-0">
                                                <div class="card-header bg-success" style="background-color: #28a745 !important;">
                                                    <h6 class="mb-0 text-white"><i class="ri-building-4-line me-1"></i> @emp.Name</h6>
                                                </div>
                                                <div class="card-body p-3 bg-body">
                                                    @{
                                                        var equipNaEmpresa = Model.Equipments.Where(e => e.EmpresaId == emp.Id).ToList();
                                                        var categorias = equipNaEmpresa.GroupBy(e => e.Name ?? "Desconhecido").ToList();
                                                    }
                                                    @if (!categorias.Any())
                                                    {
                                                        <p class="text-muted small fst-italic mb-0 text-center py-3">Sem equipamentos registados.</p>
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex flex-column gap-2">
                                                            @foreach(var cat in categorias)
                                                            {
                                                                var count = cat.Count();
                                                                var name = cat.Key;
                                                                var needsVerification = Model.ScheduledMaintenanceDate == null || cat.Any(e => !e.LastMaintenanceDate.HasValue || e.LastMaintenanceDate.Value.Year < Model.ScheduledMaintenanceDate.Value.Year);

                                                                <div class="d-flex justify-content-between align-items-center p-2 border rounded preventive-item-card preventive-item mb-2" data-item-name="@name">
                                                                    <div>
                                                                        <span class="fw-semibold text-body d-block" style="font-size:0.9rem;">@name (@count)</span>
                                                                        @if(needsVerification) {
                                                                            <span class="badge bg-label-warning" style="font-size:0.65rem;">⚠️ Pendente</span>
                                                                        } else {
                                                                            <span class="badge bg-label-success" style="font-size:0.65rem;">✅ Verificado</span>
                                                                        }
                                                                    </div>
                                                                    @if (needsVerification) {
                                                                        <button class="btn btn-sm btn-primary py-1 px-2" onclick="openChecklist(null, '@emp.Id', '@name', '@emp.Name', 'Empresa')">Verificar</button>
                                                                    } else {
                                                                        <button class="btn btn-sm btn-outline-secondary py-1 px-2" onclick="openChecklist(null, '@emp.Id', '@name', '@emp.Name', 'Empresa')">Revisitar</button>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Script for collapsible school toggle icon update -->
                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        document.querySelectorAll('.school-header-toggle').forEach(function (btn) {
                            btn.addEventListener('click', function () {
                                btn.classList.toggle('collapsed');
                            });
                        });
                    });
                </script>
