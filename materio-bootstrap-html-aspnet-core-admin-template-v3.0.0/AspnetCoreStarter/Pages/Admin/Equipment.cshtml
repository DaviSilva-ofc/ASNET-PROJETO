    @* Modal Schedule Maintenance *@
    <div class="modal fade" id="modalScheduleMaintenance" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-md modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" asp-page-handler="ScheduleMaintenance">
                    <div class="modal-header bg-warning">
                        <h5 class="modal-title text-white"><i class="ri-calendar-event-line me-2"></i>Agendar Manutenção Preventiva</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <p class="text-muted small mb-4">Agende uma ronda de manutenção preventiva. Isto criará tickets automáticos para os locais selecionados.</p>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Data Planeada</label>
                            <input type="date" name="scheduledDate" class="form-control" required value="@(Model.ScheduledMaintenanceDate?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Técnico Responsável (Opcional)</label>
                            <select name="technicianId" class="form-select">
                                <option value="">-- Deixar em aberto (Qualquer técnico pode aceitar) --</option>
                                @foreach (var tech in Model.Technicians)
                                {
                                    <option value="@tech.Id">@tech.Username</option>
                                }
                            </select>
                            <div class="form-text">Se não selecionar um técnico, o agendamento aparecerá como "Disponível" para todos.</div>
                        </div>

                        <div class="mb-0">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-bold mb-0">Locais / Escolas</label>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary btn-xs py-1 px-2" style="font-size: 0.75rem;" onclick="selectAllSchools()">Selecionar tudo</button>
                                    <button type="button" class="btn btn-outline-secondary btn-xs py-1 px-2" style="font-size: 0.75rem;" onclick="deselectAllSchools()">Desmarcar tudo</button>
                                </div>
                            </div>
                            <div class="border rounded p-3" id="schoolChecklistContainer" style="max-height: 200px; overflow-y: auto; background: rgba(67,89,113,0.02);">
                                @foreach (var escola in Model.AvailableEscolas.OrderBy(e => e.Name))
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input school-checkbox" type="checkbox" name="schoolIds" value="@escola.Id" id="sch_@escola.Id" checked onchange="updateScheduleButtonState()">
                                        <label class="form-check-label" for="sch_@escola.Id">
                                            @escola.Name
                                        </label>
                                    </div>
                                }
                            </div>
                            <div class="form-text">Selecione as escolas que devem ser incluídas nesta ronda.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" id="btnConfirmSchedule" class="btn btn-warning shadow-sm">
                            <i class="ri-calendar-check-line me-1"></i>Confirmar Agendamento
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Slide-over: Verificação Preventiva -->
    <div id="checklistSlideOver" style="
        position: fixed; top: 0; right: -500px; width: 500px; height: 100vh;
        background: var(--bs-body-bg, #fff); color: var(--bs-body-color); z-index: 2000;
        box-shadow: -8px 0 40px rgba(0,0,0,0.4);
        transition: right 0.4s cubic-bezier(.25,.8,.25,1);
        display: flex; flex-direction: column; overflow: hidden;
    ">
        <form method="post" asp-page-handler="SubmitPreventiveChecklist" style="display:flex;flex-direction:column;height:100%;">
            <input type="hidden" name="roomId" id="checkRoomId" />
            <input type="hidden" name="empresaId" id="checkEmpresaId" />
            <input type="hidden" name="artigo" id="checkArtigo" />

            <!-- Header -->
            <div style="background: #f1f5f9; padding: 1.5rem 2rem; flex-shrink:0; border-left: 5px solid #696cff; border-bottom: 1px solid rgba(67, 89, 113, 0.1);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-primary small mb-1 uppercase fw-bold" style="letter-spacing: 1.5px; font-size: 0.7rem;"><i class="ri-shield-check-line me-1"></i>AUDITORIA PREVENTIVA</div>
                        <h3 class="text-dark fw-bold mb-1" id="lblCheckArtigo" style="font-size: 1.4rem;">—</h3>
                        <div class="text-muted" id="lblCheckLocation" style="font-size:0.9rem;"><i class="ri-map-pin-line me-1 text-primary"></i>—</div>
                    </div>
                    <button type="button" onclick="closeChecklist()" class="btn btn-icon btn-outline-secondary" style="border-radius:12px; width:42px; height:42px; transition: all 0.2s;">
                        <i class="ri-close-line fs-3"></i>
                    </button>
                </div>
            </div>

            <!-- Body -->
            <div style="flex:1; overflow-y:auto; padding:2rem; background: var(--bs-body-bg);">

                <!-- Info Alert -->
                <div class="alert d-flex align-items-start gap-3 py-3 mb-4" style="background: rgba(105, 108, 255, 0.08); border: 1px solid rgba(105, 108, 255, 0.2); color: var(--bs-primary); border-radius: 12px;">
                    <i class="ri-information-fill fs-3 mt-1"></i>
                    <span style="font-size: 0.88rem; line-height: 1.4;">Ao confirmar, a data de verificação de <strong>todos</strong> os equipamentos desta categoria no local será atualizada para o ciclo atual.</span>
                </div>

                <!-- Checklist Section -->
                <div class="mb-5">
                    <h6 class="fw-bold mb-3 d-flex align-items-center text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px; color: var(--bs-secondary);"><i class="ri-list-check-2 me-2 text-primary fs-5"></i>Checklist de Verificação</h6>
                    <div class="d-flex flex-column gap-2">
                        @foreach(var item in new[] {
                            ("chk_estado",   "ri-computer-line",      "Estado físico (Danos/Riscos)"),
                            ("chk_func",     "ri-settings-3-line",   "Funcionamento e Boot"),
                            ("chk_cabos",    "ri-plug-line",         "Cablagem e Conexões"),
                            ("chk_limpeza",  "ri-sparkling-line",    "Limpeza (Pó e Resíduos)"),
                            ("chk_perif",    "ri-mouse-line",        "Periféricos Associados"),
                            ("chk_software", "ri-apps-2-line",       "Software e Atualizações"),
                            ("chk_etiqueta", "ri-price-tag-3-line",  "Etiqueta de Inventário")
                        })
                        {
                            <label class="d-flex align-items-center gap-3 p-3 border rounded cursor-pointer preventive-check-item transition-all" style="background: var(--bs-card-bg); border-color: rgba(67,89,113,0.12) !important; border-radius: 10px;">
                                <input type="checkbox" name="checklistItems" value="@item.Item1" class="form-check-input mt-0" style="width:1.3rem; height:1.3rem;" />
                                <div class="d-flex align-items-center justify-content-center bg-label-primary rounded-circle" style="width:34px; height:34px; flex-shrink:0;">
                                    <i class="@item.Item2 fs-5"></i>
                                </div>
                                <span style="font-size:0.92rem; font-weight: 500;">@item.Item3</span>
                            </label>
                        }
                    </div>
                </div>

                <hr class="my-5" style="opacity: 0.1; border-top: 2px dashed var(--bs-border-color);">

                <!-- Anomaly Section -->
                <div class="p-4 rounded-3 border mb-4" style="background: rgba(255, 171, 0, 0.04); border-color: rgba(255, 171, 0, 0.15) !important;">
                    <h6 class="fw-bold mb-4 text-warning d-flex align-items-center text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="ri-error-warning-line me-2 fs-5"></i>Reportar Avaria (Ticket)</h6>
                    
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-body">Artigo</label>
                            <select name="AnomalyArticle" id="checkAnomalyArtigo" class="form-select" onchange="updateCheckSpecificTypes()">
                                <option value="">Nenhuma avaria detetada</option>
                                <option value="Computadores">Computadores</option>
                                <option value="Monitores">Monitores</option>
                                <option value="Impressoras">Impressoras</option>
                                <option value="Networking">Networking</option>
                                <option value="Servidores/Infra">Servidores/Infra</option>
                                <option value="Componentes">Componentes</option>
                                <option value="Periféricos">Periféricos</option>
                                <option value="Projetores">Projetores</option>
                                <option value="Quadros Interativos">Quadros Interativos</option>
                                <option value="Outros">Outros</option>
                            </select>
                        </div>

                        <div class="col-12" id="divCheckAnomalyTipo" style="display:none;">
                            <label class="form-label small fw-bold text-body">Tipo Específico</label>
                            <select name="AnomalyType" id="checkAnomalyTipo" class="form-select">
                                <option value="">Selecione o tipo específico...</option>
                                <!-- Preenchido dinamicamente -->
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-body">Descrição Detalhada</label>
                            <textarea name="notes" id="checkNotes" class="form-control" rows="4"
                                placeholder="Descreva o que foi encontrado..."
                                style="font-size:0.9rem; background: var(--bs-body-bg); border-radius: 8px;"></textarea>
                        </div>
                    </div>
                    
                    <div class="mt-3 d-flex align-items-center gap-2 text-warning" style="font-size:0.8rem; font-weight: 500;">
                        <i class="ri-ticket-2-line fs-5"></i>
                        <span>Um Ticket será gerado automaticamente para a equipa técnica.</span>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div style="padding:1.5rem 2rem; border-top:1px solid rgba(67,89,113,0.1); background: var(--bs-card-bg); flex-shrink:0;">
                <div class="d-flex gap-3">
                    <button type="button" onclick="closeChecklist()" class="btn btn-label-secondary btn-lg flex-grow-1">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-lg flex-grow-1 shadow-sm">
                        <i class="ri-check-double-line me-1"></i>Concluir Auditoria
                    </button>
                </div>
            </div>
        </form>
    </div>
