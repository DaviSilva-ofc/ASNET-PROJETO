        document.querySelectorAll('.preventive-check-item').forEach(function (label) {
            var cb = label.querySelector('input[type=checkbox]');
            if (!cb) return;
            cb.addEventListener('change', function () {
                if (this.checked) {
                    label.style.background = 'rgba(105, 108, 255, 0.08)';
                    label.style.borderColor = '#696cff';
                } else {
                    label.style.background = 'var(--bs-card-bg)';
                    label.style.borderColor = 'rgba(67,89,113,0.1)';
                }
            });
        });
    });

