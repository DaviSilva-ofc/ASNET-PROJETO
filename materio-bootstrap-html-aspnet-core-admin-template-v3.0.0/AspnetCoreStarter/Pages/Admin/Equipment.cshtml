@page
@model AspnetCoreStarter.Pages.Admin.EquipmentModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Equipamentos";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

@section PageStyles {
<style>
    /* Searchable select wrapper */
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }

    /* Table Compression Styles */
    .table-compact th, 
    .table-compact td { 
        padding: 0.5rem 0.5rem !important; 
        font-size: 0.85rem;
    }
    .col-tipo { width: 100px; }
    .col-serie { width: 130px; }
    .col-status { width: 100px; }
    .col-acoes { min-width: 180px !important; }
</style>
}
<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Admin /</span> Equipamentos</h4>
    
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="ri-checkbox-circle-line me-1"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Inventário de Equipamentos</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                    🔍 Filtros
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEquipamento">Novo Equipamento</button>
            </div>
        </div>
        @{
            var hasActiveFilters = !string.IsNullOrEmpty(Model.FilterName) || 
                                  !string.IsNullOrEmpty(Model.FilterType) || 
                                  !string.IsNullOrEmpty(Model.FilterBrand) || 
                                  !string.IsNullOrEmpty(Model.FilterModel) || 
                                  !string.IsNullOrEmpty(Model.FilterStatus) || 
                                  !string.IsNullOrEmpty(Model.FilterSerialNumber) ||
                                  Model.FilterAgrupamentoId.HasValue || 
                                  Model.FilterEscolaId.HasValue || 
                                  Model.FilterBlocoId.HasValue || 
                                  Model.FilterRoomId.HasValue || 
                                  Model.FilterEmpresaId.HasValue;

            var locationText = "";
            if (Model.ActiveFilterRoom != null) locationText = $"Sala: {Model.ActiveFilterRoom.Name}";
            else if (Model.ActiveFilterBloco != null) locationText = $"Bloco: {Model.ActiveFilterBloco.Name}";
            else if (Model.ActiveFilterEscola != null) locationText = $"Escola: {Model.ActiveFilterEscola.Name}";
            else if (Model.ActiveFilterAgrupamento != null) locationText = $"Agrupamento: {Model.ActiveFilterAgrupamento.Name}";
            else if (Model.ActiveFilterEmpresa != null) locationText = $"Empresa: {Model.ActiveFilterEmpresa.Name}";
        }

        @if (hasActiveFilters)
        {
            <div class="card-body">
                <div class="alert alert-info d-flex flex-wrap justify-content-between align-items-center mb-0 gap-2" role="alert">
                    <div class="d-flex flex-wrap align-items-center gap-1">
                        <i class="ri-filter-3-line me-1"></i>
                        <span>Filtros Ativos: </span>
                        @if (!string.IsNullOrEmpty(Model.FilterName)) { <span class="badge bg-label-info">Artigo: @Model.FilterName</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterType)) { <span class="badge bg-label-info">Tipo: @Model.FilterType</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterBrand)) { <span class="badge bg-label-info">Marca: @Model.FilterBrand</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterModel)) { <span class="badge bg-label-info">Modelo: @Model.FilterModel</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterStatus)) { <span class="badge bg-label-info">Status: @Model.FilterStatus</span> }
                        @if (!string.IsNullOrEmpty(Model.FilterSerialNumber)) { <span class="badge bg-label-info">S/N: @Model.FilterSerialNumber</span> }
                        @if (!string.IsNullOrEmpty(locationText)) { <span class="badge bg-label-info">@locationText</span> }
                    </div>
                    <a asp-page="./Equipment" class="btn btn-sm btn-outline-secondary">Limpar Todos os Filtros</a>
                </div>
            </div>
        }
        <div class="table-responsive text-nowrap">
            <table class="table table-hover table-compact">
                <thead>
                    <tr>
                        <th>Artigo</th>
                        <th class="col-tipo">Tipo</th>
                        <th class="col-serie">Nº Série</th>
                        <th>Localização (Sala)</th>
                        <th class="col-status">Status</th>
                        <th class="col-acoes">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Equipments)
                    {
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <strong class="text-dark">@item.Name</strong>
                                    <small class="text-muted" style="font-size: 0.75rem;">
                                        @(item.Brand ?? "Genérico") @(item.Model ?? "")
                                    </small>
                                </div>
                            </td>
                            <td>@item.Type</td>
                            <td><span class="badge bg-label-secondary">@item.SerialNumber</span></td>
                            <td>
                                @if (item.Room != null)
                                {
                                    <span>@item.Room.Name (@item.Room.Block?.Name)</span>
                                }
                                else if (item.Empresa != null)
                                {
                                    <span class="text-warning"><i class="ri-building-4-line me-1"></i> @item.Empresa.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == "Avariado") {
                                    <span class="badge bg-label-danger">Avariado</span>
                                } else if (item.Status == "Associado") {
                                    <span class="badge bg-label-warning">Associado (Em Intervenção)</span>
                                } else {
                                    <span class="badge bg-label-success">@(item.Status == "Funcionando" || string.IsNullOrEmpty(item.Status) ? "A funcionar" : item.Status)</span>
                                }
                            </td>
                            <td style="white-space: nowrap; width: 1%;">
                                <div class="d-flex align-items-center gap-1">
                                    @if (item.Status == null || (!item.Status.Contains("repara", StringComparison.OrdinalIgnoreCase) && !item.Status.Contains("manutenção", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <a asp-page="./Tickets" asp-route-eqId="@item.Id" class="btn btn-sm btn-icon text-primary p-0" title="Solicitar Ticket">
                                            <i class="ri-add-circle-line"></i>
                                        </a>
                                    }
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline-block;">
                                        @if (item.Status == "Avariado" || item.Status == "Indisponível" || item.Status == "Danificado")
                                        {
                                            <button type="submit" class="btn btn-sm btn-icon text-success p-0" title="Marcar como Funcional">
                                                <i class="ri-check-line"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-icon text-warning p-0" title="Marcar como Avariado">
                                                <i class="ri-error-warning-line"></i>
                                            </button>
                                        }
                                    </form>
                                    <button type="button" class="btn btn-sm btn-icon text-info p-0" title="Código QR" 
                                            onclick="showQRCode('@item.Id', 'equip', '@(item.Name?.Replace("'", "\\'"))', '@(item.Room?.Name?.Replace("'", "\\'"))')">
                                        <i class="ri-qr-code-line"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon text-primary p-0" title="Editar"
                                            onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@item.Brand', '@item.Model', '@item.SerialNumber', '@item.RoomId', '@item.EmpresaId', '@item.Status')">
                                        <i class="ri-edit-line"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Tem a certeza que deseja eliminar este equipamento?');" style="display:inline-block;">
                                        <button type="submit" class="btn btn-sm btn-icon text-danger p-0" title="Eliminar">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


    @* Modal Editar Equipamento *@
    <div class="modal fade" id="modalEditarEquipamento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <form method="post" asp-page-handler="Edit">
                    <input type="hidden" asp-for="NewEquipment.Id" id="editId" />
                    <input type="hidden" asp-for="LocationType" id="editLocationType" value="escola" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bx bx-edit me-2"></i>Editar Equipamento</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Artigo</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar artigo..." onkeyup="filterSelect(this, 'editArtigo')">
                                    <select asp-for="NewEquipment.Name" id="editArtigo" class="form-select" required onchange="updateBrandsModels('edit'); updateSpecificTypes('edit');">
                                        <option value="">Selecione...</option>
                                        <option value="Computadores">Computadores</option>
                                        <option value="Monitores">Monitores</option>
                                        <option value="Impressoras">Impressoras</option>
                                        <option value="Networking">Networking</option>
                                        <option value="Servidores/Infra">Servidores/Infra</option>
                                        <option value="Componentes">Componentes</option>
                                        <option value="Periféricos">Periféricos</option>
                                        <option value="Projetores">Projetores</option>
                                        <option value="Quadros Interativos">Quadros Interativos</option>
                                        <option value="Outros">Outros</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tipo Específico</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar tipo..." onkeyup="filterSelect(this, 'editTipo')">
                                    <select asp-for="NewEquipment.Type" id="editTipo" class="form-select" required>
                                        <option value="">Selecione o artigo primeiro...</option>
                                        <!-- Computadores -->
                                        <option value="Desktop" data-artigo="Computadores">Desktop</option>
                                        <option value="Portátil" data-artigo="Computadores">Portátil</option>
                                        <option value="AIO" data-artigo="Computadores">AIO</option>
                                        <option value="Laptop" data-artigo="Computadores">Laptop</option>
                                        <!-- Monitores -->
                                        <option value="Monitor" data-artigo="Monitores">Monitor</option>
                                        <option value="Televisão" data-artigo="Monitores">Televisão</option>
                                        <option value="TV" data-artigo="Monitores">TV</option>
                                        <!-- Impressoras -->
                                        <option value="Impressora" data-artigo="Impressoras">Impressora</option>
                                        <!-- Networking -->
                                        <option value="Router" data-artigo="Networking">Router</option>
                                        <option value="Switch" data-artigo="Networking">Switch</option>
                                        <option value="Access Point" data-artigo="Networking">Access Point</option>
                                        <option value="Firewall" data-artigo="Networking">Firewall</option>
                                        <!-- Servidores/Infra -->
                                        <option value="Servidor" data-artigo="Servidores/Infra">Servidor</option>
                                        <option value="Storage" data-artigo="Servidores/Infra">Storage</option>
                                        <option value="NAS" data-artigo="Servidores/Infra">NAS</option>
                                        <!-- Componentes -->
                                        <option value="Motherboard" data-artigo="Componentes">Motherboard</option>
                                        <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
                                        <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
                                        <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
                                        <option value="Processador (CPU)" data-artigo="Componentes">Processador (CPU)</option>
                                        <option value="Placa Gráfica" data-artigo="Componentes">Placa Gráfica</option>
                                        <option value="Fonte Alimentação" data-artigo="Componentes">Fonte Alimentação</option>
                                        <!-- Periféricos -->
                                        <option value="Teclado" data-artigo="Periféricos">Teclado</option>
                                        <option value="Rato" data-artigo="Periféricos">Rato</option>
                                        <option value="Headphones" data-artigo="Periféricos">Headphones</option>
                                        <option value="Colunas" data-artigo="Periféricos">Colunas</option>
                                        <!-- Projetores -->
                                        <option value="Projetor" data-artigo="Projetores">Projetor</option>
                                        <!-- Quadros Interativos -->
                                        <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
                                        <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
                                        <!-- Outros -->
                                        <option value="Cabo/Adaptador" data-artigo="Outros">Cabo/Adaptador</option>
                                        <option value="Outro" data-artigo="Outros">Outro</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Marca</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar marca..." onkeyup="filterSelect(this, 'editMarca')">
                                    <select asp-for="NewEquipment.Brand" id="editMarca" class="form-select" required onchange="updateModels('edit')">
                                        <option value="">Selecione...</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Modelo</label>
                                <div class="select-search-wrapper">
                                    <input type="text" class="select-search-input" placeholder="Pesquisar modelo..." onkeyup="filterSelect(this, 'editModelo')">
                                    <select asp-for="NewEquipment.Model" id="editModelo" class="form-select" required>
                                        <option value="">Selecione a marca primeiro...</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Nº Série</label>
                                <input type="text" asp-for="NewEquipment.SerialNumber" id="editSerial" class="form-control" required />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Sala (Opcional se for Empresa)</label>
                                <select asp-for="NewEquipment.RoomId" id="editSala" class="form-select">
                                    <option value="">Nenhuma / Empresa</option>
                                    @foreach (var sala in Model.Rooms)
                                    {
                                        <option value="@sala.Id">@sala.Name (@(sala.Block?.Name ?? "N/A"))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Estado do Equipamento</label>
                                <select asp-for="NewEquipment.Status" id="editStatus" class="form-select" required>
                                    <option value="A funcionar">A funcionar</option>
                                    <option value="Armazenado">Armazenado</option>
                                    <option value="Avariado">Avariado</option>
                                    <option value="Indisponível">Indisponível</option>
                                    <option value="Em Reparação">Em Reparação</option>
                                </select>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Empresa (Opcional se for Sala)</label>
                                <select asp-for="NewEquipment.EmpresaId" id="editEmpresa" class="form-select">
                                    <option value="">Nenhuma / Escola</option>
                                    @foreach (var emp in Model.AvailableEmpresas)
                                    {
                                        <option value="@emp.Id">@emp.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Novo Equipamento -->
    <div class="modal fade" id="modalEquipamento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Add" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registar Equipamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Artigo</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar artigo..." oninput="filterSelect(this, 'regArtigo')" />
                            <select name="NewEquipment.Name" id="regArtigo" class="form-select" required onchange="updateBrandsModels(); updateSpecificTypes();">
                                <option value="">Selecione o artigo...</option>
                                <option value="Computadores">Computadores</option>
                                <option value="Monitores">Monitores</option>
                                <option value="Impressoras">Impressoras</option>
                                <option value="Networking">Networking</option>
                                <option value="Servidores/Infra">Servidores/Infra</option>
                                <option value="Componentes">Componentes</option>
                                <option value="Periféricos">Periféricos</option>
                                <option value="Projetores">Projetores</option>
                                <option value="Quadros Interativos">Quadros Interativos</option>
                                <option value="Outros">Outros</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo Específico</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar tipo..." oninput="filterSelect(this, 'regTipo')" />
                            <select name="NewEquipment.Type" id="regTipo" class="form-select" required>
                                <option value="">Selecione o tipo...</option>
                                <!-- Computadores -->
                                <option value="Desktop" data-artigo="Computadores">Desktop</option>
                                <option value="Portátil" data-artigo="Computadores">Portátil</option>
                                <option value="AIO" data-artigo="Computadores">AIO</option>
                                <option value="Laptop" data-artigo="Computadores">Laptop</option>
                                <!-- Monitores -->
                                <option value="Monitor" data-artigo="Monitores">Monitor</option>
                                <option value="Televisão" data-artigo="Monitores">Televisão</option>
                                <option value="TV" data-artigo="Monitores">TV</option>
                                <!-- Impressoras -->
                                <option value="Impressora" data-artigo="Impressoras">Impressora</option>
                                <!-- Networking -->
                                <option value="Router" data-artigo="Networking">Router</option>
                                <option value="Switch" data-artigo="Networking">Switch</option>
                                <option value="Access Point" data-artigo="Networking">Access Point</option>
                                <option value="Firewall" data-artigo="Networking">Firewall</option>
                                <!-- Servidores/Infra -->
                                <option value="Servidor" data-artigo="Servidores/Infra">Servidor</option>
                                <option value="Storage" data-artigo="Servidores/Infra">Storage</option>
                                <option value="NAS" data-artigo="Servidores/Infra">NAS</option>
                                <!-- Componentes -->
                                <option value="Motherboard" data-artigo="Componentes">Motherboard</option>
                                <option value="Disco HDD" data-artigo="Componentes">Disco HDD</option>
                                <option value="Disco SSD" data-artigo="Componentes">Disco SSD</option>
                                <option value="Memória RAM" data-artigo="Componentes">Memória RAM</option>
                                <option value="Processador (CPU)" data-artigo="Componentes">Processador (CPU)</option>
                                <option value="Placa Gráfica" data-artigo="Componentes">Placa Gráfica</option>
                                <option value="Fonte Alimentação" data-artigo="Componentes">Fonte Alimentação</option>
                                <!-- Periféricos -->
                                <option value="Teclado" data-artigo="Periféricos">Teclado</option>
                                <option value="Rato" data-artigo="Periféricos">Rato</option>
                                <option value="Headphones" data-artigo="Periféricos">Headphones</option>
                                <option value="Colunas" data-artigo="Periféricos">Colunas</option>
                                <!-- Projetores -->
                                <option value="Projetor" data-artigo="Projetores">Projetor</option>
                                <!-- Quadros Interativos -->
                                <option value="Quadro Interativo" data-artigo="Quadros Interativos">Quadro Interativo</option>
                                <option value="Mesa Interativa" data-artigo="Quadros Interativos">Mesa Interativa</option>
                                <!-- Outros -->
                                <option value="Cabo/Adaptador" data-artigo="Outros">Cabo/Adaptador</option>
                                <option value="Outro" data-artigo="Outros">Outro</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Marca</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar marca..." oninput="filterSelect(this, 'regMarca')" />
                                <select name="NewEquipment.Brand" id="regMarca" class="form-select" onchange="updateModels()">
                                    <option value="">Selecione a marca...</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Modelo</label>
                            <div class="select-search-wrapper">
                                <input type="text" class="select-search-input" placeholder="Pesquisar modelo..." oninput="filterSelect(this, 'regModelo')" />
                                <select name="NewEquipment.Model" id="regModelo" class="form-select">
                                    <option value="">Selecione o modelo...</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nº Série</label>
                        <input type="text" name="NewEquipment.SerialNumber" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-primary fw-bold">Estado Inicial</label>
                        <select name="NewEquipment.Status" class="form-select border-primary" required>
                            <option value="A funcionar" selected>A funcionar</option>
                            <option value="Armazenado">Armazenado (Stock)</option>
                            <option value="Avariado">Avariado</option>
                        </select>
                    </div>
                    <!-- Location Type Toggle -->
                    <div class="mb-3">
                        <label class="form-label">Tipo de Localização</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="locToggle" id="locEscola" value="escola" checked autocomplete="off" onchange="toggleLocationType()">
                            <label class="btn btn-outline-primary" for="locEscola"><i class="ri-school-line me-1"></i> Escola / Sala</label>
                            <input type="radio" class="btn-check" name="locToggle" id="locEmpresa" value="empresa" autocomplete="off" onchange="toggleLocationType()">
                            <label class="btn btn-outline-warning" for="locEmpresa"><i class="ri-building-4-line me-1"></i> Empresa</label>
                        </div>
                        <input type="hidden" asp-for="LocationType" id="hdnLocationType" value="escola" />
                    </div>

                    <!-- Escola/Sala Location Fields -->
                    <div id="divLocEscola">
