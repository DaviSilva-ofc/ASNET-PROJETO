    function updateSpecificTypes(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const tipoSelect = document.getElementById(prefix + 'Tipo');
        const options = tipoSelect.querySelectorAll('option');

        tipoSelect.value = "";
        
        // Trigger filterSelect to update display based on BOTH artigo AND any current search
        const wrapper = tipoSelect.closest('.select-search-wrapper');
        const searchInput = wrapper ? wrapper.querySelector('.select-search-input') : null;
        filterSelect(searchInput, prefix + 'Tipo');
    }

    function updateBrandsModels(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const marcaSelect = document.getElementById(prefix + 'Marca');
        const modeloSelect = document.getElementById(prefix + 'Modelo');
        const tipoSelect = document.getElementById(prefix + 'Tipo');
        const isFilter = (prefix === 'filter');

        marcaSelect.innerHTML = isFilter ? '<option value="">Todas</option>' : '<option value="">Selecione a marca...</option>';
        modeloSelect.innerHTML = isFilter ? '<option value="">Todos</option>' : '<option value="">Selecione o modelo...</option>';

        // Filter specific types in the dropdown
        if (tipoSelect) {
            Array.from(tipoSelect.options).forEach(opt => {
                if (opt.value === "") {
                    if (isFilter) opt.textContent = "Todos";
                    return;
                }
                const dataArt = opt.getAttribute('data-artigo');
                opt.style.display = (!artigo || !dataArt || dataArt === artigo) ? 'block' : 'none';
            });
        }

        // Clear search inputs
        var marcaWrapper = marcaSelect.closest('.select-search-wrapper');
        if (marcaWrapper) marcaWrapper.querySelector('.select-search-input').value = '';
        var modeloWrapper = modeloSelect.closest('.select-search-wrapper');
        if (modeloWrapper) modeloWrapper.querySelector('.select-search-input').value = '';

        if (artigo && brandModelData[artigo]) {
            var brands = Object.keys(brandModelData[artigo]).sort();
            brands.forEach(function(brand) {
                marcaSelect.add(new Option(brand, brand));
            });
        }

        if (window.jQuery && jQuery.fn.select2) {
            $(marcaSelect).trigger('change.select2');
            $(modeloSelect).trigger('change.select2');
            if (tipoSelect) $(tipoSelect).trigger('change.select2');
        }
    }

    function updateModels(prefix = 'reg') {
        const artigo = document.getElementById(prefix + 'Artigo').value;
        const marca = document.getElementById(prefix + 'Marca').value;
        const modeloSelect = document.getElementById(prefix + 'Modelo');
        const isFilter = (prefix === 'filter');

        modeloSelect.innerHTML = isFilter ? '<option value="">Todos</option>' : '<option value="">Selecione o modelo...</option>';
        var modeloWrapper = modeloSelect.closest('.select-search-wrapper');
        if (modeloWrapper) modeloWrapper.querySelector('.select-search-input').value = '';

        if (artigo && marca && brandModelData[artigo] && brandModelData[artigo][marca]) {
            brandModelData[artigo][marca].forEach(function(model) {
                modeloSelect.add(new Option(model, model));
            });
        }

        if (window.jQuery && jQuery.fn.select2) {
            $(modeloSelect).trigger('change.select2');
        }
    }

    function filterModalTypesByArticle() {
        const artSelect = document.getElementById('filterArtigo');
        const typeSelect = document.getElementById('filterTipo');
        if (!artSelect || !typeSelect) return;

        const artigo = (artSelect.value || "").trim();
        const selectedType = typeSelect.value;

        Array.from(typeSelect.options).forEach(opt => {
            if (opt.value === "") return;
            const dataArt = (opt.getAttribute('data-artigo') || "").trim();
            const allowed = !artigo || dataArt === artigo;
            opt.hidden = !allowed;
            opt.disabled = !allowed;
            opt.style.display = allowed ? '' : 'none';
        });

        if (selectedType) {
            const selectedOpt = Array.from(typeSelect.options).find(o => o.value === selectedType);
            if (!selectedOpt || selectedOpt.disabled) typeSelect.value = "";
        }

        if (window.jQuery && jQuery.fn.select2) {
            $('#filterTipo').trigger('change.select2');
        }
    }

    function openEditModal(id, name, type, brand, model, serial, roomId, empId, status) {
        document.getElementById('editId').value = id;
        
        // Set Artigo with normalization
        const artSelect = document.getElementById('editArtigo');
        const cleanName = (name || '').toLowerCase().trim();
        
        // Try to find a matching option (case insensitive)
        let matchingOpt = Array.from(artSelect.options).find(o => o.value.toLowerCase().trim() === cleanName);
        
        // Specific normalization rules
        if (!matchingOpt) {
            if (cleanName === 'computador') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Computadores');
            else if (cleanName === 'monitor' || cleanName === 'televisão' || cleanName === 'tv') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Monitores');
            else if (cleanName === 'impressora') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Impressoras');
            else if (cleanName === 'componente') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Componentes');
            else if (cleanName === 'periférico' || cleanName === 'rato' || cleanName === 'teclado') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Periféricos');
            else if (cleanName === 'projetor') matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Projetores');
            else if (cleanName.includes('quadro') || cleanName.includes('board')) matchingOpt = Array.from(artSelect.options).find(o => o.value === 'Quadros Interativos');
        }

        if (matchingOpt) {
            artSelect.value = matchingOpt.value;
        } else {
            artSelect.value = 'Outros'; 
        }

        // Trigger updates
        updateBrandsModels('edit');
        updateSpecificTypes('edit');

        // Set Marca and trigger models update
        const marcaSelect = document.getElementById('editMarca');
        marcaSelect.value = brand;
        updateModels('edit');

        // Set others
        document.getElementById('editModelo').value = model;
        
        // Set type (Tipo Específico)
        const tipoSelect = document.getElementById('editTipo');
        const cleanType = (type || '').toLowerCase().trim();
        let matchedType = Array.from(tipoSelect.options).find(o => o.value.toLowerCase().trim() === cleanType);
        if (matchedType) {
            tipoSelect.value = matchedType.value;
        } else {
            // If it's something like "Monitor" but the Artigo is "Computadores", it won't be visible.
            // But if it's "Desktop" and Artigo is "Computadores", it works.
            tipoSelect.value = type || ""; 
        }

        document.getElementById('editSerial').value = serial;
        document.getElementById('editSala').value = roomId || "";
        document.getElementById('editEmpresa').value = empId || "";
        
        const statusSelect = document.getElementById('editStatus');
        if (statusSelect) {
            if (status === "Funcionando" || !status) status = "A funcionar";
            statusSelect.value = status;
        }

        const locType = empId ? "empresa" : "escola";
        const locIdInput = document.getElementById('editLocationType');
        if (locIdInput) locIdInput.value = locType;

        var modal = new bootstrap.Modal(document.getElementById('modalEditarEquipamento'));
        modal.show();
    }

