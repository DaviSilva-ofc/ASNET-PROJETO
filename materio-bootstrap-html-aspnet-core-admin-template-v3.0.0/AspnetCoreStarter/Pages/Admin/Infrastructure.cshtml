    <!-- Modal Novo Estabelecimento (Migrated from Clients) -->
    <div class="modal fade" id="modalAddEstabelecimento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="AddEstabelecimento" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registar Novo Estabelecimento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tipo de Estabelecimento</label>
                        <select asp-for="NewEstabType" class="form-select" id="estabTypeSelect" onchange="toggleEstabParent()" required>
                            <option value="">-- Selecione o Tipo --</option>
                            <option value="Agrupamento">Agrupamento</option>
                            <option value="Escola">Escola</option>
                            <option value="Bloco">Bloco</option>
                            <option value="Sala">Sala</option>
                            <option value="Empresa">Empresa</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input type="text" asp-for="NewEstabName" class="form-control" placeholder="Ex: Escola Secundária X" required />
                    </div>

                    <div class="mb-3" id="divParentSelect" style="display:none;">
                        <label class="form-label" id="labelParentSelect">Pertence a</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" id="searchParentInput" placeholder="Pesquisar..." oninput="filterSelect(this, 'estabParentSelect')" />
                            <select asp-for="NewEstabParentId" class="form-select" id="estabParentSelect">
                                <option value="">-- Selecione o Agrupamento --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3" id="divEstabAddress" style="display:none;">
                        <label class="form-label">Endereço</label>
                        <input type="text" asp-for="NewEstabAddress" class="form-control" placeholder="Ex: Rua, Cidade" />
                    </div>

                    <div class="mb-3" id="divEstabCoordinator" style="display:none;">
                        <label class="form-label">Coordenador (Opcional)</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar coordenador..." oninput="filterSelect(this, 'estabCoordinatorSelect')" />
                            <select asp-for="NewEstabCoordinatorId" class="form-select" id="estabCoordinatorSelect">
                                <option value="0">-- Sem Coordenador --</option>
                                @foreach (var coord in Model.AvailableCoordenadores)
                                {
                                    <option value="@coord.Id">@coord.Username</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3" id="divEstabProfessor" style="display:none;">
                        <label class="form-label">Professor Responsável (Opcional)</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar professor..." oninput="filterSelect(this, 'estabProfessorSelect')" />
                            <select asp-for="NewEstabProfessorId" class="form-select" id="estabProfessorSelect">
                                <option value="0">-- Sem Professor --</option>
                                @foreach (var prof in Model.AvailableProfessores)
                                {
                                    <option value="@prof.Id">@prof.Username</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3" id="divEstabIndividualClient" style="display:none;">
                        <label class="form-label">Cliente Individual (Opcional)</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar cliente individual..." oninput="filterSelect(this, 'estabIndividualClientSelect')" />
                            <select asp-for="NewEstabIndividualClientId" class="form-select" id="estabIndividualClientSelect">
                                <option value="0">-- Sem Cliente Vinculado --</option>
                                @foreach (var client in Model.AvailableIndividualClients)
                                {
                                    <option value="@client.Id">@client.Username</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Registar</button>
                </div>
            </form>
        </div>
    </div>


