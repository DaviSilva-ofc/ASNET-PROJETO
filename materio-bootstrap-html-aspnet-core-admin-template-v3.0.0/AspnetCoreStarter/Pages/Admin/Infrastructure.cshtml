@page
@model AspnetCoreStarter.Pages.Admin.InfrastructureModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Infraestrutura";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/notyf/notyf.dist.css" />
}

@section PageStyles {
<style>
    .dark-style .card-header h5,
    [data-bs-theme="dark"] .card-header h5 { color: #fff !important; }

    .dark-style .list-group-item,
    [data-bs-theme="dark"] .list-group-item {
        background-color: transparent;
        color: #cbcbe2;
        border-color: rgba(255,255,255,0.1);
    }

    .dark-style .text-muted,
    [data-bs-theme="dark"] .text-muted { color: #a1acb8 !important; }

    .dark-style .card,
    [data-bs-theme="dark"] .card {
        background-color: #2b2c40;
        box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
    }

    .dark-style h4.fw-bold,
    [data-bs-theme="dark"] h4.fw-bold { color: #f5f5f9 !important; }

    /* New Styles for Client Dashboard */
    .bg-light-section {
        background-color: rgba(67, 89, 113, 0.02);
        transition: all 0.3s ease;
    }
    .dark-style .bg-light-section,
    [data-bs-theme="dark"] .bg-light-section {
        background-color: rgba(255, 255, 255, 0.03);
    }

    .bg-light-section:hover {
        background-color: rgba(67, 89, 113, 0.05);
    }
    .dark-style .bg-light-section:hover,
    [data-bs-theme="dark"] .bg-light-section:hover {
        background-color: rgba(255, 255, 255, 0.06);
    }

    .infra-tree .tree-node {
        position: relative;
        padding: 4px 0;
    }

    .tree-node i {
        font-size: 1.1rem;
        vertical-align: middle;
        opacity: 0.8;
    }

    .cursor-pointer { cursor: pointer; }

    /* Animation for arrows */
    [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        transition: transform 0.3s ease;
        font-weight: bold;
        color: var(--bs-primary);
        font-size: 1.4rem;
        display: inline-block;
        line-height: 1;
        background-color: rgba(105, 108, 255, 0.15);
        border: 1px solid rgba(105, 108, 255, 0.3);
        border-radius: 4px;
        padding: 4px;
        margin-right: 8px;
    }

    [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: var(--bs-primary);
        color: #fff;
    }

    .dark-style [data-bs-toggle="collapse"] i.ri-arrow-right-s-line {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }
    .dark-style [data-bs-toggle="collapse"]:not(.collapsed) i.ri-arrow-right-s-line {
        background-color: #696cff;
        color: #fff;
    }

    .agrupamento-node { color: var(--bs-primary); }
    .school-node { color: var(--bs-success); }
    .bloc-node { color: var(--bs-info); }
    .room-node { color: var(--bs-warning); }
    .director-node { color: #8592a3; }
    .equip-node { color: #a1acb8; }

    /* Icon Base Fix */
    .icon-base {
        font-size: 1.25rem;
        vertical-align: middle;
        line-height: 1;
    }

    .tree-node i.ri-arrow-right-s-line,
    .tree-node i.ri-arrow-down-s-line {
        background-color: rgba(105, 108, 255, 0.1);
        border-radius: 4px;
        padding: 4px;
        font-weight: bold;
        transition: all 0.2s;
    }

    .collapse.show + .d-flex i.ri-arrow-right-s-line,
    [aria-expanded="true"] i.ri-arrow-right-s-line {
        transform: rotate(90deg);
        background-color: #696cff;
        color: white;
    }

    .dark-style .agrupamento-node { color: #696cff; }
    .dark-style .school-node { color: #71dd37; }
    .dark-style .bloc-node { color: #03c3ec; }
    .dark-style .room-node { color: #ffab00; }
    .dark-style .director-node { color: #e1e1e3; }
    .dark-style .equip-node { color: #707186; }

    /* Fix for header buttons visibility */
    .edit-header-btn {
        background-color: rgba(255, 255, 255, 0.2);
        color: white !important;
        border: 1px solid rgba(255, 255, 255, 0.5) !important;
        padding: 5px;
        border-radius: 0.375rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    .edit-header-btn:hover {
        background-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    .edit-header-btn i {
        font-size: 1.3rem !important;
        display: block;
        color: white !important;
    }
    /* Tab Styling */
    .nav-tabs .nav-link.active {
        border-bottom-color: var(--bs-primary);
        color: var(--bs-primary) !important;
        font-weight: 600;
    }
    .dark-style .nav-tabs .nav-link.active {
        background-color: rgba(105, 108, 255, 0.1);
        border-bottom-color: #696cff;
        color: #696cff !important;
    }
    /* Searchable select wrapper */
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
    .select-search-wrapper select option.hidden-option { display: none; }

    /* Subtle Delete Buttons */
    .btn-delete-subtle {
        opacity: 0.2;
        transition: all 0.2s ease;
        padding: 0 4px;
        font-size: 0.85rem;
        color: #8592a3 !important;
        border: none !important;
        background: transparent !important;
    }

    .tree-node:hover .btn-delete-subtle,
    .d-flex:hover > .btn-delete-subtle,
    .d-flex:hover > form > .btn-delete-subtle {
        opacity: 1;
    }

    .btn-delete-subtle:hover {
        color: #ff3e1d !important;
        transform: scale(1.2);
    }

    .dark-style .btn-delete-subtle { color: #a1acb8 !important; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Admin /</span> Infraestrutura</h4>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-checkbox-circle-line me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-error-warning-line me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Creator Menu Card -->
    <div class="card mb-4 border-primary shadow-sm">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <h5 class="mb-2 mb-md-0 fw-bold text-primary"><i class="icon-base ri-tools-line me-2"></i>Gestão da Infraestrutura</h5>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary btn-md shadow-sm" data-bs-toggle="modal" data-bs-target="#modalAddEstabelecimento">
                        <i class="icon-base ri-add-line me-1"></i> Novo Estabelecimento
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="nav-align-top mb-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#navs-agrupamentos" aria-controls="navs-agrupamentos" aria-selected="true">
                    <i class="tf-icons ri-organization-chart me-1"></i> Agrupamentos
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#navs-empresas" aria-controls="navs-empresas" aria-selected="false">
                    <i class="tf-icons ri-building-line me-1"></i> Empresas
                </button>
            </li>
        </ul>
        <div class="tab-content">
            <!-- Agrupamentos Tab -->
            <div class="tab-pane fade show active" id="navs-agrupamentos" role="tabpanel">
                <div class="row">
        @foreach (var client in Model.Clients)
        {
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center cursor-pointer"
                         data-bs-toggle="collapse" data-bs-target="#client-@client.Agrupamento.Id">
                        <div class="d-flex align-items-center">
                            <h5 class="mb-0 text-white me-3">
                                <strong>@client.Agrupamento.Name - @client.DirectorName</strong>
                            </h5>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button type="button" class="edit-header-btn"
                                    data-id="@client.Agrupamento.Id"
                                    data-name="@client.Agrupamento.Name"
                                    data-director="@client.DirectorUserId"
                                    onclick="event.stopPropagation(); openEditAgrupamento(this)"
                                    title="Editar Agrupamento e Diretor">
                                ✏️
                            </button>
                            <form method="post" asp-page-handler="DeleteAgrupamento" asp-route-id="@client.Agrupamento.Id"
                                  onsubmit="return confirm('Excluir este agrupamento?');"
                                  style="display:inline;" onclick="event.stopPropagation();">
                                <button type="submit" class="edit-header-btn bg-transparent border-white ms-1" title="Excluir Agrupamento" style="opacity: 0.7;">
                                    🗑️
                                </button>
                            </form>
                            <i class="icon-base ri-arrow-down-s-line text-white fs-4 ms-2"></i>
                        </div>
                    </div>
                    <div id="client-@client.Agrupamento.Id" class="collapse show">
                        <div class="card-body pt-4">
                            <!-- Secções do Cliente -->
                            <div class="row">
                                <!-- Coluna Tickets -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                             data-bs-toggle="collapse" data-bs-target="#tickets-@client.Agrupamento.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-ticket-2-line me-2"></i>Tickets</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="tickets-@client.Agrupamento.Id" class="collapse show">
                                            <h3 class="mb-1 text-primary">@client.TicketCount</h3>
                                            <p class="text-muted small mb-2">Tickets ativos em todas as escolas</p>
                                            <a asp-page="./Tickets" asp-route-agrupamentoId="@client.Agrupamento.Id" class="btn btn-sm btn-outline-primary w-100 mt-2">
                                                Gerir Tickets
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Coluna Contratos -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                             data-bs-toggle="collapse" data-bs-target="#contracts-@client.Agrupamento.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-file-list-3-line me-2"></i>Contratos</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="contracts-@client.Agrupamento.Id" class="collapse show">
                                            <h3 class="mb-1 text-success">@client.ContractCount</h3>
                                            <p class="text-muted small mb-2">Contratos registados para este agrupamento</p>
                                            <a asp-page="./Contracts" asp-route-agrupamentoId="@client.Agrupamento.Id" class="btn btn-sm btn-outline-success w-100 mt-2">
                                                Gerir Contratos
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Coluna Agrupamento (Árvore) -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                             data-bs-toggle="collapse" data-bs-target="#infra-@client.Agrupamento.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-node-tree me-2"></i>Agrupamento</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="infra-@client.Agrupamento.Id" class="collapse show mt-3">
                                            <div class="infra-tree">
                                                <div class="tree-node director-node mb-2 d-flex align-items-center">
                                                    <i class="icon-base ri-user-star-line me-1"></i> <strong>Diretor: @client.DirectorName</strong>
                                                    <button class="btn btn-sm btn-icon btn-outline-secondary ms-2 border-0"
                                                            data-id="@client.DirectorUserId"
                                                            data-name="@client.DirectorName"
                                                            onclick="openEditDirector(this)"
                                                            title="Editar Nome do Diretor">
                                                        ✏️
                                                    </button>
                                                </div>
                                                <div class="tree-node agrupamento-node">
                                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-schools-@client.Agrupamento.Id">
                                                        <i class="icon-base ri-arrow-right-s-line"></i>
                                                        <i class="icon-base ri-community-line me-1"></i> <strong>@client.Agrupamento.Name</strong>
                                                    </div>

                                                    <div id="tree-schools-@client.Agrupamento.Id" class="collapse">
                                                        @{ var schools = client.Schools; }
                                                        @foreach (var schoolVm in schools)
                                                        {
                                                            <div class="tree-node school-node ms-4 mt-2">
                                                                <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-blocks-@schoolVm.School.Id">
                                                                    <i class="icon-base ri-arrow-right-s-line"></i>
                                                                    <i class="icon-base ri-building-line me-1"></i> <strong>@schoolVm.School.Name</strong>
                                                                    <span class="ms-2 text-muted small">(Coord: @schoolVm.CoordinatorName)</span>
                                                                    <div class="d-flex align-items-center ms-auto">
                                                                        <button class="btn btn-sm btn-icon btn-outline-secondary border-0"
                                                                                data-id="@schoolVm.School.Id"
                                                                                data-name="@schoolVm.School.Name"
                                                                                data-address="@schoolVm.School.Address"
                                                                                data-agrupamento="@client.Agrupamento.Id"
                                                                                data-coordinator="@schoolVm.CoordinatorUserId"
                                                                                onclick="event.stopPropagation(); openEditSchool(this)"
                                                                                title="Editar Escola">
                                                                            ✏️
                                                                        </button>
                                                                        <form method="post" asp-page-handler="DeleteSchool" asp-route-id="@schoolVm.School.Id"
                                                                              onsubmit="return confirm('Excluir esta escola?');"
                                                                              style="display:inline;" onclick="event.stopPropagation();">
                                                                            <button type="submit" class="btn-delete-subtle" title="Excluir Escola">
                                                                                🗑️
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                </div>

                                                                <div id="tree-blocks-@schoolVm.School.Id" class="collapse">
                                                                    @{ var blocs = Model.Blocos.Where(b => b.SchoolId == schoolVm.School.Id).ToList(); }
                                                                    @foreach (var bloc in blocs)
                                                                    {
                                                                        <div class="tree-node bloc-node ms-4 mt-1">
                                                                            <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-rooms-@bloc.Id">
                                                                                <i class="icon-base ri-arrow-right-s-line"></i>
                                                                                <i class="icon-base ri-box-3-line me-1"></i> @bloc.Name
                                                                                <div class="d-flex align-items-center ms-auto">
                                                                                    <button class="btn btn-sm btn-icon btn-outline-secondary border-0"
                                                                                            data-id="@bloc.Id"
                                                                                            data-name="@bloc.Name"
                                                                                            data-school="@schoolVm.School.Id"
                                                                                            onclick="event.stopPropagation(); openEditBloco(this)"
                                                                                            title="Editar Bloco">
                                                                                        ✏️
                                                                                    </button>
                                                                                    <form method="post" asp-page-handler="DeleteBloco" asp-route-id="@bloc.Id"
                                                                                          onsubmit="return confirm('Excluir este bloco?');"
                                                                                          style="display:inline;" onclick="event.stopPropagation();">
                                                                                        <button type="submit" class="btn-delete-subtle" title="Excluir Bloco">
                                                                                            🗑️
                                                                                        </button>
                                                                                    </form>
                                                                                </div>
                                                                            </div>

                                                                            <div id="tree-rooms-@bloc.Id" class="collapse">
                                                                                @{ var rooms = Model.Salas.Where(s => s.BlockId == bloc.Id).ToList(); }
                                                                                @foreach (var room in rooms)
                                                                                {
                                                                                    <div class="tree-node room-node ms-4 mt-1">
                                                                                        <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-equips-@room.Id">
                                                                                            <i class="icon-base ri-arrow-right-s-line"></i>
                                                                                            <i class="icon-base ri-door-open-line me-1"></i> @room.Name
                                                                                            @if (room.ResponsibleProfessor?.User != null)
                                                                                            {
                                                                                                <span class="ms-2 text-muted small" style="font-size: 0.75rem;">(Prof: @room.ResponsibleProfessor.User.Username)</span>
                                                                                            }
                                                                                            <div class="d-flex align-items-center ms-auto">
                                                                                                <button class="btn btn-sm btn-icon btn-outline-secondary border-0"
                                                                                                        data-id="@room.Id"
                                                                                                        data-name="@room.Name"
                                                                                                        data-bloc="@bloc.Id"
                                                                                                        data-professor="@room.ResponsibleProfessorId"
                                                                                                        onclick="event.stopPropagation(); openEditSala(this)"
                                                                                                        title="Editar Sala">
                                                                                                    ✏️
                                                                                                </button>
                                                                                                <form method="post" asp-page-handler="DeleteSala" asp-route-id="@room.Id"
                                                                                                      onsubmit="return confirm('Excluir esta sala?');"
                                                                                                      style="display:inline;" onclick="event.stopPropagation();">
                                                                                                    <button type="submit" class="btn-delete-subtle" title="Excluir Sala">
                                                                                                        🗑️
                                                                                                    </button>
                                                                                                </form>
                                                                                                <a asp-page="/Admin/Equipment" asp-route-FilterRoomId="@room.Id" class="btn btn-sm btn-icon btn-outline-info border-0 ms-1" title="Ver Equipamentos">
                                                                                                     <i class="tf-icons ri-computer-line small"></i>
                                                                                                 </a>
                                                                                            </div>
                                                                                        </div>

                                                                                        <div id="tree-equips-@room.Id" class="collapse">
                                                                                             @if (room.Equipments != null && room.Equipments.Any())
                                                                                             {
                                                                                                 var groupedEquips = room.Equipments
                                                                                                     .GroupBy(e => !string.IsNullOrEmpty(e.Type) ? e.Type : (!string.IsNullOrEmpty(e.Name) ? e.Name : "Outros"))
                                                                                                     .Select(g => new { TypeName = g.Key, Count = g.Count() })
                                                                                                     .OrderBy(g => g.TypeName)
                                                                                                     .ToList();

                                                                                                 @foreach (var group in groupedEquips)
                                                                                                 {
                                                                                                     <div class="tree-node equip-node ms-4 mt-1 small">
                                                                                                         <a asp-page="/Admin/Equipment"
                                                                                                            asp-route-FilterRoomId="@room.Id"
                                                                                                            asp-route-FilterType="@group.TypeName"
                                                                                                            class="text-secondary text-decoration-none">
                                                                                                             <i class="ri-computer-line me-1"></i> @group.TypeName (@group.Count)
                                                                                                         </a>
                                                                                                     </div>
                                                                                                 }
                                                                                             }
                                                                                             else
                                                                                             {
                                                                                                 <div class="ms-4 mt-1 small">
                                                                                                     <a asp-page="/Admin/Equipment" asp-route-FilterRoomId="@room.Id" class="text-info italic text-decoration-none" style="font-size: 0.82rem;">
                                                                                                         <i class="ri-search-line me-1"></i> Ver equipamentos
                                                                                                     </a>
                                                                                                 </div>
                                                                                             }
                                                                                         </div>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
                </div>
            </div>

            <!-- Empresas Tab -->
            <div class="tab-pane fade" id="navs-empresas" role="tabpanel">
                <div class="row">
        @foreach (var empVm in Model.EmpresasInfra)
        {
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center cursor-pointer"
                         data-bs-toggle="collapse" data-bs-target="#emp-@empVm.Empresa.Id">
                        <div class="d-flex align-items-center">
                            <h5 class="mb-0 text-white me-3">
                                <strong>@empVm.Empresa.Name - @(empVm.Responsibles.Any() ? string.Join(", ", empVm.Responsibles.Select(r => r.Username)) : "Sem Responsável")</strong>
                            </h5>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                             <button type="button" class="edit-header-btn"
                                     data-id="@empVm.Empresa.Id"
                                     data-name="@empVm.Empresa.Name"
                                     data-address="@empVm.Empresa.Location"
                                     data-client="@empVm.IndividualClientId"
                                     onclick="event.stopPropagation(); openEditEmpresa(this)"
                                     title="Editar Empresa">
                                 ✏️
                             </button>
                             <form method="post" asp-page-handler="DeleteEmpresa" asp-route-id="@empVm.Empresa.Id"
                                  onsubmit="return confirm('Excluir esta empresa?');"
                                  style="display:inline;" onclick="event.stopPropagation();">
                                <button type="submit" class="edit-header-btn bg-transparent border-white ms-1" title="Excluir Empresa" style="opacity: 0.7;">
                                    🗑️
                                </button>
                            </form>
                            <i class="icon-base ri-arrow-down-s-line text-white fs-4 ms-2"></i>
                        </div>
                    </div>
                    <div id="emp-@empVm.Empresa.Id" class="collapse show">
                        <div class="card-body pt-4">
                            <div class="row">
                                <!-- Coluna Tickets -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                             data-bs-toggle="collapse" data-bs-target="#tickets-emp-@empVm.Empresa.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-ticket-2-line me-2"></i>Tickets</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="tickets-emp-@empVm.Empresa.Id" class="collapse show">
                                            <h3 class="mb-1 text-primary">@empVm.TicketCount</h3>
                                            <p class="text-muted small mb-2">Tickets ativos vinculados</p>
                                            <a asp-page="./Tickets" asp-route-empresaId="@empVm.Empresa.Id" class="btn btn-sm btn-outline-primary w-100 mt-2">
                                                Gerir Tickets
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Coluna Contratos -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                             data-bs-toggle="collapse" data-bs-target="#contracts-emp-@empVm.Empresa.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-file-list-3-line me-2"></i>Contratos</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="contracts-emp-@empVm.Empresa.Id" class="collapse show">
                                            <h3 class="mb-1 text-success">@empVm.ContractCount</h3>
                                            <p class="text-muted small mb-2">Contratos registados para esta empresa</p>
                                            <a asp-page="./Contracts" asp-route-empresaId="@empVm.Empresa.Id" class="btn btn-sm btn-outline-success w-100 mt-2">
                                                Gerir Contratos
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Coluna Empresa (Árvore) -->
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3 h-100 bg-light-section">
                                        <div class="d-flex justify-content-between align-items-center mb-2 cursor-pointer"
                                             data-bs-toggle="collapse" data-bs-target="#infra-emp-@empVm.Empresa.Id">
                                            <h6 class="mb-0 fw-bold"><i class="icon-base ri-node-tree me-2"></i>Empresa</h6>
                                            <i class="icon-base ri-arrow-down-s-line"></i>
                                        </div>
                                        <div id="infra-emp-@empVm.Empresa.Id" class="collapse show mt-3">
                                            <div class="infra-tree">
                                                <div class="tree-node director-node mb-2 d-flex align-items-center">
                                                    <i class="icon-base ri-user-settings-line me-1"></i> 
                                                    <strong>Responsável: @(empVm.Responsibles.Any() ? empVm.Responsibles.First().Username : "Admin Geral")</strong>
                                                </div>
                                                <div class="tree-node agrupamento-node">
                                                    <div class="d-flex align-items-center cursor-pointer p-1 rounded" data-bs-toggle="collapse" data-bs-target="#tree-equips-emp-@empVm.Empresa.Id">
                                                        <i class="icon-base ri-arrow-right-s-line"></i>
                                                        <i class="icon-base ri-building-line me-1"></i> <strong>@empVm.Empresa.Name</strong>
                                                    </div>

                                                    <div id="tree-equips-emp-@empVm.Empresa.Id" class="collapse">
                                                         @if (empVm.Equipments.Any())
                                                         {
                                                             var groupedEquips = empVm.Equipments
                                                                 .GroupBy(e => !string.IsNullOrEmpty(e.Type) ? e.Type : (!string.IsNullOrEmpty(e.Name) ? e.Name : "Outros"))
                                                                 .Select(g => new { TypeName = g.Key, Count = g.Count() })
                                                                 .OrderBy(g => g.TypeName)
                                                                 .ToList();

                                                             @foreach (var group in groupedEquips)
                                                             {
                                                                 <div class="tree-node equip-node ms-4 mt-1 small">
                                                                     <a asp-page="/Admin/Equipment"
                                                                        asp-route-FilterEmpresaId="@empVm.Empresa.Id"
                                                                        asp-route-FilterType="@group.TypeName"
                                                                        class="text-secondary text-decoration-none">
                                                                         <i class="ri-computer-line me-1"></i> @group.TypeName (@group.Count)
                                                                     </a>
                                                                 </div>
                                                             }
                                                         }
                                                         else
                                                         {
                                                             <div class="ms-4 mt-1 small">
                                                                 <span class="text-muted italic" style="font-size: 0.82rem;">Sem equipamentos vinculados diretamente</span>
                                                             </div>
                                                         }
                                                     </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        @if (!Model.EmpresasInfra.Any())
        {
            <div class="col-12">
                <div class="card shadow-none border-0 text-center py-5">
                    <div class="text-muted mb-2">Nenhuma empresa registada.</div>
                    <button class="btn btn-sm btn-label-primary" data-bs-toggle="modal" data-bs-target="#modalAddEstabelecimento" onclick="setEstabType('Empresa')">
                        Criar Primeira Empresa
                    </button>
                </div>
            </div>
        }
                </div>
            </div>
        </div>
    </div>
    </div>


