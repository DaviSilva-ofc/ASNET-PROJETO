                    <div class="mb-3">
                        <label class="form-label">Nome do Diretor (Username)</label>
                        <input type="text" asp-for="EditName" id="editDirectorName" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>

</div>

@section VendorScripts {
<script src="~/vendor/libs/notyf/notyf.dist.js"></script>
}

@section PageScripts {
<script>
    // Filter select options by search input
    function filterSelect(input, selectId) {
        var filter = input.value.toLowerCase();
        var select = document.getElementById(selectId);
        var options = select.querySelectorAll('option');
        options.forEach(function(opt) {
            var text = opt.textContent.toLowerCase();
            if (text.includes(filter)) {
                opt.style.display = '';
            } else {
                opt.style.display = 'none';
            }
        });
    }

    // Reset search inputs when a modal is closed
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.modal').forEach(function(modal) {
            modal.addEventListener('hidden.bs.modal', function() {
                modal.querySelectorAll('.select-search-input').forEach(function(inp) {
                    inp.value = '';
                    var wrapper = inp.closest('.select-search-wrapper');
                    if (wrapper) {
                        wrapper.querySelectorAll('select option').forEach(function(opt) {
                            opt.style.display = '';
                        });
                    }
                });
            });
        });
    });

    // School data embedded per agrupamento: { agrupamentoId: [{id, name, coordinatorId, blocos: [{id, name, salas: [{id, name, profId}]}]}] }
    var schoolsByAgrupamento = {
        @foreach (var client in Model.Clients)
        {
            <text>@client.Agrupamento.Id: [</text>
            @foreach (var sv in client.Schools)
            {
                <text>{</text>
                <text>id: @sv.School.Id, </text>
                <text>name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sv.School.Name)), </text>
                <text>coordinatorId: @(sv.CoordinatorUserId ?? 0),</text>
                <text>blocos: [</text>
                @foreach (var b in sv.Blocos)
                {
                    <text>{</text>
                    <text>id: @b.Id, </text>
                    <text>name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(b.Name)), </text>
                    <text>salas: [</text>
                    @foreach (var s in b.Rooms)
                    {
                        <text>{id: @s.Id, name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(s.Name)), profId: @(s.ResponsibleProfessorId ?? 0)},</text>
                    }
                    <text>]</text>
                    <text>},</text>
                }
                <text>]</text>
                <text>},</text>
            }
            <text>],</text>
        }
    };

    function openEditAgrupamento(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var directorUserId = el.getAttribute('data-director');

        document.getElementById('editAgrupamentoId').value = id;
        document.getElementById('editAgrupamentoName').value = name;
        document.getElementById('editAgrupamentoDirectorUserId').value = directorUserId || 0;

        // Rebuild escola dropdown for this agrupamento
        var escolaSel = document.getElementById('editAgrEscolaId');
        escolaSel.innerHTML = '<option value="0">-- Nenhuma escola --</option>';
        var schools = schoolsByAgrupamento[id] || [];
        schools.forEach(function(s) {
            var opt = document.createElement('option');
            opt.value = s.id;
            opt.textContent = s.name;
            escolaSel.appendChild(opt);
        });

        // Reset all secondary sections
        escolaSel.value = '0';
        resetAgrEscolaFields();
        resetAgrBlocoSection();
        resetAgrSalaSection();

        var modalEl = document.getElementById('modalEditAgrupamento');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    function onAgrEscolaChange(sel) {
        var escolaId = parseInt(sel.value);
        resetAgrEscolaFields();
        resetAgrBlocoSection();
        resetAgrSalaSection();

        if (escolaId > 0) {
            document.getElementById('editAgrEscolaNameWrap').style.display = '';
            document.getElementById('editAgrCoordWrap').style.display = '';

            var agrId = document.getElementById('editAgrupamentoId').value;
            var schools = schoolsByAgrupamento[agrId] || [];
            var school = schools.find(function(s) { return s.id === escolaId; });
            if (school) {
                document.getElementById('editAgrEscolaName').value = school.name;
                document.getElementById('editAgrCoordinatorId').value = school.coordinatorId || 0;

                // Build Bloco dropdown
                document.getElementById('editAgrBlocoSection').style.display = '';
                var blocoSel = document.getElementById('editAgrBlocoId');
                blocoSel.innerHTML = '<option value="0">-- Nenhum bloco --</option>';
                (school.blocos || []).forEach(function(b) {
                    var opt = document.createElement('option');
                    opt.value = b.id;
                    opt.textContent = b.name;
                    blocoSel.appendChild(opt);
                });
            }
        }
    }

    function onAgrBlocoChange(sel) {
        var blocoId = parseInt(sel.value);
        resetAgrBlocoFields();
        resetAgrSalaSection();

        if (blocoId > 0) {
            document.getElementById('editAgrBlocoNameWrap').style.display = '';

            var agrId = document.getElementById('editAgrupamentoId').value;
            var escolaId = parseInt(document.getElementById('editAgrEscolaId').value);
            var school = (schoolsByAgrupamento[agrId] || []).find(s => s.id === escolaId);
            var bloco = (school.blocos || []).find(b => b.id === blocoId);

            if (bloco) {
                document.getElementById('editAgrBlocoName').value = bloco.name;

                // Build Sala dropdown
                document.getElementById('editAgrSalaSection').style.display = '';
                var salaSel = document.getElementById('editAgrSalaId');
                salaSel.innerHTML = '<option value="0">-- Nenhuma sala --</option>';
                (bloco.salas || []).forEach(function(s) {
                    var opt = document.createElement('option');
                    opt.value = s.id;
                    opt.textContent = s.name;
                    salaSel.appendChild(opt);
                });
            }
        }
    }

    function onAgrSalaChange(sel) {
        var salaId = parseInt(sel.value);
        resetAgrSalaFields();

        if (salaId > 0) {
            document.getElementById('editAgrSalaNameWrap').style.display = '';
            document.getElementById('editAgrSalaProfessorWrap').style.display = '';

            var agrId = document.getElementById('editAgrupamentoId').value;
            var escolaId = parseInt(document.getElementById('editAgrEscolaId').value);
            var blocoId = parseInt(document.getElementById('editAgrBlocoId').value);

            var school = (schoolsByAgrupamento[agrId] || []).find(s => s.id === escolaId);
            var bloco = (school.blocos || []).find(b => b.id === blocoId);
            var sala = (bloco.salas || []).find(s => s.id === salaId);

            if (sala) {
                document.getElementById('editAgrSalaName').value = sala.name;
                document.getElementById('editAgrResponsibleProfessorId').value = sala.profId || 0;
            }
        }
    }

    // Helpers to reset UI
    function resetAgrEscolaFields() {
        document.getElementById('editAgrEscolaNameWrap').style.display = 'none';
        document.getElementById('editAgrCoordWrap').style.display = 'none';
        document.getElementById('editAgrEscolaName').value = '';
        document.getElementById('editAgrCoordinatorId').value = '0';
    }
    function resetAgrBlocoSection() {
        document.getElementById('editAgrBlocoSection').style.display = 'none';
        document.getElementById('editAgrBlocoId').innerHTML = '<option value="0">-- Nenhum bloco --</option>';
        resetAgrBlocoFields();
    }
    function resetAgrBlocoFields() {
        document.getElementById('editAgrBlocoNameWrap').style.display = 'none';
        document.getElementById('editAgrBlocoName').value = '';
    }
    function resetAgrSalaSection() {
        document.getElementById('editAgrSalaSection').style.display = 'none';
        document.getElementById('editAgrSalaId').innerHTML = '<option value="0">-- Nenhuma sala --</option>';
        resetAgrSalaFields();
    }
    function resetAgrSalaFields() {
        document.getElementById('editAgrSalaNameWrap').style.display = 'none';
        document.getElementById('editAgrSalaProfessorWrap').style.display = 'none';
        document.getElementById('editAgrSalaName').value = '';
        document.getElementById('editAgrResponsibleProfessorId').value = '0';
    }

    function openEditSchool(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var address = el.getAttribute('data-address');
        var agrupamentoId = el.getAttribute('data-agrupamento');
        var coordinatorId = el.getAttribute('data-coordinator');

        document.getElementById('editEscolaId').value = id;
        document.getElementById('editEscolaName').value = name;
        document.getElementById('editEscolaAddress').value = address;
        document.getElementById('editEscolaAgrupamentoId').value = agrupamentoId || '';
        document.getElementById('editEscolaCoordinatorId').value = coordinatorId || 0;

        var modalEl = document.getElementById('modalEditEscola');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    function openEditBloco(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var schoolId = el.getAttribute('data-school');

        document.getElementById('editBlocoId').value = id;
        document.getElementById('editBlocoName').value = name;
        document.getElementById('editBlocoEscolaId').value = schoolId;

        var modalEl = document.getElementById('modalEditBloco');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    function openEditSala(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var blocoId = el.getAttribute('data-bloc');
        var professorId = el.getAttribute('data-professor');

        document.getElementById('editSalaId').value = id;
        document.getElementById('editSalaName').value = name;
        document.getElementById('editSalaBlocoId').value = blocoId;
        document.getElementById('editSalaProfessorId').value = professorId || "";

        var modalEl = document.getElementById('modalEditSala');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    function openEditDirector(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');

        document.getElementById('editDirectorId').value = id;
        document.getElementById('editDirectorName').value = name;

        var modalEl = document.getElementById('modalEditDirector');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    function openEditEmpresa(el) {
        var id = el.getAttribute('data-id');
        var name = el.getAttribute('data-name');
        var address = el.getAttribute('data-address');
        var clientId = el.getAttribute('data-client');

        document.getElementById('editEmpresaId').value = id;
        document.getElementById('editEmpresaName').value = name;
        document.getElementById('editEmpresaAddress').value = address || '';
        document.getElementById('editEmpresaIndividualClientId').value = clientId || 0;

        var modalEl = document.getElementById('modalEditEmpresa');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    @* Notyf Notifications Logic *@
    document.addEventListener('DOMContentLoaded', function() {
        if (window.notyfInitialized) return;
        window.notyfInitialized = true;

        if (typeof Notyf !== 'undefined') {
            const notyf = new Notyf({
                duration: 5000,
                position: { x: 'right', y: 'top' },
                types: [
                    {
                        type: 'success',
                        background: '#28a745',
                        icon: { className: 'ri-checkbox-circle-fill', tagName: 'i', color: 'white' }
                    },
                    {
                        type: 'error',
                        background: '#dc3545',
                        icon: { className: 'ri-close-circle-fill', tagName: 'i', color: 'white' }
                    }
                ]
            });

            @if (TempData["SuccessMessage"] != null)
            {
                <text>notyf.success('@TempData["SuccessMessage"]');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>notyf.error('@TempData["ErrorMessage"]');</text>
            }
        } else {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>alert('@TempData["SuccessMessage"]');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>alert('ERRO: @TempData["ErrorMessage"]');</text>
            }
        }
    });

    // Migrated and improved JS for Novo Estabelecimento
    const agrupamentosData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agrupamentos.Select(a => new { a.Id, a.Name })));
    const schoolsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Schools.Select(s => new { s.Id, s.Name, s.AgrupamentoId })));
    const blocosData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Blocos.Select(b => new { b.Id, b.Name, b.SchoolId })));

    function setEstabType(type) {
        const typeSelect = document.getElementById('estabTypeSelect');
        if (typeSelect) {
            typeSelect.value = type;
            toggleEstabParent();
        }
    }

    function toggleEstabParent() {
        const type = document.getElementById('estabTypeSelect').value;
        const divParent = document.getElementById('divParentSelect');
        const parentSelect = document.getElementById('estabParentSelect');
        const labelParent = document.getElementById('labelParentSelect');

        const divAddress = document.getElementById('divEstabAddress');
        const divCoord = document.getElementById('divEstabCoordinator');
        const divProf = document.getElementById('divEstabProfessor');
        const divIndClient = document.getElementById('divEstabIndividualClient');
        const nameInput = document.getElementById('NewEstabName');
        const searchParentInput = document.getElementById('searchParentInput');

        divParent.style.display = 'none';
        divAddress.style.display = 'none';
        divCoord.style.display = 'none';
        divProf.style.display = 'none';
        if (divIndClient) divIndClient.style.display = 'none';
        parentSelect.innerHTML = '<option value="">-- Selecione --</option>';
        parentSelect.required = false;

        if (nameInput) {
            nameInput.placeholder = 'Ex: Escola Secundária X';
        }

        if (searchParentInput) {
            searchParentInput.value = '';
            filterSelect(searchParentInput, 'estabParentSelect');
        }

        if (type === 'Escola') {
            divParent.style.display = 'block';
            divAddress.style.display = 'block';
            divCoord.style.display = 'block';
            labelParent.textContent = 'Agrupamento';
            parentSelect.innerHTML = '<option value="">-- Selecione o Agrupamento --</option>';
            if (searchParentInput) searchParentInput.placeholder = 'Pesquisar agrupamento...';
            agrupamentosData.forEach(item => {
                const opt = new Option(item.Name, item.Id);
                parentSelect.add(opt);
            });
            parentSelect.required = true;
        } else if (type === 'Bloco') {
            divParent.style.display = 'block';
            labelParent.textContent = 'Escola';
            parentSelect.innerHTML = '<option value="">-- Selecione a Escola --</option>';
            if (nameInput) nameInput.placeholder = 'Ex: A-Z ou 1-999';
            if (searchParentInput) searchParentInput.placeholder = 'Pesquisar escola...';
            schoolsData.forEach(item => {
                const opt = new Option(item.Name, item.Id);
                parentSelect.add(opt);
            });
            parentSelect.required = true;
        } else if (type === 'Sala') {
            divParent.style.display = 'block';
            divProf.style.display = 'block';
            labelParent.textContent = 'Bloco';
            parentSelect.innerHTML = '<option value="">-- Selecione o Bloco --</option>';
            if (nameInput) nameInput.placeholder = 'Ex: Sala 1, Laboratório...';
            if (searchParentInput) searchParentInput.placeholder = 'Pesquisar bloco...';
            blocosData.forEach(item => {
                const opt = new Option(item.Name, item.Id);
                parentSelect.add(opt);
            });
            parentSelect.required = true;
        } else if (type === 'Empresa') {
            divAddress.style.display = 'block';
            if (divIndClient) divIndClient.style.display = 'block';
        }
    }
</script>
}
