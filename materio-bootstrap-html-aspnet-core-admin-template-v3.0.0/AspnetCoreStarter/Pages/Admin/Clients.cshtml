@page
@model AspnetCoreStarter.Pages.Admin.ClientsModel
@{
    Layout = "Layouts/_ContentNavbarLayout";
    ViewData["Title"] = "Gestão de Clientes";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/notyf/notyf.dist.css" />
}

@section PageStyles {
<style>
    /* Subtle Delete Buttons for Tables */
    .btn-delete-subtle {
        opacity: 0.3;
        transition: all 0.2s ease;
        padding: 0 4px;
        font-size: 0.8rem;
        color: #8592a3 !important;
        border: none !important;
        background: transparent !important;
        cursor: pointer;
    }
    
    tr:hover .btn-delete-subtle,
    .d-flex:hover > .btn-delete-subtle,
    .d-flex:hover > form > .btn-delete-subtle {
        opacity: 1;
    }
    
    .btn-delete-subtle:hover {
        color: #ff3e1d !important;
        transform: scale(1.2);
    }
    
    .dark-style .btn-delete-subtle { color: #a1acb8 !important; }

    /* Subtle Edit Buttons for Tables */
    .btn-edit-subtle {
        opacity: 0.3;
        transition: all 0.2s ease;
        padding: 0 4px;
        font-size: 0.8rem;
        color: #8592a3 !important;
        border: none !important;
        background: transparent !important;
        cursor: pointer;
    }
    
    tr:hover .btn-edit-subtle,
    .d-flex:hover > .btn-edit-subtle {
        opacity: 1;
    }
    
    .btn-edit-subtle:hover {
        color: #696cff !important;
        transform: scale(1.2);
    }
    
    .dark-style .btn-edit-subtle { color: #a1acb8 !important; }

    /* Searchable select wrapper */
    .select-search-wrapper { position: relative; }
    .select-search-input {
        display: block;
        width: 100%;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid var(--bs-border-color);
        border-bottom: none;
        border-radius: 0.375rem 0.375rem 0 0;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        outline: none;
    }
    .select-search-input:focus {
        border-color: #696cff;
        box-shadow: 0 0 0 0.2rem rgba(105,108,255,0.15);
    }
    .select-search-wrapper select {
        border-radius: 0 0 0.375rem 0.375rem;
    }
    .select-search-wrapper select option.hidden-option { display: none; }
</style>
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-4">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Admin /</span> Clientes</h4>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-checkbox-circle-line me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible shadow-sm mb-4" role="alert">
            <i class="ri-error-warning-line me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Creator Menu Card -->
    <div class="card mb-4 border-primary shadow-sm">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <h5 class="mb-2 mb-md-0 fw-bold text-primary"><i class="ri-user-settings-line me-2"></i>Gestão de Clientes</h5>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-primary btn-md shadow-sm" data-bs-toggle="modal" data-bs-target="#modalFiltros">
                            <i class="ri-filter-3-line me-1"></i> Filtros
                        </button>
                        <button class="btn btn-primary btn-md shadow-sm" data-bs-toggle="modal" data-bs-target="#modalAddUser">
                            <i class="ri-user-add-line me-1"></i> Novo Utilizador
                        </button>
                    </div>
            </div>
        </div>
    </div>

    <!-- Active Filters Bar -->
    @if (Model.FilterId.HasValue || !string.IsNullOrEmpty(Model.FilterName) || !string.IsNullOrEmpty(Model.FilterEmail) || !string.IsNullOrEmpty(Model.FilterType) || Model.FilterAgrupamento.HasValue || Model.FilterEmpresa.HasValue)
    {
        <div class="alert alert-info d-flex justify-content-between align-items-center mb-4 shadow-sm" role="alert" style="padding: 0.5rem 1rem;">
            <span class="small">
                <i class="ri-information-line me-1"></i>
                Filtros ativos:
                <strong>
                    @(Model.FilterId.HasValue ? $"ID: {Model.FilterId}, " : "")
                    @(!string.IsNullOrEmpty(Model.FilterName) ? $"Nome: {Model.FilterName}, " : "")
                    @(!string.IsNullOrEmpty(Model.FilterEmail) ? $"Email: {Model.FilterEmail}, " : "")
                    @(!string.IsNullOrEmpty(Model.FilterType) ? $"Tipo: {Model.FilterType}, " : "")
                    @(Model.FilterAgrupamento.HasValue ? $"Agrupamento ID: {Model.FilterAgrupamento}, " : "")
                    @(Model.FilterEmpresa.HasValue ? $"Empresa ID: {Model.FilterEmpresa}" : "")
                </strong>
            </span>
            <a asp-page="./Clients" class="btn btn-sm btn-outline-secondary">Limpar Filtros</a>
        </div>
    }


    <!-- Diretores Table -->
    @if (string.IsNullOrEmpty(Model.FilterType) || Model.FilterType == "Diretor")
    {
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Diretores</h5>
            <span class="badge bg-label-primary">@Model.DirectorsList.Count Agrupados</span>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Agrupamento</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var d in Model.DirectorsList)
                    {
                        <tr>
                            <td><span class="badge bg-label-secondary">#@d.User?.Id</span></td>
                            <td><strong>@d.User?.Username</strong></td>
                            <td>@d.User?.Email</td>
                            <td>
                                @if (d.Agrupamento != null)
                                {
                                    <span>@d.Agrupamento.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sem Agrupamento</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <button type="button" class="btn-edit-subtle" title="Editar Diretor"
                                            data-bs-toggle="modal" data-bs-target="#modalEditUser"
                                            onclick="setEditUser('@d.UserId', '@Html.Raw((d.User?.Username ?? "").Replace("'", "\\'"))', '@Html.Raw((d.User?.Email ?? "").Replace("'", "\\'"))', 'Diretor', '@d.AgrupamentoId')">✏️</button>
                                    <form method="post" asp-page-handler="DeleteUser" asp-route-id="@d.UserId" asp-route-role="Diretor" onsubmit="return confirm('Remover este diretor?')">
                                        <button type="submit" class="btn-delete-subtle" title="Eliminar Diretor">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    }

    <!-- Coordenadores Table -->
    @if (string.IsNullOrEmpty(Model.FilterType) || Model.FilterType == "Coordenador")
    {
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Coordenadores</h5>
            <span class="badge bg-label-success">@Model.CoordinatorsList.Count Escolas</span>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Escola</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var c in Model.CoordinatorsList)
                    {
                        <tr>
                            <td><span class="badge bg-label-secondary">#@c.User?.Id</span></td>
                            <td><strong>@c.User?.Username</strong></td>
                            <td>@c.User?.Email</td>
                            <td>
                                @if (c.School != null)
                                {
                                    <span>@c.School.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sem Escola</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <button type="button" class="btn-edit-subtle" title="Editar Coordenador"
                                            data-bs-toggle="modal" data-bs-target="#modalEditUser"
                                            onclick="setEditUser('@c.UserId', '@Html.Raw((c.User?.Username ?? "").Replace("'", "\\'"))', '@Html.Raw((c.User?.Email ?? "").Replace("'", "\\'"))', 'Coordenador', '@c.SchoolId')">✏️</button>
                                    <form method="post" asp-page-handler="DeleteUser" asp-route-id="@c.UserId" asp-route-role="Coordenador" onsubmit="return confirm('Remover este coordenador?')">
                                        <button type="submit" class="btn-delete-subtle" title="Eliminar Coordenador">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    }

    <!-- Professores Table -->
    @if (string.IsNullOrEmpty(Model.FilterType) || Model.FilterType == "Professor")
    {
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Professores</h5>
            <span class="badge bg-label-info">@Model.ProfessorsList.Count Blocos</span>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Bloco/Escola</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var p in Model.ProfessorsList)
                    {
                        <tr>
                            <td><span class="badge bg-label-secondary">#@p.User?.Id</span></td>
                            <td><strong>@p.User?.Username</strong></td>
                            <td>@p.User?.Email</td>
                            <td>
                                @if (p.Bloco != null)
                                {
                                    <span>@p.Bloco.Name (@p.Bloco.School?.Name)</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sem Bloco</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <button type="button" class="btn-edit-subtle" title="Editar Professor"
                                            data-bs-toggle="modal" data-bs-target="#modalEditUser"
                                            onclick="setEditUser('@p.UserId', '@Html.Raw((p.User?.Username ?? "").Replace("'", "\\'"))', '@Html.Raw((p.User?.Email ?? "").Replace("'", "\\'"))', 'Professor', '@p.BlocoId')">✏️</button>
                                    <form method="post" asp-page-handler="DeleteUser" asp-route-id="@p.UserId" asp-route-role="Professor" onsubmit="return confirm('Remover este professor?')">
                                        <button type="submit" class="btn-delete-subtle" title="Eliminar Professor">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    }

    <!-- Clientes Independentes Table -->
    @if (string.IsNullOrEmpty(Model.FilterType) || Model.FilterType == "Cliente Individual")
    {
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Clientes Independentes</h5>
            <span class="badge bg-label-warning">@Model.IndependentClientsList.Count Utilizadores</span>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Empresa</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var u in Model.IndependentClientsList)
                    {
                        <tr>
                            <td><span class="badge bg-label-secondary">#@u.Id</span></td>
                            <td><strong>@u.Username</strong></td>
                            <td>@u.Email</td>
                            <td>
                                @if (u.Empresa != null)
                                {
                                    <span>@u.Empresa.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sem Empresa</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <button type="button" class="btn-edit-subtle" title="Editar Cliente"
                                            data-bs-toggle="modal" data-bs-target="#modalEditUser"
                                            onclick="setEditUser('@u.Id', '@Html.Raw((u.Username ?? "").Replace("'", "\\'"))', '@Html.Raw((u.Email ?? "").Replace("'", "\\'"))', 'Cliente Independente', '@u.EmpresaId')">✏️</button>
                                    <form method="post" asp-page-handler="DeleteUser" asp-route-id="@u.Id" asp-route-role="Cliente Independente" onsubmit="return confirm('Remover este cliente?')">
                                        <button type="submit" class="btn-delete-subtle" title="Eliminar Cliente">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    }

    <!-- Modal Adicionar Utilizador (Unificado) -->
    <div class="modal fade" id="modalAddUser" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form id="formAddUser" method="post" asp-page-handler="AddUser" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Novo Utilizador</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome Completo</label>
                        <input type="text" asp-for="NewUserName" class="form-control" placeholder="Ex: João Silva" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" asp-for="NewUserEmail" class="form-control" placeholder="joao@exemplo.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Palavra-passe</label>
                        <input type="password" asp-for="NewUserPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo de Utilizador</label>
                        <select asp-for="NewUserRole" id="addUserRole" class="form-select" required onchange="toggleAddUserRoleFields()">
                            <option value="">-- Selecione o Tipo --</option>
                            <option value="Diretor">Diretor</option>
                            <option value="Coordenador">Coordenador</option>
                            <option value="Professor">Professor</option>
                            <option value="Cliente Independente">Cliente Independente</option>
                        </select>
                    </div>

                    <!-- Dependent Field: Agrupamento for Diretor -->
                    <div id="divAddDiretorAgrupamento" class="mb-3" style="display:none;">
                        <label class="form-label text-primary fw-bold">Agrupamento</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar agrupamento..." oninput="filterSelect(this, 'addUserAgrupamento')" />
                            <select asp-for="SelectedParentId" id="addUserAgrupamento" class="form-select">
                                <option value="">-- Selecione um Agrupamento --</option>
                                @foreach (var item in Model.Agrupamentos) {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Dependent Field: Escola for Coordenador -->
                    <div id="divAddCoordenadorEscola" class="mb-3" style="display:none;">
                        <label class="form-label text-success fw-bold">Escola</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar escola..." oninput="filterSelect(this, 'addUserEscola')" />
                            <select asp-for="SelectedParentId" id="addUserEscola" class="form-select">
                                <option value="">-- Selecione uma Escola --</option>
                                @foreach (var item in Model.Schools) {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Dependent Field: Bloco for Professor -->
                    <div id="divAddProfessorBloco" class="mb-3" style="display:none;">
                        <label class="form-label text-info fw-bold">Bloco</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar bloco..." oninput="filterSelect(this, 'addUserBloco')" />
                            <select asp-for="SelectedParentId" id="addUserBloco" class="form-select">
                                <option value="">-- Selecione um Bloco --</option>
                                @foreach (var item in Model.Blocos) {
                                    <option value="@item.Id">@item.Name (@item.School?.Name)</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Dependent Field: Empresa for Cliente Independente -->
                    <div id="divAddUserEmpresa" class="mb-3" style="display:none;">
                        <label class="form-label text-warning fw-bold">Empresa</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar empresa..." oninput="filterSelect(this, 'addUserEmpresa')" />
                            <select asp-for="NewUserEmpresaId" id="addUserEmpresa" class="form-select">
                                <option value="">-- Selecione uma Empresa --</option>
                                @foreach (var item in Model.Empresas) {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Registrar Utilizador</button>
                </div>
            </form>
        </div>
    </div>


    <!-- Modal Editar Utilizador -->
    <div class="modal fade" id="modalEditUser" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="EditUser" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">✏️ Editar Utilizador</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editUserId" name="EditUserId" />
                    <input type="hidden" id="editUserRole" name="EditUserRole" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nome</label>
                        <input type="text" id="editUserName" name="EditUserName" class="form-control" required placeholder="Nome do utilizador" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" id="editUserEmail" name="EditUserEmail" class="form-control" required placeholder="email@exemplo.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nova Palavra-passe <span class="text-muted small">(deixe em branco para manter)</span></label>
                        <input type="password" id="editUserPassword" name="EditUserPassword" class="form-control" placeholder="••••••••" />
                    </div>
                    <div class="mb-3" id="editAgrupamentoDiv" style="display:none;">
                        <label class="form-label fw-semibold">Agrupamento</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar agrupamento..." oninput="filterSelect(this, 'editAgrupamentoSelect')" />
                            <select name="SelectedParentId" class="form-select" id="editAgrupamentoSelect" disabled>
                                <option value="">-- Sem Alteração --</option>
                                @foreach (var item in Model.Agrupamentos)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3" id="editEscolaDiv" style="display:none;">
                        <label class="form-label fw-semibold">Escola</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar escola..." oninput="filterSelect(this, 'editEscolaSelect')" />
                            <select name="SelectedParentId" class="form-select" id="editEscolaSelect" disabled>
                                <option value="">-- Sem Alteração --</option>
                                @foreach (var item in Model.Schools)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3" id="editBlocoDiv" style="display:none;">
                        <label class="form-label fw-semibold">Bloco</label>
                        <div class="select-search-wrapper">
                            <input type="text" class="select-search-input" placeholder="Pesquisar bloco..." oninput="filterSelect(this, 'editBlocoSelect')" />
                            <select name="SelectedParentId" class="form-select" id="editBlocoSelect" disabled>
                                <option value="">-- Sem Alteração --</option>
                                @foreach (var item in Model.Blocos)
                                {
                                    <option value="@item.Id">@item.Name (@item.School?.Name)</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">💾 Guardar Alterações</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Filtros -->
    <div class="modal fade" id="modalFiltros" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <form method="get" class="modal-content">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title">Filtrar Clientes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label fw-semibold small">ID</label>
                            <input type="number" asp-for="FilterId" class="form-control" placeholder="ID..." />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold small">Nome</label>
                            <input type="text" asp-for="FilterName" class="form-control" placeholder="Pesquisar por nome..." />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold small">Email</label>
                            <input type="text" asp-for="FilterEmail" class="form-control" placeholder="Pesquisar por email..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Tipo de Cliente</label>
                            <select asp-for="FilterType" class="form-select">
                                <option value="">-- Todos os Tipos --</option>
                                <option value="Diretor">Diretor</option>
                                <option value="Coordenador">Coordenador</option>
                                <option value="Professor">Professor</option>
                                <option value="Cliente Individual">Cliente Individual</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Agrupamento / Empresa</label>
                            <select id="filterAgrupamentoEmpresa" class="form-select" name="_filter_group">
                                <option value="">-- Todos --</option>
                                <optgroup label="Agrupamentos">
                                    @foreach (var item in Model.Agrupamentos)
                                    {
                                        <option value="agr_@item.Id">@item.Name</option>
                                    }
                                </optgroup>
                                <optgroup label="Empresas">
                                    @foreach (var item in Model.Empresas)
                                    {
                                        <option value="emp_@item.Id">@item.Name</option>
                                    }
                                </optgroup>
                            </select>
                            <input type="hidden" asp-for="FilterAgrupamento" id="hiddenFilterAgrupamento" />
                            <input type="hidden" asp-for="FilterEmpresa" id="hiddenFilterEmpresa" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
                </div>
            </form>
        </div>
    </div>

</div>

@section PageScripts {
<script>
    // Combined Agrupamento/Empresa filter: resolve to correct hidden fields before submit
    document.addEventListener('DOMContentLoaded', function () {
        var combinedSelect = document.getElementById('filterAgrupamentoEmpresa');
        if (combinedSelect) {
            // Restore selection on page load from hidden fields
            var hiddenAgr = document.getElementById('hiddenFilterAgrupamento');
            var hiddenEmp = document.getElementById('hiddenFilterEmpresa');
            if (hiddenAgr && hiddenAgr.value) {
                combinedSelect.value = 'agr_' + hiddenAgr.value;
            } else if (hiddenEmp && hiddenEmp.value) {
                combinedSelect.value = 'emp_' + hiddenEmp.value;
            }

            // Before form submit, parse the selected value and populate hidden fields
            combinedSelect.closest('form').addEventListener('submit', function () {
                var val = combinedSelect.value;
                hiddenAgr.value = '';
                hiddenEmp.value = '';
                if (val.startsWith('agr_')) {
                    hiddenAgr.value = val.replace('agr_', '');
                } else if (val.startsWith('emp_')) {
                    hiddenEmp.value = val.replace('emp_', '');
                }
            });
        }
    });

    // Filter select options by search input
    function filterSelect(input, selectId) {
        var filter = input.value.toLowerCase();
        var select = document.getElementById(selectId);
        var options = select.querySelectorAll('option');
        options.forEach(function(opt) {
            var text = opt.textContent.toLowerCase();
            opt.style.display = text.includes(filter) ? '' : 'none';
        });
    }

    // Reset search inputs when a modal is closed
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.modal').forEach(function(modal) {
            modal.addEventListener('hidden.bs.modal', function() {
                modal.querySelectorAll('.select-search-input').forEach(function(inp) {
                    inp.value = '';
                    var wrapper = inp.closest('.select-search-wrapper');
                    if (wrapper) {
                        wrapper.querySelectorAll('select option').forEach(function(opt) {
                            opt.style.display = '';
                        });
                    }
                });
            });
        });
    });

    function setEditUser(id, name, email, role, currentParentId) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editUserName').value = name;
        document.getElementById('editUserEmail').value = email;
        document.getElementById('editUserRole').value = role;
        document.getElementById('editUserPassword').value = '';
        document.querySelector('#modalEditUser .modal-title').textContent = '✏️ Editar ' + role;

        // Reset visibility
        document.getElementById('editAgrupamentoDiv').style.display = 'none';
        document.getElementById('editEscolaDiv').style.display = 'none';
        document.getElementById('editBlocoDiv').style.display = 'none';
        document.getElementById('editEmpresaDiv').style.display = 'none';
        document.getElementById('editAgrupamentoSelect').disabled = true;
        document.getElementById('editEscolaSelect').disabled = true;
        document.getElementById('editBlocoSelect').disabled = true;
        document.getElementById('editEmpresaSelect').disabled = true;

        // Show relevant dropdown and enable it (to avoid sending data for wrong role)
        if (role === 'Diretor') {
            document.getElementById('editAgrupamentoDiv').style.display = 'block';
            var sel = document.getElementById('editAgrupamentoSelect');
            sel.disabled = false;
            sel.value = currentParentId || '';
        } else if (role === 'Coordenador') {
            document.getElementById('editEscolaDiv').style.display = 'block';
            var sel = document.getElementById('editEscolaSelect');
            sel.disabled = false;
            sel.value = currentParentId || '';
        } else if (role === 'Professor') {
            document.getElementById('editBlocoDiv').style.display = 'block';
            var sel = document.getElementById('editBlocoSelect');
            sel.disabled = false;
            sel.value = currentParentId || '';
        } else if (role === 'Cliente Independente') {
            document.getElementById('editEmpresaDiv').style.display = 'block';
            var sel = document.getElementById('editEmpresaSelect');
            sel.disabled = false;
            sel.value = currentParentId || '';
        }
    }

    function toggleAddUserRoleFields() {
        const role = document.getElementById('addUserRole').value;
        const divAgr = document.getElementById('divAddDiretorAgrupamento');
        const divEsc = document.getElementById('divAddCoordenadorEscola');
        const divBlo = document.getElementById('divAddProfessorBloco');

        const divEmp = document.getElementById('divAddUserEmpresa');
 
         // Hide all first
         divAgr.style.display = 'none';
         divEsc.style.display = 'none';
         divBlo.style.display = 'none';
         divEmp.style.display = 'none';
         
         // Disable inner selects so ASP.NET binding doesn't get multiple values for SelectedParentId
         document.getElementById('addUserAgrupamento').disabled = true;
         document.getElementById('addUserEscola').disabled = true;
         document.getElementById('addUserBloco').disabled = true;
         document.getElementById('addUserEmpresa').disabled = true;

        if (role === 'Diretor') {
            divAgr.style.display = 'block';
            document.getElementById('addUserAgrupamento').disabled = false;
        } else if (role === 'Coordenador') {
            divEsc.style.display = 'block';
            document.getElementById('addUserEscola').disabled = false;
        } else if (role === 'Professor') {
            divBlo.style.display = 'block';
            document.getElementById('addUserBloco').disabled = false;
        } else if (role === 'Cliente Independente') {
            document.getElementById('divAddUserEmpresa').style.display = 'block';
            document.getElementById('addUserEmpresa').disabled = false;
        }
    }


    // Director Assignment Warning
    document.addEventListener('DOMContentLoaded', function() {
        const formAddUser = document.getElementById('formAddUser');
        const selectRole = document.getElementById('addUserRole');
        const selectAgrupamento = document.getElementById('addUserAgrupamento');
        const agrupamentosComDiretor = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DirectorsList.Select(d => d.AgrupamentoId).Where(id => id.HasValue).Distinct()));

        if (formAddUser && selectAgrupamento) {
            formAddUser.addEventListener('submit', function(e) {
                if (selectRole.value === 'Diretor') {
                    const selectedId = parseInt(selectAgrupamento.value);
                    if (agrupamentosComDiretor.includes(selectedId)) {
                        if (!confirm('Já existe um diretor neste agrupamento. Deseja prosseguir de qualquer forma?')) {
                            e.preventDefault();
                        }
                    }
                }
            });
        }
    });
</script>
}
